# ─── Traceon production environment variables ────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────

# SQL Server SA password (16+ chars, upper + lower + digit + symbol)
DB_SA_PASSWORD=YourStr0ng!P@ssword

# JWT signing key (at least 32 characters)
JWT_KEY=CHANGE_ME_TO_A_RANDOM_32_CHAR_STRING!!

# SendGrid API key
SMTP_PASSWORD=

# External auth secrets
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_SECRET=

# OpenAI
OPENAI_API_KEY=

# Azure Document Intelligence
AZURE_DI_KEY=

# GitHub personal access token (for feedback → issue creation)
GITHUB_TOKEN=

# Your domains
API_DOMAIN=api.traceon.example.com
BLAZOR_DOMAIN=traceon.example.com
