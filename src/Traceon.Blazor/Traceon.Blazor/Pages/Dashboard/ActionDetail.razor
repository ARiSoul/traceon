                DropShadow = new DropShadow { Enabled = false }
            }
        };
    }

    private RenderFragment RenderCrossFieldTimeSeries(CrossFieldResult result) => __builder =>
    {
        var chartKey = $"cfts-{result.RuleId}";
        _selectedSeries.TryGetValue(chartKey, out var selected);
        var hasFilter = selected is { Count: > 0 };
        var visibleSeries = hasFilter
            ? result.TimeSeriesData.Where(s => selected!.Contains(s.SeriesLabel)).ToList()
            : result.TimeSeriesData;

        var visibleColors = hasFilter
            ? result.TimeSeriesData
                .Select((s, i) => (s, i))
                .Where(x => selected!.Contains(x.s.SeriesLabel))
                .Select(x => x.i < CrossFieldPalette.Count ? CrossFieldPalette[x.i] : "#999")
                .ToList()
            : CrossFieldPalette;

        <div class="d-flex flex-wrap gap-1 mb-2">
            @for (var i = 0; i < result.TimeSeriesData.Count; i++)
            {
                var s = result.TimeSeriesData[i];
                var isActive = !hasFilter || selected!.Contains(s.SeriesLabel);
                var color = i < CrossFieldPalette.Count ? CrossFieldPalette[i] : "#999";
                var idx = i;
                <button class="btn btn-sm px-2 py-0 border @(isActive ? "" : "opacity-25")"
                        style="font-size:.75rem; color:@color; border-color:@color !important;"
                        @onclick="() => ToggleCrossFieldTimeSeriesSeries(chartKey, result.TimeSeriesData[idx].SeriesLabel, result.TimeSeriesData.Count)">
                    <i class="bi bi-circle-fill me-1" style="font-size:.5rem;"></i>@s.SeriesLabel
                </button>
            }
            @if (hasFilter)
            {
                <button class="btn btn-outline-secondary btn-sm px-2 py-0" style="font-size:.75rem;"
                        @onclick="() => InvertCrossFieldTimeSeriesSeries(chartKey, result.TimeSeriesData)">
                    <i class="bi bi-arrow-left-right me-1"></i>@L["Common_Invert"]
                </button>
                <button class="btn btn-outline-secondary btn-sm px-2 py-0" style="font-size:.75rem;"
                        @onclick="() => { _selectedSeries.Remove(chartKey); }">
                    <i class="bi bi-arrow-counterclockwise me-1"></i>@L["DataGrid_ResetAll"]
                </button>
            }
        </div>
        <div @key="@($"{chartKey}-{(hasFilter ? string.Join(',', selected!) : "all")}-{_loadKey}")">
            <ApexChart TItem="NumericDataPoint"
                       Options="BuildCrossFieldTimeSeriesOptions(result, visibleColors)"
                       Height="300">
                @foreach (var series in visibleSeries)
                {
                    <ApexPointSeries TItem="NumericDataPoint"
                                    Items="series.Points"
                                    SeriesType="SeriesType.Line"
                                    Name="@series.SeriesLabel"
                                    XValue="p => p.Date"
                                    YValue="p => p.Value"
                                    OrderBy="p => p.X" />
                }
            </ApexChart>
        </div>
    };

    private ApexChartOptions<NumericDataPoint> BuildCrossFieldTimeSeriesOptions(CrossFieldResult result, List<string> colors)
    {
        var yTitle = result.Unit is not null && result.Unit != "UN"
            ? result.Unit
            : FormatAggregationLabel(result.Aggregation);

        return new ApexChartOptions<NumericDataPoint>
        {
            Chart = new Chart
            {
                Toolbar = new Toolbar { Show = true, AutoSelected = AutoSelected.Pan },
                Zoom = new Zoom { Enabled = true, AllowMouseWheelZoom = false }
            },
            Xaxis = new XAxis
            {
                Type = XAxisType.Datetime,
                Labels = new XAxisLabels
                {
                    DatetimeFormatter = new DatetimeFormatter
                    {
                        Day = "dd MMM",
                        Month = "MMM yyyy"
                    }
                }
            },
            Yaxis = [new YAxis { Title = new AxisTitle { Text = yTitle } }],
            Stroke = new Stroke { Curve = Curve.Smooth, Width = 2 },
            Colors = colors,
            Legend = new Legend { Position = LegendPosition.Bottom, Show = false },
            Tooltip = new Tooltip { X = new TooltipX { Format = "dd MMM yyyy" } }
        };
    }

    private void ToggleCrossFieldTimeSeriesSeries(string chartKey, string seriesName, int totalCount)
    {
        if (!_selectedSeries.TryGetValue(chartKey, out var selected))
        {
            _selectedSeries[chartKey] = [seriesName];
            return;
        }

        if (selected.Contains(seriesName))
        {
            if (selected.Count > 1)
                selected.Remove(seriesName);
            else
                _selectedSeries.Remove(chartKey);
        }
        else
        {
            selected.Add(seriesName);
            if (selected.Count >= totalCount)
                _selectedSeries.Remove(chartKey);
        }
    }

    private void InvertCrossFieldTimeSeriesSeries(string chartKey, IReadOnlyList<CrossFieldTimeSeries> allSeries)
    {
        if (!_selectedSeries.TryGetValue(chartKey, out var selected))
            return;

        var inverted = allSeries
            .Where(s => !selected.Contains(s.SeriesLabel))
            .Select(s => s.SeriesLabel)
            .ToHashSet();

        if (inverted.Count == 0 || inverted.Count == allSeries.Count)
            _selectedSeries.Remove(chartKey);
        else
            _selectedSeries[chartKey] = inverted;
    }

