    private ApexChartOptions<NumericDataPoint> BuildDropdownTrendOptions(DropdownValueTrendSeries trend, List<string> colors)
    {
        var unitLabel = trend.ValueFieldUnit != "UN" ? trend.ValueFieldUnit : trend.ValueFieldName;
        return new ApexChartOptions<NumericDataPoint>
        {
            Chart = new Chart
            {
                Toolbar = new Toolbar { Show = true, AutoSelected = AutoSelected.Pan },
                Zoom = new Zoom { Enabled = true, AllowMouseWheelZoom = false }
            },
            Xaxis = new XAxis
            {
                Type = XAxisType.Datetime,
                Labels = new XAxisLabels
                {
                    DatetimeFormatter = new DatetimeFormatter
                    {
                        Day = "dd MMM",
                        Month = "MMM yyyy"
                    }
                }
            },
            Yaxis = [new YAxis { Title = new AxisTitle { Text = unitLabel } }],
            Stroke = new Stroke { Curve = Curve.Smooth, Width = 2 },
            Colors = colors,
            Legend = new Legend { Position = LegendPosition.Bottom, Show = false },
            Tooltip = new Tooltip { X = new TooltipX { Format = "dd MMM yyyy" } }
        };
    }

    private void ToggleDropdownTrendSeries(string chartKey, string seriesName, int totalCount)
    {
        if (!_selectedSeries.TryGetValue(chartKey, out var selected))
        {
            // No filter active — first click isolates this single series
            _selectedSeries[chartKey] = [seriesName];
            return;
        }

        if (selected.Contains(seriesName))
        {
            // Already selected — remove it (but don't allow empty set)
            if (selected.Count > 1)
                selected.Remove(seriesName);
            else
                _selectedSeries.Remove(chartKey); // last one — restore all
        }
        else
        {
            // Not selected — add it
            selected.Add(seriesName);
            // If all are now selected, just clear the filter
            if (selected.Count >= totalCount)
                _selectedSeries.Remove(chartKey);
        }
    }

    private void InvertDropdownTrendSeries(string chartKey, IReadOnlyList<DropdownValueSeries> allSeries)
    {
        if (!_selectedSeries.TryGetValue(chartKey, out var selected))
            return;

        var inverted = allSeries
            .Where(s => !selected.Contains(s.ValueLabel))
            .Select(s => s.ValueLabel)
            .ToHashSet();

        if (inverted.Count == 0 || inverted.Count == allSeries.Count)
            _selectedSeries.Remove(chartKey);
        else
            _selectedSeries[chartKey] = inverted;
    }

    private static readonly List<string> CrossFieldPalette = new()
