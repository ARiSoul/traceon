@page "/dashboard/action/{ActionId:guid}/detail"
@attribute [Authorize]

<PageTitle>Action Analytics - Traceon</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-1">
            <i class="bi bi-graph-up-arrow me-2"></i>
            Action Analytics
        </h3>
        <p class="text-muted mb-0">
            Deep dive into <strong>@(_data?.Stats.Name ?? "...")</strong>
        </p>
    </div>
    <div class="d-flex gap-2">
        <a href="/dashboard" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
        </a>
    </div>
</div>

<ErrorAlert Errors="_errors" OnDismiss="() => _errors = []" />

<!-- Period Filter -->
<div class="row g-2 mb-4">
    <div class="col-12 col-md-3">
        <label class="form-label form-label-sm mb-1">
            <i class="bi bi-calendar-range me-1"></i>Period
        </label>
        <select class="form-select form-select-sm" value="@_periodMode" @onchange="OnPeriodModeChanged">
            <option value="all">All Time</option>
            <option value="days">Last N Days</option>
            <option value="months">Last N Months</option>
            <option value="custom">Custom Range</option>
        </select>
    </div>
    @if (_periodMode is "days" or "months")
    {
        <div class="col-6 col-md-2">
            <label class="form-label form-label-sm mb-1">
                @(_periodMode == "days" ? "Days" : "Months")
            </label>
            <input type="number" class="form-control form-control-sm" min="1"
                   value="@_periodValue" @onchange="OnPeriodValueChanged" />
        </div>
    }
    else if (_periodMode == "custom")
    {
        <div class="col-6 col-md-2">
            <label class="form-label form-label-sm mb-1">From</label>
            <input type="date" class="form-control form-control-sm"
                   value="@_customFrom?.ToString("yyyy-MM-dd")" @onchange="OnCustomFromChanged" />
        </div>
        <div class="col-6 col-md-2">
            <label class="form-label form-label-sm mb-1">To</label>
            <input type="date" class="form-control form-control-sm"
                   value="@_customTo?.ToString("yyyy-MM-dd")" @onchange="OnCustomToChanged" />
        </div>
    }
</div>

@if (_loading)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (_data is null)
{
    <div class="alert alert-warning">
        <i class="bi bi-question-circle me-2"></i>Action not found.
    </div>
}
else
{
    <!-- Key Metrics -->
    <div class="row row-cols-2 row-cols-md-5 g-3 mb-4">
        <div class="col">
            <div class="card h-100">
                <div class="card-body text-center py-2">
                    <div class="fs-4 fw-bold text-primary">@_data.Stats.EntryCount</div>
                    <small class="text-muted">Entries</small>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100">
                <div class="card-body text-center py-2">
                    <div class="fs-4 fw-bold text-success">@_data.Stats.FieldCount</div>
                    <small class="text-muted">Fields</small>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100">
                <div class="card-body text-center py-2">
                    <div class="fs-4 fw-bold text-info">@FormatGap(_data.Stats.AverageGapDays)</div>
                    <small class="text-muted">Avg. Gap</small>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100">
                <div class="card-body text-center py-2">
                    <div class="fs-4 fw-bold text-danger">
                        <i class="bi bi-fire me-1"></i>@_data.Stats.Streak
                    </div>
                    <small class="text-muted">Streak</small>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100">
                <div class="card-body text-center py-2">
                    <div class="fs-4 fw-bold text-warning">@FormatRelative(_data.Stats.LastEntryUtc)</div>
                    <small class="text-muted">Last Entry</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Entry Frequency Chart -->
    @if (_data.DailyEntries.Count > 0)
    {
        <div class="card mb-4">
            <div class="card-header">
                <h6 class="mb-0"><i class="bi bi-bar-chart me-2"></i>Entry Frequency</h6>
            </div>
            <div class="card-body">
                <ApexChart TItem="DailyCount"
                           Options="_frequencyOptions"
                           Height="250"
                           @ref="_frequencyChart">
                    <ApexPointSeries TItem="DailyCount"
                                    Items="_data.DailyEntries"
                                    SeriesType="SeriesType.Area"
                                    Name="Entries"
                                    XValue="d => d.Date"
                                    YValue="d => d.Count"
                                    OrderBy="d => d.X" />
                </ApexChart>
            </div>
        </div>
    }

    <!-- Numeric Field Trend Charts -->
    @foreach (var series in _data.NumericSeries)
    {
        <div class="card mb-4">
            <div class="card-header">
                <h6 class="mb-0">
                    <i class="bi bi-graph-up me-2"></i>@series.Name
                    @if (series.Unit != "UN")
                    {
                        <span class="badge bg-info ms-1">@series.Unit</span>
                    }
                </h6>
            </div>
            <div class="card-body">
                <ApexChart TItem="NumericDataPoint"
                           Options="BuildNumericOptions(series)"
                           Height="250">
                    <ApexPointSeries TItem="NumericDataPoint"
                                    Items="series.Points"
                                    SeriesType="SeriesType.Line"
                                    Name="@series.Name"
                                    XValue="p => p.Date"
                                    YValue="p => p.Value"
                                    OrderBy="p => p.X" />
                </ApexChart>
            </div>
        </div>
    }

    <!-- Boolean Field Charts -->
    @foreach (var series in _data.BooleanSeries)
    {
        <div class="card mb-4">
            <div class="card-header">
                <h6 class="mb-0"><i class="bi bi-toggles me-2"></i>@series.Name</h6>
            </div>
            <div class="card-body">
                <ApexChart TItem="BooleanDataPoint"
                           Options="BuildBooleanOptions(series)"
                           Height="250">
                    <ApexPointSeries TItem="BooleanDataPoint"
                                    Items="series.Points"
                                    SeriesType="SeriesType.Bar"
                                    Name="True"
                                    XValue="p => p.Date"
                                    YValue="p => (decimal)p.TrueCount"
                                    OrderBy="p => p.X" />
                    <ApexPointSeries TItem="BooleanDataPoint"
                                    Items="series.Points"
                                    SeriesType="SeriesType.Bar"
                                    Name="False"
                                    XValue="p => p.Date"
                                    YValue="p => (decimal)p.FalseCount"
                                    OrderBy="p => p.X" />
                </ApexChart>
            </div>
        </div>
    }

    <!-- Dropdown Distribution Charts -->
    @foreach (var series in _data.DropdownSeries)
    {
        <div class="card mb-4">
            <div class="card-header">
                <h6 class="mb-0"><i class="bi bi-pie-chart me-2"></i>@series.Name Distribution</h6>
            </div>
            <div class="card-body">
                <ApexChart TItem="DropdownDataPoint"
                           Options="BuildDonutOptions(series)"
                           Height="280">
                    <ApexPointSeries TItem="DropdownDataPoint"
                                    Items="series.Distribution"
                                    SeriesType="SeriesType.Donut"
                                    Name="Count"
                                    XValue="p => p.Label"
                                    YValue="p => p.Count"
                                    OrderByDescending="p => p.Y" />
                </ApexChart>
            </div>
        </div>
    }

    <!-- Field Summary Stats (reuse existing pattern) -->
    @if (_data.Stats.FieldStats.Count > 0)
    {
        <h5 class="mb-3"><i class="bi bi-sliders me-2"></i>Field Summary</h5>
        <div class="row g-3 mb-4">
            @foreach (var field in _data.Stats.FieldStats)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card border h-100">
                        <div class="card-body p-3">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <strong>@field.Name</strong>
                                <div class="d-flex gap-1">
                                    @if (field.Type is FieldType.Integer or FieldType.Decimal && field.Unit != "UN")
                                    {
                                        <span class="badge bg-info">@field.Unit</span>
                                    }
                                    <span class="badge bg-secondary">@field.Type</span>
                                </div>
                            </div>
                            @if (field.Type is FieldType.Integer or FieldType.Decimal && field.NumericCount > 0)
                            {
                                var u = field.Unit != "UN" ? $" {field.Unit}" : "";
                                <div class="row g-1 text-center">
                                    <div class="col-3">
                                        <div class="small fw-bold text-primary">@FormatDecimal(field.NumericMin)@u</div>
                                        <div class="text-muted" style="font-size: 0.6rem;">Min</div>
                                    </div>
                                    <div class="col-3">
                                        <div class="small fw-bold text-success">@FormatDecimal(field.NumericAvg)@u</div>
                                        <div class="text-muted" style="font-size: 0.6rem;">Avg</div>
                                    </div>
                                    <div class="col-3">
                                        <div class="small fw-bold text-danger">@FormatDecimal(field.NumericMax)@u</div>
                                        <div class="text-muted" style="font-size: 0.6rem;">Max</div>
                                    </div>
                                    <div class="col-3">
                                        <div class="small fw-bold text-warning">@FormatDecimal(field.NumericSum)@u</div>
                                        <div class="text-muted" style="font-size: 0.6rem;">Sum</div>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <small class="text-muted">@field.TotalValues values recorded</small>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

@code {
    [Parameter] public Guid ActionId { get; set; }
    [Inject] private DashboardService DashService { get; set; } = default!;

    private ActionDetailData? _data;
    private bool _loading = true;
    private IReadOnlyList<string> _errors = [];
    private ApexChart<DailyCount>? _frequencyChart;

    private string _periodMode = "all";
    private int _periodValue = 90;
    private DateTime? _customFrom;
    private DateTime? _customTo;

    private ApexChartOptions<DailyCount> _frequencyOptions = new();

    protected override async Task OnInitializedAsync()
    {
        BuildFrequencyOptions();
        await LoadAsync();
    }

    private void BuildFrequencyOptions()
    {
        _frequencyOptions = new ApexChartOptions<DailyCount>
        {
            Chart = new Chart
            {
                Toolbar = new Toolbar { Show = true },
                Zoom = new Zoom { Enabled = true }
            },
            Xaxis = new XAxis
            {
                Type = XAxisType.Datetime
            },
            Yaxis = [new YAxis { Title = new AxisTitle { Text = "Entries" }, Min = 0 }],
            Stroke = new Stroke { Curve = Curve.Smooth, Width = 2 },
            Fill = new Fill { Opacity = new Opacity(0.3) },
            Colors = ["#0d6efd"],
            Tooltip = new Tooltip { X = new TooltipX { Format = "MMM dd, yyyy" } }
        };
    }

    private static ApexChartOptions<NumericDataPoint> BuildNumericOptions(NumericFieldSeries series)
    {
        var yTitle = series.Unit != "UN" ? series.Unit : series.Name;
        return new ApexChartOptions<NumericDataPoint>
        {
            Chart = new Chart
            {
                Toolbar = new Toolbar { Show = true },
                Zoom = new Zoom { Enabled = true }
            },
            Xaxis = new XAxis { Type = XAxisType.Datetime },
            Yaxis = [new YAxis { Title = new AxisTitle { Text = yTitle } }],
            Stroke = new Stroke { Curve = Curve.Smooth, Width = 2 },
            Colors = ["#198754"],
            Markers = new Markers { Size = 3 },
            Tooltip = new Tooltip { X = new TooltipX { Format = "MMM dd, yyyy" } }
        };
    }

    private static ApexChartOptions<BooleanDataPoint> BuildBooleanOptions(BooleanFieldSeries series)
    {
        return new ApexChartOptions<BooleanDataPoint>
        {
            Chart = new Chart
            {
                Stacked = true,
                Toolbar = new Toolbar { Show = true }
            },
            Xaxis = new XAxis { Type = XAxisType.Datetime },
            Yaxis = [new YAxis { Title = new AxisTitle { Text = "Count" }, Min = 0 }],
            Colors = ["#198754", "#dc3545"],
            PlotOptions = new PlotOptions
            {
                Bar = new PlotOptionsBar { ColumnWidth = "70%" }
            },
            Tooltip = new Tooltip { X = new TooltipX { Format = "MMM dd, yyyy" } }
        };
    }

    private static ApexChartOptions<DropdownDataPoint> BuildDonutOptions(DropdownFieldSeries series)
    {
        return new ApexChartOptions<DropdownDataPoint>
        {
            Chart = new Chart { },
            Legend = new Legend { Position = LegendPosition.Bottom }
        };
    }

    private (DateTime? From, DateTime? To) ResolveDateRange() => _periodMode switch
    {
        "days" => (DateTime.UtcNow.AddDays(-_periodValue), null),
        "months" => (DateTime.UtcNow.AddMonths(-_periodValue), null),
        "custom" => (_customFrom, _customTo?.AddDays(1)),
        _ => (null, null)
    };

    private async Task LoadAsync()
    {
        _loading = true;
        _errors = [];
        try
        {
            var (from, to) = ResolveDateRange();
            _data = await DashService.LoadActionDetailAsync(ActionId, from, to);
        }
        catch (Exception ex)
        {
            _errors = [$"Failed to load: {ex.Message}"];
        }
        _loading = false;
    }

    private async Task OnPeriodModeChanged(ChangeEventArgs e)
    {
        _periodMode = e.Value?.ToString() ?? "all";
        if (_periodMode == "custom")
        {
            _customFrom = DateTime.Today.AddMonths(-3);
            _customTo = DateTime.Today;
        }
        await LoadAsync();
    }

    private async Task OnPeriodValueChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var val) && val > 0)
        {
            _periodValue = val;
            await LoadAsync();
        }
    }

    private async Task OnCustomFromChanged(ChangeEventArgs e)
    {
        _customFrom = DateTime.TryParse(e.Value?.ToString(), out var d) ? d : null;
        await LoadAsync();
    }

    private async Task OnCustomToChanged(ChangeEventArgs e)
    {
        _customTo = DateTime.TryParse(e.Value?.ToString(), out var d) ? d : null;
        await LoadAsync();
    }

    private static string FormatGap(double? days)
    {
        if (days is null) return "—";
        return days.Value switch
        {
            < 1 => $"{(int)(days.Value * 24)}h",
            < 2 => "~1d",
            < 7 => $"{days.Value:F1}d",
            _ => $"{days.Value / 7:F1}w"
        };
    }

    private static string FormatRelative(DateTime? utc)
    {
        if (utc is null) return "—";
        var diff = DateTime.UtcNow - utc.Value;
        return diff.TotalHours switch
        {
            < 1 => "now",
            < 24 => $"{(int)diff.TotalHours}h",
            < 48 => "yday",
            _ => $"{(int)diff.TotalDays}d"
        };
    }

    private static string FormatDecimal(decimal? value)
    {
        if (value is null) return "—";
        return value == Math.Truncate(value.Value) ? value.Value.ToString("F0") : value.Value.ToString("F2");
    }
}
