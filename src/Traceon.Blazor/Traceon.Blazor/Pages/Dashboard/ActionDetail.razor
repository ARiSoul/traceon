                Style = new DataLabelsStyle { FontSize = "10px" }
            }
        };
    }

    private ApexChartOptions<DropdownDataPoint> BuildDonutOptions(DropdownFieldSeries series)
    {
        return new ApexChartOptions<DropdownDataPoint>
        {
            Chart = new Chart { },
            Legend = new Legend
            {
                Position = LegendPosition.Bottom,
                Formatter = "function(seriesName, opts) { return seriesName + ' — ' + opts.w.globals.series[opts.seriesIndex]; }"
            },
            DataLabels = new DataLabels
            {
                Enabled = true,
