    private static ApexChartOptions<CrossFieldGroup> BuildCrossFieldPieOptions(CrossFieldResult result)
    {
        return new ApexChartOptions<CrossFieldGroup>
        {
            Chart = new Chart { },
            Colors = CrossFieldPalette,
            Legend = new Legend
            {
                Position = LegendPosition.Bottom,
                Formatter = "function(seriesName, opts) { return seriesName + ' — ' + opts.w.globals.series[opts.seriesIndex]; }"
            },
            DataLabels = new DataLabels
            {
                Enabled = true,
                Formatter = "function(val) { return Math.round(val) + '%'; }",
