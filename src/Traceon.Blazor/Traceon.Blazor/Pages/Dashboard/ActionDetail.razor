            {
                Yaxis =
                [
                    new AnnotationsYAxis
                    {
                        Y = balance.GoalValue.Value,
                        BorderColor = "#ff9800",
                        StrokeDashArray = 4,
                        Label = new Label
                        {
                            Text = $"{L["Analytics_Goal"]}: {goalLabel}",
                            Style = new Style { Background = "#ff9800", Color = "#fff" }
                        }
                    }
                ]
            };
        }

        return options;
    }

    private static string FormatNumeric(decimal value, bool isInteger)
    {
        if (isInteger) return ((int)value).ToString("N0");
        return value == Math.Truncate(value) ? $"{value:N0}" : $"{value:N2}";
    }

    private string FormatAggregationLabel(AnalyticsAggregation agg) => agg switch
    {
        AnalyticsAggregation.Sum => L["Aggregation_Sum"],
        AnalyticsAggregation.Avg => L["Aggregation_Avg"],
        AnalyticsAggregation.Min => L["Aggregation_Min"],
        AnalyticsAggregation.Max => L["Aggregation_Max"],
        AnalyticsAggregation.Count => L["Aggregation_Count"],
        AnalyticsAggregation.SignedSum => L["Aggregation_SignedSum"],
        AnalyticsAggregation.CountByValue => L["Aggregation_CountByValue"],
        _ => agg.ToString()
    };

    private static string FormatCrossFieldValue(decimal value, CrossFieldResult result)
    {
        var unit = result.Unit is not null && result.Unit != "UN" ? $" {result.Unit}" : "";
        if (result.Aggregation is AnalyticsAggregation.Count or AnalyticsAggregation.CountByValue)
            return ((int)value).ToString();
        return value == Math.Truncate(value)
            ? $"{value:F0}{unit}"
            : $"{value:F2}{unit}";
    }

    private static string FormatMetricValue(decimal value)
        => value == Math.Truncate(value) ? $"{value:F0}" : $"{value:F2}";

    private RenderFragment RenderCountByValueResult(CrossFieldResult result) => __builder =>
    {
        var sortedGroups = result.Groups.OrderByDescending(g => g.Value).ToList();
        var grandTotal = sortedGroups.Sum(g => g.Value);
        var hasMetrics = result.ValueMetrics.Count > 0 && sortedGroups.Any(g => g.Metrics is not null);
        var unitSuffix = result.ValueFieldUnit is not null ? $" {result.ValueFieldUnit}" : "";

        <!-- Overview bar chart -->
        <ApexChart TItem="CrossFieldGroup"
                   Options="BuildCrossFieldBarOptions(result)"
                   Height="200">
            <ApexPointSeries TItem="CrossFieldGroup"
                            Items="sortedGroups"
                            SeriesType="SeriesType.Bar"
                            Name="@L["Aggregation_Count"]"
                            XValue="g => g.Key"
                            YValue="g => g.Value"
                            OrderByDescending="g => g.Y" />
        </ApexChart>

        <!-- Hierarchical breakdown -->
        <div class="mt-3">
            @foreach (var grp in sortedGroups)
            {
                var grpPct = grandTotal > 0 ? (double)(grp.Value / grandTotal * 100) : 0;
                var maxSubVal = grp.SubGroups.Count > 0 ? grp.SubGroups.Max(s => s.Value) : 1;

                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <span class="fw-semibold">
                            <i class="bi bi-folder2 me-1 text-primary"></i>@grp.Key
                        </span>
                        <span>
                            <span class="badge bg-primary rounded-pill">@((int)grp.Value)</span>
                            <small class="text-muted ms-1">(@grpPct.ToString("F1")%)</small>
                        </span>
                    </div>

                    @if (hasMetrics && grp.Metrics is not null)
                    {
                        <div class="d-flex gap-3 ps-3 mb-1">
                            @foreach (var m in result.ValueMetrics.OrderBy(m => m))
                            {
                                if (grp.Metrics.TryGetValue(m, out var mVal))
                                {
                                    <small class="text-muted">
                                        <span class="fw-semibold">@L[$"Aggregation_{m}"]:</span>
                                        @FormatMetricValue(mVal)@unitSuffix
                                    </small>
                                }
                            }
                        </div>
                    }

                    @if (grp.SubGroups.Count > 0)
                    {
                        <div class="ps-3 border-start border-2 border-primary-subtle">
                            @foreach (var sub in grp.SubGroups)
                            {
                                var subWidthPct = (int)(sub.Value / maxSubVal * 100);
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    <span class="text-truncate" style="min-width: 80px; max-width: 140px; font-size: 0.8rem;">@sub.Key</span>
                                    <div class="flex-grow-1">
                                        <div class="progress" style="height: 14px;">
                                            <div class="progress-bar bg-info bg-opacity-75" style="width: @subWidthPct%">
                                                @if (subWidthPct > 20)
                                                {
                                                    <small>@((int)sub.Value)</small>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                    @if (subWidthPct <= 20)
                                    {
                                        <small class="text-muted flex-shrink-0">@((int)sub.Value)</small>
                                    }
                                    @if (hasMetrics && sub.Metrics is not null)
                                    {
                                        <span class="flex-shrink-0 d-flex gap-2">
                                            @foreach (var m in result.ValueMetrics.OrderBy(m => m))
                                            {
                                                if (sub.Metrics.TryGetValue(m, out var sVal))
                                                {
                                                    <small class="text-muted" title="@L[$"Aggregation_{m}"]">
                                                        @L[$"Metric_{m}"] @FormatMetricValue(sVal)@unitSuffix
                                                    </small>
                                                }
                                            }
                                        </span>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <small class="text-muted ps-3">@L["Common_NoDataYet"]</small>
                    }
                </div>
            }
        </div>

        <!-- Summary totals table -->
        <div class="table-responsive mt-2">
            <table class="table table-sm mb-0">
                <tfoot>
                    <tr class="table-light">
                        <td class="fw-bold">@L["Analytics_Total"]</td>
                        <td class="text-end fw-bold">
                            @((int)grandTotal)
                            @if (hasMetrics)
                            {
                                var allMetricsGroups = sortedGroups.Where(g => g.Metrics is not null).SelectMany(g => g.Metrics!).ToList();
                                @foreach (var m in result.ValueMetrics.OrderBy(m => m))
                                {
                                    var vals = allMetricsGroups.Where(kv => kv.Key.Equals(m, StringComparison.OrdinalIgnoreCase)).Select(kv => kv.Value).ToList();
                                    if (vals.Count > 0)
                                    {
                                        var total = m.Equals("Avg", StringComparison.OrdinalIgnoreCase) ? vals.Average()
                                                  : m.Equals("Min", StringComparison.OrdinalIgnoreCase) ? vals.Min()
                                                  : m.Equals("Max", StringComparison.OrdinalIgnoreCase) ? vals.Max()
                                                  : vals.Sum();
                                        <small class="text-muted ms-2">@L[$"Aggregation_{m}"]: @FormatMetricValue(total)@unitSuffix</small>
                                    }
                                }
                            }
                        </td>
                    </tr>
                </tfoot>
            </table>
        </div>
    };

    private (DateTime? From, DateTime? To) ResolveDateRange() => _periodMode switch
    {
        "days" => (DateTime.UtcNow.AddDays(-_periodValue), null),
        "months" => (DateTime.UtcNow.AddMonths(-_periodValue), null),
        "years" => (DateTime.UtcNow.AddYears(-_periodValue), null),
        "month" when _selectedMonth.HasValue => (_selectedMonth.Value, _selectedMonth.Value.AddMonths(1)),
        "custom" => (_customFrom, _customTo?.AddDays(1)),
        _ => (null, null)
    };

    private async Task LoadAsync()
    {
        _loading = true;
        _errors = [];
        await LoadDataCoreAsync();
        _loading = false;
    }

    private async Task LoadDataCoreAsync()
    {
        try
        {
            var (from, to) = ResolveDateRange();
            _data = await DashService.LoadActionDetailAsync(ActionId, from, to);
            _loadKey++;
        }
        catch (Exception ex)
        {
            _errors = [L["Analytics_LoadFailed", ex.Message]];
        }
    }

    private async Task ApplyFiltersAsync()
    {
        _applying = true;
        await SaveFiltersAsync();
        await LoadDataCoreAsync();
        _applying = false;
    }

    private async Task ResetFiltersAsync()
    {
        _applying = true;
        _periodMode = "all";
        _periodValue = 90;
        _customFrom = null;
        _customTo = null;
        _selectedMonth = null;
        try { await LocalStorage.RemoveItemAsync(DetailStorageKey); } catch { }
        await LoadDataCoreAsync();
        _applying = false;
    }

    // ── Filter persistence ──

    private async Task RestoreFiltersAsync()
    {
        try
        {
            var state = await LocalStorage.GetItemAsync<ActionDetailFilterState>(DetailStorageKey);
            if (state is null) return;
            if (state.PeriodMode is not null) _periodMode = state.PeriodMode;
            if (state.PeriodValue.HasValue) _periodValue = state.PeriodValue.Value;
            _customFrom = state.CustomFrom;
            _customTo = state.CustomTo;
            _selectedMonth = state.SelectedMonth;
        }
        catch { /* best effort */ }
    }

    private async Task SaveFiltersAsync()
    {
        try
        {
            await LocalStorage.SetItemAsync(DetailStorageKey, new ActionDetailFilterState
            {
                PeriodMode = _periodMode,
                PeriodValue = _periodValue,
                CustomFrom = _customFrom,
                CustomTo = _customTo,
                SelectedMonth = _selectedMonth
            });
        }
        catch { /* best effort */ }
    }

    private sealed class ActionDetailFilterState
    {
        public string? PeriodMode { get; set; }
        public int? PeriodValue { get; set; }
        public DateTime? CustomFrom { get; set; }
        public DateTime? CustomTo { get; set; }
        public DateTime? SelectedMonth { get; set; }
    }

    // ── Chart visibility persistence ──

    private async void ToggleChartVisibility(string chartKey, bool hide)
    {
        if (hide)
            _hiddenCharts.Add(chartKey);
        else
            _hiddenCharts.Remove(chartKey);
        await SaveHiddenChartsAsync();
    }

    private async Task RestoreHiddenChartsAsync()
    {
        try
        {
            var hidden = await LocalStorage.GetItemAsync<List<string>>(ChartVisibilityKey);
            if (hidden is { Count: > 0 })
                _hiddenCharts = new HashSet<string>(hidden, StringComparer.Ordinal);
        }
        catch { /* best effort */ }
    }

    private async Task SaveHiddenChartsAsync()
    {
        try
        {
            if (_hiddenCharts.Count > 0)
                await LocalStorage.SetItemAsync(ChartVisibilityKey, _hiddenCharts.ToList());
            else
                await LocalStorage.RemoveItemAsync(ChartVisibilityKey);
        }
        catch { /* best effort */ }
    }

    private string BuildEntriesUrl()
    {
        var (from, to) = ResolveDateRange();
        var url = $"/entries/action/{ActionId}";
        var queryParams = new List<string>();
        if (from.HasValue) queryParams.Add($"from={from.Value:yyyy-MM-dd}");
        if (to.HasValue) queryParams.Add($"to={to.Value:yyyy-MM-dd}");
        return queryParams.Count > 0 ? $"{url}?{string.Join("&", queryParams)}" : url;
    }

    private string FormatGap(double? days)
    {
        if (days is null) return "—";
        return days.Value switch
        {
            (< 1) => L["Gap_Hours", (int)(days.Value * 24)],
            (< 2) => L["Gap_About1D"],
            (< 7) => L["Gap_DShort", days.Value.ToString("F1")],
            _ => L["Gap_WShort", (days.Value / 7).ToString("F1")]
        };
    }

    private string FormatRelative(DateTime? utc)
    {
        if (utc is null) return "—";
        var diff = DateTime.UtcNow - utc.Value;
        return diff.TotalHours switch
        {
            (< 1) => L["Time_Now"],
            (< 24) => L["Gap_Hours", (int)diff.TotalHours],
            (< 48) => L["Time_YDay"],
            _ => L["Gap_DShort", (int)diff.TotalDays]
        };
    }

    private static string FormatDecimal(decimal? value)
    {
        if (value is null) return "—";
        return value == Math.Truncate(value.Value) ? value.Value.ToString("F0") : value.Value.ToString("F2");
    }

    private static string FormatNumeric(decimal? value, bool isInteger)
    {
        if (value is null) return "—";
        if (isInteger) return ((int)Math.Round(value.Value)).ToString();
        return value == Math.Truncate(value.Value)
            ? value.Value.ToString("F0")
            : value.Value.ToString("F2");
    }
}
