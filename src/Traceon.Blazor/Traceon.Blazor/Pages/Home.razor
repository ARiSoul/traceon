@page "/"

<PageTitle>Traceon</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-1">
            <i class="bi bi-bullseye me-2"></i>
            Traceon
        </h3>
        <p class="text-muted mb-0">Track, measure, and improve your daily actions</p>
    </div>
</div>

<AuthorizeView>
    <Authorized>
        <div class="row g-3">
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="bi bi-list-check text-primary me-2"></i>Tracked Actions
                        </h5>
                        <p class="card-text text-muted">Create and manage the actions you want to track over time.</p>
                        <a href="/tracked-actions" class="btn btn-outline-primary">
                            <i class="bi bi-arrow-right me-1"></i>Go to Actions
                        </a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="bi bi-tags text-info me-2"></i>Tags
                        </h5>
                        <p class="card-text text-muted">Organize your actions with tags for easy filtering and grouping.</p>
                        <a href="/tags" class="btn btn-outline-info">
                            <i class="bi bi-arrow-right me-1"></i>Go to Tags
                        </a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="bi bi-sliders text-warning me-2"></i>Field Definitions
                        </h5>
                        <p class="card-text text-muted">Define reusable field templates for your tracked actions.</p>
                        <a href="/field-definitions" class="btn btn-outline-warning">
                            <i class="bi bi-arrow-right me-1"></i>Go to Fields
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="card">
            <div class="card-body text-center py-5">
                <i class="bi bi-box-arrow-in-right display-4 text-muted mb-3 d-block"></i>
                <h5>Welcome to Traceon</h5>
                <p class="text-muted">Please log in to start tracking your actions.</p>
                <a href="/auth/login" class="btn btn-primary">
                    <i class="bi bi-box-arrow-in-right me-1"></i>Login
                </a>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>
