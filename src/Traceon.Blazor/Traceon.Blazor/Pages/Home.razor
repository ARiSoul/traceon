@page "/"
@inject IStringLocalizer<SharedResource> L

<PageTitle>Traceon</PageTitle>

<AuthorizeView>
    <Authorized>
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h3 class="mb-1">
                    <i class="bi bi-bullseye me-2"></i>
                    Traceon
                </h3>
                <p class="text-muted mb-0">@L["Home_Subtitle"]</p>
            </div>
            <a href="/tracked-actions/create" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i>@L["ActionCreate_Title"]
            </a>
        </div>

        <ErrorAlert Errors="_errors" OnDismiss="() => _errors = []" />

        @if (_loggedActionName is not null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-check-circle-fill"></i>
                    <span><strong>@_loggedActionName</strong> @L["Home_TrackedSuccess"]</span>
                    <button type="button" class="btn-close" @onclick="() => _loggedActionName = null"></button>
                </div>
            </div>
        }

        @if (_loading)
        {
            <div class="d-flex justify-content-center py-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">@L["Common_Loading"]</span>
                </div>
            </div>
        }
        else if (_actions.Count == 0)
        {
            <div class="text-center py-4 mb-4">
                <i class="bi bi-rocket-takeoff display-3 text-primary mb-3 d-block"></i>
                <h4>@L["Onboard_Welcome"]</h4>
                <p class="text-muted" style="max-width: 500px; margin: 0 auto;">@L["Onboard_Hint"]</p>
            </div>

            @if (_installingTemplate is not null)
            {
                <div class="text-center py-3">
                    <div class="spinner-border text-primary mb-2"></div>
                    <p class="text-muted">@L["Onboard_Installing"]</p>
                </div>
            }
            else if (_installSuccess)
            {
                <div class="alert alert-success text-center">
                    <i class="bi bi-check-circle me-1"></i>@L["Onboard_Installed"]
                </div>
            }
            else
            {
                @if (_templates.Count > 0)
                {
                    <h5 class="mb-3 text-center">
                        <i class="bi bi-box-seam me-1"></i>@L["Onboard_ChooseTemplate"]
                    </h5>

                    <div class="row g-3 justify-content-center mb-4">
                        @foreach (var template in _templates)
                        {
                            <div class="col-12 col-sm-6 col-lg-3">
                                <div class="card h-100 border-2 template-card" style="cursor: pointer; border-color: @template.Color;"
                                     @onclick="() => InstallTemplateAsync(template.Id)">
                                    <div class="card-body text-center">
                                        <i class="bi @template.Icon display-5 d-block mb-2" style="color: @template.Color;"></i>
                                        <h6 class="card-title">@L[template.NameKey]</h6>
                                        <p class="card-text text-muted small mb-2">@L[template.DescriptionKey]</p>
                                        <div class="d-flex flex-wrap justify-content-center gap-1">
                                            @foreach (var action in template.Actions)
                                            {
                                                <span class="badge bg-body-secondary text-body border">@L[action.NameKey]</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="d-flex align-items-center mb-3" style="max-width: 600px; margin: 0 auto;">
                        <hr class="flex-grow-1" />
                        <span class="px-3 text-muted small">@L["Onboard_Or"]</span>
                        <hr class="flex-grow-1" />
                    </div>
                }

                <div class="text-center">
                    <a href="/tracked-actions/create" class="btn btn-outline-primary">
                        <i class="bi bi-plus-circle me-1"></i>@L["Onboard_StartFromScratch"]
                    </a>
                </div>
            }
        }
        else
        {
            <div class="d-flex align-items-center gap-2 mb-3">
                <h5 class="mb-0">
                    <i class="bi bi-lightning-charge me-1"></i>@L["Home_QuickTracking"]
                </h5>
                <button class="btn btn-sm @(_showFilters ? "btn-primary" : "btn-outline-secondary")"
                        @onclick="() => _showFilters = !_showFilters">
                    <i class="bi bi-funnel me-1"></i>@L["Common_Filter"]
                    @if (_hasActiveFilters)
                    {
                        <span class="badge bg-light text-primary ms-1">!</span>
                    }
                </button>
                @if (_actions.Count > 1)
                {
                    <button class="btn btn-sm @(_reordering ? "btn-primary" : "btn-outline-secondary")"
                            @onclick="ToggleReorder">
                        <i class="bi bi-arrows-move me-1"></i>@(_reordering ? L["Home_Done"] : L["Home_Reorder"])
                    </button>
                }
            </div>

            @if (_showFilters)
            {
                <div class="card card-body mb-3">
                    <div class="row g-2 align-items-end">
                        <div class="col-md-4">
                            <label class="form-label small mb-1">@L["Common_Search"]</label>
                            <input type="text" class="form-control form-control-sm"
                                   placeholder="@L["Home_SearchPlaceholder"]"
                                   @bind="_filterText" @bind:event="oninput" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small mb-1">@L["Common_Tags"]</label>
                            <div class="d-flex flex-wrap gap-1">
                                @foreach (var tag in _allTags)
                                {
                                    var selected = _selectedTags.Contains(tag);
                                    <button class="btn btn-sm @(selected ? "" : "btn-outline-secondary")"
                                            style="@(selected ? $"background-color: {tag.Color}; color: #fff; border-color: {tag.Color};" : "")"
                                            @onclick="() => ToggleTag(tag)">
                                        @tag.Name
                                    </button>
                                }
                                @if (_allTags.Count == 0)
                                {
                                    <span class="text-muted small">@L["Home_NoTags"]</span>
                                }
                            </div>
                        </div>
                        <div class="col-md-2">
                            @if (_hasActiveFilters)
                            {
                                <button class="btn btn-sm btn-outline-secondary w-100" @onclick="ClearFilters">
                                    <i class="bi bi-x-circle me-1"></i>@L["DataGrid_Clear"]
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }

            @if (FilteredActions.Count == 0)
            {
                <p class="text-muted text-center py-3">
                    <i class="bi bi-search me-1"></i>@L["Home_NoMatchingActions"]
                </p>
            }

            <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-3 mb-4">
                @foreach (var action in FilteredActions)
                {
                    <div class="col"
                         draggable="@(_reordering ? "true" : "false")"
                         @ondragstart="() => _dragIndex = _actions.IndexOf(action)"
                         @ondragover:preventDefault="_reordering"
                         @ondrop="() => OnDrop(_actions.IndexOf(action))"
                         style="@(_reordering ? "cursor: grab;" : "")">
                        @if (_reordering)
                        {
                            <div class="card h-100 border-dashed">
                                <div class="card-body d-flex align-items-center gap-2 py-3">
                                    <i class="bi bi-grip-vertical text-muted fs-5"></i>
                                    <span class="badge bg-secondary rounded-pill">@(_actions.IndexOf(action) + 1)</span>
                                    <strong class="flex-grow-1 text-truncate">@action.Name</strong>
                                </div>
                            </div>
                        }
                        else
                        {
                            <QuickTrackCard Action="action"
                                            Highlighted="action.Name == _loggedActionName"
                                            Balances="@(_balances.GetValueOrDefault(action.Id) ?? [])"
                                            OnTrack="OpenTrackModal" />
                        }
                    </div>
                }
            </div>
        }

        <QuickTrackModal @ref="_trackModal"
                         ActionName="@(_selectedAction?.Name ?? "")"
                         OnConfirm="OnTrackConfirmedAsync" />
    </Authorized>
    <NotAuthorized>
        <div class="d-flex justify-content-center align-items-center" style="min-height: 60vh;">
            <div class="card" style="max-width: 400px; width: 100%;">
                <div class="card-body text-center py-5">
                    <i class="bi bi-bullseye display-4 text-primary mb-3 d-block"></i>
                    <h4>@L["Home_Welcome"]</h4>
                                         <p class="text-muted">@L["Home_WelcomeHint"]</p>
                                         <a href="/auth/login" class="btn btn-primary w-100 mb-2">
                                             <i class="bi bi-box-arrow-in-right me-1"></i>@L["Auth_Login"]
                                         </a>
                                         <a href="/auth/register" class="btn btn-outline-secondary w-100">
                                             <i class="bi bi-person-plus me-1"></i>@L["Home_Register"]
                                         </a>
                </div>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    [Inject] private TrackedActionService ActionService { get; set; } = default!;
    [Inject] private ActionEntryService EntryService { get; set; } = default!;
    [Inject] private ActionFieldService FieldService { get; set; } = default!;
    [Inject] private FieldAnalyticsRuleService AnalyticsRuleService { get; set; } = default!;
    [Inject] private TemplateService TemplateService { get; set; } = default!;
    [Inject] private LocalizationService LocalizationService { get; set; } = default!;
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;

    private List<TrackedActionResponse> _actions = [];
    private Dictionary<Guid, List<BalanceSummary>> _balances = [];
    private IReadOnlyList<string> _errors = [];
    private bool _loading = true;
    private string? _loggedActionName;
    private bool _reordering;
    private int _dragIndex = -1;

    // Filters
    private bool _showFilters;
    private string _filterText = string.Empty;
    private HashSet<TrackedActionTagSummary> _selectedTags = new(TagComparer.Instance);
    private List<TrackedActionTagSummary> _allTags = [];
    private bool _hasActiveFilters => !string.IsNullOrWhiteSpace(_filterText) || _selectedTags.Count > 0;

    // Onboarding
    private IReadOnlyList<TemplatePackResponse> _templates = [];
    private string? _installingTemplate;
    private bool _installSuccess;

    private QuickTrackModal _trackModal = default!;
    private TrackedActionResponse? _selectedAction;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState;
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            _actions = (await ActionService.GetAllAsync())
                .OrderBy(a => a.SortOrder)
                .ThenByDescending(a => a.CreatedAtUtc)
                .ToList();

            if (_actions.Count == 0)
            {
                _templates = await TemplateService.GetTemplatesAsync();
            }
            else
            {
                _allTags = _actions
                    .SelectMany(a => a.Tags)
                    .DistinctBy(t => t.Name, StringComparer.OrdinalIgnoreCase)
                    .OrderBy(t => t.Name)
                    .ToList();
                _ = LoadBalancesAsync();
            }
        }
        _loading = false;
    }

    private async Task InstallTemplateAsync(string templateId)
    {
        _installingTemplate = templateId;
        StateHasChanged();

        var (success, _) = await TemplateService.InstallAsync(templateId, LocalizationService.CurrentLanguage);

        if (success)
        {
            _installSuccess = true;
            _installingTemplate = null;
            StateHasChanged();

            // Brief pause to show success, then reload
            await Task.Delay(800);
            _actions = (await ActionService.GetAllAsync())
                .OrderBy(a => a.SortOrder)
                .ThenByDescending(a => a.CreatedAtUtc)
                .ToList();
            _installSuccess = false;
        }

        _installingTemplate = null;
        StateHasChanged();
    }

    private void OnDrop(int targetIndex)
    {
        if (_dragIndex < 0 || _dragIndex == targetIndex) return;
        var item = _actions[_dragIndex];
        _actions.RemoveAt(_dragIndex);
        _actions.Insert(targetIndex, item);
        _dragIndex = -1;
    }

    private List<TrackedActionResponse> FilteredActions
    {
        get
        {
            IEnumerable<TrackedActionResponse> result = _actions;

            if (!string.IsNullOrWhiteSpace(_filterText))
            {
                result = result.Where(a =>
                    a.Name.Contains(_filterText, StringComparison.OrdinalIgnoreCase) ||
                    (a.Description is not null && a.Description.Contains(_filterText, StringComparison.OrdinalIgnoreCase)));
            }

            if (_selectedTags.Count > 0)
            {
                var tagNames = _selectedTags.Select(t => t.Name).ToHashSet(StringComparer.OrdinalIgnoreCase);
                result = result.Where(a => a.Tags.Any(t => tagNames.Contains(t.Name)));
            }

            return result.ToList();
        }
    }

    private void ToggleTag(TrackedActionTagSummary tag)
    {
        if (!_selectedTags.Remove(tag))
            _selectedTags.Add(tag);
    }

    private void ClearFilters()
    {
        _filterText = string.Empty;
        _selectedTags.Clear();
    }

    private sealed class TagComparer : IEqualityComparer<TrackedActionTagSummary>
    {
        public static readonly TagComparer Instance = new();
        public bool Equals(TrackedActionTagSummary? x, TrackedActionTagSummary? y) =>
            string.Equals(x?.Name, y?.Name, StringComparison.OrdinalIgnoreCase);
        public int GetHashCode(TrackedActionTagSummary obj) =>
            StringComparer.OrdinalIgnoreCase.GetHashCode(obj.Name);
    }

    private async Task ToggleReorder()
    {
        if (_reordering)
        {
            var orderedIds = _actions.Select(a => a.Id).ToList();
            var (success, errors) = await ActionService.ReorderAsync(orderedIds);
            if (!success)
                _errors = errors;
        }
        _reordering = !_reordering;
    }

    private void OpenTrackModal(TrackedActionResponse action)
    {
        _selectedAction = action;
        _loggedActionName = null;
        _errors = [];
        _trackModal.Show();
    }

    private async Task OnTrackConfirmedAsync((DateTime OccurredAtUtc, string? Notes) entry)
    {
        if (_selectedAction is null) return;

        var request = new CreateActionEntryRequest(entry.OccurredAtUtc, entry.Notes);
        var (success, errors) = await EntryService.CreateAsync(_selectedAction.Id, request);

        if (success)
            _loggedActionName = _selectedAction.Name;
        else
            _errors = errors;

        _selectedAction = null;
    }

    private async Task LoadBalancesAsync()
    {
        try
        {
            var actionsWithFields = _actions.Where(a => a.FieldCount > 0).ToList();
            foreach (var action in actionsWithFields)
            {
                var fields = await FieldService.GetByTrackedActionAsync(action.Id);
                var fieldMap = fields.ToDictionary(f => f.Id);

                var rules = await AnalyticsRuleService.GetByTrackedActionAsync(action.Id);
                var signedSumRules = rules
                    .Where(r => r.Aggregation == AnalyticsAggregation.SignedSum)
                    .ToList();

                // Check if we need entries (SignedSum rules or goal fields)
                var goalFields = fields.Where(f =>
                    f.FieldType is FieldType.Integer or FieldType.Decimal &&
                    f.TargetValueMode == TargetValueMode.Goal &&
                    f.TargetValue.HasValue).ToList();

                if (signedSumRules.Count == 0 && goalFields.Count == 0) continue;

                var entryRequest = new DataGridRequest(1, 10_000, "OccurredAtUtc", false, null);
                var entryResult = await EntryService.QueryAsync(entryRequest, null,
                    $"TrackedActionId eq {action.Id}");
                var entries = entryResult.Items.ToList();
                if (entries.Count == 0) continue;

                var actionBalances = new List<BalanceSummary>();

                // SignedSum analytics rules
                foreach (var rule in signedSumRules)
                {
                    if (!fieldMap.TryGetValue(rule.MeasureFieldId, out var measureField))
                        continue;
                    if (measureField.FieldType is not (FieldType.Integer or FieldType.Decimal))
                        continue;

                    HashSet<string>? negativeValueSet = null;
                    if (rule.NegativeValues is not null)
                    {
                        negativeValueSet = DropdownValuesHelper.Split(rule.NegativeValues)
                            .ToHashSet(StringComparer.OrdinalIgnoreCase);
                    }

                    decimal total = 0;
                    foreach (var e in entries)
                    {
                        var measureVal = e.FieldValues
                            .FirstOrDefault(fv => fv.ActionFieldId == rule.MeasureFieldId)?.Value;
                        if (!decimal.TryParse(measureVal, CultureInfo.InvariantCulture, out var val)) continue;

                        var signVal = rule.SignFieldId.HasValue
                            ? e.FieldValues.FirstOrDefault(fv => fv.ActionFieldId == rule.SignFieldId.Value)?.Value
                            : null;

                        if (negativeValueSet is not null && signVal is not null &&
                            negativeValueSet.Contains(signVal))
                            val = -val;

                        total += val;
                    }

                    var unit = measureField.Unit is not null && measureField.Unit != "UN"
                        ? measureField.Unit : "";

                    actionBalances.Add(new BalanceSummary
                    {
                        Label = rule.Label ?? measureField.Name,
                        Unit = unit,
                        CurrentBalance = total,
                        GoalValue = measureField.TargetValueMode == TargetValueMode.Goal ? measureField.TargetValue : null,
                        MeasureFieldId = rule.MeasureFieldId
                    });
                }

                // Goal-based numeric fields not already covered by SignedSum rules
                var coveredIds = actionBalances.Select(b => b.MeasureFieldId).Where(id => id.HasValue).Select(id => id!.Value).ToHashSet();
                foreach (var field in goalFields.Where(f => !coveredIds.Contains(f.Id)))
                {
                    var total = entries
                        .Select(e => e.FieldValues.FirstOrDefault(fv => fv.ActionFieldId == field.Id)?.Value)
                        .Where(v => decimal.TryParse(v, CultureInfo.InvariantCulture, out _))
                        .Sum(v => decimal.Parse(v!, CultureInfo.InvariantCulture));

                    var unit = field.Unit is not null && field.Unit != "UN" ? field.Unit : "";
                    actionBalances.Add(new BalanceSummary
                    {
                        Label = field.Name,
                        Unit = unit,
                        CurrentBalance = total,
                        GoalValue = field.TargetValue,
                        MeasureFieldId = field.Id
                    });
                }

                if (actionBalances.Count > 0)
                {
                    _balances[action.Id] = actionBalances;
                    StateHasChanged();
                }
            }
        }
        catch { /* balances are optional, don't break the home page */ }
    }
}
