@page "/feedback"
@attribute [Authorize]
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Feedback_Title"] - Traceon</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-1">
            <i class="bi bi-chat-dots me-2"></i>@L["Feedback_Title"]
        </h3>
        <p class="text-muted mb-0">
            @L["Feedback_Subtitle"]
            <br />
            <a href="https://github.com/ARiSoul/traceon/issues" target="_blank" rel="noopener noreferrer">
                <i class="bi bi-github me-1"></i>@L["Feedback_ViewIssues"]
            </a>
        </p>
    </div>
</div>

@if (_sent)
{
    <div class="alert alert-success">
        <i class="bi bi-check-circle me-2"></i>@L["Feedback_Success"]
    </div>
    <button class="btn btn-outline-primary" @onclick="Reset">
        <i class="bi bi-plus-circle me-1"></i>@L["Feedback_SendAnother"]
    </button>
}
else
{
    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle me-1"></i>@_error
        </div>
    }

    <div class="card" style="max-width: 700px;">
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label fw-semibold">@L["Feedback_Category"]</label>
                <select class="form-select" @bind="_category">
                    <option value="Bug">@L["Feedback_Bug"]</option>
                    <option value="Feature">@L["Feedback_Feature"]</option>
                    <option value="General">@L["Feedback_General"]</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">@L["Feedback_Message"]</label>
                <textarea class="form-control" rows="6" @bind="_message"
                          placeholder="@L["Feedback_Placeholder"]"></textarea>
            </div>

            <button class="btn btn-primary" @onclick="SendAsync" disabled="@(_sending || string.IsNullOrWhiteSpace(_message))">
                @if (_sending)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                else
                {
                    <i class="bi bi-send me-1"></i>
                }
                @L["Feedback_Send"]
            </button>
        </div>
    </div>
}

@code {
    [Inject] private FeedbackService FeedbackService { get; set; } = default!;

    private string _category = "General";
    private string _message = string.Empty;
    private bool _sending;
    private bool _sent;
    private string? _error;

    private async Task SendAsync()
    {
        _sending = true;
        _error = null;

        var (success, error) = await FeedbackService.SendAsync(_category, _message);

        if (success)
        {
            _sent = true;
        }
        else
        {
            _error = error ?? L["Feedback_Failed"];
        }

        _sending = false;
    }

    private void Reset()
    {
        _sent = false;
        _message = string.Empty;
        _category = "General";
        _error = null;
    }
}
