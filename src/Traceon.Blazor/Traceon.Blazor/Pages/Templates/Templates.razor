@page "/templates"
@attribute [Authorize]
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Templates_Title"] - Traceon</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-1">
            <i class="bi bi-box-seam me-2"></i>@L["Templates_Title"]
        </h3>
        <p class="text-muted mb-0">@L["Templates_Subtitle"]</p>
    </div>
</div>

<ErrorAlert Errors="_errors" OnDismiss="() => _errors = []" />

@if (!string.IsNullOrEmpty(_successMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@_successMessage
        <button type="button" class="btn-close" @onclick="() => _successMessage = null"></button>
    </div>
}

@if (_loading)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">@L["Common_Loading"]</span>
        </div>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var template in _templates)
        {
            <div class="col-12 col-sm-6 col-lg-3">
                <div class="card h-100 border-2" style="border-color: @template.Color;">
                    <div class="card-body d-flex flex-column text-center">
                        <i class="bi @template.Icon display-4 d-block mb-2" style="color: @template.Color;"></i>
                        <h5 class="card-title">@L[template.NameKey]</h5>
                        <p class="card-text text-muted small mb-3">@L[template.DescriptionKey]</p>

                        <div class="d-flex flex-wrap justify-content-center gap-1 mb-3">
                            @foreach (var action in template.Actions)
                            {
                                <span class="badge bg-light text-dark border">
                                    @L[action.NameKey]
                                    <span class="text-muted ms-1">(@action.FieldCount)</span>
                                </span>
                            }
                        </div>

                        <div class="mt-auto">
                            <button class="btn btn-sm btn-outline-primary w-100"
                                    disabled="@(_installingId is not null)"
                                    @onclick="() => InstallAsync(template.Id, template.NameKey)">
                                @if (_installingId == template.Id)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                else
                                {
                                    <i class="bi bi-download me-1"></i>
                                }
                                @L["Templates_Install"]
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    [Inject] private TemplateService TemplateService { get; set; } = default!;

    private IReadOnlyList<TemplatePackResponse> _templates = [];
    private IReadOnlyList<string> _errors = [];
    private string? _successMessage;
    private bool _loading = true;
    private string? _installingId;

    protected override async Task OnInitializedAsync()
    {
        _templates = await TemplateService.GetTemplatesAsync();
        _loading = false;
    }

    private async Task InstallAsync(string templateId, string nameKey)
    {
        _installingId = templateId;
        _errors = [];
        _successMessage = null;
        StateHasChanged();

        var (success, result) = await TemplateService.InstallAsync(templateId);

        if (success && result is not null)
        {
            _successMessage = string.Format(
                L["Templates_InstallSuccess"],
                L[nameKey],
                result.ActionsCreated,
                result.FieldDefinitionsCreated,
                result.TagsCreated);
        }
        else
        {
            _errors = [L["Templates_InstallFailed"]];
        }

        _installingId = null;
    }
}
