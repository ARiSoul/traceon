@page "/forgot-password"

<h3>Forgot Password</h3>

@if (_submitted)
{
    <div class="alert alert-success">
        If an account with that email exists, a password reset code has been generated.
        Check the API logs for the reset code, then <a href="/reset-password">reset your password</a>.
    </div>
}
else
{
    @if (_errors.Count > 0)
    {
        <div class="alert alert-danger">
            <ul class="mb-0">
                @foreach (var error in _errors)
                {
                    <li>@error</li>
                }
            </ul>
        </div>
    }

    <EditForm Model="_model" OnValidSubmit="HandleSubmit" FormName="ForgotPasswordForm">
        <div class="mb-3">
            <label class="form-label">Email</label>
            <InputText @bind-Value="_model.Email" class="form-control" />
        </div>
        <button type="submit" class="btn btn-primary" disabled="@_loading">
            @(_loading ? "Sending..." : "Send Reset Code")
        </button>
        <a href="/login" class="btn btn-link">Back to Login</a>
    </EditForm>
}

@code {
    [Inject] private AuthService Auth { get; set; } = default!;

    private ForgotPasswordModel _model = new();
    private IReadOnlyList<string> _errors = [];
    private bool _loading;
    private bool _submitted;

    private async Task HandleSubmit()
    {
        _loading = true;
        _errors = [];

        var (success, errors) = await Auth.ForgotPasswordAsync(new ForgotPasswordRequest(_model.Email));

        if (success)
            _submitted = true;
        else
            _errors = errors.Count > 0 ? errors : ["Request failed."];

        _loading = false;
    }

    private sealed class ForgotPasswordModel
    {
        public string Email { get; set; } = string.Empty;
    }
}
