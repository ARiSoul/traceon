    // ── Batch assignment ──

    private string? GetBatchValue(Guid fieldId) =>
        _batchValues.TryGetValue(fieldId, out var v) ? v : null;

    private void ApplyBatchSelection(Guid fieldId, string? value)
    {
        if (string.IsNullOrEmpty(value))
        {
            _batchValues.Remove(fieldId);
            return;
        }

        _batchValues[fieldId] = value;

        // Clear batch values for dependent fields whose options may have changed
        ClearInvalidBatchDependents(fieldId);

        // "__new__" just stores the intent — don't apply until the user types the value
        if (value == "__new__")
            return;

        foreach (var item in _receiptItems.Where(i => i.Include))
        {
            item.SetCategoryValue(fieldId, value);
            ClearInvalidDependents(item, fieldId);
        }

        RefreshNewValues();
    }

    private void OnBatchNewValueEntered(Guid fieldId, string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return;

        _batchValues[fieldId] = value;

        foreach (var item in _receiptItems.Where(i => i.Include))
        {
            item.SetCategoryValue(fieldId, value);
            ClearInvalidDependents(item, fieldId);
        }

        RefreshNewValues();
    }

    private void ClearInvalidBatchDependents(Guid changedFieldId)
    {
        if (_depRules.Count == 0) return;

        var dependentFieldIds = _depRules
            .Where(r => r.SourceFieldId == changedFieldId)
            .Select(r => r.TargetFieldId)
            .Distinct()
            .ToList();

        foreach (var depFieldId in dependentFieldIds)
        {
            if (_batchValues.TryGetValue(depFieldId, out var bv) && !string.IsNullOrEmpty(bv) && bv != "__new__")
            {
                var depField = _dropdownFields.FirstOrDefault(f => f.Id == depFieldId);
                if (depField is not null)
                {
                    var validOptions = GetBatchDropdownOptions(depField);
                    if (!validOptions.Contains(bv, StringComparer.OrdinalIgnoreCase))
                    {
                        _batchValues.Remove(depFieldId);
                        ClearInvalidBatchDependents(depFieldId);
                    }
                }
            }
        }
    }

    private void RefreshNewValues()
    {
        _newDropdownValues = [];

        foreach (var field in _dropdownFields)
        {
            var existingValues = GetDropdownOptions(field).ToHashSet(StringComparer.OrdinalIgnoreCase);

            var assignedValues = _receiptItems
                .Where(i => i.Include)
                .Select(i => i.GetCategoryValue(field.Id))
                .Where(v => !string.IsNullOrEmpty(v) && v != "__new__")
                .Distinct(StringComparer.OrdinalIgnoreCase);

            foreach (var val in assignedValues)
            {
                if (!existingValues.Contains(val!))
                {
                    _newDropdownValues.Add((field.Name, val!));
                }
            }
        }
    }

    private async Task ImportEntriesAsync()
    {
        _importing = true;
        _errors = [];
        _importedCount = 0;

        try
        {
            // 1. Append new dropdown values to field definitions
            foreach (var field in _dropdownFields)
            {
                var existingValues = GetDropdownOptions(field).ToHashSet(StringComparer.OrdinalIgnoreCase);

                var newValues = _receiptItems
                    .Where(i => i.Include)
                    .Select(i => i.GetCategoryValue(field.Id))
                    .Where(v => !string.IsNullOrEmpty(v) && v != "__new__" && !existingValues.Contains(v!))
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .ToList();

                if (newValues.Count == 0) continue;

                if (field.FieldType == FieldType.CompositeDropdown &&
                    _compositeRefFieldDefs.TryGetValue(field.Id, out var refDefs) && refDefs.Count > 0)
                {
                    // For CompositeDropdown fields, append new values to the FIRST referenced
                    // field definition (the leaf dropdown that actually stores the values).
                    // If there's a dependency rule chain, we also need to check which ref is correct
                    // based on the source value; fall back to the first ref if undetermined.
                    foreach (var newVal in newValues)
                    {
                        // Find which referenced field def already contains a matching group
                        // (via dependency rules from the parent), or default to the first one.
                        var targetDef = FindRefFieldDefForValue(field.Id, newVal!) ?? refDefs[0];
                        await FieldDefService.AppendDropdownValueAsync(targetDef.Id, newVal!);
                    }
                }
                else
                {
                    // Regular Dropdown: append directly to the action field's own field definition
                    foreach (var newVal in newValues)
                    {
                        await FieldDefService.AppendDropdownValueAsync(field.FieldDefinitionId, newVal!);
                    }
                }
            }

            // 2. Create/update dependency rules for new value combinations
            await EnsureDependencyRulesForImportAsync();

            // 3. Create one entry per included receipt item
            var includedItems = _receiptItems.Where(i => i.Include).ToList();

            var occurredAt = DateTime.SpecifyKind(_importDate, DateTimeKind.Utc);

            foreach (var item in includedItems)
            {
                var fieldValues = new List<ActionEntryFieldValue>();

                // Map OCR columns to action fields via column mappings
                foreach (var mapping in _columnMappings.Where(m => m.TargetFieldId != Guid.Empty))
                {
                    var value = mapping.SourceProperty switch
                    {
                        "Description" => item.Description,
                        "Quantity" => item.Quantity?.ToString("G"),
                        "UnitPrice" => item.UnitPrice?.ToString("F2"),
                        "TotalPrice" => item.TotalPrice?.ToString("F2"),
                        "Discount" => item.Discount?.ToString("F2"),
                        _ => null
                    };

                    if (value is not null)
                    {
                        fieldValues.Add(new ActionEntryFieldValue(mapping.TargetFieldId, value));
                    }
                }

                // Map dropdown category values (includes fixed values applied via SyncFieldMappingsToLegacy)
                foreach (var field in _dropdownFields)
                {
                    var catValue = item.GetCategoryValue(field.Id);
                    if (!string.IsNullOrEmpty(catValue) && catValue != "__new__")
                    {
                        fieldValues.Add(new ActionEntryFieldValue(field.Id, catValue));
                    }
                }

                // Map fixed/merchant values for non-dropdown fields
                var mappedFieldIds = fieldValues.Select(fv => fv.ActionFieldId).ToHashSet();
                foreach (var fm in _fieldMappings)
                {
                    if (mappedFieldIds.Contains(fm.FieldId)) continue;

                    var fixedVal = fm.Source switch
                    {
                        ReceiptFieldMappingSource.FixedValue => fm.FixedValue,
                        ReceiptFieldMappingSource.MerchantName => _scanResult?.MerchantName,
                        _ => null
                    };

                    if (!string.IsNullOrEmpty(fixedVal))
                    {
                        fieldValues.Add(new ActionEntryFieldValue(fm.FieldId, fixedVal));
                    }
                }

                var request = new CreateActionEntryRequest(
                    occurredAt,
                    Notes: $"Receipt: {_scanResult?.MerchantName} — {item.Description}",
                    FieldValues: fieldValues);

                var (success, _) = await EntryService.CreateAsync(_selectedActionId, request);
                if (success) _importedCount++;
            }

            _currentStep = 4;
            _ = DeleteDraftAsync();
        }
        catch
        {
            _errors = [L["Receipt_ImportFailed"]];
        }

        _importing = false;
    }

    private void Reset()
    {
        _currentStep = 0;
        _selectedFile = null;
        _scanResult = null;
        _selectedActionId = Guid.Empty;
        _selectedActionName = string.Empty;
        _actionFields = [];
        _dropdownFields = [];
        _columnMappings = [];
        _fieldMappings = [];
        _receiptItems = [];
        _newDropdownValues = [];
        _resolvedDropdownOptions = [];
        _compositeRefFieldDefs = [];
        _depRules = [];
        _batchValues.Clear();
        _patternsAppliedCount = 0;
        CloseRuleEditor();
        _errors = [];
        _successMessage = null;
        _importedCount = 0;
        _importDate = DateTime.Today;
        _draftId = null;
        _showDraftPicker = false;
    }

    private static string FormatFileSize(long bytes) => bytes switch
    {
        < 1024 => $"{bytes} B",
        < 1024 * 1024 => $"{bytes / 1024.0:F1} KB",
        _ => $"{bytes / (1024.0 * 1024.0):F1} MB"
    };

    // ── Draft persistence ──

    private ReceiptScanDraftState BuildDraftState() => new()
    {
        CurrentStep = _currentStep,
        SelectedActionId = _selectedActionId,
        SelectedActionName = _selectedActionName,
        MerchantName = _scanResult?.MerchantName,
        TransactionDate = _scanResult?.TransactionDate,
        Subtotal = _scanResult?.Subtotal,
        Tax = _scanResult?.Tax,
        TotalDiscount = _scanResult?.TotalDiscount,
        Total = _scanResult?.Total,
        Confidence = _scanResult?.Confidence ?? 0,
        Items = _receiptItems.Select(i => new DraftReceiptItem
        {
            Description = i.Description,
            Quantity = i.Quantity,
            UnitPrice = i.UnitPrice,
            Discount = i.Discount,
            TotalPrice = i.TotalPrice,
            Include = i.Include,
            MatchedRuleId = i.MatchedRule?.Id,
            CategoryValues = _dropdownFields
                .Select(f => (Key: f.Id.ToString(), Val: i.GetCategoryValue(f.Id)))
                .Where(kv => kv.Val is not null)
                .ToDictionary(kv => kv.Key, kv => kv.Val!)
        }).ToList(),
        FieldMappings = _fieldMappings.Select(fm => new DraftFieldMapping
        {
            FieldId = fm.FieldId,
            FieldName = fm.FieldName,
            Source = (int)fm.Source,
            FixedValue = fm.FixedValue
        }).ToList()
    };

    private void RestoreFromDraft(ReceiptScanDraftState state)
    {
        // Never restore to step < 2 — upload (step 1) requires a file that isn't persisted
        _currentStep = Math.Max(state.CurrentStep, 2);
        _selectedActionId = state.SelectedActionId;
        _selectedActionName = state.SelectedActionName;

        _scanResult = new ReceiptScanResult
        {
            MerchantName = state.MerchantName,
            TransactionDate = state.TransactionDate,
            Subtotal = state.Subtotal,
            Tax = state.Tax,
            TotalDiscount = state.TotalDiscount,
            Total = state.Total,
            Confidence = state.Confidence,
            Items = state.Items.Select(i => new ReceiptLineItem
            {
                Description = i.Description,
                Quantity = i.Quantity,
                UnitPrice = i.UnitPrice,
                Discount = i.Discount,
                TotalPrice = i.TotalPrice
            }).ToList()
        };

        _receiptItems = state.Items.Select(i =>
        {
            var row = new ReceiptItemRow
            {
                Description = i.Description,
                Quantity = i.Quantity,
                UnitPrice = i.UnitPrice,
                Discount = i.Discount,
                TotalPrice = i.TotalPrice,
                Include = i.Include
            };
            foreach (var (key, val) in i.CategoryValues)
            {
                if (Guid.TryParse(key, out var fieldId))
                    row.SetCategoryValue(fieldId, val);
            }
            return row;
        }).ToList();

        // Field mappings will be restored after loading action fields
        // Store them temporarily for post-load restoration
        _draftFieldMappings = state.FieldMappings;
    }

    // Temporary storage for draft field mappings until action fields are loaded
    private List<DraftFieldMapping>? _draftFieldMappings;

    private async Task SaveDraftAsync()
    {
        // Only save from step 2+ (Map) — steps 0-1 have no scan data to persist.
        if (_currentStep < 2 || _selectedActionId == Guid.Empty) return;

        try
        {
            var state = BuildDraftState();
            var json = System.Text.Json.JsonSerializer.Serialize(state);

            if (_draftId.HasValue)
            {
                await DraftService.UpdateAsync(_draftId.Value, new UpdateReceiptScanDraftRequest(
                    json,
                    _scanResult?.MerchantName,
                    _scanResult?.TransactionDate,
                    _scanResult?.Total,
                    _currentStep));
            }
            else
            {
                var created = await DraftService.CreateAsync(new CreateReceiptScanDraftRequest(
                    _selectedActionId,
                    _selectedActionName,
                    json,
                    _scanResult?.MerchantName,
                    _scanResult?.TransactionDate,
                    _scanResult?.Total,
                    _currentStep));

                if (created is not null)
                    _draftId = created.Id;
            }
        }
        catch
        {
            // Draft save is best-effort — don't block the wizard
        }
    }

    private async Task DeleteDraftAsync()
    {
        if (_draftId.HasValue)
        {
            try { await DraftService.DeleteAsync(_draftId.Value); } catch { }
            _draftId = null;
        }
    }

    private async Task ResumeDraftAsync(ReceiptScanDraftResponse draft)
    {
        _showDraftPicker = false;
        _draftId = draft.Id;

        try
        {
            var state = System.Text.Json.JsonSerializer.Deserialize<ReceiptScanDraftState>(draft.SerializedState);
            if (state is null) return;

            RestoreFromDraft(state);

            // Load server-side data for the selected action
            await LoadFieldsForRestoredDraft();
        }
        catch
        {
            _errors = [L["Receipt_DraftRestoreFailed"]];
            Reset();
        }
    }

    /// <summary>
    /// Loads action fields, dropdown options, mapping rules, and dependency rules for a restored draft,
    /// then re-applies the saved field mappings and item category values.
    /// </summary>
    private async Task LoadFieldsForRestoredDraft()
    {
        _actionFields = await FieldService.GetByTrackedActionAsync(_selectedActionId);

        _dropdownFields = _actionFields
            .Where(f => f.FieldType is FieldType.Dropdown or FieldType.CompositeDropdown)
            .ToList();

        await ResolveDropdownOptionsAsync();

        try { _depRules = await DepRuleService.GetByTrackedActionAsync(_selectedActionId); } catch { _depRules = []; }

        try
        {
            _receiptConfig = await RcptConfigService.GetByActionAsync(_selectedActionId);
            _mappingRules = _receiptConfig is not null
                ? await RcptConfigService.GetMappingRulesAsync(_selectedActionId)
                : [];
        }
        catch { _receiptConfig = null; _mappingRules = []; }

        // Restore field mappings from draft
        if (_draftFieldMappings is { Count: > 0 })
        {
            _fieldMappings = _actionFields.Select(f =>
            {
                var saved = _draftFieldMappings.FirstOrDefault(m => m.FieldId == f.Id);
                return new ReceiptFieldMapping
                {
                    FieldId = f.Id,
                    FieldName = f.Name,
                    FieldType = f.FieldType,
                    Source = saved is not null ? (ReceiptFieldMappingSource)saved.Source : ReceiptFieldMappingSource.None,
                    FixedValue = saved?.FixedValue
                };
            }).ToList();
            _draftFieldMappings = null;
        }
        else
        {
            _fieldMappings = _actionFields.Select(f => new ReceiptFieldMapping
            {
                FieldId = f.Id,
                FieldName = f.Name,
                FieldType = f.FieldType,
                Source = ReceiptFieldMappingSource.None
            }).ToList();

            if (_receiptConfig is not null)
                ApplyReceiptConfigToFieldMappings();
            else
                AutoDetectFieldMappings();
        }

        _batchValues.Clear();
        SyncFieldMappingsToLegacy();

        // Re-match mapping rules to items that had a matched rule
        foreach (var item in _receiptItems)
        {
            if (item.MatchedRule is null)
            {
                // Try to re-match from server rules
                foreach (var rule in _mappingRules.OrderByDescending(r => r.Priority))
                {
                    if (MatchesPattern(item.Description, rule.Pattern))
                    {
                        item.MatchedRule = rule;
                        break;
                    }
                }
            }
        }

        _patternsAppliedCount = _receiptItems.Count(i => i.MatchedRule is not null);
        RefreshNewValues();
    }

    private async Task AbandonDraftAsync(ReceiptScanDraftResponse draft)
    {
        try { await DraftService.DeleteAsync(draft.Id); } catch { }
        _drafts.Remove(draft);
        if (_drafts.Count == 0)
            _showDraftPicker = false;
    }

    private void StartNewScan()
    {
        _showDraftPicker = false;
    }

    // ── Dependency rules for import ──

    /// <summary>
    /// For a CompositeDropdown field, determines which referenced FieldDefinition should
    /// receive the new value. Uses dependency rules to find the parent value → group mapping.
    /// If undetermined, returns null (caller falls back to first ref).
    /// </summary>
    private FieldDefinitionResponse? FindRefFieldDefForValue(Guid compositeFieldId, string newValue)
    {
        if (!_compositeRefFieldDefs.TryGetValue(compositeFieldId, out var refDefs) || refDefs.Count <= 1)
            return refDefs?.FirstOrDefault();

        // Look at which source value (parent) is associated with items that have this new value,
        // then find which ref field def is governed by that source value via dependency rules.
        var depRulesForTarget = _depRules
            .Where(r => r.RuleType == DependencyRuleType.FilterDropdownValues && r.TargetFieldId == compositeFieldId)
            .ToList();

        if (depRulesForTarget.Count == 0) return null;

        // Find the source field values that accompany items with this target value
        var sourceFieldId = depRulesForTarget.First().SourceFieldId;
        var sourceValue = _receiptItems
            .Where(i => i.Include)
            .Where(i => string.Equals(i.GetCategoryValue(compositeFieldId), newValue, StringComparison.OrdinalIgnoreCase))
            .Select(i => i.GetCategoryValue(sourceFieldId))
            .FirstOrDefault(v => !string.IsNullOrEmpty(v));

        if (string.IsNullOrEmpty(sourceValue)) return null;

        // The source value itself lives in a parent dropdown. Find which ref field def
        // in the parent's composite refs contains this source value — that tells us the "group".
        var sourceField = _dropdownFields.FirstOrDefault(f => f.Id == sourceFieldId);
        if (sourceField is null) return null;

        // If the source field is also composite, find which of its ref defs contains sourceValue
        if (sourceField.FieldType == FieldType.CompositeDropdown &&
            _compositeRefFieldDefs.TryGetValue(sourceField.Id, out var parentRefDefs))
        {
            var matchingParentRef = parentRefDefs.FirstOrDefault(rd =>
                rd.DropdownValues != null &&
                rd.DropdownValues.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                    .Contains(sourceValue, StringComparer.OrdinalIgnoreCase));

            if (matchingParentRef is not null)
            {
                // The matching parent ref's Id should correspond to one of our target's refs
                // Find the ref def whose Id matches or that is paired by convention (same index)
                var parentIdx = parentRefDefs.IndexOf(matchingParentRef);
                if (parentIdx >= 0 && parentIdx < refDefs.Count)
                    return refDefs[parentIdx];
            }
        }

        // Fallback: if the source is a plain Dropdown field, sourceValue IS the field def name.
        // Find which ref field def has the same DefaultName as the source value.
        return refDefs.FirstOrDefault(rd =>
            string.Equals(rd.DefaultName, sourceValue, StringComparison.OrdinalIgnoreCase));
    }

    /// <summary>
    /// After appending new dropdown values, creates or updates dependency rules
    /// so that every (sourceValue → targetValue) pair from the imported items
    /// is represented in the action's dependency configuration.
    /// </summary>
    private async Task EnsureDependencyRulesForImportAsync()
    {
        if (_depRules.Count == 0) return;

        // Group existing rules by dependency chain (source field → target field)
        var chainGroups = _depRules
            .Where(r => r.RuleType == DependencyRuleType.FilterDropdownValues)
            .GroupBy(r => (r.SourceFieldId, r.TargetFieldId))
            .ToList();

        foreach (var chainGroup in chainGroups)
        {
            var (sourceFieldId, targetFieldId) = chainGroup.Key;
            var rulesForChain = chainGroup.ToList();

            // Collect all unique (sourceValue, targetValue) pairs from included items
            var neededPairs = _receiptItems
                .Where(i => i.Include)
                .Select(i => (
                    Source: i.GetCategoryValue(sourceFieldId),
                    Target: i.GetCategoryValue(targetFieldId)
                ))
                .Where(p => !string.IsNullOrEmpty(p.Source) && p.Source != "__new__"
                          && !string.IsNullOrEmpty(p.Target) && p.Target != "__new__")
                .Select(p => (Source: p.Source!, Target: p.Target!))
                .Distinct()
                .ToList();

            if (neededPairs.Count == 0) continue;

            // Group by source value to batch constraint updates
            var pairsBySource = neededPairs
                .GroupBy(p => p.Source, StringComparer.OrdinalIgnoreCase);

            foreach (var sourceGroup in pairsBySource)
            {
                var sourceValue = sourceGroup.Key;
                var targetValues = sourceGroup
                    .Select(p => p.Target)
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .ToList();

                // Find existing rule for this source value
                var existingRule = rulesForChain.FirstOrDefault(r =>
                    string.Equals(r.SourceValue, sourceValue, StringComparison.OrdinalIgnoreCase));

                if (existingRule is not null)
                {
                    // Parse existing constraints and check if new values are missing
                    var existingConstraints = (existingRule.TargetConstraint ?? "")
                        .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                        .ToHashSet(StringComparer.OrdinalIgnoreCase);

                    var newTargets = targetValues
                        .Where(v => !existingConstraints.Contains(v))
                        .ToList();

                    if (newTargets.Count > 0)
                    {
                        foreach (var t in newTargets) existingConstraints.Add(t);
                        var updatedConstraint = string.Join(",",
                            existingConstraints.OrderBy(v => v, StringComparer.OrdinalIgnoreCase));

                        await DepRuleService.UpdateAsync(
                            _selectedActionId,
                            existingRule.Id,
                            new UpdateFieldDependencyRuleRequest(TargetConstraint: updatedConstraint));
                    }
                }
                else
                {
                    // Create a new rule for this source value
                    var constraint = string.Join(",",
                        targetValues.OrderBy(v => v, StringComparer.OrdinalIgnoreCase));
                    var maxSort = rulesForChain.Count > 0 ? rulesForChain.Max(r => r.SortOrder) + 1 : 0;

                    await DepRuleService.CreateAsync(
                        _selectedActionId,
                        new CreateFieldDependencyRuleRequest(
                            sourceFieldId,
                            sourceValue,
                            targetFieldId,
                            DependencyRuleType.FilterDropdownValues,
                            constraint,
                            maxSort));
                }
            }
        }
    }

