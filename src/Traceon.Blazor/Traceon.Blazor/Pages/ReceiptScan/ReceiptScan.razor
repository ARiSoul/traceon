    // ── Inline rule editor (Map step) ──

    private void OpenRuleEditor(ReceiptItemRow item, ReceiptMappingRuleResponse? existingRule)
    {
        _ruleEditItem = item;
        if (existingRule is not null)
        {
            _ruleEditExistingRuleId = existingRule.Id;
            _ruleEditPattern = string.Empty; // user types the new keyword to add
            _ruleEditFieldId = existingRule.TargetFieldId;
            _ruleEditValue = existingRule.Value;
        }
        else
        {
            _ruleEditExistingRuleId = Guid.Empty;
            _ruleEditPattern = item.Description;
            // Pre-select the field mapped to ReceiptDescription — rules naturally target it.
            // Fall back to the first uncategorized dropdown field, then any dropdown field.
            var descMapFieldId = _fieldMappings
                .FirstOrDefault(m => m.Source == ReceiptFieldMappingSource.ReceiptDescription)?.FieldId;
            var targetField = descMapFieldId.HasValue
                ? _dropdownFields.FirstOrDefault(f => f.Id == descMapFieldId.Value)
                : _dropdownFields.FirstOrDefault(f => string.IsNullOrEmpty(item.GetCategoryValue(f.Id)))
                  ?? _dropdownFields.FirstOrDefault();
            _ruleEditFieldId = targetField?.Id ?? Guid.Empty;
            _ruleEditValue = string.Empty;
            _ruleEditNewValue = string.Empty;
        }
    }

    private void CloseRuleEditor()
    {
        _ruleEditItem = null;
        _ruleEditExistingRuleId = Guid.Empty;
        _ruleEditPattern = string.Empty;
        _ruleEditValue = string.Empty;
        _ruleEditNewValue = string.Empty;
        _ruleEditFieldId = Guid.Empty;
    }

    private void OnSelectExistingRule(string? ruleIdStr)
    {
        if (Guid.TryParse(ruleIdStr, out var ruleId) && ruleId != Guid.Empty)
        {
            var rule = _mappingRules.FirstOrDefault(r => r.Id == ruleId);
            if (rule is not null)
            {
                _ruleEditExistingRuleId = rule.Id;
                _ruleEditFieldId = rule.TargetFieldId;
                _ruleEditValue = rule.Value;
                // Keep the user's pattern text (the keyword to add)
            }
        }
        else
        {
            _ruleEditExistingRuleId = Guid.Empty;
        }
    }

    private async Task SaveInlineRuleAsync()
    {
        if (string.IsNullOrWhiteSpace(_ruleEditPattern)) return;
        var effectiveValue = _ruleEditValue == "__new__" ? _ruleEditNewValue.Trim() : _ruleEditValue;
        _ruleEditSaving = true;

        try
        {
            if (_ruleEditExistingRuleId != Guid.Empty)
            {
                // Append pattern to existing rule
                var existing = _mappingRules.FirstOrDefault(r => r.Id == _ruleEditExistingRuleId);
                if (existing is not null)
                {
                    var newPattern = string.IsNullOrWhiteSpace(existing.Pattern)
                        ? _ruleEditPattern
                        : $"{existing.Pattern},{_ruleEditPattern}";
                    var updateReq = new UpdateReceiptMappingRuleRequest(Pattern: newPattern);
                    await RcptConfigService.UpdateMappingRuleAsync(_selectedActionId, existing.Id, updateReq);
                }
            }
            else
            {
                // Create new rule
                var createReq = new CreateReceiptMappingRuleRequest(
                    _ruleEditFieldId, _ruleEditPattern, effectiveValue, Priority: 0);
                await RcptConfigService.CreateMappingRuleAsync(_selectedActionId, createReq);
            }

            // Reload rules and re-apply
            _mappingRules = await RcptConfigService.GetMappingRulesAsync(_selectedActionId);
            ApplyServerMappingRules();
            CloseRuleEditor();
        }
        catch
        {
            _errors = [L["Receipt_RuleSaveFailed"]];
        }

        _ruleEditSaving = false;
    }

