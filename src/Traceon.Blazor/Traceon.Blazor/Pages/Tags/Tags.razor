@page "/tags"
@attribute [Authorize]
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Tags_Title"] - Traceon</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-1">
            <i class="bi bi-tags me-2"></i>
            @L["Tags_Title"]
        </h3>
        <p class="text-muted mb-0">@L["Tags_Subtitle"]</p>
    </div>
</div>

<ErrorAlert Errors="_errors" OnDismiss="() => _errors = []" />

@if (_showForm)
{
    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">@L["Tags_New"]</h5>
            <EditForm Model="_newTag" OnValidSubmit="CreateAsync" FormName="CreateTagForm">
                <DataAnnotationsValidator />
                <div class="row g-3">
                    <div class="col-md-5">
                        <label class="form-label">@L["Common_Name"] <span class="text-danger">*</span></label>
                        <InputText @bind-Value="_newTag.Name" class="form-control" />
                        <ValidationMessage For="() => _newTag.Name" />
                    </div>
                    <div class="col-md-5">
                        <label class="form-label">@L["Common_Description"]</label>
                        <InputText @bind-Value="_newTag.Description" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">@L["Tags_Color"]</label>
                        <input type="color" class="form-control form-control-color w-100" @bind="_newTag.Color" />
                    </div>
                </div>
                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-circle me-1"></i>@L["Common_Create"]
                    </button>
                    <button type="button" class="btn btn-outline-secondary" @onclick="() => _showForm = false">
                        <i class="bi bi-x-circle me-1"></i>@L["Common_Cancel"]
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

<DataGrid @ref="_grid"
          TItem="TagResponse"
          LoadData="LoadDataAsync"
          Columns="_columns"
          FilterPlaceholder="@L["Filter_ByNameOrDesc"]"
          EmptyText="@L["Tags_Empty"]">
    <Toolbar>
        <button class="btn btn-primary" @onclick="() => _showForm = !_showForm">
            <i class="bi bi-plus-circle me-1"></i> @L["Tags_New"]
        </button>
    </Toolbar>
    <RowActions>
        <ListActionsDropdown PrimaryText="@L["Common_Edit"]"
                             PrimaryIcon="pencil-square"
                             PrimaryButtonStyle="primary"
                             PrimaryAction="() => EditTag(context.Id)"
                             Actions="GetActions(context)"
                             OnAfterAction="StateHasChanged" />
    </RowActions>
</DataGrid>

@code {
    [Inject] private TagService Service { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private DataGrid<TagResponse> _grid = default!;
    private TagModel _newTag = new();
    private IReadOnlyList<string> _errors = [];
    private bool _showForm;

    private List<DataGridColumn<TagResponse>> _columns = [];

    protected override void OnInitialized()
    {
        _columns =
        [
            new() { Title = L["Common_Name"], Selector = x => x.Name, SortField = "Name", IsMobileTitle = true },
            new() { Title = L["Common_Description"], Selector = x => x.Description, HideOnMobile = true },
            new()
            {
                Title = L["Tags_Color"],
                Selector = x => x.Color,
                Template = ColorBadge
            },
            new() { Title = L["Common_Created"], Selector = x => x.CreatedAtUtc.ToLocalTime(), SortField = "CreatedAtUtc", Format = "g", HideOnMobile = true },
        ];
    }

    private static RenderFragment ColorBadge(TagResponse tag) => builder =>
    {
        builder.OpenElement(0, "span");
        builder.AddAttribute(1, "class", "badge rounded-pill");
        builder.AddAttribute(2, "style", $"background-color: {tag.Color}");
        builder.AddContent(3, tag.Color);
        builder.CloseElement();
    };

    private Task<DataGridResult<TagResponse>> LoadDataAsync(DataGridRequest request)
        => Service.QueryAsync(request, ["Name", "Description"]);

    private List<ListAction> GetActions(TagResponse tag)
    {
        return
        [
            ListAction.Button(L["Common_Delete"], () => DeleteAsync(tag.Id), "trash", ListActionStyle.Danger),
        ];
    }

    private void EditTag(Guid id)
    {
        Nav.NavigateTo($"/tags/{id}/edit");
    }

    private async Task CreateAsync()
    {
        _errors = [];
        var (success, errors) = await Service.CreateAsync(new CreateTagRequest(_newTag.Name, _newTag.Description, _newTag.Color));

        if (success)
        {
            _newTag = new();
            _showForm = false;
            await _grid.RefreshAsync();
        }
        else
        {
            _errors = errors;
        }
    }

    private async Task DeleteAsync(Guid id)
    {
        _errors = [];
        var (success, errors) = await Service.DeleteAsync(id);

        if (success)
            await _grid.RefreshAsync();
        else
            _errors = errors;
    }

    private sealed class TagModel
    {
        [Required]
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public string Color { get; set; } = "#0d6efd";
    }
}
