@page "/auth/forgot-password"
@inject IStringLocalizer<SharedResource> L

<h3>@L["Auth_ForgotPasswordTitle"]</h3>

@if (_submitted)
{
    <div class="alert alert-success">
        @L["Auth_ResetCodeSent"]
        <a href="/auth/reset-password">@L["Auth_ResetPassword"]</a>.
    </div>
}
else
{
    <ErrorAlert Errors="_errors" />

    <EditForm Model="_model" OnValidSubmit="HandleSubmit" FormName="ForgotPasswordForm">
        <DataAnnotationsValidator />
        <div class="mb-3">
            <label class="form-label">@L["Common_Email"]</label>
            <InputText @bind-Value="_model.Email" class="form-control" />
            <ValidationMessage For="() => _model.Email" />
        </div>
        <button type="submit" class="btn btn-primary" disabled="@_loading">
            @(_loading ? L["Auth_Sending"] : L["Auth_SendResetCode"])
        </button>
        <a href="/auth/login" class="btn btn-link">@L["Auth_BackToLogin"]</a>
    </EditForm>
}

@code {
    [Inject] private AuthService Auth { get; set; } = default!;

    private ForgotPasswordModel _model = new();
    private IReadOnlyList<string> _errors = [];
    private bool _loading;
    private bool _submitted;

    private async Task HandleSubmit()
    {
        _loading = true;
        _errors = [];

        var (success, errors) = await Auth.ForgotPasswordAsync(new ForgotPasswordRequest(_model.Email));

        if (success)
            _submitted = true;
        else
            _errors = errors.Count > 0 ? errors : ["Request failed."];

        _loading = false;
    }

    private sealed class ForgotPasswordModel
    {
        [Required, EmailAddress]
        public string Email { get; set; } = string.Empty;
    }
}
