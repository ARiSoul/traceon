@page "/auth/reset-password"
@inject IStringLocalizer<SharedResource> L

<h3>@L["Auth_ResetPassword"]</h3>

@if (_resetSuccess)
{
    <div class="alert alert-success">
        @L["Auth_ResetSuccess"] <a href="/auth/login">@L["Auth_Login"]</a>
    </div>
}
else
{
    <ErrorAlert Errors="_errors" />

    @if (_hasLinkParams)
    {
        <p class="text-muted mb-3">@L["Auth_ResetForEmail"] <strong>@_model.Email</strong></p>
    }

    <EditForm Model="_model" OnValidSubmit="HandleSubmit" FormName="ResetPasswordForm">
        <DataAnnotationsValidator />

        @if (!_hasLinkParams)
        {
            <div class="mb-3">
                <label class="form-label">@L["Common_Email"]</label>
                <InputText @bind-Value="_model.Email" class="form-control" />
                <ValidationMessage For="() => _model.Email" />
            </div>
            <div class="mb-3">
                <label class="form-label">@L["Auth_ResetCode"]</label>
                <InputText @bind-Value="_model.ResetCode" class="form-control" />
                <ValidationMessage For="() => _model.ResetCode" />
            </div>
        }

        <div class="mb-3">
            <label class="form-label">@L["Auth_NewPassword"]</label>
            <InputText @bind-Value="_model.NewPassword" type="password" class="form-control" />
            <ValidationMessage For="() => _model.NewPassword" />
        </div>
        <div class="mb-3">
            <label class="form-label">@L["Auth_ConfirmPassword"]</label>
            <InputText @bind-Value="_model.ConfirmPassword" type="password" class="form-control" />
            <ValidationMessage For="() => _model.ConfirmPassword" />
        </div>
        <button type="submit" class="btn btn-primary" disabled="@_loading">
            @(_loading ? L["Auth_Resetting"] : L["Auth_ResetPassword"])
        </button>
        <a href="/auth/login" class="btn btn-link">@L["Auth_BackToLogin"]</a>
    </EditForm>
}

@code {
    [Inject] private AuthService Auth { get; set; } = default!;

    [SupplyParameterFromQuery(Name = "code")] public string? Code { get; set; }
    [SupplyParameterFromQuery(Name = "email")] public string? Email { get; set; }

    private ResetPasswordModel _model = new();
    private IReadOnlyList<string> _errors = [];
    private bool _loading;
    private bool _resetSuccess;
    private bool _hasLinkParams;

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(Code) && !string.IsNullOrEmpty(Email))
        {
            _model.Email = Email;
            _model.ResetCode = Code;
            _hasLinkParams = true;
        }
    }

    private async Task HandleSubmit()
    {
        _loading = true;
        _errors = [];

        var (success, errors) = await Auth.ResetPasswordAsync(
            new ResetPasswordRequest(_model.Email, _model.ResetCode, _model.NewPassword));

        if (success)
            _resetSuccess = true;
        else
            _errors = errors.Count > 0 ? errors : [L["Auth_ResetFailed"]];

        _loading = false;
    }

    private sealed class ResetPasswordModel
    {
        [Required, EmailAddress]
        public string Email { get; set; } = string.Empty;

        [Required]
        public string ResetCode { get; set; } = string.Empty;

        [Required]
        public string NewPassword { get; set; } = string.Empty;

        [Required, Compare(nameof(NewPassword))]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
