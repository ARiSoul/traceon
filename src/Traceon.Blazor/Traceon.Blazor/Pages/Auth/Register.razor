@page "/auth/register"
@inject IStringLocalizer<SharedResource> L

<h3>@L["Auth_Register"]</h3>

<ErrorAlert Errors="_errors" />

@if (_registered)
{
    <div class="alert alert-success">@L["Auth_RegisterSuccess"] <a href="/auth/login">@L["Auth_Login"]</a>.</div>
}
else
{
    @if (_externalProviders.Count > 0)
    {
        <div class="d-grid gap-2 mb-3">
            @foreach (var provider in _externalProviders)
            {
                var (icon, btnClass) = provider switch
                {
                    "Google" => ("google", "btn-outline-danger"),
                    "Microsoft" => ("microsoft", "btn-outline-primary"),
                    _ => ("box-arrow-in-right", "btn-outline-secondary")
                };
                <a href="@Auth.GetExternalLoginUrl(provider)" class="btn @btnClass">
                    <i class="bi bi-@icon me-2"></i>@L["Auth_SignUpWith"] @provider
                </a>
            }
        </div>
        <div class="d-flex align-items-center mb-3">
            <hr class="flex-grow-1" />
            <span class="px-3 text-muted small">@L["Auth_OrWithEmail"]</span>
            <hr class="flex-grow-1" />
        </div>
    }

    <EditForm Model="_model" OnValidSubmit="HandleRegister" FormName="RegisterForm">
        <DataAnnotationsValidator />
        <div class="mb-3">
            <label class="form-label">@L["Common_Email"]</label>
            <InputText @bind-Value="_model.Email" class="form-control" />
            <ValidationMessage For="() => _model.Email" />
        </div>
        <div class="mb-3">
            <label class="form-label">@L["Common_Password"]</label>
            <InputText @bind-Value="_model.Password" type="password" class="form-control" />
            <ValidationMessage For="() => _model.Password" />
        </div>
        <div class="mb-3">
            <label class="form-label">@L["Auth_ConfirmPassword"]</label>
            <InputText @bind-Value="_model.ConfirmPassword" type="password" class="form-control" />
            <ValidationMessage For="() => _model.ConfirmPassword" />
        </div>
        <button type="submit" class="btn btn-primary" disabled="@_loading">
            @(_loading ? L["Auth_Registering"] : L["Auth_Register"])
        </button>
        <a href="/auth/login" class="btn btn-link">@L["Auth_AlreadyHaveAccount"]</a>
    </EditForm>
}

@code {
    [Inject] private AuthService Auth { get; set; } = default!;

    private RegisterModel _model = new();
    private IReadOnlyList<string> _errors = [];
    private IReadOnlyList<string> _externalProviders = [];
    private bool _loading;
    private bool _registered;

    protected override async Task OnInitializedAsync()
    {
        _externalProviders = await Auth.GetExternalProvidersAsync();
    }

    private async Task HandleRegister()
    {
        _loading = true;
        _errors = [];

        var (success, errors) = await Auth.RegisterAsync(new RegisterRequest(_model.Email, _model.Password));

        if (success)
            _registered = true;
        else
            _errors = errors.Count > 0 ? errors : [L["Auth_RegisterFailed"]];

        _loading = false;
    }

    private sealed class RegisterModel
    {
        [Required, EmailAddress]
        public string Email { get; set; } = string.Empty;

        [Required]
        public string Password { get; set; } = string.Empty;

        [Required, Compare(nameof(Password))]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
