@page "/field-definitions/create"
@page "/field-definitions/{Id:guid}/edit"
@attribute [Authorize]

<PageTitle>@(_isEdit ? "Edit" : "Create") Field Definition - Traceon</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-1">
            <i class="bi bi-@(_isEdit ? "pencil-square" : "plus-circle") me-2"></i>
            @(_isEdit ? "Edit" : "Create") Field Definition
        </h3>
        <p class="text-muted mb-0">@(_isEdit ? "Update the details of your field definition" : "Define a new reusable field template")</p>
    </div>
    <a href="/field-definitions" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to List
    </a>
</div>

<ErrorAlert Errors="_errors" OnDismiss="() => _errors = []" />

@if (_loading)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (_isEdit && _model is null)
{
    <div class="alert alert-warning">
        <i class="bi bi-question-circle me-2"></i>
        Field definition not found.
    </div>
}
else
{
    <div class="card">
        <div class="card-body">
            <EditForm Model="_model" OnValidSubmit="SaveAsync" FormName="FieldDefinitionForm">
                <DataAnnotationsValidator />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Name <span class="text-danger">*</span></label>
                        <InputText @bind-Value="_model!.DefaultName" class="form-control" />
                        <ValidationMessage For="() => _model!.DefaultName" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Type <span class="text-danger">*</span></label>
                        <InputSelect @bind-Value="_model!.Type" class="form-select">
                            @foreach (var type in Enum.GetValues<FieldType>())
                            {
                                <option value="@type">@type</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Required by default</label>
                        <div class="form-check mt-2">
                            <InputCheckbox @bind-Value="_model!.DefaultIsRequired" class="form-check-input" id="isRequired" />
                            <label class="form-check-label" for="isRequired">Yes</label>
                        </div>
                    </div>
                </div>

                <div class="row g-3 mt-1">
                    <div class="col-12">
                        <label class="form-label">Description</label>
                        <InputText @bind-Value="_model!.DefaultDescription" class="form-control" />
                    </div>
                </div>

                @if (_model!.Type is FieldType.Integer or FieldType.Decimal or FieldType.Date)
                {
                    <div class="row g-3 mt-1">
                        <div class="col-md-6">
                            <label class="form-label">Min @(_model.Type == FieldType.Date ? "Date" : "Value")</label>
                            @switch (_model.Type)
                            {
                                case FieldType.Integer:
                                    <InputNumber @bind-Value="_model.IntMinValue" class="form-control" />
                                    break;
                                case FieldType.Decimal:
                                    <InputNumber @bind-Value="_model.DecimalMinValue" class="form-control" />
                                    break;
                                case FieldType.Date:
                                    <InputDate @bind-Value="_model.MinDateValue" class="form-control" />
                                    break;
                            }
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Max @(_model.Type == FieldType.Date ? "Date" : "Value")</label>
                            @switch (_model.Type)
                            {
                                case FieldType.Integer:
                                    <InputNumber @bind-Value="_model.IntMaxValue" class="form-control" />
                                    break;
                                case FieldType.Decimal:
                                    <InputNumber @bind-Value="_model.DecimalMaxValue" class="form-control" />
                                    break;
                                case FieldType.Date:
                                    <InputDate @bind-Value="_model.MaxDateValue" class="form-control" />
                                    break;
                            }
                        </div>
                    </div>
                }

                @if (_model.Type == FieldType.Dropdown)
                {
                    <div class="row g-3 mt-1">
                        <div class="col-12">
                            <label class="form-label">Dropdown Values <span class="text-danger">*</span></label>
                            <InputText @bind-Value="_model.DropdownValues" class="form-control"
                                       placeholder="Comma-separated values, e.g.: Low, Medium, High" />
                            <div class="form-text">Enter comma-separated values for the dropdown options.</div>
                        </div>
                    </div>
                }

                <div class="row g-3 mt-1">
                    <div class="col-12">
                        <label class="form-label">Default Value</label>

                        @switch (_model.Type)
                        {
                            case FieldType.Boolean:
                                <div class="form-check mt-2">
                                    <InputCheckbox @bind-Value="_model.DefaultBoolValue" class="form-check-input" id="defaultBool" />
                                    <label class="form-check-label" for="defaultBool">Checked by default</label>
                                </div>
                                break;

                            case FieldType.Integer:
                                <InputNumber @bind-Value="_model.DefaultIntValue" class="form-control" step="1" />
                                break;

                            case FieldType.Decimal:
                                <InputNumber @bind-Value="_model.DefaultDecimalValue" class="form-control" />
                                break;

                            case FieldType.Date:
                                <InputDate @bind-Value="_model.DefaultDateValue" class="form-control" />
                                break;

                            case FieldType.Dropdown:
                                @if (_model.ParsedDropdownValues.Length > 0)
                                {
                                    <InputSelect @bind-Value="_model.DefaultValue" class="form-select">
                                        <option value="">— Select a default —</option>
                                        @foreach (var val in _model.ParsedDropdownValues)
                                        {
                                            <option value="@val">@val</option>
                                        }
                                    </InputSelect>
                                }
                                else
                                {
                                    <InputText @bind-Value="_model.DefaultValue" class="form-control" disabled />
                                    <div class="form-text text-warning">
                                        <i class="bi bi-info-circle me-1"></i>Define dropdown values above first.
                                    </div>
                                }
                                break;

                            default:
                                <InputText @bind-Value="_model.DefaultValue" class="form-control" />
                                break;
                        }
                    </div>
                </div>

                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-success" disabled="@_saving">
                        @if (_saving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        else
                        {
                            <i class="bi bi-check-circle me-1"></i>
                        }
                        @(_isEdit ? "Save Changes" : "Create")
                    </button>
                    <a href="/field-definitions" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle me-1"></i>Cancel
                    </a>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter] public Guid? Id { get; set; }
    [Inject] private FieldDefinitionService Service { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private FieldModel? _model;
    private IReadOnlyList<string> _errors = [];
    private bool _loading = true;
    private bool _saving;
    private bool _isEdit => Id.HasValue;

    protected override async Task OnInitializedAsync()
    {
        if (_isEdit)
        {
            var field = await Service.GetByIdAsync(Id!.Value);

            if (field is not null)
            {
                _model = new FieldModel
                {
                    DefaultName = field.DefaultName,
                    DefaultDescription = field.DefaultDescription,
                    Type = field.Type,
                    DropdownValues = field.DropdownValues,
                    DefaultIsRequired = field.DefaultIsRequired,
                    DefaultValue = field.DefaultValue
                };

                _model.LoadTypedDefaults(field.DefaultMinValue, field.DefaultMaxValue);
            }
        }
        else
        {
            _model = new FieldModel();
        }

        _loading = false;
    }

    private async Task SaveAsync()
    {
        if (_model is null) return;

        _saving = true;
        _errors = [];

        var validationErrors = _model.ValidateMinMax();
        if (validationErrors.Count > 0)
        {
            _errors = validationErrors;
            _saving = false;
            return;
        }

        var defaultValue = _model.ResolveDefaultValue();
        var (minValue, maxValue) = _model.ResolveMinMax();
        var dropdownValues = _model.Type == FieldType.Dropdown ? _model.DropdownValues : null;

        bool success;
        IReadOnlyList<string> errors;

        if (_isEdit)
        {
            (success, errors) = await Service.UpdateAsync(Id!.Value, new UpdateFieldDefinitionRequest(
                _model.DefaultName,
                _model.Type,
                _model.DefaultDescription,
                dropdownValues,
                maxValue,
                minValue,
                _model.DefaultIsRequired,
                defaultValue));
        }
        else
        {
            (success, errors) = await Service.CreateAsync(new CreateFieldDefinitionRequest(
                _model.DefaultName,
                _model.Type,
                _model.DefaultDescription,
                dropdownValues,
                maxValue,
                minValue,
                _model.DefaultIsRequired,
                defaultValue));
        }

        if (success)
            Nav.NavigateTo("/field-definitions");
        else
            _errors = errors.Count > 0 ? errors : ["An error occurred."];

        _saving = false;
    }

    private sealed class FieldModel
    {
        [Required]
        public string DefaultName { get; set; } = string.Empty;
        public string? DefaultDescription { get; set; }
        public FieldType Type { get; set; } = FieldType.Text;
        public string? DropdownValues { get; set; }
        public bool DefaultIsRequired { get; set; }
        public string? DefaultValue { get; set; }

        // Integer min/max
        public int? IntMinValue { get; set; }
        public int? IntMaxValue { get; set; }

        // Decimal min/max
        public decimal? DecimalMinValue { get; set; }
        public decimal? DecimalMaxValue { get; set; }

        // Date min/max
        public DateTime? MinDateValue { get; set; }
        public DateTime? MaxDateValue { get; set; }

        // Type-specific default value helpers
        public bool DefaultBoolValue { get; set; }
        public int? DefaultIntValue { get; set; }
        public decimal? DefaultDecimalValue { get; set; }
        public DateTime? DefaultDateValue { get; set; }

        public string[] ParsedDropdownValues =>
            string.IsNullOrWhiteSpace(DropdownValues)
                ? []
                : DropdownValues.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        public void LoadTypedDefaults(decimal? apiMin, decimal? apiMax)
        {
            switch (Type)
            {
                case FieldType.Integer:
                    IntMinValue = apiMin.HasValue ? (int)apiMin.Value : null;
                    IntMaxValue = apiMax.HasValue ? (int)apiMax.Value : null;
                    break;
                case FieldType.Decimal:
                    DecimalMinValue = apiMin;
                    DecimalMaxValue = apiMax;
                    break;
            }

            if (string.IsNullOrWhiteSpace(DefaultValue)) return;

            switch (Type)
            {
                case FieldType.Boolean:
                    DefaultBoolValue = DefaultValue.Equals("true", StringComparison.OrdinalIgnoreCase);
                    break;
                case FieldType.Integer when int.TryParse(DefaultValue, out var i):
                    DefaultIntValue = i;
                    break;
                case FieldType.Decimal when decimal.TryParse(DefaultValue, out var d):
                    DefaultDecimalValue = d;
                    break;
                case FieldType.Date when DateTime.TryParse(DefaultValue, out var dt):
                    DefaultDateValue = dt;
                    break;
            }
        }

        public string? ResolveDefaultValue() => Type switch
        {
            FieldType.Boolean => DefaultBoolValue ? "true" : "false",
            FieldType.Integer => DefaultIntValue?.ToString(),
            FieldType.Decimal => DefaultDecimalValue?.ToString(),
            FieldType.Date => DefaultDateValue?.ToString("yyyy-MM-dd"),
            _ => DefaultValue
        };

        public (decimal? Min, decimal? Max) ResolveMinMax() => Type switch
        {
            FieldType.Integer => (IntMinValue, IntMaxValue),
            FieldType.Decimal => (DecimalMinValue, DecimalMaxValue),
            _ => (null, null)
        };

        public IReadOnlyList<string> ValidateMinMax()
        {
            var errors = new List<string>();

            switch (Type)
            {
                case FieldType.Integer:
                    if (IntMinValue.HasValue && IntMaxValue.HasValue && IntMinValue > IntMaxValue)
                        errors.Add("Min value cannot be greater than max value.");
                    if (DefaultIntValue.HasValue)
                    {
                        if (IntMinValue.HasValue && DefaultIntValue < IntMinValue)
                            errors.Add($"Default value cannot be less than min value ({IntMinValue}).");
                        if (IntMaxValue.HasValue && DefaultIntValue > IntMaxValue)
                            errors.Add($"Default value cannot be greater than max value ({IntMaxValue}).");
                    }
                    break;

                case FieldType.Decimal:
                    if (DecimalMinValue.HasValue && DecimalMaxValue.HasValue && DecimalMinValue > DecimalMaxValue)
                        errors.Add("Min value cannot be greater than max value.");
                    if (DefaultDecimalValue.HasValue)
                    {
                        if (DecimalMinValue.HasValue && DefaultDecimalValue < DecimalMinValue)
                            errors.Add($"Default value cannot be less than min value ({DecimalMinValue}).");
                        if (DecimalMaxValue.HasValue && DefaultDecimalValue > DecimalMaxValue)
                            errors.Add($"Default value cannot be greater than max value ({DecimalMaxValue}).");
                    }
                    break;

                case FieldType.Date:
                    if (MinDateValue.HasValue && MaxDateValue.HasValue && MinDateValue > MaxDateValue)
                        errors.Add("Min date cannot be later than max date.");
                    if (DefaultDateValue.HasValue)
                    {
                        if (MinDateValue.HasValue && DefaultDateValue < MinDateValue)
                            errors.Add($"Default date cannot be earlier than min date ({MinDateValue:yyyy-MM-dd}).");
                        if (MaxDateValue.HasValue && DefaultDateValue > MaxDateValue)
                            errors.Add($"Default date cannot be later than max date ({MaxDateValue:yyyy-MM-dd}).");
                    }
                    break;
            }

            return errors;
        }
    }
}
