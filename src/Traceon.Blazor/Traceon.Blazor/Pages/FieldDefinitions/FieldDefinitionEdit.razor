@page "/field-definitions/create"
@page "/field-definitions/{Id:guid}/edit"
@attribute [Authorize]
@inject IStringLocalizer<SharedResource> L

<PageTitle>@(_isEdit ? L["FieldEdit_EditTitle"] : L["FieldEdit_CreateTitle"]) - Traceon</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-1">
            <i class="bi bi-@(_isEdit ? "pencil-square" : "plus-circle") me-2"></i>
            @(_isEdit ? L["FieldEdit_EditTitle"] : L["FieldEdit_CreateTitle"])
        </h3>
        <p class="text-muted mb-0">@(_isEdit ? L["FieldEdit_EditSubtitle"] : L["FieldEdit_CreateSubtitle"])</p>
    </div>
    <a href="/field-definitions" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>@L["FieldEdit_BackToFields"]
    </a>
</div>

<ErrorAlert Errors="_errors" OnDismiss="() => _errors = []" />

@if (_loading)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">@L["Common_Loading"]</span>
        </div>
    </div>
}
else if (_isEdit && _model is null)
{
    <div class="alert alert-warning">
        <i class="bi bi-question-circle me-2"></i>
        @L["FieldEdit_NotFound"]
    </div>
}
else
{
    <div class="card">
        <div class="card-body">
            <EditForm Model="_model" OnValidSubmit="SaveAsync" FormName="FieldDefinitionForm">
                <DataAnnotationsValidator />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">@L["Common_Name"] <span class="text-danger">*</span></label>
                        <InputText @bind-Value="_model!.DefaultName" class="form-control" />
                        <ValidationMessage For="() => _model!.DefaultName" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">@L["Common_Type"] <span class="text-danger">*</span></label>
                        <InputSelect @bind-Value="_model!.Type" class="form-select">
                            @foreach (var type in Enum.GetValues<FieldType>())
                            {
                                <option value="@type">@type</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">@L["Fields_RequiredByDefault"]</label>
                        <div class="form-check mt-2">
                            <InputCheckbox @bind-Value="_model!.DefaultIsRequired" class="form-check-input" id="isRequired" />
                            <label class="form-check-label" for="isRequired">@L["Common_Yes"]</label>
                        </div>
                    </div>
                </div>

                @if (_model!.Type is FieldType.Integer or FieldType.Decimal)
                {
                    <div class="row g-3 mt-1">
                        <div class="col-md-6">
                            <label class="form-label">@L["Fields_Unit"]</label>
                            <input type="text" class="form-control" @bind="_model.Unit" placeholder="@L["Fields_UnitPlaceholder"]" />
                            <div class="form-text">@L["Fields_UnitHint"]</div>
                        </div>
                    </div>
                }

                <div class="row g-3 mt-1">
                    <div class="col-12">
                        <label class="form-label">@L["Common_Description"]</label>
                        <InputText @bind-Value="_model!.DefaultDescription" class="form-control" />
                    </div>
                </div>

                @if (_model!.Type is FieldType.Integer or FieldType.Decimal or FieldType.Date)
                {
                    <div class="row g-3 mt-1">
                        <div class="col-md-6">
                            <label class="form-label">@(_model.Type == FieldType.Date ? L["Fields_MinDate"] : L["Fields_MinValue"])</label>
                            @switch (_model.Type)
                            {
                                case FieldType.Integer:
                                    <InputNumber @bind-Value="_model.IntMinValue" class="form-control" />
                                    break;
                                case FieldType.Decimal:
                                    <InputNumber @bind-Value="_model.DecimalMinValue" class="form-control" />
                                    break;
                                case FieldType.Date:
                                    <InputDate @bind-Value="_model.MinDateValue" class="form-control" />
                                    break;
                            }
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@(_model.Type == FieldType.Date ? L["Fields_MaxDate"] : L["Fields_MaxValue"])</label>
                            @switch (_model.Type)
                            {
                                case FieldType.Integer:
                                    <InputNumber @bind-Value="_model.IntMaxValue" class="form-control" />
                                    break;
                                case FieldType.Decimal:
                                    <InputNumber @bind-Value="_model.DecimalMaxValue" class="form-control" />
                                    break;
                                case FieldType.Date:
                                    <InputDate @bind-Value="_model.MaxDateValue" class="form-control" />
                                    break;
                            }
                        </div>
                    </div>
                }

                @if (_model.Type == FieldType.Dropdown)
                {
                    <div class="row g-3 mt-1">
                        <div class="col-12">
                            <label class="form-label">@L["Fields_DropdownValues"] <span class="text-danger">*</span></label>
                            <InputText @bind-Value="_model.DropdownValues" class="form-control"
                                       placeholder="@L["Fields_DropdownPlaceholder"]" />
                            <div class="form-text">@L["Fields_DropdownHint"]</div>
                        </div>
                    </div>
                }

                @if (_model.Type == FieldType.CompositeDropdown)
                {
                    <div class="row g-3 mt-1">
                        <div class="col-12">
                            <label class="form-label">@L["Fields_SourceDropdowns"] <span class="text-danger">*</span></label>
                            <div class="form-text mb-2">@L["Fields_SourceDropdownsHint"]</div>
                            @if (_availableDropdownFields.Count == 0)
                            {
                                <div class="alert alert-info py-2">
                                    <i class="bi bi-info-circle me-1"></i>@L["Fields_NoDropdownsAvailable"]
                                </div>
                            }
                            else
                            {
                                <div class="border rounded p-2" style="max-height: 200px; overflow-y: auto;">
                                    @foreach (var field in _availableDropdownFields.OrderBy(f => f.DefaultName, StringComparer.CurrentCultureIgnoreCase))
                                    {
                                        var fieldId = field.Id;
                                        var isSelected = _model.SourceFieldIds.Contains(fieldId);
                                        var valuesPreview = string.IsNullOrWhiteSpace(field.DropdownValues)
                                            ? ""
                                            : string.Join(", ", field.DropdownValues.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).Take(4));
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="@($"src-{fieldId}")"
                                                   checked="@isSelected"
                                                   @onchange="e => ToggleSourceField(fieldId, (bool)(e.Value ?? false))" />
                                            <label class="form-check-label" for="@($"src-{fieldId}")">
                                                <span class="fw-semibold">@field.DefaultName</span>
                                                @if (!string.IsNullOrEmpty(valuesPreview))
                                                {
                                                    <small class="text-muted ms-1">(@valuesPreview@(field.DropdownValues!.Split(',').Length > 4 ? ", ..." : ""))</small>
                                                }
                                            </label>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }

                <div class="row g-3 mt-1">
                    <div class="col-12">
                        <label class="form-label">@L["Fields_DefaultValue"]</label>

                        @switch (_model.Type)
                        {
                            case FieldType.Boolean:
                                <div class="form-check mt-2">
                                    <InputCheckbox @bind-Value="_model.DefaultBoolValue" class="form-check-input" id="defaultBool" />
                                    <label class="form-check-label" for="defaultBool">@L["Fields_CheckedByDefault"]</label>
                                </div>
                                break;

                            case FieldType.Integer:
                                <InputNumber @bind-Value="_model.DefaultIntValue" class="form-control" step="1" />
                                break;

                            case FieldType.Decimal:
                                <InputNumber @bind-Value="_model.DefaultDecimalValue" class="form-control" />
                                break;

                            case FieldType.Date:
                                <InputDate @bind-Value="_model.DefaultDateValue" class="form-control" />
                                break;

                            case FieldType.Dropdown:
                                @if (_model.ParsedDropdownValues.Length > 0)
                                {
                                    <InputSelect @bind-Value="_model.DefaultValue" class="form-select">
                                        <option value="">@L["Fields_SelectDefault"]</option>
                                        @foreach (var val in _model.ParsedDropdownValues)
                                        {
                                            <option value="@val">@val</option>
                                        }
                                    </InputSelect>
                                }
                                else
                                {
                                    <InputText @bind-Value="_model.DefaultValue" class="form-control" disabled />
                                    <div class="form-text text-warning">
                                        <i class="bi bi-info-circle me-1"></i>@L["Fields_DefineDropdownFirst"]
                                    </div>
                                }
                                break;

                            case FieldType.CompositeDropdown:
                                <small class="text-muted">
                                    <i class="bi bi-layers me-1"></i>@L["Fields_CompositeNoDefault"]
                                </small>
                                break;

                            default:
                                <InputText @bind-Value="_model.DefaultValue" class="form-control" />
                                break;
                        }
                    </div>
                </div>

                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-success" disabled="@_saving">
                        @if (_saving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        else
                        {
                            <i class="bi bi-check-circle me-1"></i>
                        }
                        @(_isEdit ? L["Common_SaveChanges"] : L["Common_Create"])
                    </button>
                    <a href="/field-definitions" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle me-1"></i>@L["Common_Cancel"]
                    </a>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter] public Guid? Id { get; set; }
    [Inject] private FieldDefinitionService Service { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private FieldDefinitionModel? _model;
    private IReadOnlyList<string> _errors = [];
    private bool _loading = true;
    private bool _saving;
    private bool _isEdit => Id.HasValue;
    private List<FieldDefinitionResponse> _availableDropdownFields = [];

    protected override async Task OnInitializedAsync()
    {
        if (_isEdit)
        {
            var field = await Service.GetByIdAsync(Id!.Value);

            if (field is not null)
            {
                _model = new FieldDefinitionModel
                {
                    DefaultName = field.DefaultName,
                    DefaultDescription = field.DefaultDescription,
                    Type = field.Type,
                    DropdownValues = field.DropdownValues,
                    DefaultIsRequired = field.DefaultIsRequired,
                    DefaultValue = field.DefaultValue,
                    Unit = field.Unit
                };

                _model.LoadTypedDefaults(field.DefaultMinValue, field.DefaultMaxValue);
            }
        }
        else
        {
            _model = new FieldDefinitionModel();
        }

        var all = await Service.GetAllAsync();
        _availableDropdownFields = all
            .Where(f => f.Type == FieldType.Dropdown && (!_isEdit || f.Id != Id!.Value))
            .ToList();

        _loading = false;
    }

    private void ToggleSourceField(Guid fieldId, bool isChecked)
    {
        if (_model is null) return;
        var ids = _model.SourceFieldIds;
        if (isChecked && !ids.Contains(fieldId))
            ids.Add(fieldId);
        else
            ids.Remove(fieldId);
        _model.SourceFieldIds = ids;
    }

    private async Task SaveAsync()
    {
        if (_model is null) return;

        _saving = true;
        _errors = [];

        var validationErrors = _model.ValidateMinMax(L);
        if (validationErrors.Count > 0)
        {
            _errors = validationErrors;
            _saving = false;
            return;
        }

        var defaultValue = _model.ResolveDefaultValue();
        var (minValue, maxValue) = _model.ResolveMinMax();
        var dropdownValues = _model.Type is FieldType.Dropdown or FieldType.CompositeDropdown ? _model.DropdownValues : null;

        bool success;
        IReadOnlyList<string> errors;

        if (_isEdit)
        {
            (success, errors) = await Service.UpdateAsync(Id!.Value, new UpdateFieldDefinitionRequest(
                _model.DefaultName,
                _model.Type,
                _model.DefaultDescription,
                dropdownValues,
                maxValue,
                minValue,
                _model.DefaultIsRequired,
                defaultValue,
                _model.Unit));
        }
        else
        {
            (success, errors) = await Service.CreateAsync(new CreateFieldDefinitionRequest(
                _model.DefaultName,
                _model.Type,
                _model.DefaultDescription,
                dropdownValues,
                maxValue,
                minValue,
                _model.DefaultIsRequired,
                defaultValue,
                _model.Unit));
        }

        if (success)
            Nav.NavigateTo("/field-definitions");
        else
            _errors = errors.Count > 0 ? errors : [L["Common_ErrorOccurred"]];

        _saving = false;
    }


}
