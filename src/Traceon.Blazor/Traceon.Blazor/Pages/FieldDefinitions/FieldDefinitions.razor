@page "/field-definitions"
@attribute [Authorize]

<PageTitle>Field Definitions - Traceon</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-1">
            <i class="bi bi-sliders me-2"></i>
            Field Definitions
        </h3>
        <p class="text-muted mb-0">Define reusable field templates that can be assigned to tracked actions</p>
    </div>
</div>

@if (_errors.Count > 0)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <ul class="mb-0 d-inline">
            @foreach (var error in _errors)
            {
                <li>@error</li>
            }
        </ul>
        <button type="button" class="btn-close" @onclick="() => _errors = []"></button>
    </div>
}

<DataGrid @ref="_grid"
          TItem="FieldDefinitionResponse"
          LoadData="LoadDataAsync"
          Columns="_columns"
          FilterPlaceholder="Filter by name..."
          EmptyText="No field definitions yet. Create one to get started!">
    <Toolbar>
        <a href="/field-definitions/create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i> New Field Definition
        </a>
    </Toolbar>
    <RowActions>
        <ListActionsDropdown PrimaryText="Edit"
                             PrimaryIcon="pencil-square"
                             PrimaryButtonStyle="primary"
                             PrimaryAction="() => EditField(context.Id)"
                             Actions="GetActions(context)" />
    </RowActions>
</DataGrid>

@code {
    [Inject] private FieldDefinitionService Service { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private DataGrid<FieldDefinitionResponse> _grid = default!;
    private IReadOnlyList<string> _errors = [];

    private static readonly List<DataGridColumn<FieldDefinitionResponse>> _columns =
    [
        new() { Title = "Name", Selector = x => x.DefaultName, SortField = "DefaultName" },
        new() { Title = "Type", Selector = x => x.Type },
        new() { Title = "Required", Selector = x => x.DefaultIsRequired ? "Yes" : "No" },
        new() { Title = "Created", Selector = x => x.CreatedAtUtc.ToLocalTime(), SortField = "CreatedAtUtc", Format = "g" },
    ];

    private Task<DataGridResult<FieldDefinitionResponse>> LoadDataAsync(DataGridRequest request)
        => Service.QueryAsync(request, ["DefaultName"]);

    private List<ListAction> GetActions(FieldDefinitionResponse field)
    {
        return
        [
            ListAction.Button("Delete", () => DeleteAsync(field.Id), "trash", ListActionStyle.Danger),
        ];
    }

    private void EditField(Guid id)
    {
        Nav.NavigateTo($"/field-definitions/{id}/edit");
    }

    private async Task DeleteAsync(Guid id)
    {
        _errors = [];
        var (success, errors) = await Service.DeleteAsync(id);

        if (success)
            await _grid.RefreshAsync();
        else
            _errors = errors;
    }
}
