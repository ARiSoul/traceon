@page "/tracked-actions/{TrackedActionId:guid}/entries/new"
@page "/tracked-actions/{TrackedActionId:guid}/entries/{EntryId:guid}/edit"
@attribute [Authorize]
@inject IStringLocalizer<SharedResource> L

<PageTitle>@(_isEdit ? L["Entry_EditTitle"] : L["Entry_NewTitle"]) - Traceon</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-1">
            <i class="bi bi-@(_isEdit ? "pencil-square" : "plus-square") me-2"></i>
            @(_isEdit ? L["Entry_EditTitle"] : L["Entry_NewTitle"])
        </h3>
        <p class="text-muted mb-0">
            @(_isEdit ? L["Entry_EditSubtitle"] : L["Entry_NewSubtitle"])
            <strong>@(_actionName ?? "...")</strong>
        </p>
    </div>
    <a href="@_returnUrl" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>@L["Common_Back"]
    </a>
</div>

<ErrorAlert Errors="_errors" OnDismiss="() => _errors = []" />

@if (_loading)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">@L["Common_Loading"]</span>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-body">
            <!-- Occurrence & Notes -->
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">
                        <i class="bi bi-calendar-event me-1"></i>@L["QuickTrack_When"] <span class="text-danger">*</span>
                    </label>
                    <input type="datetime-local"
                           class="form-control"
                           step="60"
                           value="@_occurredLocal.ToString("yyyy-MM-ddTHH:mm")"
                           @onchange="OnDateTimeChanged" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">
                        <i class="bi bi-chat-text me-1"></i>@L["QuickTrack_Notes"] <span class="text-muted fw-normal">(@L["Common_Optional"])</span>
                    </label>
                    <textarea class="form-control"
                              rows="2"
                              placeholder="@L["QuickTrack_NotesPlaceholder"]"
                              data-select-on-focus
                              @bind="_notes"></textarea>
                </div>
            </div>

            <!-- Fields -->
            @if (_fieldModels.Count > 0)
            {
                <hr />
                <h6 class="mb-3">
                    <i class="bi bi-sliders me-1"></i>@L["Common_Fields"]
                </h6>

                <div class="row g-3">
                    @foreach (var model in _fieldModels)
                    {
                        <div class="@FieldColumnClass(model.Field.FieldType)">
                            <label class="form-label">
                                @model.Field.Name
                                @if (model.Field.IsRequired)
                                {
                                    <span class="text-danger">*</span>
                                }
                                <span class="badge bg-secondary ms-1" style="font-size: 0.65rem;">@model.Field.FieldType</span>
                            </label>

                            @if (!string.IsNullOrEmpty(model.Field.Description))
                            {
                                <div class="form-text mt-0 mb-1">@model.Field.Description</div>
                            }

                            @switch (model.Field.FieldType)
                            {
                                case FieldType.Text:
                                    <input type="text"
                                           class="form-control"
                                           placeholder="@model.Field.Name"
                                           data-select-on-focus
                                           @bind="model.TextValue" />
                                    break;

                                case FieldType.Integer:
                                    <div class="input-group">
                                        <input type="number"
                                               step="1"
                                               class="form-control"
                                               min="@model.Field.MinValue"
                                               max="@model.Field.MaxValue"
                                               placeholder="@model.Field.Name"
                                               data-select-on-focus
                                               @bind="model.IntValue" />
                                        @if (model.Field.Unit != "UN")
                                        {
                                            <span class="input-group-text">@model.Field.Unit</span>
                                        }
                                    </div>
                                    break;

                                case FieldType.Decimal:
                                    <div class="input-group">
                                        <input type="number"
                                               step="any"
                                               class="form-control"
                                               min="@model.Field.MinValue"
                                               max="@model.Field.MaxValue"
                                               placeholder="@model.Field.Name"
                                               data-select-on-focus
                                               @bind="model.DecimalValue" />
                                        @if (model.Field.Unit != "UN")
                                        {
                                            <span class="input-group-text">@model.Field.Unit</span>
                                        }
                                    </div>
                                    break;

                                case FieldType.Date:
                                    <input type="date"
                                           class="form-control"
                                           @bind="model.DateValue" />
                                    break;

                                case FieldType.Boolean:
                                    <div class="form-check form-switch mt-1">
                                        <input type="checkbox"
                                               class="form-check-input"
                                               id="@($"field-{model.Field.Id}")"
                                               @bind="model.BoolValue" />
                                        <label class="form-check-label" for="@($"field-{model.Field.Id}")">
                                            @(model.BoolValue ? L["Common_Yes"] : L["Common_No"])
                                        </label>
                                    </div>
                                    break;

                                case FieldType.Dropdown:
                                    <div class="input-group">
                                        <select class="form-select" value="@model.TextValue"
                                                @onchange="e => OnDropdownChanged(model, e.Value?.ToString())">
                                            <option value="">@L["Entry_Select"]</option>
                                            @foreach (var opt in model.DropdownOptions)
                                            {
                                                <option value="@opt">@opt</option>
                                            }
                                        </select>
                                        <button class="btn btn-outline-secondary" type="button"
                                                title="@L["Dropdown_AddNew"]"
                                                @onclick="() => ToggleQuickAdd(model.Field.Id)">
                                            <i class="bi bi-plus-lg"></i>
                                        </button>
                                    </div>
                                    @if (_quickAddFieldId == model.Field.Id)
                                    {
                                        <div class="input-group input-group-sm mt-1">
                                            <input type="text" class="form-control" placeholder="@L["Dropdown_NewValue"]"
                                                   @bind="_quickAddValue" @bind:event="oninput"
                                                   @onkeydown="@(e => OnQuickAddKeyDown(e, model))" />
                                            <button class="btn btn-success" type="button"
                                                    disabled="@(string.IsNullOrWhiteSpace(_quickAddValue) || _quickAddSaving)"
                                                    @onclick="() => QuickAddDropdownValueAsync(model)">
                                                @if (_quickAddSaving)
                                                {
                                                    <span class="spinner-border spinner-border-sm"></span>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-check-lg"></i>
                                                }
                                            </button>
                                            <button class="btn btn-outline-secondary" type="button"
                                                    @onclick="() => _quickAddFieldId = null">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </div>
                                    }
                                    break;

                                case FieldType.CompositeDropdown:
                                    <div class="input-group">
                                        <select class="form-select" value="@model.TextValue"
                                                @onchange="e => OnDropdownChanged(model, e.Value?.ToString())">
                                            <option value="">@L["Entry_Select"]</option>
                                            @if (model.CompositeGroups.Count > 0)
                                            {
                                                @foreach (var (groupName, values) in model.CompositeGroups)
                                                {
                                                    <optgroup label="@groupName">
                                                        @foreach (var val in values)
                                                        {
                                                            <option value="@val">@val</option>
                                                        }
                                                    </optgroup>
                                                }
                                            }
                                        </select>
                                        <button class="btn btn-outline-secondary" type="button"
                                                title="@L["Dropdown_AddNew"]"
                                                @onclick="() => ToggleCompositeQuickAdd(model)">
                                            <i class="bi bi-plus-lg"></i>
                                        </button>
                                    </div>
                                    @if (_compositeQuickAdd?.Model == model)
                                    {
                                        <div class="card card-body mt-2 p-2 border-primary">
                                            <div class="mb-2">
                                                <label class="form-label form-label-sm mb-1">@L["CompositeQuickAdd_Source"]</label>
                                                @if (!_compositeQuickAdd.IsCreatingNewSource)
                                                {
                                                    <div class="d-flex gap-1">
                                                        <select class="form-select form-select-sm"
                                                                value="@_compositeQuickAdd.SelectedSourceId"
                                                                @onchange="e => _compositeQuickAdd.SelectedSourceId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : Guid.Empty">
                                                            <option value="@Guid.Empty">@L["Entry_Select"]</option>
                                                            @foreach (var src in _compositeQuickAdd.SourceOptions)
                                                            {
                                                                <option value="@src.Id">@src.Name</option>
                                                            }
                                                        </select>
                                                        <button type="button" class="btn btn-outline-secondary btn-sm text-nowrap"
                                                                @onclick="() => _compositeQuickAdd.IsCreatingNewSource = true">
                                                            <i class="bi bi-plus-lg me-1"></i>@L["CompositeQuickAdd_NewSource"]
                                                        </button>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="d-flex gap-1">
                                                        <input type="text" class="form-control form-control-sm"
                                                               placeholder="@L["CompositeQuickAdd_NewSourceName"]"
                                                               @bind="_compositeQuickAdd.NewSourceName"
                                                               @bind:event="oninput" />
                                                        @if (_compositeQuickAdd.SourceOptions.Count > 0)
                                                        {
                                                            <button type="button" class="btn btn-outline-secondary btn-sm text-nowrap"
                                                                    @onclick="() => _compositeQuickAdd.IsCreatingNewSource = false">
                                                                @L["Common_Cancel"]
                                                            </button>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                            <div class="mb-2">
                                                <label class="form-label form-label-sm mb-1">@L["Dropdown_NewValue"]</label>
                                                <input type="text" class="form-control form-control-sm"
                                                       placeholder="@L["Dropdown_NewValue"]"
                                                       @bind="_compositeQuickAdd.NewValue" @bind:event="oninput"
                                                       @onkeydown="OnCompositeQuickAddKeyDown" />
                                            </div>
                                            @if (_compositeQuickAdd.ParentContext is not null)
                                            {
                                                <div class="form-check form-check-sm mb-2">
                                                    <input type="checkbox" class="form-check-input" id="qa-link-dep"
                                                           @bind="_compositeQuickAdd.LinkDependency" />
                                                    <label class="form-check-label small" for="qa-link-dep">
                                                        @string.Format(L["CompositeQuickAdd_Link"],
                                                            _compositeQuickAdd.ParentContext.Value.ParentFieldName,
                                                            _compositeQuickAdd.ParentContext.Value.ParentValue)
                                                    </label>
                                                </div>
                                            }
                                            <div class="d-flex gap-1">
                                                <button class="btn btn-success btn-sm" type="button"
                                                        disabled="@(!_compositeQuickAdd.IsValid || _compositeQuickAdd.Saving)"
                                                        @onclick="CompositeQuickAddSaveAsync">
                                                    @if (_compositeQuickAdd.Saving)
                                                    {
                                                        <span class="spinner-border spinner-border-sm"></span>
                                                    }
                                                    else
                                                    {
                                                        <i class="bi bi-check-lg"></i>
                                                    }
                                                </button>
                                                <button class="btn btn-outline-secondary btn-sm" type="button"
                                                        @onclick="() => _compositeQuickAdd = null">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            </div>
                                        </div>
                                    }
                                    break;
                            }
                        </div>
                    }
                </div>
            }
            @* ── Inline new dropdown field ── *@
            @if (_newFieldInline is not null)
            {
                <div class="card border-success mt-3">
                    <div class="card-header bg-success bg-opacity-10 d-flex justify-content-between align-items-center">
                        <h6 class="mb-0"><i class="bi bi-plus-circle me-2"></i>@L["NewField_Title"]</h6>
                        <button class="btn-close" @onclick="CloseNewFieldInline"></button>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-12 col-md-5">
                                <label class="form-label">@L["Common_Name"] <span class="text-danger">*</span></label>
                                <input type="text" class="form-control form-control-sm"
                                       @bind="_newFieldInline.Name"
                                       placeholder="@L["Common_Name"]" />
                            </div>
                            <div class="col-12 col-md-7">
                                <label class="form-label">@L["Fields_DropdownValues"] <span class="text-danger">*</span></label>
                                <input type="text" class="form-control form-control-sm"
                                       @bind="_newFieldInline.DropdownValues"
                                       placeholder="@L["Fields_DropdownPlaceholder"]" />
                                <div class="form-text">@L["Fields_DropdownHint"]</div>
                            </div>
                            @{
                                var newFieldParents = _fieldModels
                                    .Where(m => m.Field.FieldType == FieldType.Dropdown && !string.IsNullOrEmpty(m.TextValue))
                                    .ToList();
                            }
                            @if (newFieldParents.Count > 0)
                            {
                                <div class="col-12 col-md-6">
                                    <label class="form-label">@L["NewField_LinkParent"]</label>
                                    <select class="form-select form-select-sm" @bind="_newFieldInline.ParentFieldId">
                                        <option value="@Guid.Empty">— @L["Common_None"] —</option>
                                        @foreach (var p in newFieldParents)
                                        {
                                            <option value="@p.Field.Id">@p.Field.Name = @p.TextValue</option>
                                        }
                                    </select>
                                    <div class="form-text">@L["NewField_LinkParentHint"]</div>
                                </div>
                            }
                        </div>
                        @if (_newFieldErrors.Count > 0)
                        {
                            <div class="text-danger small mt-2">@string.Join(", ", _newFieldErrors)</div>
                        }
                        <div class="d-flex justify-content-end gap-2 mt-3">
                            <button class="btn btn-outline-secondary btn-sm" @onclick="CloseNewFieldInline">
                                @L["Common_Cancel"]
                            </button>
                            <button class="btn btn-success btn-sm" @onclick="SaveNewFieldInlineAsync"
                                    disabled="@(!_newFieldInline.IsValid || _newFieldInline.Saving)">
                                @if (_newFieldInline.Saving)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                else
                                {
                                    <i class="bi bi-check-circle me-1"></i>
                                }
                                @L["Common_Save"]
                            </button>
                        </div>
                    </div>
                </div>
            }
            </div>
            <div class="card-footer bg-light">
            <div class="d-flex justify-content-between">
                <a href="@_returnUrl" class="btn btn-outline-secondary">
                    <i class="bi bi-x-circle me-1"></i>@L["Common_Cancel"]
                </a>
                <button class="btn btn-success" @onclick="SaveAsync" disabled="@_saving">
                    @if (_saving)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    else
                    {
                        <i class="bi bi-check-circle me-1"></i>
                    }
                    @(_isEdit ? L["Common_SaveChanges"] : L["Entry_SaveEntry"])
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid TrackedActionId { get; set; }
    [Parameter] public Guid? EntryId { get; set; }

    [Inject] private TrackedActionService ActionService { get; set; } = default!;
    [Inject] private ActionFieldService FieldService { get; set; } = default!;
    [Inject] private ActionEntryService EntryService { get; set; } = default!;
    [Inject] private FieldDefinitionService FieldDefService { get; set; } = default!;
    [Inject] private FieldDependencyRuleService DepRuleService { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private bool _isEdit => EntryId.HasValue;
    private bool _loading = true;
    private bool _saving;
    private IReadOnlyList<string> _errors = [];
    private string? _actionName;

    // Quick-add dropdown
    private Guid? _quickAddFieldId;
    private string _quickAddValue = string.Empty;
    private bool _quickAddSaving;

    // Dependency rules
    private List<FieldDependencyRuleResponse> _depRules = [];

    private string _returnUrl = "/";
    private DateTime _occurredLocal;
    private string? _notes;
    private List<EntryFieldModel> _fieldModels = [];

    protected override async Task OnInitializedAsync()
    {
        _returnUrl = ReturnUrl ?? "/";

        var action = await ActionService.GetByIdAsync(TrackedActionId);
        _actionName = action?.Name;

        var fields = await FieldService.GetByTrackedActionAsync(TrackedActionId);

        if (_isEdit)
        {
            var entry = await EntryService.GetByIdAsync(TrackedActionId, EntryId!.Value);
            if (entry is not null)
            {
                _occurredLocal = entry.OccurredAtUtc.ToLocalTime();
                _notes = entry.Notes;
                _fieldModels = fields.Select(f =>
                {
                    var existing = entry.FieldValues.FirstOrDefault(v => v.ActionFieldId == f.Id);
                    var model = new EntryFieldModel { Field = f };
                    model.LoadValue(existing?.Value);
                    return model;
                }).ToList();
            }
        }
        else
        {
            _occurredLocal = DateTime.Now;
            _fieldModels = fields.Select(f =>
            {
                var model = new EntryFieldModel { Field = f };
                model.LoadValue(f.DefaultValue);
                return model;
            }).ToList();

            await LoadComputedInitialValuesAsync();
        }

        try { _depRules = await DepRuleService.GetByTrackedActionAsync(TrackedActionId); } catch { _depRules = []; }
        await ResolveCompositeDropdownsAsync();
        EvaluateDependencyRules();

        _loading = false;
    }

    private async Task LoadComputedInitialValuesAsync()
    {
        var needsEntries = _fieldModels.Any(m =>
            m.Field.InitialValueBehavior != InitialValueBehavior.DefaultValue);

        if (!needsEntries) return;

        try
        {
            // Determine the widest time window needed for Min/Max/Avg fields.
            // LastValue fields always need the most recent entry regardless of period,
            // so if any LastValue field exists we must NOT restrict the date window.
            var hasLastValue = _fieldModels.Any(m =>
                m.Field.InitialValueBehavior == InitialValueBehavior.LastValue);

            DateTime? fromUtc = null;
            if (!hasLastValue)
            {
                foreach (var m in _fieldModels)
                {
                    if (m.Field.InitialValueBehavior is InitialValueBehavior.MinValue
                        or InitialValueBehavior.MaxValue or InitialValueBehavior.AvgValue)
                    {
                        var fieldFrom = GetPeriodStart(m.Field.InitialValuePeriodUnit, m.Field.InitialValuePeriodCount);
                        if (fieldFrom is not null && (fromUtc is null || fieldFrom < fromUtc))
                            fromUtc = fieldFrom;
                    }
                }
            }

            var filter = $"TrackedActionId eq {TrackedActionId}";
            if (fromUtc.HasValue)
                filter += $" and OccurredAtUtc ge {fromUtc.Value:yyyy-MM-ddTHH:mm:ssZ}";

            var request = new DataGridRequest(1, 10_000, "OccurredAtUtc", true, null);
            var result = await EntryService.QueryAsync(request, null, filter);
            var entries = result.Items;

            if (entries.Count == 0) return;

            foreach (var model in _fieldModels)
            {
                switch (model.Field.InitialValueBehavior)
                {
                    case InitialValueBehavior.LastValue:
                        var lastEntry = entries.FirstOrDefault();
                        var lastVal = lastEntry?.FieldValues
                            ?.FirstOrDefault(v => v.ActionFieldId == model.Field.Id)?.Value;
                        if (lastVal is not null)
                            model.LoadValue(lastVal);
                        break;

                    case InitialValueBehavior.MinValue:
                    case InitialValueBehavior.MaxValue:
                    case InitialValueBehavior.AvgValue:
                        var periodStart = GetPeriodStart(model.Field.InitialValuePeriodUnit, model.Field.InitialValuePeriodCount);
                        var values = entries
                            .Where(e => periodStart is null || e.OccurredAtUtc >= periodStart)
                            .Select(e => e.FieldValues
                                ?.FirstOrDefault(v => v.ActionFieldId == model.Field.Id)?.Value)
                            .Where(v => v is not null && decimal.TryParse(v, CultureInfo.InvariantCulture, out _))
                            .Select(v => decimal.Parse(v!, CultureInfo.InvariantCulture))
                            .ToList();

                        if (values.Count > 0)
                        {
                            var computed = model.Field.InitialValueBehavior switch
                            {
                                InitialValueBehavior.MinValue => values.Min(),
                                InitialValueBehavior.MaxValue => values.Max(),
                                InitialValueBehavior.AvgValue => Math.Round(values.Average(), 4),
                                _ => (decimal?)null
                            };
                            if (computed.HasValue)
                            {
                                // For Integer fields, round to whole number so int.TryParse succeeds in LoadValue
                                var formatted = model.Field.FieldType == FieldType.Integer
                                    ? ((int)Math.Round(computed.Value, 0)).ToString(CultureInfo.InvariantCulture)
                                    : computed.Value.ToString(CultureInfo.InvariantCulture);
                                model.LoadValue(formatted);
                            }
                        }
                        break;
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Traceon] Failed to compute initial field values: {ex.Message}");
        }
    }

    private static DateTime? GetPeriodStart(InitialValuePeriodUnit unit, int count)
    {
        if (unit == InitialValuePeriodUnit.AllTime || count <= 0) return null;
        return unit switch
        {
            InitialValuePeriodUnit.Days => DateTime.UtcNow.AddDays(-count),
            InitialValuePeriodUnit.Months => DateTime.UtcNow.AddMonths(-count),
            _ => null
        };
    }

    private void OnDateTimeChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var parsed))
            _occurredLocal = parsed;
    }

    private async Task SaveAsync()
    {
        _saving = true;
        _errors = [];

        // Client-side validation
        var validationErrors = Validate();
        if (validationErrors.Count > 0)
        {
            _errors = validationErrors;
            _saving = false;
            return;
        }

        var occurredUtc = _occurredLocal.ToUniversalTime();
        var fieldValues = _fieldModels.Count > 0
            ? _fieldModels.Select(m => new ActionEntryFieldValue(m.Field.Id, m.ResolveValue())).ToList()
            : null;

        bool success;
        IReadOnlyList<string> errors;

        if (_isEdit)
        {
            var request = new UpdateActionEntryRequest(occurredUtc, _notes, fieldValues);
            (success, errors) = await EntryService.UpdateAsync(TrackedActionId, EntryId!.Value, request);
        }
        else
        {
            var request = new CreateActionEntryRequest(occurredUtc, _notes, fieldValues);
            (success, errors) = await EntryService.CreateAsync(TrackedActionId, request);
        }

        if (success)
        {
            Nav.NavigateTo(_returnUrl);
            return;
        }

        _errors = errors.Count > 0 ? errors : [L["Common_ErrorOccurred"]];
        _saving = false;
    }

    private List<string> Validate()
    {
        var errors = new List<string>();

        foreach (var model in _fieldModels.Where(m => m.Field.IsRequired))
        {
            var value = model.ResolveValue();
            if (string.IsNullOrWhiteSpace(value))
                errors.Add(L["Validation_FieldRequired", model.Field.Name]);
        }

        foreach (var model in _fieldModels)
        {
            if (model.Field.FieldType is FieldType.Integer or FieldType.Decimal)
            {
                var value = model.ResolveValue();
                if (string.IsNullOrWhiteSpace(value)) continue;

                if (decimal.TryParse(value, CultureInfo.InvariantCulture, out var numericValue))
                {
                    if (model.Field.MinValue.HasValue && numericValue < model.Field.MinValue)
                        errors.Add(L["Validation_FieldMinValue", model.Field.Name, model.Field.MinValue]);
                    if (model.Field.MaxValue.HasValue && numericValue > model.Field.MaxValue)
                        errors.Add(L["Validation_FieldMaxValue", model.Field.Name, model.Field.MaxValue]);
                }
            }
        }

        return errors;
    }

    private static string FieldColumnClass(FieldType type) => type switch
    {
        FieldType.Boolean => "col-6 col-md-4",
        FieldType.Date => "col-12 col-md-6",
        _ => "col-12 col-md-6"
    };

    private sealed class EntryFieldModel
    {
        public required ActionFieldResponse Field { get; init; }
        public string? TextValue { get; set; }
        public int? IntValue { get; set; }
        public decimal? DecimalValue { get; set; }
        public DateTime? DateValue { get; set; }
        public bool BoolValue { get; set; }

        private string[]? _dropdownOverride;
        private string? _dropdownValuesOverride;

        public string? EffectiveDropdownValues => _dropdownValuesOverride ?? Field.DropdownValues;

        public void AppendCompositeSource(string sourceId)
        {
            var current = _dropdownValuesOverride ?? Field.DropdownValues ?? "ref:";
            if (!current.StartsWith("ref:", StringComparison.Ordinal))
                current = "ref:";
            var refs = current["ref:".Length..]
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .ToList();
            if (!refs.Contains(sourceId, StringComparer.OrdinalIgnoreCase))
                refs.Add(sourceId);
            _dropdownValuesOverride = "ref:" + string.Join(",", refs);
        }

        // Composite dropdown: grouped options resolved from sibling fields
        private List<(string GroupName, string[] Values)>? _originalCompositeGroups;
        public List<(string GroupName, string[] Values)> CompositeGroups { get; set; } = [];

        public void SetOriginalCompositeGroups(List<(string GroupName, string[] Values)> groups)
        {
            _originalCompositeGroups = groups;
            CompositeGroups = groups;
        }

        public void FilterCompositeGroups(HashSet<string> allowedValues)
        {
            var source = _originalCompositeGroups ?? CompositeGroups;
            CompositeGroups = source
                .Select(g => (g.GroupName, Values: g.Values
                    .Where(v => allowedValues.Contains(v, StringComparer.OrdinalIgnoreCase))
                    .ToArray()))
                .Where(g => g.Values.Length > 0)
                .ToList();
        }

        public void ResetCompositeGroups()
        {
            if (_originalCompositeGroups is not null)
                CompositeGroups = _originalCompositeGroups;
        }

        public void ClearCompositeGroups()
        {
            CompositeGroups = [];
        }

        public string[] DropdownOptions => _dropdownOverride
            ?? (string.IsNullOrWhiteSpace(Field.DropdownValues) || Field.DropdownValues.StartsWith("ref:", StringComparison.Ordinal)
                ? []
                : Field.DropdownValues.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                    .OrderBy(v => v, StringComparer.CurrentCultureIgnoreCase).ToArray());

        public void SetDropdownValues(string csv)
        {
            _dropdownOverride = string.IsNullOrWhiteSpace(csv)
                ? []
                : csv.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                    .OrderBy(v => v, StringComparer.CurrentCultureIgnoreCase).ToArray();
        }

        public void LoadValue(string? value)
        {
            if (string.IsNullOrWhiteSpace(value))
            {
                if (Field.FieldType == FieldType.Boolean)
                    BoolValue = false;
                return;
            }

            switch (Field.FieldType)
            {
                case FieldType.Boolean:
                    BoolValue = value.Equals("true", StringComparison.OrdinalIgnoreCase);
                    break;
                case FieldType.Integer when int.TryParse(value, CultureInfo.InvariantCulture, out var i):
                    IntValue = i;
                    break;
                case FieldType.Decimal when decimal.TryParse(value, CultureInfo.InvariantCulture, out var d):
                    DecimalValue = d;
                    break;
                case FieldType.Date when DateTime.TryParse(value, CultureInfo.InvariantCulture, out var dt):
                    DateValue = dt;
                    break;
                default:
                    TextValue = value;
                    break;
            }
        }

        public string? ResolveValue() => Field.FieldType switch
        {
            FieldType.Boolean => BoolValue.ToString().ToLowerInvariant(),
            FieldType.Integer => IntValue?.ToString(CultureInfo.InvariantCulture),
            FieldType.Decimal => DecimalValue?.ToString(CultureInfo.InvariantCulture),
            FieldType.Date => DateValue?.ToString("yyyy-MM-dd"),
            _ => TextValue
        };
    }

    private void ToggleQuickAdd(Guid fieldId)
    {
        if (_quickAddFieldId == fieldId)
        {
            _quickAddFieldId = null;
        }
        else
        {
            _quickAddFieldId = fieldId;
            _quickAddValue = string.Empty;
        }
    }

    private async Task QuickAddDropdownValueAsync(EntryFieldModel model)
    {
        if (string.IsNullOrWhiteSpace(_quickAddValue)) return;

        _quickAddSaving = true;
        var (success, updatedCsv) = await FieldDefService.AppendDropdownValueAsync(
            model.Field.FieldDefinitionId, _quickAddValue.Trim());

        if (success && updatedCsv is not null)
        {
            model.SetDropdownValues(updatedCsv);
            model.TextValue = _quickAddValue.Trim();
            _quickAddFieldId = null;
            _quickAddValue = string.Empty;
            EvaluateDependencyRules();
        }

        _quickAddSaving = false;
    }

    private async Task OnQuickAddKeyDown(KeyboardEventArgs e, EntryFieldModel model)
    {
        if (e.Key == "Enter")
            await QuickAddDropdownValueAsync(model);
    }

    // ── Composite dropdown resolution ──

    private List<FieldDefinitionResponse> _cachedFieldDefinitions = [];

    private async Task ResolveCompositeDropdownsAsync()
    {
        var hasComposite = _fieldModels.Any(m => m.Field.FieldType == FieldType.CompositeDropdown);
        if (!hasComposite) return;

        // Load all field definitions once so we can resolve ref: IDs
        if (_cachedFieldDefinitions.Count == 0)
            _cachedFieldDefinitions = await FieldDefService.GetAllAsync();

        var fieldDefLookup = _cachedFieldDefinitions
            .Where(fd => fd.Type == FieldType.Dropdown && !string.IsNullOrWhiteSpace(fd.DropdownValues))
            .ToDictionary(fd => fd.Id);

        foreach (var model in _fieldModels)
        {
            if (model.Field.FieldType != FieldType.CompositeDropdown) continue;
            if (string.IsNullOrWhiteSpace(model.EffectiveDropdownValues)) continue;
            if (!model.EffectiveDropdownValues.StartsWith("ref:", StringComparison.Ordinal)) continue;

            var refIds = model.EffectiveDropdownValues["ref:".Length..]
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Select(s => Guid.TryParse(s, out var id) ? id : Guid.Empty)
                .Where(id => id != Guid.Empty)
                .ToList();

            var groups = new List<(string GroupName, string[] Values)>();
            foreach (var refId in refIds)
            {
                if (fieldDefLookup.TryGetValue(refId, out var fd))
                {
                    var values = fd.DropdownValues!
                        .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                        .OrderBy(v => v, StringComparer.CurrentCultureIgnoreCase)
                        .ToArray();
                    groups.Add((fd.DefaultName, values));
                }
            }

            model.SetOriginalCompositeGroups(groups.OrderBy(g => g.GroupName, StringComparer.CurrentCultureIgnoreCase).ToList());
        }
    }

    // ── Dependency rule evaluation ──

    private void OnDropdownChanged(EntryFieldModel model, string? value)
    {
        model.TextValue = value;
        EvaluateDependencyRules();
    }

    private void EvaluateDependencyRules()
    {
        if (_depRules.Count == 0) return;

        var currentValues = _fieldModels.ToDictionary(m => m.Field.Id, m => m.TextValue ?? "");

        foreach (var model in _fieldModels)
        {
            var isComposite = model.Field.FieldType == FieldType.CompositeDropdown;
            if (model.Field.FieldType != FieldType.Dropdown && !isComposite) continue;

            var rulesForTarget = _depRules
                .Where(r => r.RuleType == DependencyRuleType.FilterDropdownValues && r.TargetFieldId == model.Field.Id)
                .ToList();

            if (rulesForTarget.Count == 0) continue;

            var matchedConstraints = new List<string>();
            var anySourceMatched = false;

            foreach (var rule in rulesForTarget)
            {
                currentValues.TryGetValue(rule.SourceFieldId, out var srcVal);

                if (!string.IsNullOrEmpty(srcVal) && string.Equals(srcVal, rule.SourceValue, StringComparison.OrdinalIgnoreCase))
                {
                    anySourceMatched = true;
                    if (!string.IsNullOrWhiteSpace(rule.TargetConstraint))
                    {
                        matchedConstraints.AddRange(
                            rule.TargetConstraint.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries));
                    }
                }
            }

            if (anySourceMatched)
            {
                var allowed = matchedConstraints.Distinct(StringComparer.OrdinalIgnoreCase).ToHashSet(StringComparer.OrdinalIgnoreCase);
                model.SetDropdownValues(string.Join(",", allowed));

                if (isComposite)
                    model.FilterCompositeGroups(allowed);

                if (!string.IsNullOrEmpty(model.TextValue) &&
                    !allowed.Contains(model.TextValue))
                {
                    model.TextValue = null;
                }
            }
            else
            {
                // Check if any source field that governs this target has a value selected
                var sourceFieldIds = rulesForTarget.Select(r => r.SourceFieldId).Distinct();
                var anySourceHasValue = sourceFieldIds.Any(sfId =>
                    currentValues.TryGetValue(sfId, out var v) && !string.IsNullOrEmpty(v));

                if (anySourceHasValue)
                {
                    // Source has a value but no rule matched → show nothing
                    model.SetDropdownValues("");
                    model.TextValue = null;

                    if (isComposite)
                        model.ClearCompositeGroups();
                }
                else
                {
                    // No source value selected yet → show all original values
                    model.SetDropdownValues(model.EffectiveDropdownValues ?? "");

                    if (isComposite)
                        model.ResetCompositeGroups();
                }
            }
        }
    }

    // ── Composite Quick-Add ──

    private CompositeQuickAddState? _compositeQuickAdd;

    private void ToggleCompositeQuickAdd(EntryFieldModel model)
    {
        if (_compositeQuickAdd?.Model == model)
        {
            _compositeQuickAdd = null;
            return;
        }

        // Parse the ref: IDs to find which source field definitions this composite pulls from
        var sourceOptions = new List<CompositeSourceOption>();
        var effectiveRefs = model.EffectiveDropdownValues;
        if (!string.IsNullOrWhiteSpace(effectiveRefs)
            && effectiveRefs.StartsWith("ref:", StringComparison.Ordinal))
        {
            var refIds = effectiveRefs["ref:".Length..]
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Select(s => Guid.TryParse(s, out var id) ? id : Guid.Empty)
                .Where(id => id != Guid.Empty)
                .ToList();

            foreach (var refId in refIds)
            {
                var fd = _cachedFieldDefinitions.FirstOrDefault(f => f.Id == refId);
                if (fd is not null)
                    sourceOptions.Add(new CompositeSourceOption(fd.Id, fd.DefaultName));
            }
        }

        // Detect parent context: find the dependency rule source that currently has a value
        (Guid ParentFieldId, string ParentFieldName, string ParentValue)? parentCtx = null;
        var rulesForTarget = _depRules
            .Where(r => r.RuleType == DependencyRuleType.FilterDropdownValues && r.TargetFieldId == model.Field.Id)
            .ToList();

        if (rulesForTarget.Count > 0)
        {
            var sourceFieldIds = rulesForTarget.Select(r => r.SourceFieldId).Distinct().ToList();
            foreach (var sfId in sourceFieldIds)
            {
                var parentModel = _fieldModels.FirstOrDefault(m => m.Field.Id == sfId);
                if (parentModel is not null && !string.IsNullOrEmpty(parentModel.TextValue))
                {
                    parentCtx = (sfId, parentModel.Field.Name, parentModel.TextValue);
                    break;
                }
            }
        }

        // Fallback: infer parent from the closest preceding dropdown/composite field that has a value.
        // This covers the case where no dep rules exist yet for this field (first-time chain setup).
        if (parentCtx is null)
        {
            var idx = _fieldModels.IndexOf(model);
            for (var i = idx - 1; i >= 0; i--)
            {
                var candidate = _fieldModels[i];
                if ((candidate.Field.FieldType == FieldType.Dropdown || candidate.Field.FieldType == FieldType.CompositeDropdown)
                    && !string.IsNullOrEmpty(candidate.TextValue))
                {
                    parentCtx = (candidate.Field.Id, candidate.Field.Name, candidate.TextValue);
                    break;
                }
            }
        }

        _compositeQuickAdd = new CompositeQuickAddState
        {
            Model = model,
            SourceOptions = sourceOptions,
            SelectedSourceId = sourceOptions.Count == 1 ? sourceOptions[0].Id : Guid.Empty,
            IsCreatingNewSource = sourceOptions.Count == 0,
            ParentContext = parentCtx,
            LinkDependency = parentCtx is not null
        };
    }

    private async Task OnCompositeQuickAddKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && _compositeQuickAdd is { IsValid: true })
            await CompositeQuickAddSaveAsync();
    }

    private async Task CompositeQuickAddSaveAsync()
    {
        if (_compositeQuickAdd is null || !_compositeQuickAdd.IsValid) return;

        _compositeQuickAdd.Saving = true;
        var newValue = _compositeQuickAdd.NewValue.Trim();

        if (_compositeQuickAdd.IsCreatingNewSource)
        {
            // 1a. Create the new source FieldDefinition with the value as its first item
            var (fdOk, created, _) = await FieldDefService.CreateWithResultAsync(
                new CreateFieldDefinitionRequest(
                    _compositeQuickAdd.NewSourceName.Trim(),
                    FieldType.Dropdown,
                    DropdownValues: newValue));

            if (!fdOk || created is null)
            {
                _compositeQuickAdd.Saving = false;
                return;
            }

            // 1b. Append the new source ID to the CompositeDropdown FieldDefinition's ref list
            var compositeFieldDef = _cachedFieldDefinitions.FirstOrDefault(fd => fd.Id == _compositeQuickAdd.Model.Field.FieldDefinitionId)
                ?? await FieldDefService.GetByIdAsync(_compositeQuickAdd.Model.Field.FieldDefinitionId);

            if (compositeFieldDef is not null)
            {
                var currentRefs = compositeFieldDef.DropdownValues is not null
                    && compositeFieldDef.DropdownValues.StartsWith("ref:", StringComparison.Ordinal)
                    ? compositeFieldDef.DropdownValues["ref:".Length..]
                        .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                        .ToList()
                    : new List<string>();

                currentRefs.Add(created.Id.ToString());

                await FieldDefService.UpdateAsync(compositeFieldDef.Id, new UpdateFieldDefinitionRequest(
                    compositeFieldDef.DefaultName,
                    FieldType.CompositeDropdown,
                    compositeFieldDef.DefaultDescription,
                    "ref:" + string.Join(",", currentRefs),
                    compositeFieldDef.DefaultMaxValue,
                    compositeFieldDef.DefaultMinValue,
                    compositeFieldDef.DefaultIsRequired,
                    compositeFieldDef.DefaultValue,
                    compositeFieldDef.Unit));
            }

            // 1c. Update the model's local ref list so ResolveCompositeDropdownsAsync picks it up
            _compositeQuickAdd.Model.AppendCompositeSource(created.Id.ToString());
        }
        else
        {
            // 1. Add value to the existing source field definition
            var (addSuccess, _) = await FieldDefService.AppendDropdownValueAsync(
                _compositeQuickAdd.SelectedSourceId, newValue);

            if (!addSuccess)
            {
                _compositeQuickAdd.Saving = false;
                return;
            }
        }

        // 2. If "link dependency" is checked, create or update the dependency rule
        if (_compositeQuickAdd is { LinkDependency: true, ParentContext: not null })
        {
            var ctx = _compositeQuickAdd.ParentContext.Value;
            var targetFieldId = _compositeQuickAdd.Model.Field.Id;

            // Find existing rule for this source+value+target combo
            var existingRule = _depRules.FirstOrDefault(r =>
                r.SourceFieldId == ctx.ParentFieldId
                && string.Equals(r.SourceValue, ctx.ParentValue, StringComparison.OrdinalIgnoreCase)
                && r.TargetFieldId == targetFieldId
                && r.RuleType == DependencyRuleType.FilterDropdownValues);

            if (existingRule is not null)
            {
                // Append to existing constraint
                var existingValues = existingRule.TargetConstraint?
                    .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                    .ToList() ?? [];

                if (!existingValues.Contains(newValue, StringComparer.OrdinalIgnoreCase))
                {
                    existingValues.Add(newValue);
                    var updatedConstraint = string.Join(",", existingValues);
                    await DepRuleService.UpdateAsync(TrackedActionId, existingRule.Id,
                        new UpdateFieldDependencyRuleRequest(
                            TargetConstraint: updatedConstraint));
                }
            }
            else
            {
                // Create new rule
                await DepRuleService.CreateAsync(TrackedActionId,
                    new CreateFieldDependencyRuleRequest(
                        ctx.ParentFieldId,
                        ctx.ParentValue,
                        targetFieldId,
                        DependencyRuleType.FilterDropdownValues,
                        newValue));
            }

            // Reload dependency rules
            try { _depRules = await DepRuleService.GetByTrackedActionAsync(TrackedActionId); } catch { }
        }

        // 3. Refresh composite dropdown sources and re-evaluate
        _cachedFieldDefinitions = await FieldDefService.GetAllAsync();
        await ResolveCompositeDropdownsAsync();
        EvaluateDependencyRules();

        // 4. Auto-select the new value
        _compositeQuickAdd.Model.TextValue = newValue;
        EvaluateDependencyRules(); // re-evaluate for downstream deps

        _compositeQuickAdd = null;
    }

    private sealed record CompositeSourceOption(Guid Id, string Name);

    private sealed class CompositeQuickAddState
    {
        public required EntryFieldModel Model { get; init; }
        public required List<CompositeSourceOption> SourceOptions { get; init; }
        public Guid SelectedSourceId { get; set; }
        public string NewValue { get; set; } = string.Empty;
        public bool LinkDependency { get; set; }
        public bool Saving { get; set; }
        public bool IsCreatingNewSource { get; set; }
        public string NewSourceName { get; set; } = string.Empty;
        public (Guid ParentFieldId, string ParentFieldName, string ParentValue)? ParentContext { get; init; }
        public bool IsValid =>
            (IsCreatingNewSource ? !string.IsNullOrWhiteSpace(NewSourceName) : SelectedSourceId != Guid.Empty)
            && !string.IsNullOrWhiteSpace(NewValue);
    }

    // ── Inline new dropdown field ──

    private NewFieldInlineState? _newFieldInline;
    private IReadOnlyList<string> _newFieldErrors = [];

    private void OpenNewFieldInline()
    {
        _newFieldInline = new NewFieldInlineState();
        _newFieldErrors = [];
    }

    private void CloseNewFieldInline()
    {
        _newFieldInline = null;
        _newFieldErrors = [];
    }

    private async Task SaveNewFieldInlineAsync()
    {
        if (_newFieldInline is null || !_newFieldInline.IsValid) return;

        _newFieldInline.Saving = true;
        _newFieldErrors = [];

        var (fdOk, created, fdErrs) = await FieldDefService.CreateWithResultAsync(
            new CreateFieldDefinitionRequest(
                _newFieldInline.Name.Trim(),
                FieldType.Dropdown,
                DropdownValues: string.Join(",", _newFieldInline.ParsedValues)));

        if (!fdOk || created is null)
        {
            _newFieldErrors = fdErrs.Count > 0 ? fdErrs : [L["Common_ErrorOccurred"]];
            _newFieldInline.Saving = false;
            return;
        }

        var nextOrder = _fieldModels.Count;
        var (afOk, afErrs) = await FieldService.CreateAsync(TrackedActionId,
            new CreateActionFieldRequest(created.Id, created.DefaultName, Order: nextOrder));

        if (!afOk)
        {
            _newFieldErrors = afErrs.Count > 0 ? afErrs : [L["Common_ErrorOccurred"]];
            _newFieldInline.Saving = false;
            return;
        }

        var allFields = await FieldService.GetByTrackedActionAsync(TrackedActionId);
        var newActionField = allFields.FirstOrDefault(f => f.FieldDefinitionId == created.Id);

        if (newActionField is not null)
        {
            if (_newFieldInline.ParentFieldId != Guid.Empty)
            {
                var parentModel = _fieldModels.FirstOrDefault(m => m.Field.Id == _newFieldInline.ParentFieldId);
                if (parentModel is not null && !string.IsNullOrEmpty(parentModel.TextValue))
                {
                    await DepRuleService.CreateAsync(TrackedActionId,
                        new CreateFieldDependencyRuleRequest(
                            _newFieldInline.ParentFieldId,
                            parentModel.TextValue,
                            newActionField.Id,
                            DependencyRuleType.FilterDropdownValues,
                            string.Join(",", _newFieldInline.ParsedValues),
                            _depRules.Count));
                    try { _depRules = await DepRuleService.GetByTrackedActionAsync(TrackedActionId); } catch { }
                }
            }

            _fieldModels.Add(new EntryFieldModel { Field = newActionField });
            EvaluateDependencyRules();
        }

        _newFieldInline = null;
    }

    private sealed class NewFieldInlineState
    {
        public string Name { get; set; } = string.Empty;
        public string DropdownValues { get; set; } = string.Empty;
        public Guid ParentFieldId { get; set; }
        public bool Saving { get; set; }

        public string[] ParsedValues => DropdownValues
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray();

        public bool IsValid => !string.IsNullOrWhiteSpace(Name) && ParsedValues.Length > 0;
    }
}
