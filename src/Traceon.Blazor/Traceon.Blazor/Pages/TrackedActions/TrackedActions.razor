@page "/tracked-actions"
@attribute [Authorize]

<PageTitle>Tracked Actions - Traceon</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-1">
            <i class="bi bi-list-check me-2"></i>
            Tracked Actions
        </h3>
        <p class="text-muted mb-0">Manage your tracked actions and monitor progress</p>
    </div>
</div>

@if (_errors.Count > 0)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <ul class="mb-0 d-inline">
            @foreach (var error in _errors)
            {
                <li>@error</li>
            }
        </ul>
        <button type="button" class="btn-close" @onclick="() => _errors = []"></button>
    </div>
}

<DataGrid @ref="_grid"
          TItem="TrackedActionResponse"
          LoadData="LoadDataAsync"
          Columns="_columns"
          FilterPlaceholder="Filter by name or description..."
          EmptyText="No tracked actions yet. Create one to get started!">
    <Toolbar>
        <a href="/tracked-actions/create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i> New Action
        </a>
    </Toolbar>
    <RowActions>
        <ListActionsDropdown PrimaryText="Edit"
                             PrimaryIcon="pencil-square"
                             PrimaryButtonStyle="primary"
                             PrimaryAction="() => EditAction(context.Id)"
                             Actions="GetActions(context)" />
    </RowActions>
</DataGrid>

@code {
    [Inject] private TrackedActionService Service { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private DataGrid<TrackedActionResponse> _grid = default!;
    private IReadOnlyList<string> _errors = [];

    private static readonly List<DataGridColumn<TrackedActionResponse>> _columns =
    [
        new() { Title = "Name", Selector = x => x.Name, SortField = "Name" },
        new() { Title = "Description", Selector = x => x.Description },
        new()
        {
            Title = "Tags",
            Selector = x => x.Tags.Count,
            Template = item => builder =>
            {
                if (item.Tags.Count == 0)
                {
                    builder.OpenElement(0, "span");
                    builder.AddAttribute(1, "class", "text-muted");
                    builder.AddContent(2, "\u2014");
                    builder.CloseElement();
                    return;
                }

                builder.OpenElement(3, "div");
                builder.AddAttribute(4, "class", "d-flex flex-wrap gap-1");
                var seq = 5;
                foreach (var tag in item.Tags)
                {
                    builder.OpenElement(seq++, "span");
                    builder.AddAttribute(seq++, "class", "badge rounded-pill");
                    builder.AddAttribute(seq++, "style", $"background-color: {tag.Color}");
                    builder.AddContent(seq++, tag.Name);
                    builder.CloseElement();
                }
                builder.CloseElement();
            }
        },
        new()
        {
            Title = "Fields",
            Selector = x => x.FieldCount,
            Template = item => builder =>
            {
                builder.OpenElement(0, "span");
                builder.AddAttribute(1, "class", "badge bg-secondary bg-opacity-10 text-secondary");
                builder.OpenElement(2, "i");
                builder.AddAttribute(3, "class", "bi bi-sliders me-1");
                builder.CloseElement();
                builder.AddContent(4, item.FieldCount);
                builder.CloseElement();
            }
        },
        new() { Title = "Created", Selector = x => x.CreatedAtUtc.ToLocalTime(), SortField = "CreatedAtUtc", Format = "g" },
    ];

    private Task<DataGridResult<TrackedActionResponse>> LoadDataAsync(DataGridRequest request)
        => Service.QueryAsync(request, ["Name", "Description"]);

    private List<ListAction> GetActions(TrackedActionResponse action)
    {
        return
        [
            ListAction.Link("Manage Fields", $"/tracked-actions/{action.Id}/fields", "sliders", ListActionStyle.Info),
            ListAction.Link("Manage Tags", $"/tracked-actions/{action.Id}/tags", "tags", ListActionStyle.Info),

            ListAction.Separator(),

            ListAction.Link("View Entries", $"/tracked-actions/{action.Id}/entries", "journal-text", ListActionStyle.Primary),
            ListAction.Link("New Entry", $"/tracked-actions/{action.Id}/entries/new", "plus-square", ListActionStyle.Success),

            ListAction.Separator(),

            ListAction.Button("Delete", () => DeleteAsync(action.Id), "trash", ListActionStyle.Danger),
        ];
    }

    private void EditAction(Guid id)
    {
        Nav.NavigateTo($"/tracked-actions/{id}/edit");
    }

    private async Task DeleteAsync(Guid id)
    {
        _errors = [];
        var (success, errors) = await Service.DeleteAsync(id);

        if (success)
            await _grid.RefreshAsync();
        else
            _errors = errors;
    }
}
