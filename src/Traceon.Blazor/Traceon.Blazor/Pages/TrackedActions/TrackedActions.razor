@page "/tracked-actions"
@attribute [Authorize]
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["TrackedActions_Title"] - Traceon</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-1">
            <i class="bi bi-list-check me-2"></i>
            @L["TrackedActions_Title"]
        </h3>
        <p class="text-muted mb-0">@L["TrackedActions_Subtitle"]</p>
    </div>
</div>

<ErrorAlert Errors="_errors" OnDismiss="() => _errors = []" />

<DataGrid @ref="_grid"
          TItem="TrackedActionResponse"
          LoadData="LoadDataAsync"
          Columns="_columns"
          DefaultSortField="SortOrder"
          FilterPlaceholder="@L["Filter_ByNameOrDesc"]"
          EmptyText="@L["TrackedActions_Empty"]">
    <Toolbar>
        <a href="/tracked-actions/create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i> @L["TrackedActions_New"]
        </a>
    </Toolbar>
    <RowActions>
        <ListActionsDropdown PrimaryText="@L["Common_Edit"]"
                             PrimaryIcon="pencil-square"
                             PrimaryButtonStyle="primary"
                             PrimaryAction="() => EditAction(context.Id)"
                             Actions="GetActions(context)"
                             OnAfterAction="StateHasChanged" />
    </RowActions>
</DataGrid>

@code {
    [Inject] private TrackedActionService Service { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private DataGrid<TrackedActionResponse> _grid = default!;
    private IReadOnlyList<string> _errors = [];

    private List<DataGridColumn<TrackedActionResponse>> _columns = [];

    protected override void OnInitialized()
    {
        _columns =
        [
            new() { Title = "#", Selector = x => x.SortOrder, SortField = "SortOrder", HideOnMobile = true },
            new() { Title = L["Common_Name"], Selector = x => x.Name, SortField = "Name", IsMobileTitle = true },
            new() { Title = L["Common_Description"], Selector = x => x.Description, HideOnMobile = true },
            new()
            {
                Title = L["Common_Fields"],
                Selector = x => x.FieldCount,
                Template = item => builder =>
                {
                    builder.OpenElement(0, "span");
                    builder.AddAttribute(1, "class", "badge bg-secondary bg-opacity-10 text-secondary");
                    builder.OpenElement(2, "i");
                    builder.AddAttribute(3, "class", "bi bi-sliders me-1");
                    builder.CloseElement();
                    builder.AddContent(4, item.FieldCount);
                    builder.CloseElement();
                },
                HideOnMobile = true
            },
            new()
            {
                Title = L["Common_Tags"],
                Selector = x => x.Tags.Count,
                Template = item => builder =>
                {
                    if (item.Tags.Count == 0)
                    {
                        builder.OpenElement(0, "span");
                        builder.AddAttribute(1, "class", "text-muted");
                        builder.AddContent(2, "\u2014");
                        builder.CloseElement();
                        return;
                    }

                    builder.OpenElement(3, "div");
                    builder.AddAttribute(4, "class", "d-flex flex-wrap gap-1");
                    var seq = 5;
                    foreach (var tag in item.Tags)
                    {
                        builder.OpenElement(seq++, "span");
                        builder.AddAttribute(seq++, "class", "badge rounded-pill");
                        builder.AddAttribute(seq++, "style", $"background-color: {tag.Color}");
                        builder.AddContent(seq++, tag.Name);
                        builder.CloseElement();
                    }
                    builder.CloseElement();
                }
            },
            new() { Title = L["Common_Entries"], Selector = x => x.EntryCount, SortField = "EntryCount" },
            new() { Title = L["Common_Created"], Selector = x => x.CreatedAtUtc.ToLocalTime(), SortField = "CreatedAtUtc", Format = "g", HideOnMobile = true },
        ];
    }

    private Task<DataGridResult<TrackedActionResponse>> LoadDataAsync(DataGridRequest request)
        => Service.QueryAsync(request, ["Name", "Description"]);

    private List<ListAction> GetActions(TrackedActionResponse action)
    {
        return
        [
            ListAction.Link(L["TrackedActions_Analytics"], $"/dashboard/action/{action.Id}/detail", "graph-up-arrow", ListActionStyle.Info),

            ListAction.Separator(),

            ListAction.Link(L["TrackedActions_ViewEntries"], $"/entries/action/{action.Id}", "journal-text", ListActionStyle.Primary),
            ListAction.Link(L["TrackedActions_NewEntry"], $"/tracked-actions/{action.Id}/entries/new?returnUrl=%2Ftracked-actions", "plus-square", ListActionStyle.Success),

            ListAction.Separator(),

            ListAction.Button(L["Common_Delete"], () => DeleteAsync(action.Id), "trash", ListActionStyle.Danger),
        ];
    }

    private void EditAction(Guid id)
    {
        Nav.NavigateTo($"/tracked-actions/{id}/edit");
    }

    private async Task DeleteAsync(Guid id)
    {
        _errors = [];
        var (success, errors) = await Service.DeleteAsync(id);

        if (success)
            await _grid.RefreshAsync();
        else
            _errors = errors;
    }
}
