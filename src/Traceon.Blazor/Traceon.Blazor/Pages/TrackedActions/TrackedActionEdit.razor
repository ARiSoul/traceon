    private async Task LoadReceiptConfigAsync()
    {
        try
        {
            _receiptConfig = await ReceiptConfigService.GetByActionAsync(Id);
            if (_receiptConfig is not null)
            {
                _rcptMappingRules = await ReceiptConfigService.GetMappingRulesAsync(Id);
            }
            else
            {
                _rcptMappingRules = [];
            }

            BuildRcptFieldMappings();
        }
        catch { _receiptConfig = null; _rcptMappingRules = []; _rcptFieldMappings = []; }
    }

    private void BuildRcptFieldMappings()
    {
        // Build one ReceiptFieldMapping per action field
        _rcptFieldMappings = _fields.Select(f => new ReceiptFieldMapping
        {
            FieldId = f.Id,
            FieldName = f.Name,
            FieldType = f.FieldType,
            Source = ReceiptFieldMappingSource.None
        }).ToList();

        // Build resolved dropdown options
        _rcptDropdownOptions = [];
        foreach (var f in _fields.Where(f => f.FieldType is FieldType.Dropdown or FieldType.CompositeDropdown))
        {
            var values = GetFieldDropdownValues(f.Id);
            if (values.Length > 0)
                _rcptDropdownOptions[f.Id] = [.. values];
        }

        if (_receiptConfig is not null)
        {
            // Apply existing config
            void SetSource(Guid? fieldId, ReceiptFieldMappingSource source)
            {
                if (fieldId is null) return;
                var fm = _rcptFieldMappings.FirstOrDefault(f => f.FieldId == fieldId.Value);
                if (fm is not null) fm.Source = source;
            }

            SetSource(_receiptConfig.TotalFieldId, ReceiptFieldMappingSource.ReceiptTotal);
            SetSource(_receiptConfig.QuantityFieldId, ReceiptFieldMappingSource.ReceiptQuantity);
            SetSource(_receiptConfig.UnitPriceFieldId, ReceiptFieldMappingSource.ReceiptUnitPrice);
            SetSource(_receiptConfig.DescriptionFieldId, ReceiptFieldMappingSource.ReceiptDescription);
            SetSource(_receiptConfig.ShopFieldId, ReceiptFieldMappingSource.MerchantName);
            SetSource(_receiptConfig.DiscountFieldId, ReceiptFieldMappingSource.ReceiptDiscount);

            _rcptDiscountTypeFieldId = _receiptConfig.ReceiptDiscountTypeFieldId;
            _rcptDiscountTypeValue = _receiptConfig.ReceiptDiscountTypeValue;

            // Restore fixed-value mappings from JSON
            if (!string.IsNullOrEmpty(_receiptConfig.StaticFieldValues))
            {
                try
                {
                    var dict = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, string>>(_receiptConfig.StaticFieldValues, _jsonOpts);
                    if (dict is not null)
                    {
                        foreach (var (key, val) in dict)
                        {
                            if (Guid.TryParse(key, out var fid))
                            {
                                var fm = _rcptFieldMappings.FirstOrDefault(f => f.FieldId == fid);
                                if (fm is not null && fm.Source == ReceiptFieldMappingSource.None)
                                {
                                    fm.Source = ReceiptFieldMappingSource.FixedValue;
                                    fm.FixedValue = val;
                                }
                            }
                        }
                    }
                }
                catch { /* ignore malformed JSON */ }
            }
        }
        else
        {
            // Auto-detect: if only one numeric field, map it to Total
            var numFields = _fields.Where(f => f.FieldType is FieldType.Decimal or FieldType.Integer).ToList();
            if (numFields.Count == 1)
            {
                var fm = _rcptFieldMappings.FirstOrDefault(f => f.FieldId == numFields[0].Id);
                if (fm is not null) fm.Source = ReceiptFieldMappingSource.ReceiptTotal;
            }

            _rcptDiscountTypeFieldId = null;
            _rcptDiscountTypeValue = null;
        }
    }

    private void OnRcptFieldMappingChanged(ReceiptFieldMapping _) => StateHasChanged();

    private void OnReceiptDiscountTypeFieldChanged(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString();
        if (string.IsNullOrWhiteSpace(raw) || !Guid.TryParse(raw, out var fieldId))
        {
            _rcptDiscountTypeFieldId = null;
            _rcptDiscountTypeValue = null;
            return;
        }

        _rcptDiscountTypeFieldId = fieldId;

        if (_rcptDiscountTypeValue is not null
            && _rcptDropdownOptions.TryGetValue(fieldId, out var options)
            && options.Count > 0
            && !options.Contains(_rcptDiscountTypeValue, StringComparer.OrdinalIgnoreCase))
        {
            _rcptDiscountTypeValue = null;
        }
    }

    private async Task EnableReceiptImportAsync()
    {
        _savingRcptCfg = true;
        var numFields = _fields.Where(f => f.FieldType is FieldType.Decimal or FieldType.Integer).ToList();
        var totalId = numFields.Count == 1 ? numFields[0].Id : (Guid?)null;

        var (ok, _) = await ReceiptConfigService.UpsertAsync(Id, new UpdateReceiptImportConfigRequest(TotalFieldId: totalId));
        if (ok) await LoadReceiptConfigAsync();
        _savingRcptCfg = false;
    }

    private async Task SaveReceiptConfigAsync()
    {
        _savingRcptCfg = true;
        _errors = [];

        Guid? FindFieldWithSource(ReceiptFieldMappingSource source) =>
            _rcptFieldMappings.FirstOrDefault(f => f.Source == source)?.FieldId;

        // Collect fixed-value mappings into a JSON dictionary
        var fixedDict = _rcptFieldMappings
            .Where(f => f.Source == ReceiptFieldMappingSource.FixedValue && !string.IsNullOrEmpty(f.FixedValue))
            .ToDictionary(f => f.FieldId.ToString(), f => f.FixedValue!);
        var staticJson = fixedDict.Count > 0
            ? System.Text.Json.JsonSerializer.Serialize(fixedDict)
            : null;

        var (ok, errs) = await ReceiptConfigService.UpsertAsync(Id, new UpdateReceiptImportConfigRequest(
            ShopFieldId: FindFieldWithSource(ReceiptFieldMappingSource.MerchantName),
            DescriptionFieldId: FindFieldWithSource(ReceiptFieldMappingSource.ReceiptDescription),
            TotalFieldId: FindFieldWithSource(ReceiptFieldMappingSource.ReceiptTotal),
            QuantityFieldId: FindFieldWithSource(ReceiptFieldMappingSource.ReceiptQuantity),
            UnitPriceFieldId: FindFieldWithSource(ReceiptFieldMappingSource.ReceiptUnitPrice),
            DiscountFieldId: FindFieldWithSource(ReceiptFieldMappingSource.ReceiptDiscount),
            ReceiptDiscountTypeFieldId: _rcptDiscountTypeFieldId,
            ReceiptDiscountTypeValue: _rcptDiscountTypeValue,
            StaticFieldValues: staticJson));

        if (!ok) _errors = errs;
        else await LoadReceiptConfigAsync();
        _savingRcptCfg = false;
    }

