                                                    && targetField.DropdownValues.StartsWith("ref:", StringComparison.Ordinal))
                                                {
                                                    <SearchableSelect Value="@mapping.StaticValue"
                                                                      ValueChanged="v => mapping.StaticValue = v"
                                                                      Groups="@ResolveCompositeGroupsForCondition(targetField)"
                                                                      Placeholder="@L["Entry_Select"]"
                                                                      Small="true" />
                                                }
                                                else
                                                {
                                                    <input type="text" class="form-control form-control-sm" @bind="mapping.StaticValue" />
                                                }
                                            </div>
                                        }
                                        else
                                        @* Conditional *@
                                        {
                                            <div class="col-6 col-md-4">
                                                <label class="form-label form-label-sm mb-1">@L["ConnAct_SourceField"]</label>
                                                <select class="form-select form-select-sm" @bind="mapping.SourceFieldId">
                                                    <option value="@Guid.Empty">@L["ConnAct_SelectField"]</option>
                                                    @foreach (var f in _connSourceFields)
                                                    {
                                                        <option value="@f.Id">@f.Name (@f.FieldType)</option>
                                                    }
                                                </select>
                                            </div>
                                        }
                                        <div class="col-auto">
                                            <button class="btn btn-outline-danger btn-sm" type="button" @onclick="() => _connRuleEditing.Mappings.RemoveAt(mIdx)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </div>

                                    @* ── Conditional value pairs ── *@
                                    @if (mapping.Mode == "Conditional")
                                    {
                                        var srcField = _connSourceFields.FirstOrDefault(f => f.Id == mapping.SourceFieldId);
                                        var tgtField = _connTargetFields.FirstOrDefault(f => f.Id == mapping.TargetFieldId);

                                        <div class="mt-2 ps-3 border-start border-primary border-2">
                                            @for (var vi = 0; vi < mapping.ValueMappings.Count; vi++)
                                            {
                                                var vIdx = vi;
                                                var pair = mapping.ValueMappings[vIdx];
                                                <div class="row g-2 mb-1 align-items-center">
                                                    <div class="col-5">
                                                        @if (srcField is not null && IsDropdownLike(srcField))
                                                        {
                                                            @if (srcField.FieldType == FieldType.CompositeDropdown
                                                                                                                                                                                    && !string.IsNullOrWhiteSpace(srcField.DropdownValues)
                                                                                                                                                                                    && srcField.DropdownValues.StartsWith("ref:", StringComparison.Ordinal))
                                                            {
                                                                <SearchableSelect Value="@pair.WhenValue"
                                                                                  ValueChanged="v => pair.WhenValue = v ?? string.Empty"
                                                                                  Groups="@ResolveCompositeGroupsForCondition(srcField)"
                                                                                  Placeholder="@L["ConnAct_WhenValue"]"
                                                                                  Small="true" />
                                                            }
                                                            else
                                                            {
                                                                <SearchableSelect Value="@pair.WhenValue"
                                                                                  ValueChanged="v => pair.WhenValue = v ?? string.Empty"
                                                                                  Options="@(GetDropdownOptions(srcField))"
                                                                                  Placeholder="@L["ConnAct_WhenValue"]"
                                                                                  Small="true" />
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <input type="text" class="form-control form-control-sm" placeholder="@L["ConnAct_WhenValue"]" @bind="pair.WhenValue" />
                                                        }
                                                    </div>
                                                    <div class="col-auto text-muted"><i class="bi bi-arrow-right"></i></div>
                                                    <div class="col-5">
                                                        @if (tgtField is not null && IsDropdownLike(tgtField))
                                                        {
                                                            @if (tgtField.FieldType == FieldType.CompositeDropdown
                                                                                                                                                                                    && !string.IsNullOrWhiteSpace(tgtField.DropdownValues)
                                                                                                                                                                                    && tgtField.DropdownValues.StartsWith("ref:", StringComparison.Ordinal))
                                                            {
                                                                <SearchableSelect Value="@pair.ThenValue"
                                                                                  ValueChanged="v => pair.ThenValue = v ?? string.Empty"
                                                                                  Groups="@ResolveCompositeGroupsForCondition(tgtField)"
                                                                                  Placeholder="@L["ConnAct_ThenValue"]"
                                                                                  Small="true" />
                                                            }
                                                            else
                                                            {
                                                                <SearchableSelect Value="@pair.ThenValue"
                                                                                  ValueChanged="v => pair.ThenValue = v ?? string.Empty"
                                                                                  Options="@(GetDropdownOptions(tgtField))"
                                                                                  Placeholder="@L["ConnAct_ThenValue"]"
                                                                                  Small="true" />
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <input type="text" class="form-control form-control-sm" placeholder="@L["ConnAct_ThenValue"]" @bind="pair.ThenValue" />
                                                        }
                                                    </div>
                                                    <div class="col-auto">
                                                        <button class="btn btn-outline-danger btn-sm py-0" type="button" @onclick="() => mapping.ValueMappings.RemoveAt(vIdx)">
                                                            <i class="bi bi-x-lg"></i>
                                                        </button>
                                                    </div>
                                                </div>
                                            }
                                            <button class="btn btn-outline-secondary btn-sm mt-1" type="button"
                                                    @onclick="() => mapping.ValueMappings.Add(new ConnValuePairModel())">
                                                <i class="bi bi-plus-lg me-1"></i>@L["ConnAct_AddValuePair"]
                                            </button>
                                        </div>
                                    }
                                </div>
                            }
                        </details>
                    </div>

                    <!-- Reverse Extra Mappings (shown when bidirectional) -->
                    @if (_connRuleEditing.IsBidirectional && _connSourceFields.Count > 0)
                    {
                        var reversedTargetFieldIds = _connRuleEditing.Mappings
                            .Where(m => m.Mode is "Source" or "Conditional" && m.SourceFieldId != Guid.Empty)
                            .Select(m => m.SourceFieldId)
                            .ToHashSet();

                        var unmappedSourceFields = _connSourceFields
                            .Where(f => !reversedTargetFieldIds.Contains(f.Id))
                            .ToList();

                        if (unmappedSourceFields.Count > 0)
                        {
                            <div class="col-12">
                                <details open>
                                    <summary class="fw-semibold mb-2">
                                        <i class="bi bi-arrow-return-left me-1"></i>@L["ConnAct_ReverseExtraMappings"]
                                    </summary>
                                    <div class="form-text mb-2">@L["ConnAct_ReverseExtraMappingsHint"]</div>
                                    @foreach (var field in unmappedSourceFields)
                                    {
                                        var revMap = _connRuleEditing.ReverseMappings.FirstOrDefault(r => r.SourceFieldId == field.Id);
                                        if (revMap is null)
                                        {
                                            revMap = new ConnReverseMappingModel { SourceFieldId = field.Id, FieldName = field.Name };
                                            _connRuleEditing.ReverseMappings.Add(revMap);
                                        }
                                        var capturedRevMap = revMap;
                                        <div class="row g-2 mb-2 align-items-center">
                                            <div class="col-12 col-md-5">
                                                <span class="text-muted small">@field.Name</span>
                                            </div>
                                            <div class="col-12 col-md-7">
                                                @if (IsDropdownLike(field))
                                                {
                                                    <SearchableSelect Value="@capturedRevMap.Value"
                                                                      ValueChanged="v => capturedRevMap.Value = v ?? string.Empty"
                                                                      Options="@GetDropdownOptions(field)"
                                                                      Placeholder="@L["Entry_Select"]"
                                                                      Small="true" />
                                                }
                                                else
                                                {
                                                    <input type="text" class="form-control form-control-sm"
                                                           @bind="capturedRevMap.Value"
                                                           placeholder="@L["ConnAct_StaticValue"]" />
                                                }
                                            </div>
                                        </div>
                                    }
                                </details>
                            </div>
                        }
                    }
                </div>

                @if (_connRuleErrors.Count > 0)
                {
                    <div class="text-danger small mt-2">@string.Join(", ", _connRuleErrors)</div>
                }

                <div class="d-flex justify-content-end gap-2 mt-3">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => _connRuleEditing = null">
                        @L["Common_Cancel"]
                    </button>
                    <button class="btn btn-success btn-sm" @onclick="SaveConnectedRuleAsync" disabled="@_savingConnRule">
                        @if (_savingConnRule)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-check-circle me-1"></i>@L["Common_Save"]
                    </button>
                </div>
            </div>
        </div>
    };
}
