    private List<(string GroupName, string[] Values)> ResolveCompositeGroupsForCondition(ActionFieldResponse field)
    {
        if (string.IsNullOrWhiteSpace(field.DropdownValues)
            || !field.DropdownValues.StartsWith("ref:", StringComparison.Ordinal))
            return [];

        var refIds = field.DropdownValues["ref:".Length..]
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(s => Guid.TryParse(s, out var id) ? id : Guid.Empty)
            .Where(id => id != Guid.Empty)
            .ToList();

        var groups = new List<(string GroupName, string[] Values)>();
        foreach (var refId in refIds)
        {
            var fd = _allFieldDefinitions.FirstOrDefault(d => d.Id == refId);
            if (fd is not null && !string.IsNullOrWhiteSpace(fd.DropdownValues))
            {
                var values = DropdownValuesHelper.Split(fd.DropdownValues)
                    .OrderBy(v => v, StringComparer.CurrentCultureIgnoreCase)
                    .ToArray();
                groups.Add((fd.DefaultName, values));
            }
        }

        return groups.OrderBy(g => g.GroupName, StringComparer.CurrentCultureIgnoreCase).ToList();
    }

    private static bool IsDropdownLike(ActionFieldResponse field)
        => field.FieldType is FieldType.Dropdown or FieldType.CompositeDropdown
           && !string.IsNullOrWhiteSpace(field.DropdownValues);

    private List<KeyValuePair<string, string>> GetOperatorsForField(ActionFieldResponse? field)
    {
        var ops = new List<KeyValuePair<string, string>>
        {
            new("Equals", L["ConnAct_OpEquals"]),
            new("NotEquals", L["ConnAct_OpNotEquals"]),
            new("In", L["ConnAct_OpIn"]),
            new("NotIn", L["ConnAct_OpNotIn"])
        };

        var isNumeric = field?.FieldType is FieldType.Integer or FieldType.Decimal;
        var isDateTime = field?.FieldType == FieldType.Date;
        var isText = field is null || field.FieldType is FieldType.Text or FieldType.Dropdown or FieldType.CompositeDropdown;

        if (isText)
        {
            ops.Add(new("Contains", L["ConnAct_OpContains"]));
            ops.Add(new("NotContains", L["ConnAct_OpNotContains"]));
        }

        if (isNumeric || isDateTime)
        {
            ops.Add(new("GreaterThan", L["ConnAct_OpGreaterThan"]));
            ops.Add(new("GreaterThanOrEqual", L["ConnAct_OpGreaterThanOrEqual"]));
            ops.Add(new("LessThan", L["ConnAct_OpLessThan"]));
            ops.Add(new("LessThanOrEqual", L["ConnAct_OpLessThanOrEqual"]));
            ops.Add(new("Between", L["ConnAct_OpBetween"]));
        }

        ops.Add(new("IsEmpty", L["ConnAct_OpIsEmpty"]));
        ops.Add(new("IsNotEmpty", L["ConnAct_OpIsNotEmpty"]));

        return ops;
    }

    private static List<string> GetDropdownOptions(ActionFieldResponse field)
        => string.IsNullOrWhiteSpace(field.DropdownValues) || field.DropdownValues.StartsWith("ref:", StringComparison.Ordinal)
            ? []
            : DropdownValuesHelper.Split(field.DropdownValues)
                .OrderBy(v => v, StringComparer.CurrentCultureIgnoreCase)
                .ToList();

    private List<string> GetConditionDropdownOptions(ActionFieldResponse? field)
    {
        if (field is null) return [];
        if (field.FieldType == FieldType.Dropdown
            && !string.IsNullOrWhiteSpace(field.DropdownValues)
            && !field.DropdownValues.StartsWith("ref:", StringComparison.Ordinal))
        {
            return DropdownValuesHelper.Split(field.DropdownValues)
                .OrderBy(v => v, StringComparer.CurrentCultureIgnoreCase)
                .ToList();
        }
        if (field.FieldType == FieldType.CompositeDropdown
            && !string.IsNullOrWhiteSpace(field.DropdownValues)
            && field.DropdownValues.StartsWith("ref:", StringComparison.Ordinal))
        {
            return ResolveCompositeGroupsForCondition(field)
                .SelectMany(g => g.Values)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(v => v, StringComparer.CurrentCultureIgnoreCase)
                .ToList();
        }
        return [];
    }

    private static HashSet<string> ParseInValues(string? value)
        => string.IsNullOrWhiteSpace(value)
            ? []
            : value.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);

    private static void ToggleInValue(ConnConditionModel cond, string value)
    {
        var current = ParseInValues(cond.Value);
        if (!current.Remove(value))
            current.Add(value);
        cond.Value = current.Count > 0 ? string.Join(",", current.OrderBy(v => v, StringComparer.OrdinalIgnoreCase)) : string.Empty;
    }

    private void AddConnMapping()
    {
        _connRuleEditing?.Mappings.Add(new ConnMappingModel());
    }

    private async Task SaveConnectedRuleAsync()
    {
        if (_connRuleEditing is null) return;

        _connRuleErrors = [];

        if (string.IsNullOrWhiteSpace(_connRuleEditing.Name))
        {
            _connRuleErrors = [L["Wizard_NameRequired"]];
            return;
        }
        if (_connRuleEditing.TargetTrackedActionId == Guid.Empty)
        {
            _connRuleErrors = [L["ConnAct_TargetAction"]];
            return;
        }

        _savingConnRule = true;

        var conditionsJson = SerializeConditions(_connRuleEditing.Conditions);
        var mappingsJson = SerializeMappings(_connRuleEditing.Mappings);
        var reverseExtraMappingsJson = _connRuleEditing.IsBidirectional
            ? SerializeReverseExtraMappings(_connRuleEditing.ReverseMappings)
            : null;

        bool success;
        IReadOnlyList<string> errors;

        if (_connRuleEditing.Id.HasValue)
        {
            (success, errors) = await ConnRuleService.UpdateAsync(_connRuleEditing.SourceTrackedActionId, _connRuleEditing.Id.Value,
                new UpdateConnectedActionRuleRequest(
                    Name: _connRuleEditing.Name,
                    IsEnabled: _connRuleEditing.IsEnabled,
                    ConditionsJson: conditionsJson,
                    FieldMappingsJson: mappingsJson,
                    CopyNotes: _connRuleEditing.CopyNotes,
                    CopyDate: _connRuleEditing.CopyDate,
                    IsBidirectional: _connRuleEditing.IsBidirectional,
                    ReverseExtraMappingsJson: reverseExtraMappingsJson));
        }
        else
        {
            (success, errors) = await ConnRuleService.CreateAsync(_connRuleEditing.SourceTrackedActionId,
                new CreateConnectedActionRuleRequest(
                    TargetTrackedActionId: _connRuleEditing.TargetTrackedActionId,
                    Name: _connRuleEditing.Name,
                    IsEnabled: _connRuleEditing.IsEnabled,
                    ConditionsJson: conditionsJson,
                    FieldMappingsJson: mappingsJson,
                    CopyNotes: _connRuleEditing.CopyNotes,
                    CopyDate: _connRuleEditing.CopyDate,
                    IsBidirectional: _connRuleEditing.IsBidirectional,
                    ReverseExtraMappingsJson: reverseExtraMappingsJson));
        }

        if (success)
        {
            _connectedRules = await ConnRuleService.GetByTrackedActionAsync(Id);
            _connRuleEditing = null;
        }
        else
        {
            _connRuleErrors = errors.Count > 0 ? errors : [L["Common_ErrorOccurred"]];
        }

        _savingConnRule = false;
    }

    private async Task DeleteConnectedRuleAsync(ConnectedActionRuleResponse rule)
    {
        string message;
        if (rule.PairedRuleId.HasValue)
        {
            message = L["ConnAct_DeleteBothConfirm"];
        }
        else
        {
            message = L["ConnAct_DeleteConfirm"];
        }

        var confirmed = await JS.InvokeAsync<bool>("confirm", message);
        if (!confirmed) return;

        var (success, _) = await ConnRuleService.DeleteAsync(rule.SourceTrackedActionId, rule.Id);
        if (success)
            _connectedRules = await ConnRuleService.GetByTrackedActionAsync(Id);
    }

    // JSON helpers for conditions/mappings
    private static string? SerializeConditions(List<ConnConditionModel> conditions)
    {
        var valid = conditions.Where(c => c.SourceFieldId != Guid.Empty
            && (c.Operator is "IsEmpty" or "IsNotEmpty" || !string.IsNullOrWhiteSpace(c.Value))).ToList();
        if (valid.Count == 0) return null;
        return System.Text.Json.JsonSerializer.Serialize(valid.Select(c => new
        {
            sourceFieldId = c.SourceFieldId,
            @operator = c.Operator,
            value = c.Value,
            value2 = c.Operator == "Between" ? c.Value2 : null
        }));
    }

    private static string? SerializeMappings(List<ConnMappingModel> mappings)
    {
        var valid = mappings.Where(m => m.TargetFieldId != Guid.Empty).ToList();
        if (valid.Count == 0) return null;
        return System.Text.Json.JsonSerializer.Serialize(valid.Select(m => new
        {
            targetFieldId = m.TargetFieldId,
            mode = m.Mode,
            sourceFieldId = m.SourceFieldId,
            staticValue = m.StaticValue,
            valueMappings = m.Mode == "Conditional" && m.ValueMappings.Count > 0
                ? m.ValueMappings
                    .Where(vm => !string.IsNullOrWhiteSpace(vm.WhenValue))
                    .Select(vm => new { when = vm.WhenValue, then = vm.ThenValue })
                    .ToList()
                : null
        }));
    }

    private static string? SerializeReverseExtraMappings(List<ConnReverseMappingModel> reverseMappings)
    {
        var valid = reverseMappings.Where(r => r.SourceFieldId != Guid.Empty && !string.IsNullOrWhiteSpace(r.Value)).ToList();
        if (valid.Count == 0) return null;
        return System.Text.Json.JsonSerializer.Serialize(valid.Select(r => new
        {
            targetFieldId = r.SourceFieldId,
            mode = "Static",
            staticValue = r.Value
        }));
    }

    private static List<ConnConditionModel> DeserializeConditions(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) return [];
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            return doc.RootElement.EnumerateArray().Select(el => new ConnConditionModel
            {
                SourceFieldId = el.TryGetProperty("sourceFieldId", out var sf) && Guid.TryParse(sf.GetString(), out var sfId) ? sfId : Guid.Empty,
                Operator = el.TryGetProperty("operator", out var op) ? op.GetString() ?? "Equals" : "Equals",
                Value = el.TryGetProperty("value", out var v) ? v.GetString() ?? "" : "",
                Value2 = el.TryGetProperty("value2", out var v2) ? v2.GetString() ?? "" : ""
            }).ToList();
        }
        catch { return []; }
    }

    private static List<ConnMappingModel> DeserializeMappings(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) return [];
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            return doc.RootElement.EnumerateArray().Select(el =>
            {
                var model = new ConnMappingModel
                {
                    TargetFieldId = el.TryGetProperty("targetFieldId", out var tf) && Guid.TryParse(tf.GetString(), out var tfId) ? tfId : Guid.Empty,
                    Mode = el.TryGetProperty("mode", out var m) ? m.GetString() ?? "Source" : "Source",
                    SourceFieldId = el.TryGetProperty("sourceFieldId", out var sf) && Guid.TryParse(sf.GetString(), out var sfId) ? sfId : Guid.Empty,
                    StaticValue = el.TryGetProperty("staticValue", out var sv) ? sv.GetString() : null
                };

                if (el.TryGetProperty("valueMappings", out var vmArr) && vmArr.ValueKind == System.Text.Json.JsonValueKind.Array)
                {
                    model.ValueMappings = vmArr.EnumerateArray().Select(vm => new ConnValuePairModel
                    {
                        WhenValue = vm.TryGetProperty("when", out var w) ? w.GetString() ?? "" : "",
                        ThenValue = vm.TryGetProperty("then", out var t) ? t.GetString() ?? "" : ""
                    }).ToList();
                }

                return model;
            }).ToList();
        }
        catch { return []; }
    }

