    private async Task OpenConnectedRuleFormAsync(ConnectedActionRuleResponse? existing)
    {
        _connRuleErrors = [];
        if (existing is not null)
        {
            _connRuleEditing = new ConnRuleEditModel
            {
                Id = existing.Id,
                SourceTrackedActionId = existing.SourceTrackedActionId,
                Name = existing.Name,
                TargetTrackedActionId = existing.TargetTrackedActionId,
                IsEnabled = existing.IsEnabled,
                CopyDate = existing.CopyDate,
                CopyNotes = existing.CopyNotes,
                IsBidirectional = existing.PairedRuleId.HasValue,
                Conditions = DeserializeConditions(existing.ConditionsJson),
                Mappings = DeserializeMappings(existing.FieldMappingsJson)
            };
            await LoadConnEditorFieldsAsync(existing.SourceTrackedActionId, existing.TargetTrackedActionId);

            // Load reverse extra mappings from paired rule
            if (existing.PairedRuleId.HasValue)
            {
                var pairedRule = _connectedRules.FirstOrDefault(r => r.Id == existing.PairedRuleId.Value);
                if (pairedRule is not null)
                {
                    var pairedMappings = DeserializeMappings(pairedRule.FieldMappingsJson);
                    var reversedTargetFieldIds = _connRuleEditing.Mappings
                        .Where(m => m.Mode is "Source" or "Conditional" && m.SourceFieldId != Guid.Empty)
                        .Select(m => m.SourceFieldId)
                        .ToHashSet();

                    _connRuleEditing.ReverseMappings = pairedMappings
                        .Where(m => m.Mode == "Static" && m.TargetFieldId != Guid.Empty
                                    && !reversedTargetFieldIds.Contains(m.TargetFieldId))
                        .Select(m =>
                        {
                            var field = _connSourceFields.FirstOrDefault(f => f.Id == m.TargetFieldId);
                            return new ConnReverseMappingModel
                            {
                                SourceFieldId = m.TargetFieldId,
                                FieldName = field?.Name ?? "?",
                                Value = m.StaticValue ?? string.Empty
                            };
                        })
                        .ToList();
                }
            }
        }
        else
        {
            _connRuleEditing = new ConnRuleEditModel { SourceTrackedActionId = Id };
            _connSourceFields = _fields.ToList();
            _connTargetFields = [];
        }
    }

    private async Task OnConnTargetActionChanged(ChangeEventArgs e)
    {
        if (_connRuleEditing is null) return;

        _connRuleEditing.TargetTrackedActionId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : Guid.Empty;
        _connRuleEditing.Mappings.Clear();
        await LoadConnEditorFieldsAsync(_connRuleEditing.SourceTrackedActionId, _connRuleEditing.TargetTrackedActionId);
    }

    private async Task LoadConnEditorFieldsAsync(Guid sourceActionId, Guid targetActionId)
    {
        var loadVersion = ++_connEditorLoadVersion;

        var sourceTask = sourceActionId == Id
            ? Task.FromResult(_fields.ToList())
            : ActionFieldService.GetByTrackedActionAsync(sourceActionId);

        var targetTask = targetActionId == Guid.Empty
            ? Task.FromResult(new List<ActionFieldResponse>())
            : targetActionId == Id
                ? Task.FromResult(_fields.ToList())
                : ActionFieldService.GetByTrackedActionAsync(targetActionId);

        try
        {
            await Task.WhenAll(sourceTask, targetTask);
            if (loadVersion != _connEditorLoadVersion) return;

            _connSourceFields = sourceTask.Result;
            _connTargetFields = targetTask.Result;
            NormalizeConnEditorMappings();
        }
        catch
        {
            if (loadVersion != _connEditorLoadVersion) return;
            _connSourceFields = sourceActionId == Id ? _fields.ToList() : [];
            _connTargetFields = [];
            NormalizeConnEditorMappings();
        }
    }

    private void NormalizeConnEditorMappings()
    {
        if (_connRuleEditing is null) return;

        var sourceIds = _connSourceFields.Select(f => f.Id).ToHashSet();
        var targetIds = _connTargetFields.Select(f => f.Id).ToHashSet();

        foreach (var cond in _connRuleEditing.Conditions)
        {
            if (cond.SourceFieldId != Guid.Empty && !sourceIds.Contains(cond.SourceFieldId))
                cond.SourceFieldId = Guid.Empty;
        }

        foreach (var mapping in _connRuleEditing.Mappings)
        {
            if (mapping.TargetFieldId != Guid.Empty && !targetIds.Contains(mapping.TargetFieldId))
                mapping.TargetFieldId = Guid.Empty;

            if (mapping.SourceFieldId != Guid.Empty && !sourceIds.Contains(mapping.SourceFieldId))
                mapping.SourceFieldId = Guid.Empty;
        }
    }

