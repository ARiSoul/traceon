@page "/tracked-actions/{Id:guid}/edit"
@attribute [Authorize]
@inject IStringLocalizer<SharedResource> L
@using Blazored.LocalStorage
@inject ILocalStorageService LocalStorage

<PageTitle>@L["ActionEdit_Title"] - Traceon</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-1">
            <i class="bi bi-pencil-square me-2"></i>
            @L["ActionEdit_Title"]
        </h3>
        <p class="text-muted mb-0">
            @L["ActionEdit_Editing"]: <strong>@(_model?.Name ?? "...")</strong>
        </p>
    </div>
    <div class="d-flex gap-2">
        <a href="/tracked-actions" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>@L["Common_BackToList"]
        </a>
        <a href="/dashboard/action/@Id/detail" class="btn btn-outline-info">
            <i class="bi bi-graph-up-arrow me-1"></i>@L["TrackedActions_Analytics"]
        </a>
        <button class="btn btn-success" @onclick="SaveBasicInfoAsync" disabled="@_saving">
            @if (_saving)
            {
                <span class="spinner-border spinner-border-sm me-1"></span>
            }
            else
            {
                <i class="bi bi-check-circle me-1"></i>
            }
            @L["Common_SaveChanges"]
        </button>
    </div>
</div>

<ErrorAlert Errors="_errors" OnDismiss="() => _errors = []" />

@if (_loading)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">@L["Common_Loading"]</span>
        </div>
    </div>
}
else if (_model is null)
{
    <div class="alert alert-warning">
        <i class="bi bi-question-circle me-2"></i>
        @L["Edit_NotFound"]
    </div>
}
else
{
    <div class="card">
        <div class="card-header p-0">
            <ul class="nav nav-tabs card-header-tabs">
                <li class="nav-item">
                    <button class="nav-link @(_activeTab == "basic" ? "active" : "")" @onclick='() => SetActiveTabAsync("basic")'>
                        <i class="bi bi-info-circle me-1"></i>@L["Edit_BasicInfo"]
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(_activeTab == "fields" ? "active" : "")" @onclick='() => SetActiveTabAsync("fields")'>
                        <i class="bi bi-sliders me-1"></i>@L["Common_Fields"]
                        @if (_fields.Count > 0)
                        {
                            <span class="badge bg-primary ms-1">@_fields.Count</span>
                        }
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(_activeTab == "tags" ? "active" : "")" @onclick='() => SetActiveTabAsync("tags")'>
                        <i class="bi bi-tags me-1"></i>@L["Common_Tags"]
                        @if (_tags.Count > 0)
                        {
                            <span class="badge bg-primary ms-1">@_tags.Count</span>
                        }
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(_activeTab == "entries" ? "active" : "")" @onclick='() => SetActiveTabAsync("entries")'>
                        <i class="bi bi-journal-text me-1"></i>@L["Common_Entries"]
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(_activeTab == "dependencies" ? "active" : "")" @onclick="ActivateDependenciesTabAsync">
                        <i class="bi bi-link-45deg me-1"></i>@L["Dep_FieldDependencies"]
                        @if (_dependencyRules.Count > 0)
                        {
                            <span class="badge bg-primary ms-1">@_dependencyRules.Count</span>
                        }
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(_activeTab == "analytics" ? "active" : "")" @onclick="ActivateAnalyticsTabAsync">
                        <i class="bi bi-diagram-3 me-1"></i>@L["Analytics_CrossField"]
                        @if (_analyticsRules.Count > 0)
                        {
                            <span class="badge bg-primary ms-1">@_analyticsRules.Count</span>
                        }
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(_activeTab == "receipt" ? "active" : "")" @onclick="ActivateReceiptTabAsync">
                        <i class="bi bi-receipt me-1"></i>@L["RcptCfg_Tab"]
                        @if (_receiptConfig is not null)
                        {
                            <span class="badge bg-success ms-1"><i class="bi bi-check-lg"></i></span>
                        }
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(_activeTab == "connected" ? "active" : "")" @onclick="ActivateConnectedTabAsync">
                        <i class="bi bi-link-45deg me-1"></i>@L["ConnAct_Tab"]
                        @if (_connectedRules.Count > 0)
                        {
                            <span class="badge bg-primary ms-1">@_connectedRules.Count</span>
                        }
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(_activeTab == "customcharts" ? "active" : "")" @onclick="ActivateCustomChartsTabAsync">
                        <i class="bi bi-bar-chart-steps me-1"></i>@L["CustomChart_Title"]
                        @if (_customCharts.Count > 0)
                        {
                            <span class="badge bg-primary ms-1">@_customCharts.Count</span>
                        }
                    </button>
                </li>
            </ul>
        </div>

        <div class="card-body">
            @if (_activeTab == "basic")
            {
                <EditForm Model="_model" FormName="EditActionForm">
                    <DataAnnotationsValidator />
                    <div class="mb-3">
                        <label class="form-label">@L["Common_Name"] <span class="text-danger">*</span></label>
                        <InputText @bind-Value="_model.Name" class="form-control" />
                        <ValidationMessage For="() => _model.Name" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">@L["Common_Description"]</label>
                        <InputText @bind-Value="_model.Description" class="form-control" />
                    </div>
                </EditForm>
            }
            else if (_activeTab == "fields")
            {
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <p class="text-muted mb-0">@L["Edit_FieldsHint"]</p>
                    <button class="btn btn-outline-primary btn-sm" @onclick="() => _showFieldSelector = true">
                        <i class="bi bi-plus-circle me-1"></i>@L["Edit_AddFields"]
                    </button>
                </div>

                @if (_fields.Count == 0)
                {
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-sliders fs-3 d-block mb-2"></i>
                        <p>@L["Edit_NoFieldsYet"]</p>
                        <button class="btn btn-primary" @onclick="() => _showFieldSelector = true">
                            <i class="bi bi-plus-circle me-1"></i>@L["Edit_SelectFields"]
                        </button>
                    </div>
                }
                else
                {
                    <div class="list-group">
                        @for (var i = 0; i < _fields.Count; i++)
                        {
                            var index = i;
                            var field = _fields[i];
                            <ActionFieldEditor Field="field"
                                               TrackedActionId="Id"
                                               OnRemove="RemoveFieldAsync"
                                               OnSaved="ReloadFieldsAsync"
                                               IsFirst="index == 0"
                                               IsLast="index == _fields.Count - 1"
                                               OnMoveUp="() => MoveFieldAsync(index, -1)"
                                               OnMoveDown="() => MoveFieldAsync(index, 1)"
                                               SiblingFields="_fields" />
                        }
                    </div>
                    @if (_savingOrder)
                    {
                        <div class="text-center mt-2">
                            <span class="spinner-border spinner-border-sm text-primary me-1"></span>
                            <small class="text-muted">@L["Edit_SavingOrder"]</small>
                        </div>
                    }
                }
            }
            else if (_activeTab == "tags")
            {
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <p class="text-muted mb-0">@L["Edit_TagsHint"]</p>
                    <button class="btn btn-outline-primary btn-sm" @onclick="() => _showTagSelector = true">
                        <i class="bi bi-plus-circle me-1"></i>@L["Edit_AddTags"]
                    </button>
                </div>

                @if (_tags.Count == 0)
                {
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-tags fs-3 d-block mb-2"></i>
                        <p>@L["Edit_NoTagsYet"]</p>
                        <button class="btn btn-primary" @onclick="() => _showTagSelector = true">
                            <i class="bi bi-plus-circle me-1"></i>@L["Edit_SelectTags"]
                        </button>
                    </div>
                }
                else
                {
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var tag in _tags)
                        {
                            <span class="badge rounded-pill fs-6 d-inline-flex align-items-center gap-1 py-2 px-3"
                                  style="background-color: @tag.Color">
                                @tag.Name
                                <button type="button" class="btn-close btn-close-white ms-1" style="font-size: 0.6rem;"
                                        @onclick="() => RemoveTagAsync(tag)"></button>
                            </span>
                        }
                    </div>
                }
            }
            else if (_activeTab == "entries")
            {
                <div class="d-flex justify-content-end mb-2">
                    <a href="@($"/tracked-actions/{Id}/entry-templates")" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-bookmark me-1"></i>@L["EntryTemplate_ManageLink"]
                    </a>
                </div>
                <EntryDataGrid TrackedActionId="Id" LockActionFilter="true" ActionFields="_fields" StorageKey="@($"action-entries-{Id}")" />
            }
            else if (_activeTab == "analytics")
            {
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <p class="text-muted mb-0">@L["Analytics_RulesHint"]</p>
                    @if (_fields.Count >= 2)
                    {
                        <button class="btn btn-outline-primary btn-sm" @onclick="() => _showRuleForm = true" disabled="@_showRuleForm">
                            <i class="bi bi-plus-circle me-1"></i>@L["Analytics_AddRule"]
                        </button>
                    }
                </div>

                @if (_fields.Count < 2)
                {
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-2"></i>@L["Analytics_NeedTwoFields"]
                    </div>
                }
                else
                {
                    @if (_showRuleForm)
                    {
                        <div class="card border-primary mb-3">
                            <div class="card-header bg-primary bg-opacity-10 d-flex justify-content-between align-items-center">
                                <h6 class="mb-0"><i class="bi bi-plus-circle me-2"></i>@L["Analytics_NewRule"]</h6>
                                <button class="btn-close" @onclick="ResetRuleForm"></button>
                            </div>
                            <div class="card-body">
                                <div class="row g-3">
                                    <div class="col-12 col-md-6">
                                        <label class="form-label">@L["Analytics_MeasureField"] <span class="text-danger">*</span></label>
                                        <select class="form-select" @bind="_newRule.MeasureFieldId">
                                            <option value="@Guid.Empty">— @L["Common_Select"] —</option>
                                            @foreach (var f in _fields.Where(f => f.FieldType is FieldType.Integer or FieldType.Decimal or FieldType.Dropdown or FieldType.CompositeDropdown).OrderBy(f => f.Name, StringComparer.CurrentCultureIgnoreCase))
                                            {
                                                <option value="@f.Id">@f.Name (@f.FieldType)</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-12 col-md-6">
                                        <label class="form-label">@L["Analytics_GroupByField"] <span class="text-danger">*</span></label>
                                        <select class="form-select" @bind="_newRule.GroupByFieldId" @bind:after="() => _newRule.GroupByMetadataFieldId = Guid.Empty">
                                            <option value="@Guid.Empty">— @L["Common_Select"] —</option>
                                            @foreach (var f in _fields.Where(f => f.Id != _newRule.MeasureFieldId).OrderBy(f => f.Name, StringComparer.CurrentCultureIgnoreCase))
                                            {
                                                <option value="@f.Id">@f.Name (@f.FieldType)</option>
                                            }
                                        </select>
                                    </div>
                                    @{
                                        var newGroupMetaSchema = GetMetadataSchemaForField(_newRule.GroupByFieldId);
                                    }
                                    @if (newGroupMetaSchema is { Count: > 0 })
                                    {
                                        <div class="col-12 col-md-6">
                                            <label class="form-label">@L["Analytics_GroupByMetadataField"]</label>
                                            <select class="form-select" @bind="_newRule.GroupByMetadataFieldId">
                                                <option value="@Guid.Empty">— @L["Analytics_GroupByMetadataField_None"] —</option>
                                                @foreach (var m in newGroupMetaSchema)
                                                {
                                                    <option value="@m.Id">@m.Name (@m.Type)</option>
                                                }
                                            </select>
                                            <div class="form-text small">
                                                <i class="bi bi-info-circle me-1"></i>@L["Analytics_GroupByMetadataField_Hint"]
                                            </div>
                                        </div>
                                    }
                                    <div class="col-12 col-md-4">
                                        <label class="form-label">@L["Analytics_Aggregation"]</label>
                                        @{
                                            var newMeasureField = _fields.FirstOrDefault(f => f.Id == _newRule.MeasureFieldId);
                                            var newMeasureIsDropdown = newMeasureField?.FieldType is FieldType.Dropdown or FieldType.CompositeDropdown;
                                        }
                                        <select class="form-select" @bind="_newRule.Aggregation">
                                            @if (newMeasureIsDropdown)
                                            {
                                                <option value="@AnalyticsAggregation.Count">@L["Analytics_Agg_Count"]</option>
                                                <option value="@AnalyticsAggregation.CountByValue">@L["Analytics_Agg_CountByValue"]</option>
                                                <option value="@AnalyticsAggregation.AggregateByValue">@L["Analytics_Agg_AggregateByValue"]</option>
                                            }
                                            else
                                            {
                                                @foreach (var agg in Enum.GetValues<AnalyticsAggregation>().Where(a => a is not AnalyticsAggregation.CountByValue and not AnalyticsAggregation.AggregateByValue))
                                                {
                                                    <option value="@agg">@agg</option>
                                                }
                                            }
                                        </select>
                                        @if (newMeasureIsDropdown)
                                        {
                                            <div class="form-text small">
                                                <i class="bi bi-info-circle me-1"></i>@L["Analytics_CountByValueHint"]
                                            </div>
                                        }
                                    </div>
                                    @if (_newRule.Aggregation is AnalyticsAggregation.CountByValue or AnalyticsAggregation.AggregateByValue && newMeasureIsDropdown)
                                    {
                                        var hasNumericFields = _fields.Any(f => f.FieldType is FieldType.Integer or FieldType.Decimal && f.Id != _newRule.MeasureFieldId && f.Id != _newRule.GroupByFieldId);
                                        var isAggregate = _newRule.Aggregation == AnalyticsAggregation.AggregateByValue;
                                        @if (hasNumericFields)
                                        {
                                            <div class="col-12">
                                                <hr class="my-2" />
                                                <small class="text-muted"><i class="bi bi-calculator me-1"></i>@(isAggregate? L["Analytics_AggregateByValueHint"] : L["Analytics_ValueFieldHint"])</small>
                                            </div>
                                            <div class="col-12 col-md-4">
                                                <label class="form-label">
                                                    @L["Analytics_ValueField"] @if (isAggregate) {
                                                    <span class="text-danger">*</span>
                                                }
                                            </label>
                                            <select class="form-select" @bind="_newRule.SignFieldId">
                                                @if (!isAggregate)
                                                {
                                                    <option value="">— @L["Common_None"] —</option>
                                                }
                                                else
                                                {
                                                    <option value="">— @L["Common_Select"] —</option>
                                                }
                                                @foreach (var f in _fields.Where(f => f.FieldType is FieldType.Integer or FieldType.Decimal && f.Id != _newRule.MeasureFieldId && f.Id != _newRule.GroupByFieldId).OrderBy(f => f.Name, StringComparer.CurrentCultureIgnoreCase))
                                                {
                                                    <option value="@f.Id">@f.Name (@f.Unit)</option>
                                                }
                                            </select>
                                        </div>
                                        @if (_newRule.SignFieldId != Guid.Empty)
                                        {
                                            <div class="col-12 col-md-4">
                                                <label class="form-label">@L["Analytics_ValueMetrics"]</label>
                                                @{
                                                    var newSelectedMetrics = DropdownValuesHelper.Split(_newRule.NegativeValues).ToHashSet(StringComparer.OrdinalIgnoreCase);
                                                }
                                                @foreach (var metric in new[] { "Sum", "Avg", "Min", "Max" })
                                                {
                                                    var capturedMetric = metric;
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="checkbox" id="new-metric-@capturedMetric" checked="@newSelectedMetrics.Contains(capturedMetric)"
                                                               @onchange="e => { _newRule.NegativeValues = ToggleNegativeValue(_newRule.NegativeValues, capturedMetric, (bool)(e.Value ?? false)); }" />
                                                        <label class="form-check-label" for="new-metric-@capturedMetric">@L[$"Aggregation_{capturedMetric}"]</label>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    }
                                }
                                @if (_newRule.Aggregation is not AnalyticsAggregation.CountByValue and not AnalyticsAggregation.AggregateByValue)
                                {
                                    <div class="col-12 col-md-4">
                                        <label class="form-label">@L["Analytics_DisplayAs"]</label>
                                        <select class="form-select" @bind="_newRule.DisplayType">
                                            @foreach (var dt in Enum.GetValues<AnalyticsDisplayType>())
                                            {
                                                <option value="@dt">@dt</option>
                                            }
                                        </select>
                                    </div>
                                }
                                <div class="col-12 col-md-4">
                                    <label class="form-label">@L["Analytics_Label"]</label>
                                    <input type="text" class="form-control" @bind="_newRule.Label" placeholder="@L["Analytics_LabelPlaceholder"]" />
                                </div>
                                <div class="col-12 col-md-4">
                                    <label class="form-label">@L["Analytics_FilterField"]</label>
                                    <select class="form-select" @bind="_newRule.FilterFieldId" @bind:after="() => _newRule.FilterMetadataFieldId = Guid.Empty">
                                        <option value="">— @L["Common_None"] —</option>
                                        @foreach (var f in _fields.Where(f => f.Id != _newRule.MeasureFieldId && f.Id != _newRule.GroupByFieldId).OrderBy(f => f.Name, StringComparer.CurrentCultureIgnoreCase))
                                        {
                                            <option value="@f.Id">@f.Name (@f.FieldType)</option>
                                        }
                                    </select>
                                </div>
                                @{
                                    var newFilterMetaSchema = _newRule.FilterFieldId != Guid.Empty
                                        ? GetMetadataSchemaForField(_newRule.FilterFieldId)
                                        : null;
                                }
                                @if (newFilterMetaSchema is { Count: > 0 })
                                {
                                    <div class="col-12 col-md-4">
                                        <label class="form-label">@L["Analytics_FilterMetadataField"]</label>
                                        <select class="form-select" @bind="_newRule.FilterMetadataFieldId" @bind:after="() => _newRule.FilterValue = null">
                                            <option value="@Guid.Empty">— @L["Analytics_FilterMetadataField_None"] —</option>
                                            @foreach (var m in newFilterMetaSchema)
                                            {
                                                <option value="@m.Id">@m.Name (@m.Type)</option>
                                            }
                                        </select>
                                    </div>
                                }
                                @if (_newRule.FilterFieldId != Guid.Empty)
                                {
                                    <div class="col-12 col-md-4">
                                        <label class="form-label">@L["Analytics_FilterValue"]</label>
                                        @{
                                            var filterField = _fields.FirstOrDefault(f => f.Id == _newRule.FilterFieldId);
                                            var newFilterMeta = _newRule.FilterMetadataFieldId != Guid.Empty && newFilterMetaSchema is not null
                                                ? newFilterMetaSchema.FirstOrDefault(m => m.Id == _newRule.FilterMetadataFieldId)
                                                : null;
                                        }
                                        @if (newFilterMeta is not null)
                                        {
                                            @RenderMetadataFilterInput(newFilterMeta, _newRule.FilterValue, v => _newRule.FilterValue = v, "new")
                                        }
                                        else if (filterField?.FieldType == FieldType.Boolean)
                                        {
                                            <select class="form-select" @bind="_newRule.FilterValue">
                                                <option value="true">True</option>
                                                <option value="false">False</option>
                                            </select>
                                        }
                                        else if (filterField?.FieldType == FieldType.Dropdown && filterField.DropdownValues is not null)
                                        {
                                            <SearchableSelect Value="@_newRule.FilterValue"
                                                              ValueChanged="v => _newRule.FilterValue = v"
                                                              Options="@(DropdownValuesHelper.Split(filterField.DropdownValues).OrderBy(v => v, StringComparer.CurrentCultureIgnoreCase).ToList())"
                                                              Placeholder="—" />
                                        }
                                        else
                                        {
                                            <input type="text" class="form-control" @bind="_newRule.FilterValue" />
                                        }
                                    </div>
                                }
                                @if (_newRule.Aggregation == AnalyticsAggregation.SignedSum)
                                {
                                    <div class="col-12">
                                        <hr class="my-2" />
                                        <small class="text-muted"><i class="bi bi-info-circle me-1"></i>@L["Analytics_SignedSumHint"]</small>
                                    </div>
                                    <div class="col-12 col-md-4">
                                        <label class="form-label">@L["Analytics_SignField"]</label>
                                        <select class="form-select" @bind="_newRule.SignFieldId">
                                            <option value="">— @L["Common_Select"] —</option>
                                            @foreach (var f in _fields.Where(f => f.FieldType == FieldType.Dropdown).OrderBy(f => f.Name, StringComparer.CurrentCultureIgnoreCase))
                                            {
                                                <option value="@f.Id">@f.Name</option>
                                            }
                                        </select>
                                    </div>
                                    @if (_newRule.SignFieldId != Guid.Empty)
                                    {
                                        <div class="col-12 col-md-4">
                                            <label class="form-label">@L["Analytics_NegativeValues"]</label>
                                            @{
                                                var signField = _fields.FirstOrDefault(f => f.Id == _newRule.SignFieldId);
                                            }
                                            @if (signField?.DropdownValues is not null)
                                            {
                                                var signOptions = DropdownValuesHelper.Split(signField.DropdownValues).OrderBy(v => v, StringComparer.CurrentCultureIgnoreCase).ToArray();
                                                var selectedNeg = DropdownValuesHelper.Split(_newRule.NegativeValues).ToHashSet(StringComparer.OrdinalIgnoreCase);
                                                @foreach (var opt in signOptions)
                                                {
                                                    var capturedOpt = opt;
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="checkbox" id="new-neg-@capturedOpt" checked="@selectedNeg.Contains(capturedOpt)"
                                                               @onchange="e => { _newRule.NegativeValues = ToggleNegativeValue(_newRule.NegativeValues, capturedOpt, (bool)(e.Value ?? false)); }" />
                                                        <label class="form-check-label" for="new-neg-@capturedOpt">@capturedOpt</label>
                                                    </div>
                                                }
                                            }
                                            else
                                            {
                                                <input type="text" class="form-control" @bind="_newRule.NegativeValues" placeholder="@L["Analytics_NegativeValuesPlaceholder"]" />
                                            }
                                        </div>
                                    }
                                }
                                @if (_newRule.Aggregation is AnalyticsAggregation.Sum or AnalyticsAggregation.SignedSum)
                                {
                                    <div class="col-12">
                                        <hr class="my-2" />
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="new-offset-enable"
                                                   checked="@_newRule.OffsetEnabled"
                                                   @onchange="e => _newRule.OffsetEnabled = (bool)(e.Value ?? false)" />
                                            <label class="form-check-label" for="new-offset-enable">
                                                <strong>@L["Analytics_OffsetEnable"]</strong>
                                            </label>
                                        </div>
                                        <small class="text-muted"><i class="bi bi-info-circle me-1"></i>@L["Analytics_OffsetHint"]</small>
                                    </div>
                                    @if (_newRule.OffsetEnabled)
                                    {
                                        <div class="col-12 col-md-4">
                                            <label class="form-label">@L["Analytics_OffsetTriggerField"]</label>
                                            <select class="form-select" @bind="_newRule.OffsetTriggerFieldId">
                                                <option value="">— @L["Common_Select"] —</option>
                                                @foreach (var f in _fields.Where(f => f.FieldType == FieldType.Dropdown).OrderBy(f => f.Name, StringComparer.CurrentCultureIgnoreCase))
                                                {
                                                    <option value="@f.Id">@f.Name</option>
                                                }
                                            </select>
                                        </div>
                                        @if (_newRule.OffsetTriggerFieldId != Guid.Empty)
                                        {
                                            <div class="col-12 col-md-4">
                                                <label class="form-label">@L["Analytics_OffsetTriggerValues"]</label>
                                                @{
                                                    var offsetTriggerField = _fields.FirstOrDefault(f => f.Id == _newRule.OffsetTriggerFieldId);
                                                }
                                                @if (offsetTriggerField?.DropdownValues is not null)
                                                {
                                                    var offsetTriggerOptions = DropdownValuesHelper.Split(offsetTriggerField.DropdownValues).OrderBy(v => v, StringComparer.CurrentCultureIgnoreCase).ToArray();
                                                    var selectedOffsetTriggers = DropdownValuesHelper.Split(_newRule.OffsetTriggerValues).ToHashSet(StringComparer.OrdinalIgnoreCase);
                                                    @foreach (var opt in offsetTriggerOptions)
                                                    {
                                                        var capturedOpt = opt;
                                                        <div class="form-check">
                                                            <input class="form-check-input" type="checkbox" id="new-offset-trig-@capturedOpt" checked="@selectedOffsetTriggers.Contains(capturedOpt)"
                                                                   @onchange="e => { _newRule.OffsetTriggerValues = ToggleNegativeValue(_newRule.OffsetTriggerValues, capturedOpt, (bool)(e.Value ?? false)); }" />
                                                            <label class="form-check-label" for="new-offset-trig-@capturedOpt">@capturedOpt</label>
                                                        </div>
                                                    }
                                                }
                                                else
                                                {
                                                    <input type="text" class="form-control" @bind="_newRule.OffsetTriggerValues" placeholder="@L["Analytics_NegativeValuesPlaceholder"]" />
                                                }
                                            </div>
                                        }
                                        <div class="col-12 col-md-4">
                                            <label class="form-label">@L["Analytics_OffsetValueField"]</label>
                                            <select class="form-select" @bind="_newRule.OffsetValueFieldId">
                                                <option value="">— @L["Common_Select"] —</option>
                                                @foreach (var f in _fields.Where(f => f.FieldType is FieldType.Integer or FieldType.Decimal).OrderBy(f => f.Name, StringComparer.CurrentCultureIgnoreCase))
                                                {
                                                    <option value="@f.Id">@f.Name</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="col-12 col-md-4">
                                            <label class="form-label">@L["Analytics_OffsetDirection"]</label>
                                            <select class="form-select" @bind="_newRule.OffsetDirection">
                                                <option value="@AnalyticsOffsetDirection.Subtract">@L["Analytics_OffsetDirectionSubtract"]</option>
                                                <option value="@AnalyticsOffsetDirection.Add">@L["Analytics_OffsetDirectionAdd"]</option>
                                            </select>
                                        </div>
                                    }
                                    @if (_newRule.Aggregation == AnalyticsAggregation.SignedSum)
                                    {
                                        <div class="col-12">
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="checkbox" id="new-collapse-batch"
                                                       checked="@_newRule.CollapseByImportBatch"
                                                       @onchange="e => _newRule.CollapseByImportBatch = (bool)(e.Value ?? false)" />
                                                <label class="form-check-label" for="new-collapse-batch">
                                                    <strong>@L["Analytics_CollapseByImportBatch"]</strong>
                                                </label>
                                            </div>
                                            <small class="text-muted"><i class="bi bi-info-circle me-1"></i>@L["Analytics_CollapseByImportBatchHint"]</small>
                                        </div>
                                    }
                                }
                            </div>
                            <ErrorAlert Errors="_ruleErrors" OnDismiss="() => _ruleErrors = []" />
                            <div class="d-flex justify-content-end gap-2 mt-3">
                                <button class="btn btn-outline-secondary btn-sm" @onclick="ResetRuleForm">
                                    @L["Common_Cancel"]
                                </button>
                                <button class="btn btn-primary btn-sm" @onclick="SaveRuleAsync" disabled="@_savingRule">
                                    @if (_savingRule)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1"></span>
                                    }
                                    <i class="bi bi-check-circle me-1"></i>@L["Common_Save"]
                                </button>
                            </div>
                        </div>
                    </div>
                }

                @if (_analyticsRules.Count == 0 && !_showRuleForm)
                {
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-diagram-3 fs-3 d-block mb-2"></i>
                        <p>@L["Analytics_NoCrossFieldRules"]</p>
                    </div>
                }
                else
                {
                    <div class="list-group">
                        @foreach (var rule in _analyticsRules)
                        {
                            @if (_editingRuleId == rule.Id)
                            {
                                <div class="list-group-item p-0">
                                    <div class="card border-warning mb-0">
                                        <div class="card-header bg-warning bg-opacity-10 d-flex justify-content-between align-items-center">
                                            <h6 class="mb-0"><i class="bi bi-pencil-square me-2"></i>@L["Analytics_EditRule"]</h6>
                                            <button class="btn-close" @onclick="CancelEditRule"></button>
                                        </div>
                                        <div class="card-body">
                                            <div class="row g-3">
                                                <div class="col-12 col-md-6">
                                                    <label class="form-label">@L["Analytics_MeasureField"]</label>
                                                    <input type="text" class="form-control" value="@rule.MeasureFieldName" disabled />
                                                </div>
                                                <div class="col-12 col-md-6">
                                                    <label class="form-label">@L["Analytics_GroupByField"]</label>
                                                    <input type="text" class="form-control" value="@rule.GroupByFieldName" disabled />
                                                </div>
                                                @{
                                                    var editGroupMetaSchema = GetMetadataSchemaForField(rule.GroupByFieldId);
                                                }
                                                @if (editGroupMetaSchema is { Count: > 0 })
                                                {
                                                    <div class="col-12 col-md-6">
                                                        <label class="form-label">@L["Analytics_GroupByMetadataField"]</label>
                                                        <select class="form-select" @bind="_editRule.GroupByMetadataFieldId">
                                                            <option value="@Guid.Empty">— @L["Analytics_GroupByMetadataField_None"] —</option>
                                                            @foreach (var m in editGroupMetaSchema)
                                                            {
                                                                <option value="@m.Id">@m.Name (@m.Type)</option>
                                                            }
                                                        </select>
                                                    </div>
                                                }
                                                <div class="col-12 col-md-4">
                                                    <label class="form-label">@L["Analytics_Aggregation"]</label>
                                                    @{
                                                        var editMeasureField = _fields.FirstOrDefault(f => f.Id == rule.MeasureFieldId);
                                                        var editMeasureIsDropdown = editMeasureField?.FieldType is FieldType.Dropdown or FieldType.CompositeDropdown;
                                                    }
                                                    <select class="form-select" @bind="_editRule.Aggregation">
                                                        @if (editMeasureIsDropdown)
                                                        {
                                                            <option value="@AnalyticsAggregation.Count">@L["Analytics_Agg_Count"]</option>
                                                            <option value="@AnalyticsAggregation.CountByValue">@L["Analytics_Agg_CountByValue"]</option>
                                                            <option value="@AnalyticsAggregation.AggregateByValue">@L["Analytics_Agg_AggregateByValue"]</option>
                                                        }
                                                        else
                                                        {
                                                            @foreach (var agg in Enum.GetValues<AnalyticsAggregation>().Where(a => a is not AnalyticsAggregation.CountByValue and not AnalyticsAggregation.AggregateByValue))
                                                            {
                                                                <option value="@agg">@agg</option>
                                                            }
                                                        }
                                                    </select>
                                                </div>
                                                @if (_editRule.Aggregation is not AnalyticsAggregation.CountByValue and not AnalyticsAggregation.AggregateByValue)
                                                {
                                                    <div class="col-12 col-md-4">
                                                        <label class="form-label">@L["Analytics_DisplayAs"]</label>
                                                        <select class="form-select" @bind="_editRule.DisplayType">
                                                            @foreach (var dt in Enum.GetValues<AnalyticsDisplayType>())
                                                            {
                                                                <option value="@dt">@dt</option>
                                                            }
                                                        </select>
                                                    </div>
                                                }
                                                <div class="col-12 col-md-4">
                                                    <label class="form-label">@L["Analytics_Label"]</label>
                                                    <input type="text" class="form-control" @bind="_editRule.Label" placeholder="@L["Analytics_LabelPlaceholder"]" />
                                                </div>
                                                <div class="col-12 col-md-4">
                                                    <label class="form-label">@L["Analytics_FilterField"]</label>
                                                    <select class="form-select" @bind="_editRule.FilterFieldId" @bind:after="() => _editRule.FilterMetadataFieldId = Guid.Empty">
                                                        <option value="">— @L["Common_None"] —</option>
                                                        @foreach (var f in _fields.Where(f => f.Id != rule.MeasureFieldId && f.Id != rule.GroupByFieldId).OrderBy(f => f.Name, StringComparer.CurrentCultureIgnoreCase))
                                                        {
                                                            <option value="@f.Id">@f.Name (@f.FieldType)</option>
                                                        }
                                                    </select>
                                                </div>
                                                @{
                                                    var editFilterMetaSchema = _editRule.FilterFieldId != Guid.Empty
                                                        ? GetMetadataSchemaForField(_editRule.FilterFieldId)
                                                        : null;
                                                }
                                                @if (editFilterMetaSchema is { Count: > 0 })
                                                {
                                                    <div class="col-12 col-md-4">
                                                        <label class="form-label">@L["Analytics_FilterMetadataField"]</label>
                                                        <select class="form-select" @bind="_editRule.FilterMetadataFieldId" @bind:after="() => _editRule.FilterValue = null">
                                                            <option value="@Guid.Empty">— @L["Analytics_FilterMetadataField_None"] —</option>
                                                            @foreach (var m in editFilterMetaSchema)
                                                            {
                                                                <option value="@m.Id">@m.Name (@m.Type)</option>
                                                            }
                                                        </select>
                                                    </div>
                                                }
                                                @if (_editRule.FilterFieldId != Guid.Empty)
                                                {
                                                    <div class="col-12 col-md-4">
                                                        <label class="form-label">@L["Analytics_FilterValue"]</label>
                                                        @{
                                                            var editFilterField = _fields.FirstOrDefault(f => f.Id == _editRule.FilterFieldId);
                                                            var editFilterMeta = _editRule.FilterMetadataFieldId != Guid.Empty && editFilterMetaSchema is not null
                                                                ? editFilterMetaSchema.FirstOrDefault(m => m.Id == _editRule.FilterMetadataFieldId)
                                                                : null;
                                                        }
                                                        @if (editFilterMeta is not null)
                                                        {
                                                            @RenderMetadataFilterInput(editFilterMeta, _editRule.FilterValue, v => _editRule.FilterValue = v, "edit")
                                                        }
                                                        else if (editFilterField?.FieldType == FieldType.Boolean)
                                                        {
                                                            <select class="form-select" @bind="_editRule.FilterValue">
                                                                <option value="true">True</option>
                                                                <option value="false">False</option>
                                                            </select>
                                                        }
                                                        else if (editFilterField?.FieldType == FieldType.Dropdown && editFilterField.DropdownValues is not null)
                                                        {
                                                            <SearchableSelect Value="@_editRule.FilterValue"
                                                                              ValueChanged="v => _editRule.FilterValue = v"
                                                                              Options="@(DropdownValuesHelper.Split(editFilterField.DropdownValues).OrderBy(v => v, StringComparer.CurrentCultureIgnoreCase).ToList())"
                                                                              Placeholder="—" />
                                                        }
                                                        else
                                                        {
                                                            <input type="text" class="form-control" @bind="_editRule.FilterValue" />
                                                        }
                                                    </div>
                                                }
                                                @if (_editRule.Aggregation is AnalyticsAggregation.CountByValue or AnalyticsAggregation.AggregateByValue && editMeasureIsDropdown)
                                                {
                                                    var editHasNumericFields = _fields.Any(f => f.FieldType is FieldType.Integer or FieldType.Decimal && f.Id != rule.MeasureFieldId && f.Id != rule.GroupByFieldId);
                                                    var editIsAggregate = _editRule.Aggregation == AnalyticsAggregation.AggregateByValue;
                                                    @if (editHasNumericFields)
                                                    {
                                                        <div class="col-12">
                                                            <hr class="my-2" />
                                                            <small class="text-muted"><i class="bi bi-calculator me-1"></i>@(editIsAggregate? L["Analytics_AggregateByValueHint"] : L["Analytics_ValueFieldHint"])</small>
                                                        </div>
                                                        <div class="col-12 col-md-4">
                                                            <label class="form-label">
                                                                @L["Analytics_ValueField"] @if (editIsAggregate) {
                                                                <span class="text-danger">*</span>
                                                            }
                                                        </label>
                                                        <select class="form-select" @bind="_editRule.SignFieldId">
                                                            @if (!editIsAggregate)
                                                            {
                                                                <option value="">— @L["Common_None"] —</option>
                                                            }
                                                            else
                                                            {
                                                                <option value="">— @L["Common_Select"] —</option>
                                                            }
                                                            @foreach (var f in _fields.Where(f => f.FieldType is FieldType.Integer or FieldType.Decimal && f.Id != rule.MeasureFieldId && f.Id != rule.GroupByFieldId).OrderBy(f => f.Name, StringComparer.CurrentCultureIgnoreCase))
                                                            {
                                                                <option value="@f.Id">@f.Name (@f.Unit)</option>
                                                            }
                                                        </select>
                                                    </div>
                                                    @if (_editRule.SignFieldId != Guid.Empty)
                                                    {
                                                        <div class="col-12 col-md-4">
                                                            <label class="form-label">@L["Analytics_ValueMetrics"]</label>
                                                            @{
                                                                var editSelectedMetrics = DropdownValuesHelper.Split(_editRule.NegativeValues).ToHashSet(StringComparer.OrdinalIgnoreCase);
                                                            }
                                                            @foreach (var metric in new[] { "Sum", "Avg", "Min", "Max" })
                                                            {
                                                                var capturedMetric = metric;
                                                                <div class="form-check">
                                                                    <input class="form-check-input" type="checkbox" id="edit-metric-@capturedMetric" checked="@editSelectedMetrics.Contains(capturedMetric)"
                                                                           @onchange="e => { _editRule.NegativeValues = ToggleNegativeValue(_editRule.NegativeValues, capturedMetric, (bool)(e.Value ?? false)); }" />
                                                                    <label class="form-check-label" for="edit-metric-@capturedMetric">@L[$"Aggregation_{capturedMetric}"]</label>
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                }
                                            }
                                            @if (_editRule.Aggregation == AnalyticsAggregation.SignedSum)
                                            {
                                                <div class="col-12">
                                                    <hr class="my-2" />
                                                    <small class="text-muted"><i class="bi bi-info-circle me-1"></i>@L["Analytics_SignedSumHint"]</small>
                                                </div>
                                                <div class="col-12 col-md-4">
                                                    <label class="form-label">@L["Analytics_SignField"]</label>
                                                    <select class="form-select" @bind="_editRule.SignFieldId">
                                                        <option value="">— @L["Common_Select"] —</option>
                                                        @foreach (var f in _fields.Where(f => f.FieldType == FieldType.Dropdown).OrderBy(f => f.Name, StringComparer.CurrentCultureIgnoreCase))
                                                        {
                                                            <option value="@f.Id">@f.Name</option>
                                                        }
                                                    </select>
                                                </div>
                                                @if (_editRule.SignFieldId != Guid.Empty)
                                                {
                                                    <div class="col-12 col-md-4">
                                                        <label class="form-label">@L["Analytics_NegativeValues"]</label>
                                                        @{
                                                            var editSignField = _fields.FirstOrDefault(f => f.Id == _editRule.SignFieldId);
                                                        }
                                                        @if (editSignField?.DropdownValues is not null)
                                                        {
                                                            var editSignOptions = DropdownValuesHelper.Split(editSignField.DropdownValues).OrderBy(v => v, StringComparer.CurrentCultureIgnoreCase).ToArray();
                                                            var editSelectedNeg = DropdownValuesHelper.Split(_editRule.NegativeValues).ToHashSet(StringComparer.OrdinalIgnoreCase);
                                                            @foreach (var opt in editSignOptions)
                                                            {
                                                                var capturedOpt = opt;
                                                                <div class="form-check">
                                                                    <input class="form-check-input" type="checkbox" id="edit-neg-@capturedOpt" checked="@editSelectedNeg.Contains(capturedOpt)"
                                                                           @onchange="e => { _editRule.NegativeValues = ToggleNegativeValue(_editRule.NegativeValues, capturedOpt, (bool)(e.Value ?? false)); }" />
                                                                    <label class="form-check-label" for="edit-neg-@capturedOpt">@capturedOpt</label>
                                                                </div>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <input type="text" class="form-control" @bind="_editRule.NegativeValues" placeholder="@L["Analytics_NegativeValuesPlaceholder"]" />
                                                        }
                                                    </div>
                                                }
                                            }
                                            @if (_editRule.Aggregation is AnalyticsAggregation.Sum or AnalyticsAggregation.SignedSum)
                                            {
                                                <div class="col-12">
                                                    <hr class="my-2" />
                                                    <div class="form-check form-switch">
                                                        <input class="form-check-input" type="checkbox" id="edit-offset-enable"
                                                               checked="@_editRule.OffsetEnabled"
                                                               @onchange="e => _editRule.OffsetEnabled = (bool)(e.Value ?? false)" />
                                                        <label class="form-check-label" for="edit-offset-enable">
                                                            <strong>@L["Analytics_OffsetEnable"]</strong>
                                                        </label>
                                                    </div>
                                                    <small class="text-muted"><i class="bi bi-info-circle me-1"></i>@L["Analytics_OffsetHint"]</small>
                                                </div>
                                                @if (_editRule.OffsetEnabled)
                                                {
                                                    <div class="col-12 col-md-4">
                                                        <label class="form-label">@L["Analytics_OffsetTriggerField"]</label>
                                                        <select class="form-select" @bind="_editRule.OffsetTriggerFieldId">
                                                            <option value="">— @L["Common_Select"] —</option>
                                                            @foreach (var f in _fields.Where(f => f.FieldType == FieldType.Dropdown).OrderBy(f => f.Name, StringComparer.CurrentCultureIgnoreCase))
                                                            {
                                                                <option value="@f.Id">@f.Name</option>
                                                            }
                                                        </select>
                                                    </div>
                                                    @if (_editRule.OffsetTriggerFieldId != Guid.Empty)
                                                    {
                                                        <div class="col-12 col-md-4">
                                                            <label class="form-label">@L["Analytics_OffsetTriggerValues"]</label>
                                                            @{
                                                                var editOffsetTriggerField = _fields.FirstOrDefault(f => f.Id == _editRule.OffsetTriggerFieldId);
                                                            }
                                                            @if (editOffsetTriggerField?.DropdownValues is not null)
                                                            {
                                                                var editOffsetTriggerOptions = DropdownValuesHelper.Split(editOffsetTriggerField.DropdownValues).OrderBy(v => v, StringComparer.CurrentCultureIgnoreCase).ToArray();
                                                                var editSelectedOffsetTriggers = DropdownValuesHelper.Split(_editRule.OffsetTriggerValues).ToHashSet(StringComparer.OrdinalIgnoreCase);
                                                                @foreach (var opt in editOffsetTriggerOptions)
                                                                {
                                                                    var capturedOpt = opt;
                                                                    <div class="form-check">
                                                                        <input class="form-check-input" type="checkbox" id="edit-offset-trig-@capturedOpt" checked="@editSelectedOffsetTriggers.Contains(capturedOpt)"
                                                                               @onchange="e => { _editRule.OffsetTriggerValues = ToggleNegativeValue(_editRule.OffsetTriggerValues, capturedOpt, (bool)(e.Value ?? false)); }" />
                                                                        <label class="form-check-label" for="edit-offset-trig-@capturedOpt">@capturedOpt</label>
                                                                    </div>
                                                                }
                                                            }
                                                            else
                                                            {
                                                                <input type="text" class="form-control" @bind="_editRule.OffsetTriggerValues" placeholder="@L["Analytics_NegativeValuesPlaceholder"]" />
                                                            }
                                                        </div>
                                                    }
                                                    <div class="col-12 col-md-4">
                                                        <label class="form-label">@L["Analytics_OffsetValueField"]</label>
                                                        <select class="form-select" @bind="_editRule.OffsetValueFieldId">
                                                            <option value="">— @L["Common_Select"] —</option>
                                                            @foreach (var f in _fields.Where(f => f.FieldType is FieldType.Integer or FieldType.Decimal).OrderBy(f => f.Name, StringComparer.CurrentCultureIgnoreCase))
                                                            {
                                                                <option value="@f.Id">@f.Name</option>
                                                            }
                                                        </select>
                                                    </div>
                                                    <div class="col-12 col-md-4">
                                                        <label class="form-label">@L["Analytics_OffsetDirection"]</label>
                                                        <select class="form-select" @bind="_editRule.OffsetDirection">
                                                            <option value="@AnalyticsOffsetDirection.Subtract">@L["Analytics_OffsetDirectionSubtract"]</option>
                                                            <option value="@AnalyticsOffsetDirection.Add">@L["Analytics_OffsetDirectionAdd"]</option>
                                                        </select>
                                                    </div>
                                                }
                                                @if (_editRule.Aggregation == AnalyticsAggregation.SignedSum)
                                                {
                                                    <div class="col-12">
                                                        <div class="form-check form-switch">
                                                            <input class="form-check-input" type="checkbox" id="edit-collapse-batch"
                                                                   checked="@_editRule.CollapseByImportBatch"
                                                                   @onchange="e => _editRule.CollapseByImportBatch = (bool)(e.Value ?? false)" />
                                                            <label class="form-check-label" for="edit-collapse-batch">
                                                                <strong>@L["Analytics_CollapseByImportBatch"]</strong>
                                                            </label>
                                                        </div>
                                                        <small class="text-muted"><i class="bi bi-info-circle me-1"></i>@L["Analytics_CollapseByImportBatchHint"]</small>
                                                    </div>
                                                }
                                            }
                                        </div>
                                        <ErrorAlert Errors="_ruleErrors" OnDismiss="() => _ruleErrors = []" />
                                        <div class="d-flex justify-content-end gap-2 mt-3">
                                            <button class="btn btn-outline-secondary btn-sm" @onclick="CancelEditRule">
                                                @L["Common_Cancel"]
                                            </button>
                                            <button class="btn btn-warning btn-sm" @onclick="UpdateRuleAsync" disabled="@_savingRule">
                                                @if (_savingRule)
                                                {
                                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                                }
                                                <i class="bi bi-check-circle me-1"></i>@L["Common_SaveChanges"]
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                                else
                        {
                            <div class="list-group-item list-group-item-action" style="cursor: pointer;" @onclick="() => StartEditRule(rule)">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <h6 class="mb-1">
                                            @if (rule.DisplayType == AnalyticsDisplayType.TimeSeries)
                                            {
                                                <i class="bi bi-graph-up me-1 text-primary"></i>
                                            }
                                            else if (rule.DisplayType is AnalyticsDisplayType.PieChart)
                                            {
                                                <i class="bi bi-pie-chart me-1 text-primary"></i>
                                            }
                                            else if (rule.DisplayType is AnalyticsDisplayType.BarChart or AnalyticsDisplayType.StackedBar)
                                            {
                                                <i class="bi bi-bar-chart me-1 text-primary"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-table me-1 text-primary"></i>
                                            }
                                            @(rule.Label ?? $"{rule.Aggregation} of {rule.MeasureFieldName} by {rule.GroupByFieldName}")
                                        </h6>
                                        <small class="text-muted">
                                            <span class="badge bg-info">@rule.Aggregation</span>
                                            @rule.MeasureFieldName
                                            <i class="bi bi-arrow-right mx-1"></i>
                                            @L["Analytics_GroupBy"] @rule.GroupByFieldName@(rule.GroupByMetadataFieldName is not null ? $" → {rule.GroupByMetadataFieldName}" : "")
                                            @if (rule.FilterFieldName is not null)
                                            {
                                                <span class="ms-2">
                                                    <i class="bi bi-funnel me-1"></i>@rule.FilterFieldName@(rule.FilterMetadataFieldName is not null ? $" → {rule.FilterMetadataFieldName}" : "") = @rule.FilterValue
                                                </span>
                                            }
                                            @if (rule.SignFieldName is not null)
                                            {
                                                <span class="ms-2">
                                                    <i class="bi bi-plus-slash-minus me-1"></i>@rule.SignFieldName → @rule.NegativeValues
                                                </span>
                                            }
                                            @if (rule.OffsetTriggerFieldName is not null && rule.OffsetValueFieldName is not null)
                                            {
                                                var offsetSign = rule.OffsetDirection == AnalyticsOffsetDirection.Add ? "+" : "−";
                                                <span class="ms-2">
                                                    <i class="bi bi-arrow-left-right me-1"></i>@rule.OffsetTriggerFieldName=@rule.OffsetTriggerValues → @offsetSign@rule.OffsetValueFieldName
                                                </span>
                                            }
                                        </small>
                                    </div>
                                    <div class="d-flex gap-1" @onclick:stopPropagation="true">
                                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => StartEditRule(rule)" title="@L["Common_Edit"]">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteRuleAsync(rule)" title="@L["Common_Delete"]">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
            }
        }
    }
            else if (_activeTab == "dependencies")
    {
        <div class="d-flex justify-content-between align-items-center mb-3">
            <p class="text-muted mb-0">@L["Dep_Hint"]</p>
            <div class="d-flex gap-2">
                <button class="btn btn-outline-success btn-sm" @onclick="() => _showHierarchyWizard = true">
                    <i class="bi bi-diagram-3 me-1"></i>@L["Hierarchy_BuildButton"]
                </button>
                @if (_dropdownFields.Count >= 2 && !_depEditorOpen)
                {
                    <button class="btn btn-outline-primary btn-sm" @onclick="OpenNewDepEditor">
                        <i class="bi bi-plus-circle me-1"></i>@L["Dep_AddMapping"]
                    </button>
                }
            </div>
        </div>

        @if (_dropdownFields.Count < 2)
        {
            <div class="alert alert-info">
                <i class="bi bi-info-circle me-2"></i>@L["Dep_NeedTwoDropdowns"]
            </div>
        }
        else
        {
            @* ── Mapping Editor ── *@
            @if (_depEditorOpen)
            {
                <div class="card border-primary mb-3">
                    <div class="card-header bg-primary bg-opacity-10 d-flex justify-content-between align-items-center">
                        <h6 class="mb-0">
                            <i class="bi bi-link-45deg me-2"></i>
                            @(_depEditingPairKey is not null ? L["Dep_EditMapping"] : L["Dep_NewMapping"])
                        </h6>
                        <button class="btn-close" @onclick="CloseDepEditor"></button>
                    </div>
                    <div class="card-body">
                        @* Field selectors (locked when editing) *@
                        <div class="row g-3 mb-3">
                            <div class="col-12 col-md-6">
                                <label class="form-label fw-semibold">@L["Dep_SourceField"] <span class="text-danger">*</span></label>
                                <select class="form-select" value="@_depSourceFieldId" @onchange="OnDepSourceFieldChanged"
                                        disabled="@(_depEditingPairKey is not null)">
                                    <option value="@Guid.Empty">— @L["Common_Select"] —</option>
                                    @foreach (var f in _dropdownFields.OrderBy(f => f.Name, StringComparer.CurrentCultureIgnoreCase))
                                    {
                                        <option value="@f.Id">@f.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label fw-semibold">@L["Dep_TargetField"] <span class="text-danger">*</span></label>
                                <select class="form-select" value="@_depTargetFieldId" @onchange="OnDepTargetFieldChanged"
                                        disabled="@(_depEditingPairKey is not null)">
                                    <option value="@Guid.Empty">— @L["Common_Select"] —</option>
                                    @foreach (var f in _dropdownFields.Where(f => f.Id != _depSourceFieldId).OrderBy(f => f.Name, StringComparer.CurrentCultureIgnoreCase))
                                    {
                                        <option value="@f.Id">@f.Name</option>
                                    }
                                </select>
                            </div>
                        </div>

                        @* Split panel: source values left, target checkboxes right *@
                        @if (_depSourceFieldId != Guid.Empty && _depTargetFieldId != Guid.Empty)
                        {
                            var srcOptions = GetFieldDropdownValues(_depSourceFieldId);
                            var tgtOptions = GetFieldDropdownValues(_depTargetFieldId);

                            @if (srcOptions.Length == 0 || tgtOptions.Length == 0)
                            {
                                <div class="alert alert-warning">
                                    <i class="bi bi-exclamation-triangle me-1"></i>@L["Dep_NoDropdownValues"]
                                </div>
                            }
                            else
                            {
                                <div class="row g-0 border rounded" style="min-height: 250px;">
                                    @* Left panel: source values *@
                                    <div class="col-12 col-md-4 border-end d-flex flex-column" style="max-height: 350px;">
                                        @if (srcOptions.Length > 8)
                                        {
                                            <div class="p-2 border-bottom flex-shrink-0">
                                                <input type="text" class="form-control form-control-sm"
                                                       placeholder="@L["Common_Search"]..."
                                                       @bind="_depSourceSearch"
                                                       @bind:event="oninput" />
                                            </div>
                                        }
                                        <div class="list-group list-group-flush overflow-y-auto flex-grow-1">
                                            @foreach (var srcVal in srcOptions.Where(v => string.IsNullOrEmpty(_depSourceSearch) || v.Contains(_depSourceSearch, StringComparison.OrdinalIgnoreCase)))
                                            {
                                                var captured = srcVal;
                                                var isActive = captured == _depActiveSourceValue;
                                                var hasMapping = _depMappings.TryGetValue(captured, out var m) && m.Count > 0;
                                                <button type="button"
                                                        class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(isActive ? "active" : "")"
                                                        @onclick="() => SelectDepSourceValue(captured)">
                                                    <span>@captured</span>
                                                    @if (hasMapping)
                                                    {
                                                        <span class="badge @(isActive ? "bg-body-tertiary text-primary" : "bg-primary") rounded-pill">@m!.Count</span>
                                                    }
                                                </button>
                                            }
                                        </div>
                                    </div>

                                    @* Right panel: target checkboxes *@
                                    <div class="col-12 col-md-8 d-flex flex-column" style="max-height: 350px;">
                                        @if (_depActiveSourceValue is null)
                                        {
                                            <div class="text-center text-muted py-4 flex-grow-1">
                                                <i class="bi bi-arrow-left-circle fs-3 d-block mb-2"></i>
                                                <p class="mb-0">@L["Dep_PickSourceValue"]</p>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="p-3 pb-0 flex-shrink-0">
                                                <div class="d-flex justify-content-between align-items-center mb-2">
                                                    <span class="fw-semibold">
                                                        @L["Dep_WhenValueIs"] <span class="badge bg-secondary">@_depActiveSourceValue</span>
                                                        → @L["Dep_AllowedValues"]:
                                                    </span>
                                                    <div class="d-flex gap-2 align-items-center">
                                                        <button type="button"
                                                                class="btn btn-sm btn-outline-secondary @(_depTargetShowOnlySelected ? "active" : "")"
                                                                @onclick="() => _depTargetShowOnlySelected = !_depTargetShowOnlySelected"
                                                                title="@L["Dep_ShowOnlySelectedTooltip"]">
                                                            <i class="bi bi-funnel"></i> @L["Dep_ShowOnlySelected"]
                                                        </button>
                                                        <div class="btn-group btn-group-sm">
                                                            <button class="btn btn-outline-secondary" @onclick="() => DepSelectAll(tgtOptions)">@L["Common_All"]</button>
                                                            <button class="btn btn-outline-secondary" @onclick="DepSelectNone">@L["Common_None"]</button>
                                                        </div>
                                                    </div>
                                                </div>
                                                @if (tgtOptions.Length > 8)
                                                {
                                                    <div class="px-3 pb-2 flex-shrink-0">
                                                        <input type="text" class="form-control form-control-sm"
                                                               placeholder="@L["Common_Search"]..."
                                                               @bind="_depTargetSearch"
                                                               @bind:event="oninput" />
                                                    </div>
                                                }
                                            </div>

                                            <div class="px-3 pb-3 overflow-y-auto flex-grow-1">
                                                @{
                                                    var compositeGroups = GetGroupedFieldDropdownValues(_depTargetFieldId);
                                                }
                                                @if (compositeGroups.Count > 0)
                                                {
                                                    @foreach (var (groupName, groupValues) in compositeGroups)
                                                    {
                                                        var depSetForGroup = _depMappings.GetValueOrDefault(_depActiveSourceValue!) ?? [];
                                                        var filteredGroupValues = groupValues
                                                            .Where(v => string.IsNullOrEmpty(_depTargetSearch) || v.Contains(_depTargetSearch, StringComparison.OrdinalIgnoreCase))
                                                            .Where(v => !_depTargetShowOnlySelected || depSetForGroup.Contains(v, StringComparer.OrdinalIgnoreCase))
                                                            .ToArray();
                                                        if (filteredGroupValues.Length == 0) continue;
                                                        var capturedGroup = filteredGroupValues;
                                                        var allGroupChecked = capturedGroup.All(v => depSetForGroup.Contains(v, StringComparer.OrdinalIgnoreCase));
                                                        <div class="mb-2">
                                                            <div class="d-flex justify-content-between align-items-center border-bottom pb-1 mb-1">
                                                                <span class="fw-semibold text-muted small">
                                                                    <i class="bi bi-collection me-1"></i>@groupName
                                                                </span>
                                                                <button type="button"
                                                                        class="btn btn-link btn-sm p-0 text-decoration-none"
                                                                        style="font-size: 0.7rem;"
                                                                        @onclick="() => DepToggleGroup(capturedGroup, !allGroupChecked)">
                                                                    @(allGroupChecked? L["Common_None"] : L["Common_All"])
                                                                </button>
                                                            </div>
                                                            <div class="row row-cols-1 row-cols-sm-2 g-1">
                                                                @foreach (var tgtVal in filteredGroupValues)
                                                                {
                                                                    var capturedTgt = tgtVal;
                                                                    var depSet = _depMappings.GetValueOrDefault(_depActiveSourceValue!) ?? [];
                                                                    var isChecked = depSet.Contains(capturedTgt, StringComparer.OrdinalIgnoreCase);
                                                                    <div class="col">
                                                                        <div class="form-check">
                                                                            <input class="form-check-input" type="checkbox" id="dep-@_depActiveSourceValue-@capturedTgt"
                                                                                   checked="@isChecked"
                                                                                   @onchange="e => ToggleDepMapping(_depActiveSourceValue, capturedTgt, (bool)(e.Value ?? false))" />
                                                                            <label class="form-check-label" for="dep-@_depActiveSourceValue-@capturedTgt">@capturedTgt</label>
                                                                        </div>
                                                                    </div>
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                }
                                                else
                                                {
                                                    <div class="row row-cols-1 row-cols-sm-2 g-1">
                                                        @{
                                                            var depSetForList = _depMappings.GetValueOrDefault(_depActiveSourceValue!) ?? [];
                                                        }
                                                        @foreach (var tgtVal in tgtOptions
                                                            .Where(v => string.IsNullOrEmpty(_depTargetSearch) || v.Contains(_depTargetSearch, StringComparison.OrdinalIgnoreCase))
                                                            .Where(v => !_depTargetShowOnlySelected || depSetForList.Contains(v, StringComparer.OrdinalIgnoreCase)))
                                                        {
                                                            var capturedTgt = tgtVal;
                                                            var isChecked = depSetForList.Contains(capturedTgt, StringComparer.OrdinalIgnoreCase);
                                                            <div class="col">
                                                                <div class="form-check">
                                                                    <input class="form-check-input" type="checkbox" id="dep-@_depActiveSourceValue-@capturedTgt"
                                                                           checked="@isChecked"
                                                                           @onchange="e => ToggleDepMapping(_depActiveSourceValue, capturedTgt, (bool)(e.Value ?? false))" />
                                                                    <label class="form-check-label" for="dep-@_depActiveSourceValue-@capturedTgt">@capturedTgt</label>
                                                                </div>
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>

                                <ErrorAlert Errors="_depErrors" OnDismiss="() => _depErrors = []" />
                                <div class="d-flex justify-content-end gap-2 mt-3">
                                    <button class="btn btn-outline-secondary btn-sm" @onclick="CloseDepEditor">@L["Common_Cancel"]</button>
                                    <button class="btn btn-primary btn-sm" @onclick="SaveAllDepMappingsAsync" disabled="@_savingDep">
                                        @if (_savingDep)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                        }
                                        <i class="bi bi-check-circle me-1"></i>@L["Common_SaveChanges"]
                                    </button>
                                </div>
                            }
                        }
                    </div>
                </div>
            }

            @* ── Rules summary grouped by source→target pair ── *@
            @if (GetGroupedDepRules().Count == 0 && !_depEditorOpen)
            {
                <div class="text-center text-muted py-4">
                    <i class="bi bi-link-45deg fs-3 d-block mb-2"></i>
                    <p>@L["Dep_NoRulesYet"]</p>
                </div>
            }
            else if (!_depEditorOpen)
            {
                <div class="list-group">
                    @foreach (var group in GetGroupedDepRules())
                    {
                        var first = group.First();
                        var pairKey = $"{first.SourceFieldId}|{first.TargetFieldId}";
                        var ruleCount = group.Count();
                        var mappedValues = group.Select(r => r.SourceValue).Where(v => v is not null).Distinct().ToList();
                        <div class="list-group-item list-group-item-action" style="cursor: pointer;" @onclick="() => OpenEditDepEditor(group.ToList())">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h6 class="mb-1">
                                        <i class="bi bi-link-45deg me-1 text-primary"></i>
                                        <span class="badge bg-secondary">@first.SourceFieldName</span>
                                        <i class="bi bi-arrow-right mx-1"></i>
                                        <span class="badge bg-info text-dark">@first.TargetFieldName</span>
                                        <span class="badge bg-primary ms-2">@ruleCount @(ruleCount == 1 ? L["Dep_Rule"] : L["Dep_Rules"])</span>
                                    </h6>
                                    <small class="text-muted">
                                        @L["Dep_MappedValues"]: @string.Join(", ", mappedValues.Take(5))@(mappedValues.Count > 5 ? $" (+{mappedValues.Count - 5})" : "")
                                    </small>
                                </div>
                                <div class="d-flex gap-1" @onclick:stopPropagation="true">
                                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => OpenEditDepEditor(group.ToList())" title="@L["Common_Edit"]">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteDepGroupAsync(group.ToList())" title="@L["Common_Delete"]">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        }
    }
    else if (_activeTab == "receipt")
    {
        <p class="text-muted mb-3">@L["RcptCfg_Hint"]</p>

        var decimalFields = _fields.Where(f => f.FieldType is FieldType.Decimal or FieldType.Integer).ToList();

        @if (decimalFields.Count == 0)
        {
            <div class="alert alert-info">
                <i class="bi bi-info-circle me-2"></i>@L["RcptCfg_NeedsDecimalField"]
            </div>
        }
        else if (_receiptConfig is null)
        {
            <div class="text-center py-4">
                <p class="text-muted mb-3"><i class="bi bi-receipt display-4 d-block mb-2 text-muted opacity-50"></i>@L["RcptCfg_NotConfigured"]</p>
                <button class="btn btn-primary" @onclick="EnableReceiptImportAsync">
                    <i class="bi bi-plus-circle me-1"></i>@L["RcptCfg_Enable"]
                </button>
            </div>
        }
        else
        {
            @* ── Field Mapping & Rules via shared editor ── *@
            <div class="mb-3 d-flex gap-2">
                <button class="btn btn-primary btn-sm" @onclick="SaveReceiptConfigAsync" disabled="@_savingRcptCfg">
                    @if (_savingRcptCfg)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    <i class="bi bi-check-circle me-1"></i>@L["Common_Save"]
                </button>
                <button class="btn btn-outline-danger btn-sm" @onclick="DisableReceiptImportAsync">
                    <i class="bi bi-x-circle me-1"></i>@L["RcptCfg_Disable"]
                </button>
            </div>

            <ReceiptFieldMappingEditor FieldMappings="_rcptFieldMappings"
                                       MappingRules="_rcptMappingRules"
                                       DropdownOptions="_rcptDropdownOptions"
                                       DependencyRules="_dependencyRules"
                                       OnMappingChanged="OnRcptFieldMappingChanged"
                                       OnAddRule="OnRcptAddRuleAsync"
                                       OnDeleteRule="DeleteRcptRuleAsync"
                                       OnUpdateRule="UpdateRcptRuleAsync">
                @{
                    var hasDiscountField = _rcptFieldMappings.Any(f => f.Source == ReceiptFieldMappingSource.ReceiptDiscount);
                    var dropdownFields = _fields.Where(f => f.FieldType is FieldType.Dropdown or FieldType.CompositeDropdown).ToList();
                    var discountTypeOptions = _rcptDiscountTypeFieldId.HasValue
                        && _rcptDropdownOptions.TryGetValue(_rcptDiscountTypeFieldId.Value, out var dtOpts)
                        ? dtOpts
                        : [];
                }
                <div class="card mb-3">
                    <div class="card-header">
                        <i class="bi bi-ticket-perforated me-2"></i>@L["RcptCfg_ReceiptDiscountSection"]
                    </div>
                    <div class="card-body">
                        <p class="text-muted small mb-3">@L["RcptCfg_ReceiptDiscountHint"]</p>

                        @if (!hasDiscountField)
                        {
                            <div class="alert alert-info small mb-0">
                                <i class="bi bi-info-circle me-1"></i>@L["RcptCfg_ReceiptDiscountNeedsDiscountField"]
                            </div>
                        }
                        else
                        {
                            <div class="row g-3">
                                <div class="col-12 col-md-6">
                                    <label class="form-label small">@L["RcptCfg_ReceiptDiscountTypeField"]</label>
                                    <select class="form-select form-select-sm"
                                            value="@(_rcptDiscountTypeFieldId?.ToString() ?? "")"
                                            @onchange="OnReceiptDiscountTypeFieldChanged">
                                        <option value="">— @L["Common_None"] —</option>
                                        @foreach (var f in dropdownFields)
                                        {
                                            <option value="@f.Id">@f.Name</option>
                                        }
                                    </select>
                                    <small class="text-muted">@L["RcptCfg_ReceiptDiscountTypeFieldHint"]</small>
                                </div>
                                <div class="col-12 col-md-6">
                                    <label class="form-label small">@L["RcptCfg_ReceiptDiscountTypeValue"]</label>
                                    @if (_rcptDiscountTypeFieldId.HasValue && discountTypeOptions.Count > 0)
                                    {
                                        <SearchableSelect Value="@_rcptDiscountTypeValue"
                                                          ValueChanged="v => _rcptDiscountTypeValue = string.IsNullOrWhiteSpace(v) ? null : v"
                                                          Options="discountTypeOptions"
                                                          Placeholder="@($"\u2014 {L["Common_Select"]} \u2014")"
                                                          Small="true" />
                                    }
                                    else
                                    {
                                        <input type="text" class="form-control form-control-sm"
                                               placeholder="@L["RcptCfg_ReceiptDiscountTypeValuePlaceholder"]"
                                               value="@(_rcptDiscountTypeValue ?? "")"
                                               @onchange="e => _rcptDiscountTypeValue = string.IsNullOrWhiteSpace(e.Value?.ToString()) ? null : e.Value!.ToString()" />
                                    }
                                    <small class="text-muted">@L["RcptCfg_ReceiptDiscountTypeValueHint"]</small>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </ReceiptFieldMappingEditor>
        }
    }
    else if (_activeTab == "connected")
    {
        <div class="d-flex justify-content-between align-items-center mb-3">
            <p class="text-muted mb-0">@L["ConnAct_Hint"]</p>
            <button class="btn btn-outline-primary btn-sm" @onclick="() => OpenConnectedRuleFormAsync(null)" disabled="@(_connRuleEditing is not null)">
                <i class="bi bi-plus-circle me-1"></i>@L["ConnAct_AddRule"]
            </button>
        </div>

        @if (_connRuleEditing is not null && !_connRuleEditing.Id.HasValue)
        {
            @RenderConnRuleEditForm()
        }

        @if (_connectedRules.Count == 0 && _connRuleEditing is null)
        {
            <div class="text-center text-muted py-4">
                <i class="bi bi-link-45deg fs-3 d-block mb-2"></i>
                <p>@L["ConnAct_NoRulesYet"]</p>
                <button class="btn btn-primary" @onclick="() => OpenConnectedRuleFormAsync(null)">
                    <i class="bi bi-plus-circle me-1"></i>@L["ConnAct_AddRule"]
                </button>
            </div>
        }
        else
        {
            <div class="list-group">
                @foreach (var rule in _connectedRules)
                {
                    var isInbound = rule.SourceTrackedActionId != Id;
                    var isPaired = rule.PairedRuleId.HasValue;
                    @if (_connRuleEditing is not null && _connRuleEditing.Id == rule.Id)
                    {
                        <div class="list-group-item p-0">
                            @RenderConnRuleEditForm()
                        </div>
                    }
                    else
                    {
                        <div class="list-group-item list-group-item-action" style="cursor: pointer;" @onclick="() => OpenConnectedRuleFormAsync(rule)">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h6 class="mb-1">
                                        <i class="bi bi-link-45deg me-1 text-primary"></i>
                                        @if (isInbound)
                                        {
                                            <span class="text-muted">@rule.SourceTrackedActionName</span>
                                            <i class="bi bi-arrow-right mx-1 text-muted"></i>
                                            <strong>@rule.TargetTrackedActionName</strong>
                                        }
                                        else
                                        {
                                            <strong>@rule.Name</strong>
                                            <i class="bi bi-arrow-right mx-1 text-muted"></i>
                                            <span class="text-primary">@rule.TargetTrackedActionName</span>
                                        }
                                    </h6>
                                    <small class="text-muted">
                                        <span class="badge @(rule.IsEnabled ? "bg-success" : "bg-secondary") me-1">
                                            @(rule.IsEnabled? L["ConnAct_Enabled"] : L["Common_No"])
                                        </span>
                                        @if (isPaired)
                                        {
                                            <span class="badge bg-info-subtle text-info-emphasis me-1">
                                                <i class="bi bi-arrow-left-right me-1"></i>@L["ConnAct_Bidirectional"]
                                            </span>
                                        }
                                        @if (isInbound)
                                        {
                                            <span class="badge bg-warning-subtle text-warning-emphasis me-1">
                                                <i class="bi bi-arrow-left me-1"></i>@L["ConnAct_Inbound"]
                                            </span>
                                        }
                                        @{
                                            var condCount = DeserializeConditions(rule.ConditionsJson).Count;
                                            var mapCount = DeserializeMappings(rule.FieldMappingsJson).Count;
                                        }
                                        @condCount @L["ConnAct_Conditions"].ToString().ToLower() · @mapCount @L["ConnAct_FieldMappings"].ToString().ToLower()
                                        @if (rule.CopyDate)
                                        {
                                            <span class="ms-1">📅</span>
                                        }
                                        @if (rule.CopyNotes)
                                        {
                                            <span class="ms-1">📝</span>
                                        }
                                    </small>
                                </div>
                                <div class="d-flex gap-1" @onclick:stopPropagation="true">
                                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => OpenConnectedRuleFormAsync(rule)" title="@L["Common_Edit"]">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteConnectedRuleAsync(rule)" title="@L["Common_Delete"]">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        }
    }
    else if (_activeTab == "customcharts")
    {
        <div class="d-flex justify-content-between align-items-center mb-3">
            <p class="text-muted mb-0">@L["CustomChart_TabHint"]</p>
            <button class="btn btn-outline-primary btn-sm" @onclick="StartCreateCustomChart" disabled="@(_ccShowForm && _ccEditingChart is null)">
                <i class="bi bi-plus-circle me-1"></i>@L["CustomChart_AddChart"]
            </button>
        </div>

        @if (_fields.Count == 0)
        {
            <div class="alert alert-info">
                <i class="bi bi-info-circle me-2"></i>@L["CustomChart_NeedFields"]
            </div>
        }
        else
        {
            @* New chart form (top) *@
            @if (_ccShowForm && _ccEditingChart is null)
            {
                @RenderCustomChartEditCard(null)
            }

            @if (_customCharts.Count == 0 && !_ccShowForm)
            {
                <div class="text-center text-muted py-4">
                    <i class="bi bi-bar-chart-steps fs-3 d-block mb-2"></i>
                    <p>@L["CustomChart_NoChartsYet"]</p>
                    <button class="btn btn-primary" @onclick="StartCreateCustomChart">
                        <i class="bi bi-plus-circle me-1"></i>@L["CustomChart_AddChart"]
                    </button>
                </div>
            }
            else if (_customCharts.Count > 0)
            {
                <div class="list-group">
                    @foreach (var chart in _customCharts)
                    {
                        @if (_ccShowForm && _ccEditingChart?.Id == chart.Id)
                        {
                            <div class="list-group-item p-0">
                                @RenderCustomChartEditCard(chart)
                            </div>
                        }
                        else
                        {
                            <div class="list-group-item list-group-item-action" style="cursor: pointer;" @onclick="() => StartEditCustomChart(chart)">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <h6 class="mb-1">
                                            <i class="bi bi-bar-chart-steps me-1 text-primary"></i>@chart.Title
                                        </h6>
                                        <small class="text-muted">
                                            @L["CustomChart_MeasureField"]: <strong>@chart.MeasureFieldName</strong>
                                            (@((AnalyticsAggregation)chart.Aggregation))
                                            @if (!string.IsNullOrEmpty(chart.GroupByFieldName))
                                            {
                                                <span class="ms-2">@L["CustomChart_GroupBy"]: <strong>@chart.GroupByFieldName</strong></span>
                                            }
                                        </small>
                                        <br />
                                        <small class="text-muted">
                                            @L["CustomChart_ChartType"]: <span class="badge bg-secondary">@((CustomChartType)chart.ChartType)</span>
                                            @if ((TimeGrouping)chart.TimeGrouping != TimeGrouping.None)
                                            {
                                                <span class="ms-2">@L["CustomChart_TimeGrouping"]: <span class="badge bg-info">@((TimeGrouping)chart.TimeGrouping)</span></span>
                                            }
                                            @if (chart.FilterConditions is not null)
                                            {
                                                <span class="ms-2 badge bg-warning text-dark">
                                                    <i class="bi bi-funnel me-1"></i>@L["CustomChart_Filters"]
                                                </span>
                                            }
                                        </small>
                                    </div>
                                    <div class="d-flex gap-1" @onclick:stopPropagation="true">
                                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => StartEditCustomChart(chart)" title="@L["Common_Edit"]">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteCustomChartAsync(chart)" title="@L["Common_Delete"]">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
            }
        }
    }
</div>
</div>
}
<HierarchyBuilderWizard IsVisible="_showHierarchyWizard"
                        TrackedActionId="Id"
                        NextFieldOrder="_fields.Count"
                        OnClose="() => _showHierarchyWizard = false"
                        OnBuilt="OnHierarchyBuiltAsync" />

<!-- Tag Selector Modal -->
<ModalSelector TItem="TagResponse"
               @bind-IsVisible="_showTagSelector"
               Title="@L["Modal_SelectTags"]"
               Icon="tags"
               LoadItems="() => TagService.GetAllAsync()"
               KeySelector="t => t.Id"
               SearchSelector="@(t => $"{t.Name} {t.Description}")"
               SearchPlaceholder="@L["Modal_SearchTags"]"
               EmptyText="@L["Modal_NoTagsAvailable"]"
