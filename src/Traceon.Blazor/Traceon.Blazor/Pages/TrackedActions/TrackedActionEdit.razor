                                    }
                                    <div class="col-6 col-md-3">
                                        <label class="form-label form-label-sm mb-1">@L["ConnAct_ConditionOperator"]</label>
                                        <select class="form-select form-select-sm" @bind="cond.Operator">
                                            @foreach (var op in GetOperatorsForField(condField))
