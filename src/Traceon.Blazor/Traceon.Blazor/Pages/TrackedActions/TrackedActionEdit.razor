@code {
    [Parameter] public Guid Id { get; set; }
    [Inject] private TrackedActionService Service { get; set; } = default!;
    [Inject] private TagService TagService { get; set; } = default!;
    [Inject] private FieldDefinitionService FieldDefinitionService { get; set; } = default!;
    [Inject] private ActionFieldService ActionFieldService { get; set; } = default!;
    [Inject] private FieldAnalyticsRuleService AnalyticsRuleService { get; set; } = default!;
    [Inject] private DropdownValueMetadataService MetadataService { get; set; } = default!;
    [Inject] private FieldDependencyRuleService DependencyRuleService { get; set; } = default!;
    [Inject] private ReceiptImportConfigService ReceiptConfigService { get; set; } = default!;
    [Inject] private ConnectedActionRuleService ConnRuleService { get; set; } = default!;
    [Inject] private ActionEntryService EntryService { get; set; } = default!;
    [Inject] private CustomChartApiService CustomChartApi { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;

    private EditModel? _model;
    private IReadOnlyList<string> _errors = [];
    private bool _loading = true;
    private bool _saving;
    private string _activeTab = "basic";
    private List<FieldDefinitionResponse> _allFieldDefinitions = [];

    // Tags
    private List<TagResponse> _tags = [];
    private List<Guid> _tagExcludedKeys => _tags.Select(t => t.Id).ToList();
    private bool _showTagSelector;
    private string _newTagName = string.Empty;
    private string _newTagColor = "#0d6efd";
    private bool _creatingTag;
    private IReadOnlyList<string> _tagCreateErrors = [];

    // Fields
    private List<ActionFieldResponse> _fields = [];
    private List<Guid> _fieldExcludedKeys => [];
    private bool _showFieldSelector;

    // Drag-and-drop reorder state
    private bool _savingOrder;

    // Analytics rules
    private List<FieldAnalyticsRuleResponse> _analyticsRules = [];
    private bool _showRuleForm;
    private bool _savingRule;
    private IReadOnlyList<string> _ruleErrors = [];
    private NewRuleModel _newRule = new();
    private Guid? _editingRuleId;
    private EditRuleModel _editRule = new();
    private Dictionary<Guid, List<DropdownValueMetadataFieldResponse>> _dropdownMetadataSchemas = new();

    // Connected Actions
    private List<ConnectedActionRuleResponse> _connectedRules = [];
    private List<TrackedActionResponse> _allActions = [];
    private List<ActionFieldResponse> _connSourceFields = [];
    private List<ActionFieldResponse> _connTargetFields = [];
    private ConnRuleEditModel? _connRuleEditing;
    private bool _savingConnRule;
    private IReadOnlyList<string> _connRuleErrors = [];
    private bool _connTabLoaded;
    private int _connEditorLoadVersion;

    // Custom Charts
    private List<CustomChartResponse> _customCharts = [];
    private bool _customChartsTabLoaded;
    private Dictionary<Guid, string[]> _resolvedDropdownValues = [];
    private bool _ccShowForm;
    private CustomChartResponse? _ccEditingChart;

    private string TabStorageKey => $"traceon_action_edit_tab_{Id}";
    private static readonly HashSet<string> _knownTabs =
        ["basic", "fields", "tags", "entries", "dependencies", "analytics", "receipt", "connected", "customcharts"];

    protected override async Task OnInitializedAsync()
    {
        var action = await Service.GetByIdAsync(Id);

        if (action is not null)
        {
            _model = new EditModel
            {
                Name = action.Name,
                Description = action.Description
            };

            var tagsTask = Service.GetTagsAsync(Id);
            var fieldsTask = ActionFieldService.GetByTrackedActionAsync(Id);
            var fieldDefsTask = FieldDefinitionService.GetAllAsync();
            await Task.WhenAll(tagsTask, fieldsTask, fieldDefsTask);

            _tags = tagsTask.Result;
            _fields = fieldsTask.Result;
            _allFieldDefinitions = fieldDefsTask.Result;

            await LoadDropdownMetadataSchemasAsync();
            await RestoreActiveTabAsync();
        }

        _loading = false;
    }

    private async Task RestoreActiveTabAsync()
    {
        try
        {
            var stored = await LocalStorage.GetItemAsync<string>(TabStorageKey);
            if (!string.IsNullOrEmpty(stored) && _knownTabs.Contains(stored))
            {
                _activeTab = stored;
                // Trigger lazy-loaders for tabs that defer data fetching.
                switch (stored)
                {
                    case "dependencies":
                        if (_dependencyRules.Count == 0) await LoadDependencyRulesAsync();
                        break;
                    case "analytics":
                        if (_analyticsRules.Count == 0) await LoadAnalyticsRulesAsync();
                        break;
                    case "receipt":
                        await LoadReceiptConfigAsync();
                        break;
                    case "connected":
                        if (!_connTabLoaded)
                        {
                            _connTabLoaded = true;
                            var rulesTask = ConnRuleService.GetByTrackedActionAsync(Id);
                            var actionsTask = Service.GetAllAsync();
                            await Task.WhenAll(rulesTask, actionsTask);
                            _connectedRules = rulesTask.Result;
                            _allActions = actionsTask.Result;
                        }
                        break;
                    case "customcharts":
                        if (!_customChartsTabLoaded)
                        {
                            BuildResolvedDropdownValues();
                            await LoadCustomChartsAsync();
                        }
                        break;
                }
            }
        }
        catch { /* localStorage may be unavailable */ }
    }

    private async Task SetActiveTabAsync(string tab)
    {
        _activeTab = tab;
        try { await LocalStorage.SetItemAsync(TabStorageKey, tab); } catch { }
    }

    private async Task LoadDropdownMetadataSchemasAsync()
    {
        var dropdownFieldDefIds = _fields
            .Where(f => f.FieldType == FieldType.Dropdown)
            .Select(f => f.FieldDefinitionId)
            .Distinct()
            .ToList();

        if (dropdownFieldDefIds.Count == 0) return;

        var tasks = dropdownFieldDefIds.Select(async id =>
            (id, schema: await MetadataService.GetFieldsAsync(id)));

        var results = await Task.WhenAll(tasks);
        _dropdownMetadataSchemas = results
            .Where(r => r.schema.Count > 0)
            .ToDictionary(r => r.id, r => r.schema.OrderBy(s => s.SortOrder).ToList());
    }

    private List<DropdownValueMetadataFieldResponse>? GetMetadataSchemaForField(Guid actionFieldId)
    {
        var af = _fields.FirstOrDefault(f => f.Id == actionFieldId);
        if (af is null || af.FieldType != FieldType.Dropdown) return null;
        return _dropdownMetadataSchemas.GetValueOrDefault(af.FieldDefinitionId);
    }

    private async Task SaveBasicInfoAsync()
    {
        if (_model is null) return;

        _saving = true;
        _errors = [];

        var (success, errors) = await Service.UpdateAsync(Id, new UpdateTrackedActionRequest(_model.Name, _model.Description));

        if (success)
            Nav.NavigateTo("/tracked-actions");
        else
            _errors = errors.Count > 0 ? errors : [L["Edit_UpdateFailed"]];

        _saving = false;
    }

    // Tags
    private async Task OnTagsSelectedAsync(List<TagResponse> tags)
    {
        _errors = [];
        foreach (var tag in tags)
        {
            var (ok, errs) = await Service.AddTagAsync(Id, tag.Id);
            if (ok)
                _tags.Add(tag);
            else
            {
                _errors = errs;
                return;
            }
        }
    }

    private async Task RemoveTagAsync(TagResponse tag)
    {
        _errors = [];
        var (ok, errs) = await Service.RemoveTagAsync(Id, tag.Id);
        if (ok)
            _tags.Remove(tag);
        else
            _errors = errs;
    }

    private async Task CreateTagInlineAsync(EventCallback onCreated)
    {
        if (string.IsNullOrWhiteSpace(_newTagName)) return;
        _creatingTag = true;
        _tagCreateErrors = [];

        var (success, errors) = await TagService.CreateAsync(
            new CreateTagRequest(_newTagName.Trim(), null, _newTagColor));

        if (success)
        {
            _newTagName = string.Empty;
            _newTagColor = "#0d6efd";
            await onCreated.InvokeAsync();
        }
        else
        {
            _tagCreateErrors = errors;
        }
        _creatingTag = false;
    }

    // Fields
    private async Task OnFieldsSelectedAsync(List<FieldDefinitionResponse> definitions)
    {
        _errors = [];
        var nextOrder = _fields.Count > 0 ? _fields.Max(f => f.Order) + 1 : 0;

        foreach (var def in definitions)
        {
            var request = new CreateActionFieldRequest(def.Id, def.DefaultName,
                def.DefaultDescription, def.DefaultMaxValue, def.DefaultMinValue,
                def.DefaultIsRequired, def.DefaultValue, def.Unit, nextOrder++);

            var (ok, errs) = await ActionFieldService.CreateAsync(Id, request);
            if (!ok)
            {
                _errors = errs;
                return;
            }
        }

        // Reload fields to get the server-assigned IDs
        _fields = await ActionFieldService.GetByTrackedActionAsync(Id);
    }

    private async Task RemoveFieldAsync(ActionFieldResponse field)
    {
        _errors = [];
        var (ok, errs) = await ActionFieldService.DeleteAsync(Id, field.Id);
        if (ok)
            _fields.Remove(field);
        else
            _errors = errs;
    }

    private async Task ReloadFieldsAsync()
    {
        _fields = await ActionFieldService.GetByTrackedActionAsync(Id);
    }

    private async Task OnFieldCreatedInlineAsync(FieldDefinitionResponse def, EventCallback onCreated)
    {
        await OnFieldsSelectedAsync([def]);
        await onCreated.InvokeAsync();
    }

    // Reorder handlers
    private async Task MoveFieldAsync(int index, int direction)
    {
        var targetIndex = index + direction;
        if (targetIndex < 0 || targetIndex >= _fields.Count) return;

        (_fields[index], _fields[targetIndex]) = (_fields[targetIndex], _fields[index]);
        await SaveFieldOrderAsync();
    }

    private async Task SaveFieldOrderAsync()
    {
        _savingOrder = true;
        _errors = [];

        for (var i = 0; i < _fields.Count; i++)
        {
            var field = _fields[i];
            if (field.Order == i) continue;

            var request = new UpdateActionFieldRequest(
                field.Name, field.Description, field.MaxValue, field.MinValue,
                field.IsRequired, field.DefaultValue, field.Unit, i,
                field.SummaryMetrics, field.TrendAggregation, field.TrendChartType, field.TargetValue);

            var (ok, errs) = await ActionFieldService.UpdateAsync(Id, field.Id, request);
            if (!ok)
            {
                _errors = errs;
                break;
            }
        }

        _fields = await ActionFieldService.GetByTrackedActionAsync(Id);
        _savingOrder = false;
    }

    // Analytics rules
    private async Task ActivateAnalyticsTabAsync()
    {
        await SetActiveTabAsync("analytics");
        if (_analyticsRules.Count == 0)
            await LoadAnalyticsRulesAsync();
    }

    private async Task LoadAnalyticsRulesAsync()
    {
        try
        {
            _analyticsRules = await AnalyticsRuleService.GetByTrackedActionAsync(Id);
        }
        catch
        {
            _analyticsRules = [];
        }
    }

    private async Task SaveRuleAsync()
    {
        _ruleErrors = [];

        if (_newRule.MeasureFieldId == Guid.Empty || _newRule.GroupByFieldId == Guid.Empty)
        {
            _ruleErrors = [L["Analytics_SelectBothFields"]];
            return;
        }

        if (_newRule.Aggregation == AnalyticsAggregation.AggregateByValue && _newRule.SignFieldId == Guid.Empty)
        {
            _ruleErrors = [L["Analytics_AggregateByValueRequiresField"]];
            return;
        }

        _savingRule = true;

        var offsetActive = _newRule.OffsetEnabled
            && _newRule.OffsetTriggerFieldId != Guid.Empty
            && _newRule.OffsetValueFieldId != Guid.Empty
            && !string.IsNullOrWhiteSpace(_newRule.OffsetTriggerValues);

        var request = new CreateFieldAnalyticsRuleRequest(
            _newRule.MeasureFieldId,
            _newRule.GroupByFieldId,
            _newRule.Aggregation,
            _newRule.DisplayType,
            _newRule.FilterFieldId != Guid.Empty ? _newRule.FilterFieldId : null,
            string.IsNullOrWhiteSpace(_newRule.FilterValue) ? null : _newRule.FilterValue,
            string.IsNullOrWhiteSpace(_newRule.Label) ? null : _newRule.Label,
            _analyticsRules.Count,
            _newRule.SignFieldId != Guid.Empty ? _newRule.SignFieldId : null,
            string.IsNullOrWhiteSpace(_newRule.NegativeValues) ? null : _newRule.NegativeValues,
            _newRule.GroupByMetadataFieldId != Guid.Empty ? _newRule.GroupByMetadataFieldId : null,
            _newRule.FilterMetadataFieldId != Guid.Empty ? _newRule.FilterMetadataFieldId : null,
            offsetActive ? _newRule.OffsetTriggerFieldId : null,
            offsetActive ? _newRule.OffsetTriggerValues : null,
            offsetActive ? _newRule.OffsetValueFieldId : null,
            offsetActive ? _newRule.OffsetDirection : null,
            _newRule.Aggregation == AnalyticsAggregation.SignedSum && _newRule.CollapseByImportBatch);

        var (ok, errs) = await AnalyticsRuleService.CreateAsync(Id, request);

        if (ok)
        {
            ResetRuleForm();
            await LoadAnalyticsRulesAsync();
        }
        else
        {
            _ruleErrors = errs;
        }

        _savingRule = false;
    }

    private async Task DeleteRuleAsync(FieldAnalyticsRuleResponse rule)
    {
        _errors = [];
        var (ok, errs) = await AnalyticsRuleService.DeleteAsync(Id, rule.Id);
        if (ok)
            _analyticsRules.Remove(rule);
        else
            _errors = errs;
    }

    private void ResetRuleForm()
    {
        _showRuleForm = false;
        _newRule = new();
        _ruleErrors = [];
    }

    private void StartEditRule(FieldAnalyticsRuleResponse rule)
    {
        _editingRuleId = rule.Id;
        _editRule = new EditRuleModel
        {
            Aggregation = rule.Aggregation,
            DisplayType = rule.DisplayType,
            Label = rule.Label,
            FilterFieldId = rule.FilterFieldId ?? Guid.Empty,
            FilterValue = rule.FilterValue,
            SignFieldId = rule.SignFieldId ?? Guid.Empty,
            NegativeValues = rule.NegativeValues,
            GroupByMetadataFieldId = rule.GroupByMetadataFieldId ?? Guid.Empty,
            FilterMetadataFieldId = rule.FilterMetadataFieldId ?? Guid.Empty,
            OffsetEnabled = rule.OffsetTriggerFieldId.HasValue && rule.OffsetValueFieldId.HasValue,
            OffsetTriggerFieldId = rule.OffsetTriggerFieldId ?? Guid.Empty,
            OffsetTriggerValues = rule.OffsetTriggerValues,
            OffsetValueFieldId = rule.OffsetValueFieldId ?? Guid.Empty,
            OffsetDirection = rule.OffsetDirection ?? AnalyticsOffsetDirection.Subtract,
            CollapseByImportBatch = rule.CollapseByImportBatch
        };
        _ruleErrors = [];
        _showRuleForm = false;
    }

    private void CancelEditRule()
    {
        _editingRuleId = null;
        _editRule = new();
        _ruleErrors = [];
    }

    private RenderFragment RenderMetadataFilterInput(
        DropdownValueMetadataFieldResponse meta,
        string? currentValue,
        Action<string?> setValue,
        string prefix) => __builder =>
    {
        var value = currentValue ?? string.Empty;

        switch (meta.Type)
        {
            case FieldType.Boolean:
                <select class="form-select" value="@value" @onchange="e => setValue(e.Value?.ToString())">
                    <option value="">—</option>
                    <option value="true">True</option>
                    <option value="false">False</option>
                </select>
                break;

            case FieldType.Dropdown when !string.IsNullOrWhiteSpace(meta.DropdownValues):
                <SearchableSelect Value="@value"
                                  ValueChanged="v => setValue(v)"
                                  Options="@(DropdownValuesHelper.Split(meta.DropdownValues).OrderBy(v => v, StringComparer.CurrentCultureIgnoreCase).ToList())"
                                  Placeholder="—" />
                break;

            case FieldType.Integer:
                <input type="number" step="1" class="form-control" value="@value"
                       @onchange="e => setValue(e.Value?.ToString())" />
                break;

            case FieldType.Decimal:
                <input type="number" step="any" class="form-control" value="@value"
                       @onchange="e => setValue(e.Value?.ToString())" />
                break;

            case FieldType.Date:
                <input type="date" class="form-control" value="@value"
                       @onchange="e => setValue(e.Value?.ToString())" />
                break;

            default:
                <input type="text" class="form-control" value="@value"
                       @onchange="e => setValue(e.Value?.ToString())" />
                break;
        }
    };

    private static string? ToggleNegativeValue(string? current, string value, bool isChecked)
    {
        var set = DropdownValuesHelper.Split(current)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        if (isChecked)
            set.Add(value);
        else
            set.Remove(value);

        return set.Count > 0 ? DropdownValuesHelper.Join(set) : null;
    }

    private async Task UpdateRuleAsync()
    {
        if (_editingRuleId is null) return;

        _ruleErrors = [];

        if (_editRule.Aggregation == AnalyticsAggregation.AggregateByValue && _editRule.SignFieldId == Guid.Empty)
        {
            _ruleErrors = [L["Analytics_AggregateByValueRequiresField"]];
            return;
        }

        _savingRule = true;

        var offsetActive = _editRule.OffsetEnabled
            && _editRule.OffsetTriggerFieldId != Guid.Empty
            && _editRule.OffsetValueFieldId != Guid.Empty
            && !string.IsNullOrWhiteSpace(_editRule.OffsetTriggerValues);

        var request = new UpdateFieldAnalyticsRuleRequest(
            _editRule.Aggregation,
            _editRule.DisplayType,
            _editRule.FilterFieldId != Guid.Empty ? _editRule.FilterFieldId : null,
            string.IsNullOrWhiteSpace(_editRule.FilterValue) ? null : _editRule.FilterValue,
            string.IsNullOrWhiteSpace(_editRule.Label) ? null : _editRule.Label,
            SignFieldId: _editRule.SignFieldId != Guid.Empty ? _editRule.SignFieldId : null,
            NegativeValues: string.IsNullOrWhiteSpace(_editRule.NegativeValues) ? null : _editRule.NegativeValues,
            ClearSignField: _editRule.SignFieldId == Guid.Empty,
            GroupByMetadataFieldId: _editRule.GroupByMetadataFieldId != Guid.Empty ? _editRule.GroupByMetadataFieldId : null,
            ClearGroupByMetadataField: _editRule.GroupByMetadataFieldId == Guid.Empty,
            FilterMetadataFieldId: _editRule.FilterMetadataFieldId != Guid.Empty ? _editRule.FilterMetadataFieldId : null,
            ClearFilterMetadataField: _editRule.FilterMetadataFieldId == Guid.Empty,
            OffsetTriggerFieldId: offsetActive ? _editRule.OffsetTriggerFieldId : null,
            OffsetTriggerValues: offsetActive ? _editRule.OffsetTriggerValues : null,
            OffsetValueFieldId: offsetActive ? _editRule.OffsetValueFieldId : null,
            OffsetDirection: offsetActive ? _editRule.OffsetDirection : null,
            ClearOffset: !offsetActive,
            CollapseByImportBatch: _editRule.Aggregation == AnalyticsAggregation.SignedSum && _editRule.CollapseByImportBatch);

        var (ok, errs) = await AnalyticsRuleService.UpdateAsync(Id, _editingRuleId.Value, request);

        if (ok)
        {
            CancelEditRule();
            await LoadAnalyticsRulesAsync();
        }
        else
        {
            _ruleErrors = errs;
        }

        _savingRule = false;
    }

