    private string[] GetFieldDropdownValues(Guid fieldId)
    {
        var field = _dropdownFields.FirstOrDefault(f => f.Id == fieldId);
        if (field?.DropdownValues is null) return [];

        if (field.FieldType == FieldType.CompositeDropdown && field.DropdownValues.StartsWith("ref:", StringComparison.Ordinal))
        {
            var refIds = field.DropdownValues["ref:".Length..]
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Select(s => Guid.TryParse(s, out var id) ? id : Guid.Empty)
                .Where(id => id != Guid.Empty)
                .ToHashSet();

            return _allFieldDefinitions
                .Where(fd => fd.Type == FieldType.Dropdown && refIds.Contains(fd.Id) && !string.IsNullOrWhiteSpace(fd.DropdownValues))
                .SelectMany(fd => DropdownValuesHelper.Split(fd.DropdownValues))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(v => v, StringComparer.CurrentCultureIgnoreCase)
                .ToArray();
        }

        return DropdownValuesHelper.Split(field.DropdownValues)
            .OrderBy(v => v, StringComparer.CurrentCultureIgnoreCase).ToArray();
    }

    private List<(string GroupName, string[] Values)> GetGroupedFieldDropdownValues(Guid fieldId)
    {
        var field = _dropdownFields.FirstOrDefault(f => f.Id == fieldId);
        if (field?.DropdownValues is null) return [];

        if (field.FieldType == FieldType.CompositeDropdown && field.DropdownValues.StartsWith("ref:", StringComparison.Ordinal))
        {
            var refIds = field.DropdownValues["ref:".Length..]
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Select(s => Guid.TryParse(s, out var id) ? id : Guid.Empty)
                .Where(id => id != Guid.Empty)
                .ToList();

            return refIds
                .Select(id => _allFieldDefinitions.FirstOrDefault(fd => fd.Id == id))
                .Where(fd => fd is not null && fd.Type == FieldType.Dropdown && !string.IsNullOrWhiteSpace(fd.DropdownValues))
                .Select(fd => (
                    GroupName: fd!.DefaultName,
                    Values: DropdownValuesHelper.Split(fd!.DropdownValues)
                        .OrderBy(v => v, StringComparer.CurrentCultureIgnoreCase)
                        .ToArray()))
                .Where(g => g.Values.Length > 0)
                .OrderBy(g => g.GroupName, StringComparer.CurrentCultureIgnoreCase)
                .ToList();
        }

        return [];
    }

    private bool IsCompositeDropdownTarget(Guid fieldId)
    {
        var field = _dropdownFields.FirstOrDefault(f => f.Id == fieldId);
        return field?.FieldType == FieldType.CompositeDropdown;
    }

