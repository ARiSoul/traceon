    private void OpenEditDepEditor(List<FieldDependencyRuleResponse> group)
    {
        var first = group.First();
        _depEditorOpen = true;
        _depEditingPairKey = $"{first.SourceFieldId}|{first.TargetFieldId}";
        _depSourceFieldId = first.SourceFieldId;
        _depTargetFieldId = first.TargetFieldId;
        _depErrors = [];
        _depSourceSearch = "";
        _depTargetSearch = "";
        _depTargetShowOnlySelected = false;

        _depMappings = new(StringComparer.OrdinalIgnoreCase);
        foreach (var rule in group)
        {
            if (rule.SourceValue is not null && rule.TargetConstraint is not null)
            {
                var values = DropdownValuesHelper.Split(rule.TargetConstraint)
                    .ToHashSet(StringComparer.OrdinalIgnoreCase);
                _depMappings[rule.SourceValue] = values;
            }
        }

        var srcOptions = GetFieldDropdownValues(_depSourceFieldId);
        _depActiveSourceValue = srcOptions.FirstOrDefault();
    }

