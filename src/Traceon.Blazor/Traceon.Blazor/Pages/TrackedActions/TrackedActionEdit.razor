        public Guid FilterFieldId { get; set; }
        public string? FilterValue { get; set; }
        public string? Label { get; set; }
        public Guid SignFieldId { get; set; }
        public string? NegativeValues { get; set; }
    }

    private sealed class EditRuleModel
    {
        public AnalyticsAggregation Aggregation { get; set; } = AnalyticsAggregation.Sum;
        public AnalyticsDisplayType DisplayType { get; set; } = AnalyticsDisplayType.BarChart;
        public Guid FilterFieldId { get; set; }
        public string? FilterValue { get; set; }
        public string? Label { get; set; }
        public Guid SignFieldId { get; set; }
        public string? NegativeValues { get; set; }
    }

    // ── Dependency rules ──

    private List<FieldDependencyRuleResponse> _dependencyRules = [];
    private List<ActionFieldResponse> _dropdownFields => _fields.Where(f => f.FieldType is FieldType.Dropdown or FieldType.CompositeDropdown).ToList();
    private bool _savingDep;
    private IReadOnlyList<string> _depErrors = [];
    private bool _showHierarchyWizard;

    private async Task OnHierarchyBuiltAsync()
    {
        _showHierarchyWizard = false;
        await ReloadFieldsAsync();
        await LoadDependencyRulesAsync();
        _allFieldDefinitions = await FieldDefinitionService.GetAllAsync();
    }

    // Editor state
    private bool _depEditorOpen;
    private string? _depEditingPairKey;
    private Guid _depSourceFieldId;
    private Guid _depTargetFieldId;
    private string? _depActiveSourceValue;
    private Dictionary<string, HashSet<string>> _depMappings = new(StringComparer.OrdinalIgnoreCase);
    private string _depSourceSearch = "";
    private string _depTargetSearch = "";

    private async Task ActivateDependenciesTabAsync()
    {
        _activeTab = "dependencies";
        if (_dependencyRules.Count == 0)
            await LoadDependencyRulesAsync();
    }

    private async Task LoadDependencyRulesAsync()
    {
        try
        {
            _dependencyRules = await DependencyRuleService.GetByTrackedActionAsync(Id);
        }
        catch
        {
            _dependencyRules = [];
        }
    }

    private List<IGrouping<(Guid SourceFieldId, Guid TargetFieldId), FieldDependencyRuleResponse>> GetGroupedDepRules()
        => _dependencyRules.GroupBy(r => (r.SourceFieldId, r.TargetFieldId)).ToList();

    private string[] GetFieldDropdownValues(Guid fieldId)
    {
        var field = _dropdownFields.FirstOrDefault(f => f.Id == fieldId);
        if (field?.DropdownValues is null) return [];

        if (field.FieldType == FieldType.CompositeDropdown && field.DropdownValues.StartsWith("ref:", StringComparison.Ordinal))
        {
            var refIds = field.DropdownValues["ref:".Length..]
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Select(s => Guid.TryParse(s, out var id) ? id : Guid.Empty)
                .Where(id => id != Guid.Empty)
                .ToHashSet();

            return _allFieldDefinitions
                .Where(fd => fd.Type == FieldType.Dropdown && refIds.Contains(fd.Id) && !string.IsNullOrWhiteSpace(fd.DropdownValues))
                .SelectMany(fd => fd.DropdownValues!.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(v => v, StringComparer.CurrentCultureIgnoreCase)
                .ToArray();
        }

        return field.DropdownValues.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .OrderBy(v => v, StringComparer.CurrentCultureIgnoreCase).ToArray();
    }

    private List<(string GroupName, string[] Values)> GetGroupedFieldDropdownValues(Guid fieldId)
    {
        var field = _dropdownFields.FirstOrDefault(f => f.Id == fieldId);
        if (field?.DropdownValues is null) return [];

        if (field.FieldType == FieldType.CompositeDropdown && field.DropdownValues.StartsWith("ref:", StringComparison.Ordinal))
        {
            var refIds = field.DropdownValues["ref:".Length..]
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Select(s => Guid.TryParse(s, out var id) ? id : Guid.Empty)
                .Where(id => id != Guid.Empty)
                .ToList();

            return refIds
                .Select(id => _allFieldDefinitions.FirstOrDefault(fd => fd.Id == id))
                .Where(fd => fd is not null && fd.Type == FieldType.Dropdown && !string.IsNullOrWhiteSpace(fd.DropdownValues))
                .Select(fd => (
                    GroupName: fd!.DefaultName,
                    Values: fd.DropdownValues!
                        .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                        .OrderBy(v => v, StringComparer.CurrentCultureIgnoreCase)
                        .ToArray()))
                .Where(g => g.Values.Length > 0)
                .OrderBy(g => g.GroupName, StringComparer.CurrentCultureIgnoreCase)
                .ToList();
        }

        return [];
    }

    private bool IsCompositeDropdownTarget(Guid fieldId)
    {
        var field = _dropdownFields.FirstOrDefault(f => f.Id == fieldId);
        return field?.FieldType == FieldType.CompositeDropdown;
    }

    private void OpenNewDepEditor()
    {
        _depEditorOpen = true;
        _depEditingPairKey = null;
        _depSourceFieldId = Guid.Empty;
        _depTargetFieldId = Guid.Empty;
        _depActiveSourceValue = null;
        _depMappings = new(StringComparer.OrdinalIgnoreCase);
        _depErrors = [];
        _depSourceSearch = "";
        _depTargetSearch = "";
    }

    private void OpenEditDepEditor(List<FieldDependencyRuleResponse> group)
    {
        var first = group.First();
        _depEditorOpen = true;
        _depEditingPairKey = $"{first.SourceFieldId}|{first.TargetFieldId}";
        _depSourceFieldId = first.SourceFieldId;
        _depTargetFieldId = first.TargetFieldId;
        _depErrors = [];
        _depSourceSearch = "";
        _depTargetSearch = "";

        _depMappings = new(StringComparer.OrdinalIgnoreCase);
        foreach (var rule in group)
        {
            if (rule.SourceValue is not null && rule.TargetConstraint is not null)
            {
                var values = rule.TargetConstraint
                    .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                    .ToHashSet(StringComparer.OrdinalIgnoreCase);
                _depMappings[rule.SourceValue] = values;
            }
        }

        var srcOptions = GetFieldDropdownValues(_depSourceFieldId);
        _depActiveSourceValue = srcOptions.FirstOrDefault();
    }

    private void SelectDepSourceValue(string value)
    {
        _depActiveSourceValue = value;
        _depTargetSearch = string.Empty;
    }

    private void CloseDepEditor()
    {
        _depEditorOpen = false;
        _depEditingPairKey = null;
        _depActiveSourceValue = null;
        _depMappings = new(StringComparer.OrdinalIgnoreCase);
        _depErrors = [];
        _depSourceSearch = "";
        _depTargetSearch = "";
    }

    private void OnDepSourceFieldChanged(ChangeEventArgs e)
    {
        _depSourceFieldId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : Guid.Empty;
        _depActiveSourceValue = null;
        _depMappings = new(StringComparer.OrdinalIgnoreCase);
        _depSourceSearch = "";
        _depTargetSearch = "";
        if (_depTargetFieldId == _depSourceFieldId)
            _depTargetFieldId = Guid.Empty;
    }

    private void OnDepTargetFieldChanged(ChangeEventArgs e)
    {
        _depTargetFieldId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : Guid.Empty;
        _depMappings = new(StringComparer.OrdinalIgnoreCase);
    }

    private void ToggleDepMapping(string sourceValue, string targetValue, bool isChecked)
    {
        if (!_depMappings.TryGetValue(sourceValue, out var set))
        {
            set = new(StringComparer.OrdinalIgnoreCase);
            _depMappings[sourceValue] = set;
        }

        if (isChecked) set.Add(targetValue);
        else set.Remove(targetValue);

        if (set.Count == 0) _depMappings.Remove(sourceValue);
    }

    private void DepSelectAll(string[] tgtOptions)
    {
        if (_depActiveSourceValue is null) return;
        _depMappings[_depActiveSourceValue] = new(tgtOptions, StringComparer.OrdinalIgnoreCase);
    }

    private void DepSelectNone()
    {
        if (_depActiveSourceValue is null) return;
        _depMappings.Remove(_depActiveSourceValue);
    }

    private void DepToggleGroup(string[] groupValues, bool select)
    {
        if (_depActiveSourceValue is null) return;
        if (!_depMappings.TryGetValue(_depActiveSourceValue, out var set))
        {
            set = new(StringComparer.OrdinalIgnoreCase);
            _depMappings[_depActiveSourceValue] = set;
        }

        foreach (var val in groupValues)
        {
            if (select) set.Add(val);
            else set.Remove(val);
        }

        if (set.Count == 0) _depMappings.Remove(_depActiveSourceValue);
    }

    private async Task SaveAllDepMappingsAsync()
    {
        _depErrors = [];

        if (_depSourceFieldId == Guid.Empty || _depTargetFieldId == Guid.Empty)
        {
            _depErrors = [L["Dep_SelectBothFields"]];
            return;
        }

        var mappingsWithValues = _depMappings
            .Where(kv => kv.Value.Count > 0)
            .ToDictionary(kv => kv.Key, kv => string.Join(",", kv.Value), StringComparer.OrdinalIgnoreCase);

        if (mappingsWithValues.Count == 0)
        {
            _depErrors = [L["Dep_SelectAllowedValues"]];
            return;
        }

        _savingDep = true;

        var existingForPair = _dependencyRules
            .Where(r => r.SourceFieldId == _depSourceFieldId && r.TargetFieldId == _depTargetFieldId)
            .ToList();

        var existingBySource = existingForPair
            .Where(r => r.SourceValue is not null)
            .ToDictionary(r => r.SourceValue!, r => r, StringComparer.OrdinalIgnoreCase);

        var hasError = false;

        foreach (var (srcVal, constraint) in mappingsWithValues)
        {
            if (existingBySource.TryGetValue(srcVal, out var existing))
            {
                if (!string.Equals(existing.TargetConstraint, constraint, StringComparison.OrdinalIgnoreCase))
                {
                    var (ok, errs) = await DependencyRuleService.UpdateAsync(Id, existing.Id,
                        new UpdateFieldDependencyRuleRequest(TargetConstraint: constraint));
                    if (!ok) { _depErrors = errs; hasError = true; break; }
                }
                existingBySource.Remove(srcVal);
            }
            else
            {
                var (ok, errs) = await DependencyRuleService.CreateAsync(Id,
                    new CreateFieldDependencyRuleRequest(_depSourceFieldId, srcVal, _depTargetFieldId,
                        DependencyRuleType.FilterDropdownValues, constraint, _dependencyRules.Count));
                if (!ok) { _depErrors = errs; hasError = true; break; }
            }
        }

        if (!hasError)
        {
            foreach (var leftover in existingBySource.Values)
            {
                var (ok, errs) = await DependencyRuleService.DeleteAsync(Id, leftover.Id);
                if (!ok) { _depErrors = errs; break; }
            }
        }

        await LoadDependencyRulesAsync();

        if (_depErrors.Count == 0)
            CloseDepEditor();

        _savingDep = false;
    }

    private async Task DeleteDepGroupAsync(List<FieldDependencyRuleResponse> group)
    {
        _errors = [];
        foreach (var rule in group)
        {
            var (ok, errs) = await DependencyRuleService.DeleteAsync(Id, rule.Id);
            if (!ok) { _errors = errs; break; }
        }
        await LoadDependencyRulesAsync();
    }

    // ── Receipt Import Config ──

    private static readonly System.Text.Json.JsonSerializerOptions _jsonOpts = new() { PropertyNameCaseInsensitive = true };

    private ReceiptImportConfigResponse? _receiptConfig;
    private List<ReceiptMappingRuleResponse> _rcptMappingRules = [];
    private List<ReceiptFieldMapping> _rcptFieldMappings = [];
    private Dictionary<Guid, List<string>> _rcptDropdownOptions = [];
    private bool _savingRcptCfg;

    private async Task ActivateReceiptTabAsync()
    {
        _activeTab = "receipt";
        await LoadReceiptConfigAsync();
    }

    private async Task LoadReceiptConfigAsync()
    {
        try
        {
            _receiptConfig = await ReceiptConfigService.GetByActionAsync(Id);
            if (_receiptConfig is not null)
            {
                _rcptMappingRules = await ReceiptConfigService.GetMappingRulesAsync(Id);
            }
            else
            {
                _rcptMappingRules = [];
            }

            BuildRcptFieldMappings();
        }
        catch { _receiptConfig = null; _rcptMappingRules = []; _rcptFieldMappings = []; }
    }

    private void BuildRcptFieldMappings()
    {
        // Build one ReceiptFieldMapping per action field
        _rcptFieldMappings = _fields.Select(f => new ReceiptFieldMapping
        {
            FieldId = f.Id,
            FieldName = f.Name,
            FieldType = f.FieldType,
            Source = ReceiptFieldMappingSource.None
        }).ToList();

        // Build resolved dropdown options
        _rcptDropdownOptions = [];
        foreach (var f in _fields.Where(f => f.FieldType is FieldType.Dropdown or FieldType.CompositeDropdown))
        {
            var values = GetFieldDropdownValues(f.Id);
            if (values.Length > 0)
                _rcptDropdownOptions[f.Id] = [.. values];
        }

        if (_receiptConfig is not null)
        {
            // Apply existing config
            void SetSource(Guid? fieldId, ReceiptFieldMappingSource source)
            {
                if (fieldId is null) return;
                var fm = _rcptFieldMappings.FirstOrDefault(f => f.FieldId == fieldId.Value);
                if (fm is not null) fm.Source = source;
            }

            SetSource(_receiptConfig.TotalFieldId, ReceiptFieldMappingSource.ReceiptTotal);
            SetSource(_receiptConfig.QuantityFieldId, ReceiptFieldMappingSource.ReceiptQuantity);
            SetSource(_receiptConfig.UnitPriceFieldId, ReceiptFieldMappingSource.ReceiptUnitPrice);
            SetSource(_receiptConfig.DescriptionFieldId, ReceiptFieldMappingSource.ReceiptDescription);
            SetSource(_receiptConfig.ShopFieldId, ReceiptFieldMappingSource.MerchantName);

            // Restore fixed-value mappings from JSON
            if (!string.IsNullOrEmpty(_receiptConfig.StaticFieldValues))
            {
                try
                {
                    var dict = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, string>>(_receiptConfig.StaticFieldValues, _jsonOpts);
                    if (dict is not null)
                    {
                        foreach (var (key, val) in dict)
                        {
                            if (Guid.TryParse(key, out var fid))
                            {
                                var fm = _rcptFieldMappings.FirstOrDefault(f => f.FieldId == fid);
                                if (fm is not null && fm.Source == ReceiptFieldMappingSource.None)
                                {
                                    fm.Source = ReceiptFieldMappingSource.FixedValue;
                                    fm.FixedValue = val;
                                }
                            }
                        }
                    }
                }
                catch { /* ignore malformed JSON */ }
            }
        }
        else
        {
            // Auto-detect: if only one numeric field, map it to Total
            var numFields = _fields.Where(f => f.FieldType is FieldType.Decimal or FieldType.Integer).ToList();
            if (numFields.Count == 1)
            {
                var fm = _rcptFieldMappings.FirstOrDefault(f => f.FieldId == numFields[0].Id);
                if (fm is not null) fm.Source = ReceiptFieldMappingSource.ReceiptTotal;
            }
        }
    }

    private void OnRcptFieldMappingChanged(ReceiptFieldMapping _) => StateHasChanged();

    private async Task EnableReceiptImportAsync()
    {
        _savingRcptCfg = true;
        var numFields = _fields.Where(f => f.FieldType is FieldType.Decimal or FieldType.Integer).ToList();
        var totalId = numFields.Count == 1 ? numFields[0].Id : (Guid?)null;

        var (ok, _) = await ReceiptConfigService.UpsertAsync(Id, new UpdateReceiptImportConfigRequest(TotalFieldId: totalId));
        if (ok) await LoadReceiptConfigAsync();
        _savingRcptCfg = false;
    }

    private async Task SaveReceiptConfigAsync()
    {
        _savingRcptCfg = true;
        _errors = [];

        Guid? FindFieldWithSource(ReceiptFieldMappingSource source) =>
            _rcptFieldMappings.FirstOrDefault(f => f.Source == source)?.FieldId;

        // Collect fixed-value mappings into a JSON dictionary
        var fixedDict = _rcptFieldMappings
            .Where(f => f.Source == ReceiptFieldMappingSource.FixedValue && !string.IsNullOrEmpty(f.FixedValue))
            .ToDictionary(f => f.FieldId.ToString(), f => f.FixedValue!);
        var staticJson = fixedDict.Count > 0
            ? System.Text.Json.JsonSerializer.Serialize(fixedDict)
            : null;

        var (ok, errs) = await ReceiptConfigService.UpsertAsync(Id, new UpdateReceiptImportConfigRequest(
            ShopFieldId: FindFieldWithSource(ReceiptFieldMappingSource.MerchantName),
            DescriptionFieldId: FindFieldWithSource(ReceiptFieldMappingSource.ReceiptDescription),
            TotalFieldId: FindFieldWithSource(ReceiptFieldMappingSource.ReceiptTotal),
            QuantityFieldId: FindFieldWithSource(ReceiptFieldMappingSource.ReceiptQuantity),
            UnitPriceFieldId: FindFieldWithSource(ReceiptFieldMappingSource.ReceiptUnitPrice),
            StaticFieldValues: staticJson));

        if (!ok) _errors = errs;
        else await LoadReceiptConfigAsync();
        _savingRcptCfg = false;
    }

    private async Task DisableReceiptImportAsync()
    {
        await ReceiptConfigService.DeleteAsync(Id);
        _receiptConfig = null;
        _rcptMappingRules = [];
        _rcptFieldMappings = [];
    }

    private async Task OnRcptAddRuleAsync(CreateReceiptMappingRuleRequest request)
    {
        var (ok, _) = await ReceiptConfigService.CreateMappingRuleAsync(Id, request);
        if (ok)
        {
            _rcptMappingRules = await ReceiptConfigService.GetMappingRulesAsync(Id);
        }
    }

    private async Task DeleteRcptRuleAsync(Guid ruleId)
    {
        await ReceiptConfigService.DeleteMappingRuleAsync(Id, ruleId);
        _rcptMappingRules = await ReceiptConfigService.GetMappingRulesAsync(Id);
    }
}
