    // — Custom Charts —

    private async Task ActivateCustomChartsTabAsync()
    {
        await SetActiveTabAsync("customcharts");
        if (!_customChartsTabLoaded)
        {
            BuildResolvedDropdownValues();
            await LoadCustomChartsAsync();
        }
    }

    private void BuildResolvedDropdownValues()
    {
        _resolvedDropdownValues = [];
        foreach (var field in _fields.Where(f =>
            f.FieldType == FieldType.CompositeDropdown
            && !string.IsNullOrWhiteSpace(f.DropdownValues)
            && f.DropdownValues.StartsWith("ref:", StringComparison.Ordinal)))
        {
            var refIds = field.DropdownValues!["ref:".Length..]
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Select(s => Guid.TryParse(s, out var id) ? id : Guid.Empty)
                .Where(id => id != Guid.Empty)
                .ToHashSet();

            var values = _allFieldDefinitions
                .Where(fd => fd.Type == FieldType.Dropdown && refIds.Contains(fd.Id) && !string.IsNullOrWhiteSpace(fd.DropdownValues))
                .SelectMany(fd => DropdownValuesHelper.Split(fd.DropdownValues))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(v => v, StringComparer.CurrentCultureIgnoreCase)
                .ToArray();

            if (values.Length > 0)
                _resolvedDropdownValues[field.Id] = values;
        }
    }

    private async Task LoadCustomChartsAsync()
    {
        try
        {
            _customCharts = await CustomChartApi.GetByTrackedActionAsync(Id);
            _customChartsTabLoaded = true;
        }
        catch
        {
            _customCharts = [];
        }
    }

