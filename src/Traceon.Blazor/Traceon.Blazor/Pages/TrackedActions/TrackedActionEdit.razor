@page "/tracked-actions/{Id:guid}/edit"
@attribute [Authorize]
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["ActionEdit_Title"] - Traceon</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-1">
            <i class="bi bi-pencil-square me-2"></i>
            @L["ActionEdit_Title"]
        </h3>
        <p class="text-muted mb-0">
            @L["ActionEdit_Editing"]: <strong>@(_model?.Name ?? "...")</strong>
        </p>
    </div>
    <div class="d-flex gap-2">
        <a href="/tracked-actions" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>@L["Common_BackToList"]
        </a>
        <a href="/dashboard/action/@Id/detail" class="btn btn-outline-info">
            <i class="bi bi-graph-up-arrow me-1"></i>@L["TrackedActions_Analytics"]
        </a>
        <button class="btn btn-success" @onclick="SaveBasicInfoAsync" disabled="@_saving">
            @if (_saving)
            {
                <span class="spinner-border spinner-border-sm me-1"></span>
            }
            else
            {
                <i class="bi bi-check-circle me-1"></i>
            }
            @L["Common_SaveChanges"]
        </button>
    </div>
</div>

<ErrorAlert Errors="_errors" OnDismiss="() => _errors = []" />

@if (_loading)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">@L["Common_Loading"]</span>
        </div>
    </div>
}
else if (_model is null)
{
    <div class="alert alert-warning">
        <i class="bi bi-question-circle me-2"></i>
        @L["Edit_NotFound"]
    </div>
}
else
{
    <div class="card">
        <div class="card-header p-0">
            <ul class="nav nav-tabs card-header-tabs">
                <li class="nav-item">
                    <button class="nav-link @(_activeTab == "basic" ? "active" : "")" @onclick='() => _activeTab = "basic"'>
                        <i class="bi bi-info-circle me-1"></i>@L["Edit_BasicInfo"]
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(_activeTab == "fields" ? "active" : "")" @onclick='() => _activeTab = "fields"'>
                        <i class="bi bi-sliders me-1"></i>@L["Common_Fields"]
                        @if (_fields.Count > 0)
                        {
                            <span class="badge bg-primary ms-1">@_fields.Count</span>
                        }
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(_activeTab == "tags" ? "active" : "")" @onclick='() => _activeTab = "tags"'>
                        <i class="bi bi-tags me-1"></i>@L["Common_Tags"]
                        @if (_tags.Count > 0)
                        {
                            <span class="badge bg-primary ms-1">@_tags.Count</span>
                        }
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(_activeTab == "entries" ? "active" : "")" @onclick='() => _activeTab = "entries"'>
                        <i class="bi bi-journal-text me-1"></i>@L["Common_Entries"]
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(_activeTab == "dependencies" ? "active" : "")" @onclick="ActivateDependenciesTabAsync">
                        <i class="bi bi-link-45deg me-1"></i>@L["Dep_FieldDependencies"]
                        @if (_dependencyRules.Count > 0)
                        {
                            <span class="badge bg-primary ms-1">@_dependencyRules.Count</span>
                        }
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(_activeTab == "analytics" ? "active" : "")" @onclick="ActivateAnalyticsTabAsync">
                        <i class="bi bi-diagram-3 me-1"></i>@L["Analytics_CrossField"]
                        @if (_analyticsRules.Count > 0)
                        {
                            <span class="badge bg-primary ms-1">@_analyticsRules.Count</span>
                        }
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(_activeTab == "receipt" ? "active" : "")" @onclick="ActivateReceiptTabAsync">
                        <i class="bi bi-receipt me-1"></i>@L["RcptCfg_Tab"]
                        @if (_receiptConfig is not null)
                        {
                            <span class="badge bg-success ms-1"><i class="bi bi-check-lg"></i></span>
                        }
                    </button>
                </li>
            </ul>
        </div>

        <div class="card-body">
            @if (_activeTab == "basic")
            {
                <EditForm Model="_model" FormName="EditActionForm">
                    <DataAnnotationsValidator />
                    <div class="mb-3">
                        <label class="form-label">@L["Common_Name"] <span class="text-danger">*</span></label>
                        <InputText @bind-Value="_model.Name" class="form-control" />
                        <ValidationMessage For="() => _model.Name" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">@L["Common_Description"]</label>
                        <InputText @bind-Value="_model.Description" class="form-control" />
                    </div>
                </EditForm>
            }
            else if (_activeTab == "fields")
            {
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <p class="text-muted mb-0">@L["Edit_FieldsHint"]</p>
                    <button class="btn btn-outline-primary btn-sm" @onclick="() => _showFieldSelector = true">
                        <i class="bi bi-plus-circle me-1"></i>@L["Edit_AddFields"]
                    </button>
                </div>

                @if (_fields.Count == 0)
                {
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-sliders fs-3 d-block mb-2"></i>
                        <p>@L["Edit_NoFieldsYet"]</p>
                        <button class="btn btn-primary" @onclick="() => _showFieldSelector = true">
                            <i class="bi bi-plus-circle me-1"></i>@L["Edit_SelectFields"]
                        </button>
                    </div>
                }
                else
                {
                    <div class="list-group">
                        @for (var i = 0; i < _fields.Count; i++)
                        {
                            var index = i;
                            var field = _fields[i];
                            <ActionFieldEditor Field="field"
                                               TrackedActionId="Id"
                                               OnRemove="RemoveFieldAsync"
                                               OnSaved="ReloadFieldsAsync"
                                               IsFirst="index == 0"
                                               IsLast="index == _fields.Count - 1"
                                               OnMoveUp="() => MoveFieldAsync(index, -1)"
                                               OnMoveDown="() => MoveFieldAsync(index, 1)"
                                               SiblingFields="_fields" />
                        }
                    </div>
                    @if (_savingOrder)
                    {
                        <div class="text-center mt-2">
                            <span class="spinner-border spinner-border-sm text-primary me-1"></span>
                            <small class="text-muted">@L["Edit_SavingOrder"]</small>
                        </div>
                    }
                }
            }
            else if (_activeTab == "tags")
            {
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <p class="text-muted mb-0">@L["Edit_TagsHint"]</p>
                    <button class="btn btn-outline-primary btn-sm" @onclick="() => _showTagSelector = true">
                        <i class="bi bi-plus-circle me-1"></i>@L["Edit_AddTags"]
                    </button>
                </div>

                @if (_tags.Count == 0)
                {
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-tags fs-3 d-block mb-2"></i>
                        <p>@L["Edit_NoTagsYet"]</p>
                        <button class="btn btn-primary" @onclick="() => _showTagSelector = true">
                            <i class="bi bi-plus-circle me-1"></i>@L["Edit_SelectTags"]
                        </button>
                    </div>
                }
                else
                {
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var tag in _tags)
                        {
                            <span class="badge rounded-pill fs-6 d-inline-flex align-items-center gap-1 py-2 px-3"
                                  style="background-color: @tag.Color">
                                @tag.Name
                                <button type="button" class="btn-close btn-close-white ms-1" style="font-size: 0.6rem;"
                                        @onclick="() => RemoveTagAsync(tag)"></button>
                            </span>
                        }
                    </div>
                }
            }
            else if (_activeTab == "entries")
            {
                <EntryDataGrid TrackedActionId="Id" LockActionFilter="true" ActionFields="_fields" StorageKey="@($"action-entries-{Id}")" />
            }
            else if (_activeTab == "analytics")
            {
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <p class="text-muted mb-0">@L["Analytics_RulesHint"]</p>
                    @if (_fields.Count >= 2)
                    {
                        <button class="btn btn-outline-primary btn-sm" @onclick="() => _showRuleForm = true" disabled="@_showRuleForm">
                            <i class="bi bi-plus-circle me-1"></i>@L["Analytics_AddRule"]
                        </button>
                    }
                </div>

                @if (_fields.Count < 2)
                {
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-2"></i>@L["Analytics_NeedTwoFields"]
                    </div>
                }
                else
                {
                    @if (_showRuleForm)
                    {
                        <div class="card border-primary mb-3">
                            <div class="card-header bg-primary bg-opacity-10 d-flex justify-content-between align-items-center">
                                <h6 class="mb-0"><i class="bi bi-plus-circle me-2"></i>@L["Analytics_NewRule"]</h6>
                                <button class="btn-close" @onclick="ResetRuleForm"></button>
                            </div>
                            <div class="card-body">
                                <div class="row g-3">
                                    <div class="col-12 col-md-6">
                                        <label class="form-label">@L["Analytics_MeasureField"] <span class="text-danger">*</span></label>
                                        <select class="form-select" @bind="_newRule.MeasureFieldId">
                                            <option value="@Guid.Empty">— @L["Common_Select"] —</option>
                                            @foreach (var f in _fields.Where(f => f.FieldType is FieldType.Integer or FieldType.Decimal or FieldType.Dropdown or FieldType.CompositeDropdown).OrderBy(f => f.Name, StringComparer.CurrentCultureIgnoreCase))
                                            {
                                                <option value="@f.Id">@f.Name (@f.FieldType)</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-12 col-md-6">
                                        <label class="form-label">@L["Analytics_GroupByField"] <span class="text-danger">*</span></label>
                                        <select class="form-select" @bind="_newRule.GroupByFieldId">
                                            <option value="@Guid.Empty">— @L["Common_Select"] —</option>
                                            @foreach (var f in _fields.Where(f => f.Id != _newRule.MeasureFieldId).OrderBy(f => f.Name, StringComparer.CurrentCultureIgnoreCase))
                                            {
                                                <option value="@f.Id">@f.Name (@f.FieldType)</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-12 col-md-4">
                                        <label class="form-label">@L["Analytics_Aggregation"]</label>
                                        @{
                                            var newMeasureField = _fields.FirstOrDefault(f => f.Id == _newRule.MeasureFieldId);
                                            var newMeasureIsDropdown = newMeasureField?.FieldType is FieldType.Dropdown or FieldType.CompositeDropdown;
                                        }
                                        <select class="form-select" @bind="_newRule.Aggregation">
                                            @if (newMeasureIsDropdown)
                                            {
                                                <option value="@AnalyticsAggregation.Count">@L["Analytics_Agg_Count"]</option>
                                                <option value="@AnalyticsAggregation.CountByValue">@L["Analytics_Agg_CountByValue"]</option>
                                            }
                                            else
                                            {
                                                @foreach (var agg in Enum.GetValues<AnalyticsAggregation>().Where(a => a != AnalyticsAggregation.CountByValue))
                                                {
                                                    <option value="@agg">@agg</option>
                                                }
                                            }
                                        </select>
                                        @if (newMeasureIsDropdown)
                                        {
                                            <div class="form-text small">
                                                <i class="bi bi-info-circle me-1"></i>@L["Analytics_CountByValueHint"]
                                            </div>
                                        }
                                    </div>
                                    @if (_newRule.Aggregation == AnalyticsAggregation.CountByValue && newMeasureIsDropdown)
                                    {
                                        var hasNumericFields = _fields.Any(f => f.FieldType is FieldType.Integer or FieldType.Decimal && f.Id != _newRule.MeasureFieldId && f.Id != _newRule.GroupByFieldId);
                                        @if (hasNumericFields)
                                        {
                                            <div class="col-12">
                                                <hr class="my-2" />
                                                <small class="text-muted"><i class="bi bi-calculator me-1"></i>@L["Analytics_ValueFieldHint"]</small>
                                            </div>
                                            <div class="col-12 col-md-4">
                                                <label class="form-label">@L["Analytics_ValueField"]</label>
                                                <select class="form-select" @bind="_newRule.SignFieldId">
                                                    <option value="">— @L["Common_None"] —</option>
                                                    @foreach (var f in _fields.Where(f => f.FieldType is FieldType.Integer or FieldType.Decimal && f.Id != _newRule.MeasureFieldId && f.Id != _newRule.GroupByFieldId).OrderBy(f => f.Name, StringComparer.CurrentCultureIgnoreCase))
                                                    {
                                                        <option value="@f.Id">@f.Name (@f.Unit)</option>
                                                    }
                                                </select>
                                            </div>
                                            @if (_newRule.SignFieldId != Guid.Empty)
                                            {
                                                <div class="col-12 col-md-4">
                                                    <label class="form-label">@L["Analytics_ValueMetrics"]</label>
                                                    @{
                                                        var newSelectedMetrics = (_newRule.NegativeValues ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToHashSet(StringComparer.OrdinalIgnoreCase);
                                                    }
                                                    @foreach (var metric in new[] { "Sum", "Avg", "Min", "Max" })
                                                    {
                                                        var capturedMetric = metric;
                                                        <div class="form-check">
                                                            <input class="form-check-input" type="checkbox" id="new-metric-@capturedMetric" checked="@newSelectedMetrics.Contains(capturedMetric)"
                                                                   @onchange="e => { _newRule.NegativeValues = ToggleNegativeValue(_newRule.NegativeValues, capturedMetric, (bool)(e.Value ?? false)); }" />
                                                            <label class="form-check-label" for="new-metric-@capturedMetric">@L[$"Aggregation_{capturedMetric}"]</label>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        }
                                    }
                                    @if (_newRule.Aggregation != AnalyticsAggregation.CountByValue)
                                    {
                                    <div class="col-12 col-md-4">
                                        <label class="form-label">@L["Analytics_DisplayAs"]</label>
                                        <select class="form-select" @bind="_newRule.DisplayType">
                                            @foreach (var dt in Enum.GetValues<AnalyticsDisplayType>())
                                            {
                                                <option value="@dt">@dt</option>
                                            }
                                        </select>
                                    </div>
                                    }
                                    <div class="col-12 col-md-4">
                                        <label class="form-label">@L["Analytics_Label"]</label>
                                        <input type="text" class="form-control" @bind="_newRule.Label" placeholder="@L["Analytics_LabelPlaceholder"]" />
                                    </div>
                                    <div class="col-12 col-md-4">
                                        <label class="form-label">@L["Analytics_FilterField"]</label>
                                        <select class="form-select" @bind="_newRule.FilterFieldId">
                                            <option value="">— @L["Common_None"] —</option>
                                            @foreach (var f in _fields.Where(f => f.Id != _newRule.MeasureFieldId && f.Id != _newRule.GroupByFieldId).OrderBy(f => f.Name, StringComparer.CurrentCultureIgnoreCase))
                                            {
                                                <option value="@f.Id">@f.Name (@f.FieldType)</option>
                                            }
                                        </select>
                                    </div>
                                    @if (_newRule.FilterFieldId != Guid.Empty)
                                    {
                                        <div class="col-12 col-md-4">
                                            <label class="form-label">@L["Analytics_FilterValue"]</label>
                                            @{
                                                var filterField = _fields.FirstOrDefault(f => f.Id == _newRule.FilterFieldId);
                                            }
                                            @if (filterField?.FieldType == FieldType.Boolean)
                                            {
                                                <select class="form-select" @bind="_newRule.FilterValue">
                                                    <option value="true">True</option>
                                                    <option value="false">False</option>
                                                </select>
                                            }
                                            else if (filterField?.FieldType == FieldType.Dropdown && filterField.DropdownValues is not null)
                                            {
                                                <select class="form-select" @bind="_newRule.FilterValue">
                                                    <option value="">—</option>
                                                                @foreach (var opt in filterField.DropdownValues.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).OrderBy(v => v, StringComparer.CurrentCultureIgnoreCase))
                                                                    {
                                                                        <option value="@opt">@opt</option>
                                                                    }
                                                                </select>
                                                            }
                                                            else
                                                            {
                                                                <input type="text" class="form-control" @bind="_newRule.FilterValue" />
                                                            }
                                                        </div>
                                                    }
                                                    @if (_newRule.Aggregation == AnalyticsAggregation.SignedSum)
                                    {
                                        <div class="col-12">
                                            <hr class="my-2" />
                                            <small class="text-muted"><i class="bi bi-info-circle me-1"></i>@L["Analytics_SignedSumHint"]</small>
                                        </div>
                                        <div class="col-12 col-md-4">
                                            <label class="form-label">@L["Analytics_SignField"]</label>
                                            <select class="form-select" @bind="_newRule.SignFieldId">
                                                <option value="">— @L["Common_Select"] —</option>
                                                @foreach (var f in _fields.Where(f => f.FieldType == FieldType.Dropdown).OrderBy(f => f.Name, StringComparer.CurrentCultureIgnoreCase))
                                                {
                                                    <option value="@f.Id">@f.Name</option>
                                                }
                                            </select>
                                        </div>
                                        @if (_newRule.SignFieldId != Guid.Empty)
                                        {
                                            <div class="col-12 col-md-4">
                                                <label class="form-label">@L["Analytics_NegativeValues"]</label>
                                                @{
                                                    var signField = _fields.FirstOrDefault(f => f.Id == _newRule.SignFieldId);
                                                }
                                                @if (signField?.DropdownValues is not null)
                                                {
                                                    var signOptions = signField.DropdownValues.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).OrderBy(v => v, StringComparer.CurrentCultureIgnoreCase).ToArray();
                                                    var selectedNeg = (_newRule.NegativeValues ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToHashSet(StringComparer.OrdinalIgnoreCase);
                                                    @foreach (var opt in signOptions)
                                                    {
                                                        var capturedOpt = opt;
                                                        <div class="form-check">
                                                            <input class="form-check-input" type="checkbox" id="new-neg-@capturedOpt" checked="@selectedNeg.Contains(capturedOpt)"
                                                                   @onchange="e => { _newRule.NegativeValues = ToggleNegativeValue(_newRule.NegativeValues, capturedOpt, (bool)(e.Value ?? false)); }" />
                                                            <label class="form-check-label" for="new-neg-@capturedOpt">@capturedOpt</label>
                                                        </div>
                                                    }
                                                }
                                                else
                                                {
                                                    <input type="text" class="form-control" @bind="_newRule.NegativeValues" placeholder="@L["Analytics_NegativeValuesPlaceholder"]" />
                                                }
                                            </div>
                                        }
                                    }
                                </div>
                                <ErrorAlert Errors="_ruleErrors" OnDismiss="() => _ruleErrors = []" />
                                <div class="d-flex justify-content-end gap-2 mt-3">
                                    <button class="btn btn-outline-secondary btn-sm" @onclick="ResetRuleForm">
                                        @L["Common_Cancel"]
                                    </button>
                                    <button class="btn btn-primary btn-sm" @onclick="SaveRuleAsync" disabled="@_savingRule">
                                        @if (_savingRule)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                        }
                                        <i class="bi bi-check-circle me-1"></i>@L["Common_Save"]
                                    </button>
                                </div>
                            </div>
                        </div>
                    }

                    @if (_analyticsRules.Count == 0 && !_showRuleForm)
                    {
                        <div class="text-center text-muted py-4">
                            <i class="bi bi-diagram-3 fs-3 d-block mb-2"></i>
                            <p>@L["Analytics_NoCrossFieldRules"]</p>
                        </div>
                    }
                    else
                    {
                        <div class="list-group">
                            @foreach (var rule in _analyticsRules)
                            {
                                @if (_editingRuleId == rule.Id)
                                {
                                    <div class="list-group-item p-0">
                                        <div class="card border-warning mb-0">
                                            <div class="card-header bg-warning bg-opacity-10 d-flex justify-content-between align-items-center">
                                                <h6 class="mb-0"><i class="bi bi-pencil-square me-2"></i>@L["Analytics_EditRule"]</h6>
                                                <button class="btn-close" @onclick="CancelEditRule"></button>
                                            </div>
                                            <div class="card-body">
                                                <div class="row g-3">
                                                    <div class="col-12 col-md-6">
                                                        <label class="form-label">@L["Analytics_MeasureField"]</label>
                                                        <input type="text" class="form-control" value="@rule.MeasureFieldName" disabled />
                                                    </div>
                                                    <div class="col-12 col-md-6">
                                                        <label class="form-label">@L["Analytics_GroupByField"]</label>
                                                        <input type="text" class="form-control" value="@rule.GroupByFieldName" disabled />
                                                    </div>
                                                    <div class="col-12 col-md-4">
                                                        <label class="form-label">@L["Analytics_Aggregation"]</label>
                                                        @{
                                                            var editMeasureField = _fields.FirstOrDefault(f => f.Id == rule.MeasureFieldId);
                                                            var editMeasureIsDropdown = editMeasureField?.FieldType is FieldType.Dropdown or FieldType.CompositeDropdown;
                                                        }
                                                        <select class="form-select" @bind="_editRule.Aggregation">
                                                            @if (editMeasureIsDropdown)
                                                            {
                                                                <option value="@AnalyticsAggregation.Count">@L["Analytics_Agg_Count"]</option>
                                                                <option value="@AnalyticsAggregation.CountByValue">@L["Analytics_Agg_CountByValue"]</option>
                                                            }
                                                            else
                                                            {
                                                                @foreach (var agg in Enum.GetValues<AnalyticsAggregation>().Where(a => a != AnalyticsAggregation.CountByValue))
                                                                {
                                                                    <option value="@agg">@agg</option>
                                                                }
                                                            }
                                                        </select>
                                                    </div>
                                                    @if (_editRule.Aggregation != AnalyticsAggregation.CountByValue)
                                                    {
                                                    <div class="col-12 col-md-4">
                                                        <label class="form-label">@L["Analytics_DisplayAs"]</label>
                                                        <select class="form-select" @bind="_editRule.DisplayType">
                                                            @foreach (var dt in Enum.GetValues<AnalyticsDisplayType>())
                                                            {
                                                                <option value="@dt">@dt</option>
                                                            }
                                                        </select>
                                                    </div>
                                                    }
                                                    <div class="col-12 col-md-4">
                                                        <label class="form-label">@L["Analytics_Label"]</label>
                                                        <input type="text" class="form-control" @bind="_editRule.Label" placeholder="@L["Analytics_LabelPlaceholder"]" />
                                                    </div>
                                                    <div class="col-12 col-md-4">
                                                        <label class="form-label">@L["Analytics_FilterField"]</label>
                                                        <select class="form-select" @bind="_editRule.FilterFieldId">
                                                            <option value="">— @L["Common_None"] —</option>
                                                            @foreach (var f in _fields.Where(f => f.Id != rule.MeasureFieldId && f.Id != rule.GroupByFieldId).OrderBy(f => f.Name, StringComparer.CurrentCultureIgnoreCase))
                                                            {
                                                                <option value="@f.Id">@f.Name (@f.FieldType)</option>
                                                            }
                                                        </select>
                                                    </div>
                                                    @if (_editRule.FilterFieldId != Guid.Empty)
                                                    {
                                                        <div class="col-12 col-md-4">
                                                            <label class="form-label">@L["Analytics_FilterValue"]</label>
                                                            @{
                                                                var editFilterField = _fields.FirstOrDefault(f => f.Id == _editRule.FilterFieldId);
                                                            }
                                                            @if (editFilterField?.FieldType == FieldType.Boolean)
                                                            {
                                                                <select class="form-select" @bind="_editRule.FilterValue">
                                                                    <option value="true">True</option>
                                                                    <option value="false">False</option>
                                                                </select>
                                                            }
                                                            else if (editFilterField?.FieldType == FieldType.Dropdown && editFilterField.DropdownValues is not null)
                                                            {
                                                                <select class="form-select" @bind="_editRule.FilterValue">
                                                                    <option value="">—</option>
                                                                    @foreach (var opt in editFilterField.DropdownValues.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).OrderBy(v => v, StringComparer.CurrentCultureIgnoreCase))
                                                                        {
                                                                            <option value="@opt">@opt</option>
                                                                        }
                                                                </select>
                                                            }
                                                            else
                                                            {
                                                                <input type="text" class="form-control" @bind="_editRule.FilterValue" />
                                                            }
                                                        </div>
                                                    }
                                                    @if (_editRule.Aggregation == AnalyticsAggregation.CountByValue && editMeasureIsDropdown)
                                                    {
                                                        var editHasNumericFields = _fields.Any(f => f.FieldType is FieldType.Integer or FieldType.Decimal && f.Id != rule.MeasureFieldId && f.Id != rule.GroupByFieldId);
                                                        @if (editHasNumericFields)
                                                        {
                                                            <div class="col-12">
                                                                <hr class="my-2" />
                                                                <small class="text-muted"><i class="bi bi-calculator me-1"></i>@L["Analytics_ValueFieldHint"]</small>
                                                            </div>
                                                            <div class="col-12 col-md-4">
                                                                <label class="form-label">@L["Analytics_ValueField"]</label>
                                                                <select class="form-select" @bind="_editRule.SignFieldId">
                                                                    <option value="">— @L["Common_None"] —</option>
                                                                    @foreach (var f in _fields.Where(f => f.FieldType is FieldType.Integer or FieldType.Decimal && f.Id != rule.MeasureFieldId && f.Id != rule.GroupByFieldId).OrderBy(f => f.Name, StringComparer.CurrentCultureIgnoreCase))
                                                                    {
                                                                        <option value="@f.Id">@f.Name (@f.Unit)</option>
                                                                    }
                                                                </select>
                                                            </div>
                                                            @if (_editRule.SignFieldId != Guid.Empty)
                                                            {
                                                                <div class="col-12 col-md-4">
                                                                    <label class="form-label">@L["Analytics_ValueMetrics"]</label>
                                                                    @{
                                                                        var editSelectedMetrics = (_editRule.NegativeValues ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToHashSet(StringComparer.OrdinalIgnoreCase);
                                                                    }
                                                                    @foreach (var metric in new[] { "Sum", "Avg", "Min", "Max" })
                                                                    {
                                                                        var capturedMetric = metric;
                                                                        <div class="form-check">
                                                                            <input class="form-check-input" type="checkbox" id="edit-metric-@capturedMetric" checked="@editSelectedMetrics.Contains(capturedMetric)"
                                                                                   @onchange="e => { _editRule.NegativeValues = ToggleNegativeValue(_editRule.NegativeValues, capturedMetric, (bool)(e.Value ?? false)); }" />
                                                                            <label class="form-check-label" for="edit-metric-@capturedMetric">@L[$"Aggregation_{capturedMetric}"]</label>
                                                                        </div>
                                                                    }
                                                                </div>
                                                            }
                                                        }
                                                    }
                                                    @if (_editRule.Aggregation == AnalyticsAggregation.SignedSum)
                                                    {
                                                        <div class="col-12">
                                                            <hr class="my-2" />
                                                            <small class="text-muted"><i class="bi bi-info-circle me-1"></i>@L["Analytics_SignedSumHint"]</small>
                                                        </div>
                                                        <div class="col-12 col-md-4">
                                                            <label class="form-label">@L["Analytics_SignField"]</label>
                                                            <select class="form-select" @bind="_editRule.SignFieldId">
                                                                <option value="">— @L["Common_Select"] —</option>
                                                                @foreach (var f in _fields.Where(f => f.FieldType == FieldType.Dropdown).OrderBy(f => f.Name, StringComparer.CurrentCultureIgnoreCase))
                                                                {
                                                                    <option value="@f.Id">@f.Name</option>
                                                                }
                                                            </select>
                                                        </div>
                                                        @if (_editRule.SignFieldId != Guid.Empty)
                                                        {
                                                            <div class="col-12 col-md-4">
                                                                <label class="form-label">@L["Analytics_NegativeValues"]</label>
                                                                @{
                                                                    var editSignField = _fields.FirstOrDefault(f => f.Id == _editRule.SignFieldId);
                                                                }
                                                                @if (editSignField?.DropdownValues is not null)
                                                                {
                                                                    var editSignOptions = editSignField.DropdownValues.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).OrderBy(v => v, StringComparer.CurrentCultureIgnoreCase).ToArray();
                                                                    var editSelectedNeg = (_editRule.NegativeValues ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToHashSet(StringComparer.OrdinalIgnoreCase);
                                                                    @foreach (var opt in editSignOptions)
                                                                    {
                                                                        var capturedOpt = opt;
                                                                        <div class="form-check">
                                                                            <input class="form-check-input" type="checkbox" id="edit-neg-@capturedOpt" checked="@editSelectedNeg.Contains(capturedOpt)"
                                                                                   @onchange="e => { _editRule.NegativeValues = ToggleNegativeValue(_editRule.NegativeValues, capturedOpt, (bool)(e.Value ?? false)); }" />
                                                                            <label class="form-check-label" for="edit-neg-@capturedOpt">@capturedOpt</label>
                                                                        </div>
                                                                    }
                                                                }
                                                                else
                                                                {
                                                                    <input type="text" class="form-control" @bind="_editRule.NegativeValues" placeholder="@L["Analytics_NegativeValuesPlaceholder"]" />
                                                                }
                                                            </div>
                                                        }
                                                    }
                                                </div>
                                                <ErrorAlert Errors="_ruleErrors" OnDismiss="() => _ruleErrors = []" />
                                                <div class="d-flex justify-content-end gap-2 mt-3">
                                                    <button class="btn btn-outline-secondary btn-sm" @onclick="CancelEditRule">
                                                        @L["Common_Cancel"]
                                                    </button>
                                                    <button class="btn btn-warning btn-sm" @onclick="UpdateRuleAsync" disabled="@_savingRule">
                                                        @if (_savingRule)
                                                        {
                                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                                        }
                                                        <i class="bi bi-check-circle me-1"></i>@L["Common_SaveChanges"]
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="list-group-item list-group-item-action" style="cursor: pointer;" @onclick="() => StartEditRule(rule)">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <h6 class="mb-1">
                                                    @if (rule.DisplayType is AnalyticsDisplayType.PieChart)
                                                    {
                                                        <i class="bi bi-pie-chart me-1 text-primary"></i>
                                                    }
                                                    else if (rule.DisplayType is AnalyticsDisplayType.BarChart or AnalyticsDisplayType.StackedBar)
                                                    {
                                                        <i class="bi bi-bar-chart me-1 text-primary"></i>
                                                    }
                                                    else
                                                    {
                                                        <i class="bi bi-table me-1 text-primary"></i>
                                                    }
                                                    @(rule.Label ?? $"{rule.Aggregation} of {rule.MeasureFieldName} by {rule.GroupByFieldName}")
                                                </h6>
                                                <small class="text-muted">
                                                    <span class="badge bg-info">@rule.Aggregation</span>
                                                    @rule.MeasureFieldName
                                                    <i class="bi bi-arrow-right mx-1"></i>
                                                    @L["Analytics_GroupBy"] @rule.GroupByFieldName
                                                    @if (rule.FilterFieldName is not null)
                                                    {
                                                        <span class="ms-2">
                                                            <i class="bi bi-funnel me-1"></i>@rule.FilterFieldName = @rule.FilterValue
                                                        </span>
                                                    }
                                                    @if (rule.SignFieldName is not null)
                                                    {
                                                        <span class="ms-2">
                                                            <i class="bi bi-plus-slash-minus me-1"></i>@rule.SignFieldName → @rule.NegativeValues
                                                        </span>
                                                    }
                                                </small>
                                            </div>
                                            <div class="d-flex gap-1" @onclick:stopPropagation="true">
                                                <button class="btn btn-outline-secondary btn-sm" @onclick="() => StartEditRule(rule)" title="@L["Common_Edit"]">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteRuleAsync(rule)" title="@L["Common_Delete"]">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    }
                }
            }
            else if (_activeTab == "dependencies")
            {
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <p class="text-muted mb-0">@L["Dep_Hint"]</p>
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-success btn-sm" @onclick="() => _showHierarchyWizard = true">
                            <i class="bi bi-diagram-3 me-1"></i>@L["Hierarchy_BuildButton"]
                        </button>
                        @if (_dropdownFields.Count >= 2 && !_depEditorOpen)
                        {
                            <button class="btn btn-outline-primary btn-sm" @onclick="OpenNewDepEditor">
                                <i class="bi bi-plus-circle me-1"></i>@L["Dep_AddMapping"]
                            </button>
                        }
                    </div>
                </div>

                @if (_dropdownFields.Count < 2)
                {
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-2"></i>@L["Dep_NeedTwoDropdowns"]
                    </div>
                }
                else
                {
                    @* ── Mapping Editor ── *@
                    @if (_depEditorOpen)
                    {
                        <div class="card border-primary mb-3">
                            <div class="card-header bg-primary bg-opacity-10 d-flex justify-content-between align-items-center">
                                <h6 class="mb-0">
                                    <i class="bi bi-link-45deg me-2"></i>
                                    @(_depEditingPairKey is not null ? L["Dep_EditMapping"] : L["Dep_NewMapping"])
                                </h6>
                                <button class="btn-close" @onclick="CloseDepEditor"></button>
                            </div>
                            <div class="card-body">
                                @* Field selectors (locked when editing) *@
                                <div class="row g-3 mb-3">
                                    <div class="col-12 col-md-6">
                                        <label class="form-label fw-semibold">@L["Dep_SourceField"] <span class="text-danger">*</span></label>
                                        <select class="form-select" value="@_depSourceFieldId" @onchange="OnDepSourceFieldChanged"
                                                disabled="@(_depEditingPairKey is not null)">
                                            <option value="@Guid.Empty">— @L["Common_Select"] —</option>
                                            @foreach (var f in _dropdownFields.OrderBy(f => f.Name, StringComparer.CurrentCultureIgnoreCase))
                                            {
                                                <option value="@f.Id">@f.Name</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-12 col-md-6">
                                        <label class="form-label fw-semibold">@L["Dep_TargetField"] <span class="text-danger">*</span></label>
                                        <select class="form-select" value="@_depTargetFieldId" @onchange="OnDepTargetFieldChanged"
                                                disabled="@(_depEditingPairKey is not null)">
                                            <option value="@Guid.Empty">— @L["Common_Select"] —</option>
                                            @foreach (var f in _dropdownFields.Where(f => f.Id != _depSourceFieldId).OrderBy(f => f.Name, StringComparer.CurrentCultureIgnoreCase))
                                            {
                                                <option value="@f.Id">@f.Name</option>
                                            }
                                        </select>
                                    </div>
                                </div>

                                @* Split panel: source values left, target checkboxes right *@
                                @if (_depSourceFieldId != Guid.Empty && _depTargetFieldId != Guid.Empty)
                                {
                                    var srcOptions = GetFieldDropdownValues(_depSourceFieldId);
                                    var tgtOptions = GetFieldDropdownValues(_depTargetFieldId);

                                    @if (srcOptions.Length == 0 || tgtOptions.Length == 0)
                                    {
                                        <div class="alert alert-warning">
                                            <i class="bi bi-exclamation-triangle me-1"></i>@L["Dep_NoDropdownValues"]
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="row g-0 border rounded" style="min-height: 250px;">
                                            @* Left panel: source values *@
                                            <div class="col-12 col-md-4 border-end d-flex flex-column" style="max-height: 350px;">
                                                @if (srcOptions.Length > 8)
                                                {
                                                    <div class="p-2 border-bottom flex-shrink-0">
                                                        <input type="text" class="form-control form-control-sm"
                                                               placeholder="@L["Common_Search"]..."
                                                               @bind="_depSourceSearch"
                                                               @bind:event="oninput" />
                                                    </div>
                                                }
                                                <div class="list-group list-group-flush overflow-y-auto flex-grow-1">
                                                    @foreach (var srcVal in srcOptions.Where(v => string.IsNullOrEmpty(_depSourceSearch) || v.Contains(_depSourceSearch, StringComparison.OrdinalIgnoreCase)))
                                                    {
                                                        var captured = srcVal;
                                                        var isActive = captured == _depActiveSourceValue;
                                                        var hasMapping = _depMappings.TryGetValue(captured, out var m) && m.Count > 0;
                                                        <button type="button"
                                                                class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(isActive ? "active" : "")"
                                                                @onclick="() => SelectDepSourceValue(captured)">
                                                            <span>@captured</span>
                                                            @if (hasMapping)
                                                            {
                                                                <span class="badge @(isActive ? "bg-light text-primary" : "bg-primary") rounded-pill">@m!.Count</span>
                                                            }
                                                        </button>
                                                    }
                                                </div>
                                            </div>

                                            @* Right panel: target checkboxes *@
                                            <div class="col-12 col-md-8 d-flex flex-column" style="max-height: 350px;">
                                                @if (_depActiveSourceValue is null)
                                                {
                                                    <div class="text-center text-muted py-4 flex-grow-1">
                                                        <i class="bi bi-arrow-left-circle fs-3 d-block mb-2"></i>
                                                        <p class="mb-0">@L["Dep_PickSourceValue"]</p>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="p-3 pb-0 flex-shrink-0">
                                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                                            <span class="fw-semibold">
                                                                @L["Dep_WhenValueIs"] <span class="badge bg-secondary">@_depActiveSourceValue</span>
                                                                → @L["Dep_AllowedValues"]:
                                                            </span>
                                                            <div class="btn-group btn-group-sm">
                                                                <button class="btn btn-outline-secondary" @onclick="() => DepSelectAll(tgtOptions)">@L["Common_All"]</button>
                                                                <button class="btn btn-outline-secondary" @onclick="DepSelectNone">@L["Common_None"]</button>
                                                        </div>
                                                    </div>
                                                    @if (tgtOptions.Length > 8)
                                                    {
                                                        <div class="px-3 pb-2 flex-shrink-0">
                                                            <input type="text" class="form-control form-control-sm"
                                                                   placeholder="@L["Common_Search"]..."
                                                                   @bind="_depTargetSearch"
                                                                   @bind:event="oninput" />
                                                        </div>
                                                    }
                                                    </div>

                                                    <div class="px-3 pb-3 overflow-y-auto flex-grow-1">
                                                    @{
                                                        var compositeGroups = GetGroupedFieldDropdownValues(_depTargetFieldId);
                                                    }
                                                    @if (compositeGroups.Count > 0)
                                                    {
                                                        @foreach (var (groupName, groupValues) in compositeGroups)
                                                        {
                                                            var filteredGroupValues = string.IsNullOrEmpty(_depTargetSearch)
                                                                ? groupValues
                                                                : groupValues.Where(v => v.Contains(_depTargetSearch, StringComparison.OrdinalIgnoreCase)).ToArray();
                                                            if (filteredGroupValues.Length == 0) continue;
                                                            var capturedGroup = filteredGroupValues;
                                                            var depSetForGroup = _depMappings.GetValueOrDefault(_depActiveSourceValue!) ?? [];
                                                            var allGroupChecked = capturedGroup.All(v => depSetForGroup.Contains(v, StringComparer.OrdinalIgnoreCase));
                                                            <div class="mb-2">
                                                                <div class="d-flex justify-content-between align-items-center border-bottom pb-1 mb-1">
                                                                    <span class="fw-semibold text-muted small">
                                                                        <i class="bi bi-collection me-1"></i>@groupName
                                                                    </span>
                                                                    <button type="button"
                                                                            class="btn btn-link btn-sm p-0 text-decoration-none"
                                                                            style="font-size: 0.7rem;"
                                                                            @onclick="() => DepToggleGroup(capturedGroup, !allGroupChecked)">
                                                                        @(allGroupChecked ? L["Common_None"] : L["Common_All"])
                                                                    </button>
                                                                </div>
                                                                <div class="row row-cols-1 row-cols-sm-2 g-1">
                                                                    @foreach (var tgtVal in filteredGroupValues)
                                                                    {
                                                                        var capturedTgt = tgtVal;
                                                                        var depSet = _depMappings.GetValueOrDefault(_depActiveSourceValue!) ?? [];
                                                                        var isChecked = depSet.Contains(capturedTgt, StringComparer.OrdinalIgnoreCase);
                                                                        <div class="col">
                                                                            <div class="form-check">
                                                                                <input class="form-check-input" type="checkbox" id="dep-@_depActiveSourceValue-@capturedTgt"
                                                                                       checked="@isChecked"
                                                                                       @onchange="e => ToggleDepMapping(_depActiveSourceValue, capturedTgt, (bool)(e.Value ?? false))" />
                                                                                <label class="form-check-label" for="dep-@_depActiveSourceValue-@capturedTgt">@capturedTgt</label>
                                                                            </div>
                                                                        </div>
                                                                    }
                                                                </div>
                                                            </div>
                                                        }
                                                    }
                                                    else
                                                    {
                                                    <div class="row row-cols-1 row-cols-sm-2 g-1">
                                                        @foreach (var tgtVal in tgtOptions.Where(v => string.IsNullOrEmpty(_depTargetSearch) || v.Contains(_depTargetSearch, StringComparison.OrdinalIgnoreCase)))
                                                        {
                                                            var capturedTgt = tgtVal;
                                                            var depSet = _depMappings.GetValueOrDefault(_depActiveSourceValue!) ?? [];
                                                            var isChecked = depSet.Contains(capturedTgt, StringComparer.OrdinalIgnoreCase);
                                                            <div class="col">
                                                                <div class="form-check">
                                                                    <input class="form-check-input" type="checkbox" id="dep-@_depActiveSourceValue-@capturedTgt"
                                                                           checked="@isChecked"
                                                                           @onchange="e => ToggleDepMapping(_depActiveSourceValue, capturedTgt, (bool)(e.Value ?? false))" />
                                                                    <label class="form-check-label" for="dep-@_depActiveSourceValue-@capturedTgt">@capturedTgt</label>
                                                                </div>
                                                            </div>
                                                        }
                                                    </div>
                                                    }
                                                    </div>
                                                }
                                            </div>
                                        </div>

                                        <ErrorAlert Errors="_depErrors" OnDismiss="() => _depErrors = []" />
                                        <div class="d-flex justify-content-end gap-2 mt-3">
                                            <button class="btn btn-outline-secondary btn-sm" @onclick="CloseDepEditor">@L["Common_Cancel"]</button>
                                            <button class="btn btn-primary btn-sm" @onclick="SaveAllDepMappingsAsync" disabled="@_savingDep">
                                                @if (_savingDep) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                <i class="bi bi-check-circle me-1"></i>@L["Common_SaveChanges"]
                                            </button>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    }

                    @* ── Rules summary grouped by source→target pair ── *@
                    @if (GetGroupedDepRules().Count == 0 && !_depEditorOpen)
                    {
                        <div class="text-center text-muted py-4">
                            <i class="bi bi-link-45deg fs-3 d-block mb-2"></i>
                            <p>@L["Dep_NoRulesYet"]</p>
                        </div>
                    }
                    else if (!_depEditorOpen)
                    {
                        <div class="list-group">
                            @foreach (var group in GetGroupedDepRules())
                            {
                                var first = group.First();
                                var pairKey = $"{first.SourceFieldId}|{first.TargetFieldId}";
                                var ruleCount = group.Count();
                                var mappedValues = group.Select(r => r.SourceValue).Where(v => v is not null).Distinct().ToList();
                                <div class="list-group-item list-group-item-action" style="cursor: pointer;" @onclick="() => OpenEditDepEditor(group.ToList())">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <h6 class="mb-1">
                                                <i class="bi bi-link-45deg me-1 text-primary"></i>
                                                <span class="badge bg-secondary">@first.SourceFieldName</span>
                                                <i class="bi bi-arrow-right mx-1"></i>
                                                <span class="badge bg-info text-dark">@first.TargetFieldName</span>
                                                <span class="badge bg-primary ms-2">@ruleCount @(ruleCount == 1 ? L["Dep_Rule"] : L["Dep_Rules"])</span>
                                            </h6>
                                            <small class="text-muted">
                                                @L["Dep_MappedValues"]: @string.Join(", ", mappedValues.Take(5))@(mappedValues.Count > 5 ? $" (+{mappedValues.Count - 5})" : "")
                                            </small>
                                        </div>
                                        <div class="d-flex gap-1" @onclick:stopPropagation="true">
                                            <button class="btn btn-outline-secondary btn-sm" @onclick="() => OpenEditDepEditor(group.ToList())" title="@L["Common_Edit"]">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteDepGroupAsync(group.ToList())" title="@L["Common_Delete"]">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                }
            }
            else if (_activeTab == "receipt")
            {
                <p class="text-muted mb-3">@L["RcptCfg_Hint"]</p>

                var decimalFields = _fields.Where(f => f.FieldType is FieldType.Decimal or FieldType.Integer).ToList();

                @if (decimalFields.Count == 0)
                {
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-2"></i>@L["RcptCfg_NeedsDecimalField"]
                    </div>
                }
                else if (_receiptConfig is null)
                {
                    <div class="text-center py-4">
                        <p class="text-muted mb-3"><i class="bi bi-receipt display-4 d-block mb-2 text-muted opacity-50"></i>@L["RcptCfg_NotConfigured"]</p>
                        <button class="btn btn-primary" @onclick="EnableReceiptImportAsync">
                            <i class="bi bi-plus-circle me-1"></i>@L["RcptCfg_Enable"]
                        </button>
                    </div>
                }
                else
                {
                    @* ── Field Mapping & Rules via shared editor ── *@
                    <div class="mb-3 d-flex gap-2">
                        <button class="btn btn-primary btn-sm" @onclick="SaveReceiptConfigAsync" disabled="@_savingRcptCfg">
                            @if (_savingRcptCfg) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            <i class="bi bi-check-circle me-1"></i>@L["Common_Save"]
                        </button>
                        <button class="btn btn-outline-danger btn-sm" @onclick="DisableReceiptImportAsync">
                            <i class="bi bi-x-circle me-1"></i>@L["RcptCfg_Disable"]
                        </button>
                    </div>

                    <ReceiptFieldMappingEditor
                        FieldMappings="_rcptFieldMappings"
                        MappingRules="_rcptMappingRules"
                        DropdownOptions="_rcptDropdownOptions"
                        DependencyRules="_dependencyRules"
                        OnMappingChanged="OnRcptFieldMappingChanged"
                        OnAddRule="OnRcptAddRuleAsync"
                        OnDeleteRule="DeleteRcptRuleAsync" />
                }
            }
        </div>
    </div>
}

<!-- Hierarchy Builder Wizard -->
<HierarchyBuilderWizard IsVisible="_showHierarchyWizard"
                        TrackedActionId="Id"
                        NextFieldOrder="_fields.Count"
                        OnClose="() => _showHierarchyWizard = false"
                        OnBuilt="OnHierarchyBuiltAsync" />

<!-- Tag Selector Modal -->
<ModalSelector TItem="TagResponse"
               @bind-IsVisible="_showTagSelector"
               Title="@L["Modal_SelectTags"]"
               Icon="tags"
               LoadItems="() => TagService.GetAllAsync()"
               KeySelector="t => t.Id"
               SearchSelector="@(t => $"{t.Name} {t.Description}")"
               SearchPlaceholder="@L["Modal_SearchTags"]"
               EmptyText="@L["Modal_NoTagsAvailable"]"
               ExcludedKeys="_tagExcludedKeys"
               OnConfirm="OnTagsSelectedAsync">
    <CreateTemplate>
        <div class="row g-2 align-items-end">
            <div class="col">
                <label class="form-label form-label-sm mb-1">@L["Common_Name"] <span class="text-danger">*</span></label>
                <input type="text" class="form-control form-control-sm" @bind="_newTagName" placeholder="@L["Common_Name"]" />
            </div>
            <div class="col-auto">
                <label class="form-label form-label-sm mb-1">@L["Tags_Color"]</label>
                <input type="color" class="form-control form-control-sm form-control-color" @bind="_newTagColor" />
            </div>
            <div class="col-auto">
                <button class="btn btn-success btn-sm" @onclick="() => CreateTagInlineAsync(context)" disabled="@_creatingTag">
                    @if (_creatingTag)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    <i class="bi bi-plus-circle me-1"></i>@L["Common_Create"]
                </button>
            </div>
        </div>
        @if (_tagCreateErrors.Count > 0)
        {
            <div class="text-danger small mt-1">@string.Join(", ", _tagCreateErrors)</div>
        }
    </CreateTemplate>
    <ItemTemplate>
        <div class="d-flex align-items-center gap-2">
            <span class="badge rounded-pill" style="background-color: @context.Color">&nbsp;&nbsp;</span>
            <span>@context.Name</span>
        </div>
    </ItemTemplate>
</ModalSelector>

<!-- Field Selector Modal -->
<ModalSelector TItem="FieldDefinitionResponse"
               @bind-IsVisible="_showFieldSelector"
               Title="@L["Modal_SelectFields"]"
               Icon="sliders"
               LoadItems="() => FieldDefinitionService.GetAllAsync()"
               KeySelector="f => f.Id"
               SearchSelector="@(f => $"{f.DefaultName} {f.Type}")"
               SearchPlaceholder="@L["Modal_SearchFields"]"
               EmptyText="@L["Modal_NoFieldsAvailable"]"
               ExcludedKeys="_fieldExcludedKeys"
               OnConfirm="OnFieldsSelectedAsync">
    <ItemTemplate>
        <div class="d-flex align-items-center gap-2 w-100">
            <span>@context.DefaultName</span>
            <span class="badge bg-secondary ms-auto">@context.Type</span>
        </div>
    </ItemTemplate>
    <CreateTemplate>
        <FieldDefinitionForm OnCreated="async fd => await OnFieldCreatedInlineAsync(fd, context)" />
    </CreateTemplate>
</ModalSelector>

@code {
    [Parameter] public Guid Id { get; set; }
    [Inject] private TrackedActionService Service { get; set; } = default!;
    [Inject] private TagService TagService { get; set; } = default!;
    [Inject] private FieldDefinitionService FieldDefinitionService { get; set; } = default!;
    [Inject] private ActionFieldService ActionFieldService { get; set; } = default!;
    [Inject] private FieldAnalyticsRuleService AnalyticsRuleService { get; set; } = default!;
    [Inject] private FieldDependencyRuleService DependencyRuleService { get; set; } = default!;
    [Inject] private ReceiptImportConfigService ReceiptConfigService { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private EditModel? _model;
    private IReadOnlyList<string> _errors = [];
    private bool _loading = true;
    private bool _saving;
    private string _activeTab = "basic";
    private List<FieldDefinitionResponse> _allFieldDefinitions = [];

    // Tags
    private List<TagResponse> _tags = [];
    private List<Guid> _tagExcludedKeys => _tags.Select(t => t.Id).ToList();
    private bool _showTagSelector;
    private string _newTagName = string.Empty;
    private string _newTagColor = "#0d6efd";
    private bool _creatingTag;
    private IReadOnlyList<string> _tagCreateErrors = [];

    // Fields
    private List<ActionFieldResponse> _fields = [];
    private List<Guid> _fieldExcludedKeys => [];
    private bool _showFieldSelector;

    // Drag-and-drop reorder state
    private bool _savingOrder;

    // Analytics rules
    private List<FieldAnalyticsRuleResponse> _analyticsRules = [];
    private bool _showRuleForm;
    private bool _savingRule;
    private IReadOnlyList<string> _ruleErrors = [];
    private NewRuleModel _newRule = new();
    private Guid? _editingRuleId;
    private EditRuleModel _editRule = new();

    protected override async Task OnInitializedAsync()
    {
        var action = await Service.GetByIdAsync(Id);

        if (action is not null)
        {
            _model = new EditModel
            {
                Name = action.Name,
                Description = action.Description
            };

            var tagsTask = Service.GetTagsAsync(Id);
            var fieldsTask = ActionFieldService.GetByTrackedActionAsync(Id);
            var fieldDefsTask = FieldDefinitionService.GetAllAsync();
            await Task.WhenAll(tagsTask, fieldsTask, fieldDefsTask);

            _tags = tagsTask.Result;
            _fields = fieldsTask.Result;
            _allFieldDefinitions = fieldDefsTask.Result;
        }

        _loading = false;
    }

    private async Task SaveBasicInfoAsync()
    {
        if (_model is null) return;

        _saving = true;
        _errors = [];

        var (success, errors) = await Service.UpdateAsync(Id, new UpdateTrackedActionRequest(_model.Name, _model.Description));

        if (success)
            Nav.NavigateTo("/tracked-actions");
        else
            _errors = errors.Count > 0 ? errors : [L["Edit_UpdateFailed"]];

        _saving = false;
    }

    // Tags
    private async Task OnTagsSelectedAsync(List<TagResponse> tags)
    {
        _errors = [];
        foreach (var tag in tags)
        {
            var (ok, errs) = await Service.AddTagAsync(Id, tag.Id);
            if (ok)
                _tags.Add(tag);
            else
            {
                _errors = errs;
                return;
            }
        }
    }

    private async Task RemoveTagAsync(TagResponse tag)
    {
        _errors = [];
        var (ok, errs) = await Service.RemoveTagAsync(Id, tag.Id);
        if (ok)
            _tags.Remove(tag);
        else
            _errors = errs;
    }

    private async Task CreateTagInlineAsync(EventCallback onCreated)
    {
        if (string.IsNullOrWhiteSpace(_newTagName)) return;
        _creatingTag = true;
        _tagCreateErrors = [];

        var (success, errors) = await TagService.CreateAsync(
            new CreateTagRequest(_newTagName.Trim(), null, _newTagColor));

        if (success)
        {
            _newTagName = string.Empty;
            _newTagColor = "#0d6efd";
            await onCreated.InvokeAsync();
        }
        else
        {
            _tagCreateErrors = errors;
        }
        _creatingTag = false;
    }

    // Fields
    private async Task OnFieldsSelectedAsync(List<FieldDefinitionResponse> definitions)
    {
        _errors = [];
        var nextOrder = _fields.Count > 0 ? _fields.Max(f => f.Order) + 1 : 0;

        foreach (var def in definitions)
        {
            var request = new CreateActionFieldRequest(def.Id, def.DefaultName,
                def.DefaultDescription, def.DefaultMaxValue, def.DefaultMinValue,
                def.DefaultIsRequired, def.DefaultValue, def.Unit, nextOrder++);

            var (ok, errs) = await ActionFieldService.CreateAsync(Id, request);
            if (!ok)
            {
                _errors = errs;
                return;
            }
        }

        // Reload fields to get the server-assigned IDs
        _fields = await ActionFieldService.GetByTrackedActionAsync(Id);
    }

    private async Task RemoveFieldAsync(ActionFieldResponse field)
    {
        _errors = [];
        var (ok, errs) = await ActionFieldService.DeleteAsync(Id, field.Id);
        if (ok)
            _fields.Remove(field);
        else
            _errors = errs;
    }

    private async Task ReloadFieldsAsync()
    {
        _fields = await ActionFieldService.GetByTrackedActionAsync(Id);
    }

    private async Task OnFieldCreatedInlineAsync(FieldDefinitionResponse def, EventCallback onCreated)
    {
        await OnFieldsSelectedAsync([def]);
        await onCreated.InvokeAsync();
    }

    // Reorder handlers
    private async Task MoveFieldAsync(int index, int direction)
    {
        var targetIndex = index + direction;
        if (targetIndex < 0 || targetIndex >= _fields.Count) return;

        (_fields[index], _fields[targetIndex]) = (_fields[targetIndex], _fields[index]);
        await SaveFieldOrderAsync();
    }

    private async Task SaveFieldOrderAsync()
    {
        _savingOrder = true;
        _errors = [];

        for (var i = 0; i < _fields.Count; i++)
        {
            var field = _fields[i];
            if (field.Order == i) continue;

            var request = new UpdateActionFieldRequest(
                field.Name, field.Description, field.MaxValue, field.MinValue,
                field.IsRequired, field.DefaultValue, field.Unit, i,
                field.SummaryMetrics, field.TrendAggregation, field.TrendChartType, field.TargetValue);

            var (ok, errs) = await ActionFieldService.UpdateAsync(Id, field.Id, request);
            if (!ok)
            {
                _errors = errs;
                break;
            }
        }

        _fields = await ActionFieldService.GetByTrackedActionAsync(Id);
        _savingOrder = false;
    }

    // Analytics rules
    private async Task ActivateAnalyticsTabAsync()
    {
        _activeTab = "analytics";
        if (_analyticsRules.Count == 0)
            await LoadAnalyticsRulesAsync();
    }

    private async Task LoadAnalyticsRulesAsync()
    {
        try
        {
            _analyticsRules = await AnalyticsRuleService.GetByTrackedActionAsync(Id);
        }
        catch
        {
            _analyticsRules = [];
        }
    }

    private async Task SaveRuleAsync()
    {
        _ruleErrors = [];

        if (_newRule.MeasureFieldId == Guid.Empty || _newRule.GroupByFieldId == Guid.Empty)
        {
            _ruleErrors = [L["Analytics_SelectBothFields"]];
            return;
        }

        _savingRule = true;

        var request = new CreateFieldAnalyticsRuleRequest(
            _newRule.MeasureFieldId,
            _newRule.GroupByFieldId,
            _newRule.Aggregation,
            _newRule.DisplayType,
            _newRule.FilterFieldId != Guid.Empty ? _newRule.FilterFieldId : null,
            string.IsNullOrWhiteSpace(_newRule.FilterValue) ? null : _newRule.FilterValue,
            string.IsNullOrWhiteSpace(_newRule.Label) ? null : _newRule.Label,
            _analyticsRules.Count,
            _newRule.SignFieldId != Guid.Empty ? _newRule.SignFieldId : null,
            string.IsNullOrWhiteSpace(_newRule.NegativeValues) ? null : _newRule.NegativeValues);

        var (ok, errs) = await AnalyticsRuleService.CreateAsync(Id, request);

        if (ok)
        {
            ResetRuleForm();
            await LoadAnalyticsRulesAsync();
        }
        else
        {
            _ruleErrors = errs;
        }

        _savingRule = false;
    }

    private async Task DeleteRuleAsync(FieldAnalyticsRuleResponse rule)
    {
        _errors = [];
        var (ok, errs) = await AnalyticsRuleService.DeleteAsync(Id, rule.Id);
        if (ok)
            _analyticsRules.Remove(rule);
        else
            _errors = errs;
    }

    private void ResetRuleForm()
    {
        _showRuleForm = false;
        _newRule = new();
        _ruleErrors = [];
    }

    private void StartEditRule(FieldAnalyticsRuleResponse rule)
    {
        _editingRuleId = rule.Id;
        _editRule = new EditRuleModel
        {
            Aggregation = rule.Aggregation,
            DisplayType = rule.DisplayType,
            Label = rule.Label,
            FilterFieldId = rule.FilterFieldId ?? Guid.Empty,
            FilterValue = rule.FilterValue,
            SignFieldId = rule.SignFieldId ?? Guid.Empty,
            NegativeValues = rule.NegativeValues
        };
        _ruleErrors = [];
        _showRuleForm = false;
    }

    private void CancelEditRule()
    {
        _editingRuleId = null;
        _editRule = new();
        _ruleErrors = [];
    }

    private static string? ToggleNegativeValue(string? current, string value, bool isChecked)
    {
        var set = (current ?? "")
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        if (isChecked)
            set.Add(value);
        else
            set.Remove(value);

        return set.Count > 0 ? string.Join(",", set) : null;
    }

    private async Task UpdateRuleAsync()
    {
        if (_editingRuleId is null) return;

        _savingRule = true;
        _ruleErrors = [];

        var request = new UpdateFieldAnalyticsRuleRequest(
            _editRule.Aggregation,
            _editRule.DisplayType,
            _editRule.FilterFieldId != Guid.Empty ? _editRule.FilterFieldId : null,
            string.IsNullOrWhiteSpace(_editRule.FilterValue) ? null : _editRule.FilterValue,
            string.IsNullOrWhiteSpace(_editRule.Label) ? null : _editRule.Label,
            SignFieldId: _editRule.SignFieldId != Guid.Empty ? _editRule.SignFieldId : null,
            NegativeValues: string.IsNullOrWhiteSpace(_editRule.NegativeValues) ? null : _editRule.NegativeValues,
            ClearSignField: _editRule.SignFieldId == Guid.Empty);

        var (ok, errs) = await AnalyticsRuleService.UpdateAsync(Id, _editingRuleId.Value, request);

        if (ok)
        {
            CancelEditRule();
            await LoadAnalyticsRulesAsync();
        }
        else
        {
            _ruleErrors = errs;
        }

        _savingRule = false;
    }

    private sealed class EditModel
    {
        [Required]
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
    }

    private sealed class NewRuleModel
    {
        public Guid MeasureFieldId { get; set; }
        public Guid GroupByFieldId { get; set; }
        public AnalyticsAggregation Aggregation { get; set; } = AnalyticsAggregation.Sum;
