@page "/entries"
@page "/entries/action/{ActionId:guid}"
@attribute [Authorize]
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Entries_Title"] - Traceon</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-1">
            <i class="bi bi-journal-text me-2"></i>
            @L["Entries_Title"]
        </h3>
        <p class="text-muted mb-0">@L["Entries_Subtitle"]</p>
    </div>
</div>

<EntryDataGrid TrackedActionId="ActionId" StorageKey="entries" />

@code {
    [Parameter] public Guid? ActionId { get; set; }
}
