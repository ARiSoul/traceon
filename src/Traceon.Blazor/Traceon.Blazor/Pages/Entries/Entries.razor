@page "/entries"
@page "/entries/action/{ActionId:guid}"
@attribute [Authorize]

<PageTitle>Entries - Traceon</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-1">
            <i class="bi bi-journal-text me-2"></i>
            Entries
        </h3>
        <p class="text-muted mb-0">View and manage all your tracked entries</p>
    </div>
</div>

<EntryDataGrid TrackedActionId="ActionId" />

@code {
    [Parameter] public Guid? ActionId { get; set; }
}
