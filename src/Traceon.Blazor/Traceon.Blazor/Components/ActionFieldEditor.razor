@using Traceon.Contracts.Enums
@inject IStringLocalizer<SharedResource> L

<div class="list-group-item p-0">
    <!-- Summary row -->
    <div class="d-flex justify-content-between align-items-center p-3"
         style="cursor: pointer;"
         @onclick="ToggleExpand">
        <div class="d-flex align-items-center gap-2 flex-grow-1 overflow-hidden">
            <div class="btn-group btn-group-sm me-1" role="group" @onclick:stopPropagation="true">
                <button class="btn btn-outline-secondary py-0 px-1" @onclick="OnMoveUp" disabled="@IsFirst" title="@L["Common_MoveUp"]">
                    <i class="bi bi-chevron-up"></i>
                </button>
                <button class="btn btn-outline-secondary py-0 px-1" @onclick="OnMoveDown" disabled="@IsLast" title="@L["Common_MoveDown"]">
                    <i class="bi bi-chevron-down"></i>
                </button>
            </div>
            <i class="bi bi-@(_isExpanded ? "chevron-down" : "chevron-right") text-muted"></i>
            <strong class="text-truncate">@Field.Name</strong>
            @if (!string.IsNullOrEmpty(Field.FieldDefinitionName) && !string.Equals(Field.Name, Field.FieldDefinitionName, StringComparison.OrdinalIgnoreCase))
            {
                <span class="text-muted small" title="@L["FieldEditor_SourceFieldDef"]">
                    <i class="bi bi-link-45deg"></i>@Field.FieldDefinitionName
                </span>
            }
            <span class="badge bg-secondary">@Field.FieldType</span>
            @if (Field.FieldType is FieldType.Integer or FieldType.Decimal && Field.Unit != "UN")
            {
                <span class="badge bg-info">@Field.Unit</span>
            }
            @if (Field.IsRequired)
            {
                <span class="badge bg-danger">@L["Common_Required"]</span>
            }
        </div>
        <div class="d-flex gap-1" @onclick:stopPropagation="true">
            <button class="btn btn-outline-danger btn-sm" @onclick="() => OnRemove.InvokeAsync(Field)" title="@L["Common_Delete"]">
                <i class="bi bi-trash"></i>
            </button>
        </div>
    </div>

    <!-- Inline edit form -->
    @if (_isExpanded)
    {
        <div class="border-top px-3 pb-3 pt-2 bg-body-tertiary">
            <ErrorAlert Errors="_fieldErrors" />

            <div class="row g-2">
                <div class="col-md-6">
                    <label class="form-label form-label-sm mb-1">@L["Common_Name"] <span class="text-danger">*</span></label>
                    <input type="text" class="form-control form-control-sm" @bind="_name" />
                </div>
                <div class="col-md-6">
                    <label class="form-label form-label-sm mb-1">@L["Common_Description"]</label>
                    <input type="text" class="form-control form-control-sm" @bind="_description" />
                </div>
            </div>

            @if (Field.FieldType is FieldType.Integer or FieldType.Decimal or FieldType.Date)
            {
                <div class="row g-2 mt-1">
                    <div class="col-md-6">
                        <label class="form-label form-label-sm mb-1">@(Field.FieldType == FieldType.Date ? L["Fields_MinDate"] : L["Fields_MinValue"])</label>
                        @switch (Field.FieldType)
                        {
                            case FieldType.Integer:
                                <input type="number" step="1" class="form-control form-control-sm" @bind="_intMinValue" />
                                break;
                            case FieldType.Decimal:
                                <input type="number" class="form-control form-control-sm" @bind="_decimalMinValue" />
                                break;
                            case FieldType.Date:
                                <input type="date" class="form-control form-control-sm" @bind="_minDate" />
                                break;
                        }
                    </div>
                    <div class="col-md-6">
                        <label class="form-label form-label-sm mb-1">@(Field.FieldType == FieldType.Date ? L["Fields_MaxDate"] : L["Fields_MaxValue"])</label>
                        @switch (Field.FieldType)
                        {
                            case FieldType.Integer:
                                <input type="number" step="1" class="form-control form-control-sm" @bind="_intMaxValue" />
                                break;
                            case FieldType.Decimal:
                                <input type="number" class="form-control form-control-sm" @bind="_decimalMaxValue" />
                                break;
                            case FieldType.Date:
                                <input type="date" class="form-control form-control-sm" @bind="_maxDate" />
                                break;
                        }
                    </div>
                </div>
            }

            @if (Field.FieldType is FieldType.Integer or FieldType.Decimal)
            {
                <div class="row g-2 mt-1">
                    <div class="col-md-6">
                        <label class="form-label form-label-sm mb-1">@L["Fields_Unit"]</label>
                        <input type="text" class="form-control form-control-sm" @bind="_unit" placeholder="@L["Fields_UnitPlaceholder"]" />
                    </div>
                </div>
            }

            <div class="row g-2 mt-1">
                <div class="col-md-6">
                    <label class="form-label form-label-sm mb-1">@L["Fields_DefaultValue"]</label>
                    @switch (Field.FieldType)
                    {
                        case FieldType.Boolean:
                            <div class="form-check mt-1">
                                <input type="checkbox" class="form-check-input" id="@($"dfBool-{Field.Id}")" @bind="_defaultBool" />
                                <label class="form-check-label" for="@($"dfBool-{Field.Id}")">@L["Fields_CheckedByDefault"]</label>
                            </div>
                            break;
                        case FieldType.Integer:
                            <input type="number" step="1" class="form-control form-control-sm" @bind="_defaultInt" />
                            break;
                        case FieldType.Decimal:
                            <input type="number" class="form-control form-control-sm" @bind="_defaultDecimal" />
                            break;
                        case FieldType.Date:
                            <input type="date" class="form-control form-control-sm" @bind="_defaultDate" />
                            break;
                        case FieldType.Dropdown:
                            @if (ParsedDropdownValues.Length > 0)
                            {
                                <select class="form-select form-select-sm" @bind="_defaultValue">
                                    <option value="">@L["Fields_SelectDefault"]</option>
                                    @foreach (var val in ParsedDropdownValues)
                                    {
                                        <option value="@val">@val</option>
                                    }
                                </select>
                            }
                            else
                            {
                                <input type="text" class="form-control form-control-sm" disabled />
                                <small class="text-warning">
                                    <i class="bi bi-info-circle me-1"></i>@L["Fields_DefineDropdownFirst"]
                                </small>
                            }
                            break;
                        case FieldType.CompositeDropdown:
                            <small class="text-muted">
                                <i class="bi bi-layers me-1"></i>@L["Fields_CompositeNoDefault"]
                            </small>
                            break;
                        default:
                            <input type="text" class="form-control form-control-sm" @bind="_defaultValue" />
                            break;
                    }
                </div>
                <div class="col-md-6 d-flex align-items-end">
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="@($"req-{Field.Id}")" @bind="_isRequired" />
                        <label class="form-check-label" for="@($"req-{Field.Id}")">@L["Common_Required"]</label>
                    </div>
                </div>
            </div>

            @if (Field.FieldType is FieldType.Integer or FieldType.Decimal)
            {
                <hr class="my-2" />
                <div class="d-flex align-items-center gap-1 mb-2">
                    <i class="bi bi-bar-chart-line text-muted"></i>
                    <strong class="small">@L["FieldEditor_AnalyticsConfig"]</strong>
                </div>

                <div class="row g-2">
                    <div class="col-12">
                        <label class="form-label form-label-sm mb-1">@L["FieldEditor_SummaryMetrics"]</label>
                        <div class="d-flex flex-wrap gap-3">
                            @foreach (var metric in new[] {
                                (SummaryMetrics.Min, L["Metric_Min"].Value),
                                (SummaryMetrics.Max, L["Metric_Max"].Value),
                                (SummaryMetrics.Avg, L["Metric_Avg"].Value),
                                (SummaryMetrics.Sum, L["Metric_Sum"].Value),
                                (SummaryMetrics.Count, L["Metric_Count"].Value),
                                (SummaryMetrics.Latest, L["Metric_Latest"].Value) })
                            {
                                var flag = metric.Item1;
                                var label = metric.Item2;
                                <div class="form-check form-check-inline">
                                    <input type="checkbox" class="form-check-input"
                                           id="@($"sm-{flag}-{Field.Id}")"
                                           checked="@_summaryMetrics.HasFlag(flag)"
                                           @onchange="e => ToggleSummaryMetric(flag, (bool)e.Value!)" />
                                    <label class="form-check-label small" for="@($"sm-{flag}-{Field.Id}")">@label</label>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="row g-2 mt-1">
                    <div class="col-md-4">
                        <label class="form-label form-label-sm mb-1">@L["FieldEditor_TrendAggregation"]</label>
                        <select class="form-select form-select-sm" @bind="_trendAggregation">
                            <option value="@TrendAggregation.AllPoints">@L["FieldEditor_AllPoints"]</option>
                            <option value="@TrendAggregation.Average">@L["FieldEditor_DailyAverage"]</option>
                            <option value="@TrendAggregation.Min">@L["FieldEditor_DailyMin"]</option>
                            <option value="@TrendAggregation.Max">@L["FieldEditor_DailyMax"]</option>
                            <option value="@TrendAggregation.Sum">@L["FieldEditor_DailySum"]</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label form-label-sm mb-1">@L["FieldEditor_ChartType"]</label>
                        <select class="form-select form-select-sm" @bind="_trendChartType">
                            <option value="@TrendChartType.Line">@L["FieldEditor_Line"]</option>
                            <option value="@TrendChartType.Bar">@L["FieldEditor_Bar"]</option>
                            <option value="@TrendChartType.Area">@L["FieldEditor_Area"]</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label form-label-sm mb-1">@L["FieldEditor_TargetValue"]</label>
                        <input type="number" class="form-control form-control-sm" @bind="_targetValue" />
                    </div>
                </div>
                @if (_targetValue.HasValue)
                {
                    <div class="row g-2 mt-1">
                        <div class="col-md-4">
                            <label class="form-label form-label-sm mb-1">@L["FieldEditor_TargetValueMode"]</label>
                            <select class="form-select form-select-sm" @bind="_targetValueMode">
                                <option value="@TargetValueMode.PerEntry">@L["TargetMode_PerEntry"]</option>
                                <option value="@TargetValueMode.Goal">@L["TargetMode_Goal"]</option>
                            </select>
                        </div>
                    </div>
                }
            }

            @if (Field.FieldType is FieldType.Dropdown or FieldType.CompositeDropdown)
            {
                var numericSiblings = SiblingFields.Where(f => f.FieldType is FieldType.Integer or FieldType.Decimal && f.Id != Field.Id).ToList();
                @if (numericSiblings.Count > 0)
                {
                    <hr class="my-2" />
                    <div class="d-flex align-items-center gap-1 mb-2">
                        <i class="bi bi-graph-up text-muted"></i>
                        <strong class="small">@L["FieldEditor_DropdownTrendConfig"]</strong>
                    </div>
                    <div class="form-text mt-0 mb-2">@L["FieldEditor_DropdownTrendHint"]</div>

                    <div class="row g-2">
                        <div class="col-md-4">
                            <label class="form-label form-label-sm mb-1">@L["Analytics_ValueField"]</label>
                            <select class="form-select form-select-sm" value="@(_dropdownTrendValueFieldId?.ToString() ?? "")"
                                    @onchange="e => _dropdownTrendValueFieldId = Guid.TryParse(e.Value?.ToString(), out var g) ? g : null">
                                <option value="">— @L["Common_None"] —</option>
                                @foreach (var f in numericSiblings.OrderBy(f => f.Name, StringComparer.CurrentCultureIgnoreCase))
                                {
                                    <option value="@f.Id">@f.Name (@f.Unit)</option>
                                }
                            </select>
                        </div>
                        @if (_dropdownTrendValueFieldId.HasValue)
                        {
                            <div class="col-md-4">
                                <label class="form-label form-label-sm mb-1">@L["FieldEditor_TrendAggregation"]</label>
                                <select class="form-select form-select-sm" @bind="_dropdownTrendAggregation">
                                    <option value="@TrendAggregation.Sum">@L["FieldEditor_DailySum"]</option>
                                    <option value="@TrendAggregation.Average">@L["FieldEditor_DailyAverage"]</option>
                                    <option value="@TrendAggregation.Min">@L["FieldEditor_DailyMin"]</option>
                                    <option value="@TrendAggregation.Max">@L["FieldEditor_DailyMax"]</option>
                                    <option value="@TrendAggregation.AllPoints">@L["FieldEditor_AllPoints"]</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label form-label-sm mb-1">@L["FieldEditor_ChartType"]</label>
                                <select class="form-select form-select-sm" @bind="_dropdownTrendChartType">
                                    <option value="@TrendChartType.Line">@L["FieldEditor_Line"]</option>
                                    <option value="@TrendChartType.Bar">@L["FieldEditor_Bar"]</option>
                                    <option value="@TrendChartType.Area">@L["FieldEditor_Area"]</option>
                                </select>
                            </div>
                        }
                    </div>
                }
            }

            <hr class="my-2" />
            <div class="d-flex align-items-center gap-1 mb-2">
                <i class="bi bi-play-circle text-muted"></i>
                <strong class="small">@L["FieldEditor_InitialValueConfig"]</strong>
            </div>
            <div class="form-text mt-0 mb-2">@L["FieldEditor_InitialValueHint"]</div>

            <div class="row g-2">
                <div class="col-md-4">
                    <label class="form-label form-label-sm mb-1">@L["FieldEditor_InitialValueBehavior"]</label>
                    <select class="form-select form-select-sm" @bind="_initialValueBehavior">
                        <option value="@InitialValueBehavior.DefaultValue">@L["FieldEditor_IV_Default"]</option>
                        <option value="@InitialValueBehavior.LastValue">@L["FieldEditor_IV_Last"]</option>
                        @if (Field.FieldType is FieldType.Integer or FieldType.Decimal)
                        {
                            <option value="@InitialValueBehavior.MinValue">@L["FieldEditor_IV_Min"]</option>
                            <option value="@InitialValueBehavior.MaxValue">@L["FieldEditor_IV_Max"]</option>
                            <option value="@InitialValueBehavior.AvgValue">@L["FieldEditor_IV_Avg"]</option>
                            <option value="@InitialValueBehavior.AutoCounter">@L["FieldEditor_IV_AutoCounter"]</option>
                        }
                    </select>
                </div>
                @if (_initialValueBehavior is InitialValueBehavior.MinValue or InitialValueBehavior.MaxValue or InitialValueBehavior.AvgValue)
                {
                    <div class="col-md-4">
                        <label class="form-label form-label-sm mb-1">@L["FieldEditor_IV_Period"]</label>
                        <select class="form-select form-select-sm" @bind="_initialValuePeriodUnit">
                            <option value="@InitialValuePeriodUnit.AllTime">@L["Common_AllTime"]</option>
                            <option value="@InitialValuePeriodUnit.Days">@L["Dashboard_LastNDays"]</option>
                            <option value="@InitialValuePeriodUnit.Months">@L["Dashboard_LastNMonths"]</option>
                        </select>
                    </div>
                    @if (_initialValuePeriodUnit is not InitialValuePeriodUnit.AllTime)
                    {
                        <div class="col-md-4">
                            <label class="form-label form-label-sm mb-1">
                                @(_initialValuePeriodUnit == InitialValuePeriodUnit.Days ? L["Dashboard_Days"] : L["Dashboard_Months"])
                            </label>
                            <input type="number" min="1" class="form-control form-control-sm" @bind="_initialValuePeriodCount" />
                        </div>
                    }
                }
            </div>

            @if (_initialValueBehavior == InitialValueBehavior.AutoCounter && Field.FieldType is FieldType.Integer or FieldType.Decimal)
            {
                <div class="border rounded p-2 mt-2 bg-body">
                    <div class="form-text mb-2">@L["FieldEditor_AutoCounterHint"]</div>

                    <div class="row g-2">
                        <div class="col-md-3">
                            <label class="form-label form-label-sm mb-1">@L["FieldEditor_AC_Direction"]</label>
                            <select class="form-select form-select-sm" @bind="_autoDirection">
                                <option value="inc">@L["FieldEditor_AC_Increment"]</option>
                                <option value="dec">@L["FieldEditor_AC_Decrement"]</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label form-label-sm mb-1">@L["FieldEditor_AC_Step"]</label>
                            @if (Field.FieldType == FieldType.Integer)
                            {
                                <input type="number" step="1" min="0" class="form-control form-control-sm" @bind="_autoStepInt" />
                            }
                            else
                            {
                                <input type="number" min="0" class="form-control form-control-sm" @bind="_autoStepDecimal" />
                            }
                        </div>
                        <div class="col-md-3">
                            <label class="form-label form-label-sm mb-1">@L["FieldEditor_AC_StartValue"]</label>
                            @if (Field.FieldType == FieldType.Integer)
                            {
                                <input type="number" step="1" class="form-control form-control-sm" @bind="_autoStartInt" />
                            }
                            else
                            {
                                <input type="number" class="form-control form-control-sm" @bind="_autoStartDecimal" />
                            }
                        </div>
                        @if (_autoConditions.Count > 1)
                        {
                            <div class="col-md-3">
                                <label class="form-label form-label-sm mb-1">@L["FieldEditor_AC_ConditionLogic"]</label>
                                <select class="form-select form-select-sm" @bind="_autoConditionLogic">
                                    <option value="@FilterLogic.And">@L["FieldEditor_AC_LogicAnd"]</option>
                                    <option value="@FilterLogic.Or">@L["FieldEditor_AC_LogicOr"]</option>
                                </select>
                            </div>
                        }
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-3 mb-1">
                        <strong class="small">@L["FieldEditor_AC_Conditions"]</strong>
                        <button type="button" class="btn btn-outline-primary btn-sm" @onclick="AddAutoCondition" disabled="@(EligibleConditionFields.Count == 0)">
                            <i class="bi bi-plus-lg me-1"></i>@L["FieldEditor_AC_AddCondition"]
                        </button>
                    </div>

                    @if (_autoConditions.Count == 0)
                    {
                        <div class="text-muted small fst-italic">@L["FieldEditor_AC_NoConditionsHint"]</div>
                    }
                    else
                    {
                        @for (var i = 0; i < _autoConditions.Count; i++)
                        {
                            var idx = i;
                            var c = _autoConditions[idx];
                            var refField = SiblingFields.FirstOrDefault(f => f.Id == c.FieldId);
                            <div class="row g-2 align-items-end mb-2">
                                <div class="col-md-4">
                                    <label class="form-label form-label-sm mb-1">@L["FieldEditor_AC_Field"]</label>
                                    <select class="form-select form-select-sm" value="@c.FieldId" @onchange="e => OnAutoConditionFieldChanged(idx, e.Value?.ToString())">
                                        <option value="">— @L["Common_Select"] —</option>
                                        @foreach (var ef in EligibleConditionFields)
                                        {
                                            <option value="@ef.Id">@ef.Name (@ef.FieldType)</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label form-label-sm mb-1">@L["FieldEditor_AC_Operator"]</label>
                                    <select class="form-select form-select-sm"
                                            value="@(c.UseCurrentValue ? FilterOperator.Equals : c.Operator)"
                                            disabled="@c.UseCurrentValue"
                                            @onchange="e => OnAutoConditionOperatorChanged(idx, e.Value?.ToString())">
                                        @foreach (var op in OperatorsFor(refField?.FieldType))
                                        {
                                            <option value="@op">@OperatorLabel(op)</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label form-label-sm mb-1">@L["FieldEditor_AC_Value"]</label>
                                    @if (c.UseCurrentValue)
                                    {
                                        <input class="form-control form-control-sm" disabled value="@L["FieldEditor_AC_UseCurrentValuePlaceholder"]" />
                                    }
                                    else if (refField is null)
                                    {
                                        <input class="form-control form-control-sm" disabled />
                                    }
                                    else if (c.Operator is FilterOperator.IsEmpty or FilterOperator.IsNotEmpty)
                                    {
                                        <input class="form-control form-control-sm" disabled placeholder="—" />
                                    }
                                    else if (refField.FieldType is FieldType.Dropdown or FieldType.CompositeDropdown)
                                    {
                                        var opts = string.IsNullOrWhiteSpace(refField.DropdownValues)
                                            ? new List<string>()
                                            : DropdownValuesHelper.Split(refField.DropdownValues).ToList();
                                        <SearchableSelect Value="@c.Value"
                                                          ValueChanged="v => OnAutoConditionValueChanged(idx, v)"
                                                          Options="opts"
                                                          Placeholder="@L["Common_Select"]"
                                                          Small="true" />
                                    }
                                    else if (refField.FieldType == FieldType.Boolean)
                                    {
                                        <select class="form-select form-select-sm" value="@c.Value" @onchange="e => OnAutoConditionValueChanged(idx, e.Value?.ToString())">
                                            <option value="">—</option>
                                            <option value="true">@L["Common_Yes"]</option>
                                            <option value="false">@L["Common_No"]</option>
                                        </select>
                                    }
                                    else if (refField.FieldType == FieldType.Date)
                                    {
                                        <input type="date" class="form-control form-control-sm" value="@c.Value" @onchange="e => OnAutoConditionValueChanged(idx, e.Value?.ToString())" />
                                    }
                                    else if (refField.FieldType is FieldType.Integer or FieldType.Decimal)
                                    {
                                        <input type="number" class="form-control form-control-sm" value="@c.Value" @onchange="e => OnAutoConditionValueChanged(idx, e.Value?.ToString())" />
                                    }
                                    else
                                    {
                                        <input class="form-control form-control-sm" value="@c.Value" @onchange="e => OnAutoConditionValueChanged(idx, e.Value?.ToString())" />
                                    }
                                </div>
                                <div class="col-md-1 d-flex justify-content-end">
                                    <button type="button" class="btn btn-outline-danger btn-sm" @onclick="() => RemoveAutoCondition(idx)" title="@L["Common_Remove"]">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                                <div class="col-12">
                                    <div class="form-check form-check-sm small">
                                        <input class="form-check-input" type="checkbox" id="@($"acuc-{Field.Id}-{idx}")"
                                               checked="@c.UseCurrentValue"
                                               @onchange="e => OnAutoConditionUseCurrentChanged(idx, (bool)(e.Value ?? false))" />
                                        <label class="form-check-label text-muted" for="@($"acuc-{Field.Id}-{idx}")"
                                               title="@L["FieldEditor_AC_UseCurrentValueHint"]">
                                            @L["FieldEditor_AC_UseCurrentValue"]
                                        </label>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
            }

            <div class="d-flex gap-2 mt-3">
                <button class="btn btn-success btn-sm" @onclick="SaveAsync" disabled="@_saving">
                    @if (_saving)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    <i class="bi bi-check-circle me-1"></i>@L["Common_Save"]
                </button>
                <button class="btn btn-outline-secondary btn-sm" @onclick="CancelEdit">
                    <i class="bi bi-x me-1"></i>@L["Common_Cancel"]
                </button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public required ActionFieldResponse Field { get; set; }
    [Parameter, EditorRequired] public required Guid TrackedActionId { get; set; }
    [Parameter, EditorRequired] public required EventCallback<ActionFieldResponse> OnRemove { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback OnMoveUp { get; set; }
    [Parameter] public EventCallback OnMoveDown { get; set; }
    [Parameter] public bool IsFirst { get; set; }
    [Parameter] public bool IsLast { get; set; }
    [Parameter] public IReadOnlyList<ActionFieldResponse> SiblingFields { get; set; } = [];

    [Inject] private ActionFieldService ActionFieldService { get; set; } = default!;

    private bool _isExpanded;
    private bool _saving;
    private IReadOnlyList<string> _fieldErrors = [];

    // Editable fields
    private string _name = string.Empty;
    private string? _description;
    private bool _isRequired;
    private string? _defaultValue;
    private string? _unit;
    private int _order;
    private SummaryMetrics _summaryMetrics = SummaryMetrics.All;
    private TrendAggregation _trendAggregation = TrendAggregation.AllPoints;
    private TrendChartType _trendChartType = TrendChartType.Line;
    private decimal? _targetValue;
    private TargetValueMode _targetValueMode = TargetValueMode.PerEntry;
    private InitialValueBehavior _initialValueBehavior = InitialValueBehavior.DefaultValue;
    private InitialValuePeriodUnit _initialValuePeriodUnit = InitialValuePeriodUnit.AllTime;
    private int _initialValuePeriodCount;
    private Guid? _dropdownTrendValueFieldId;
    private TrendAggregation _dropdownTrendAggregation = TrendAggregation.AllPoints;
    private TrendChartType _dropdownTrendChartType = TrendChartType.Line;

    // Typed values
    private int? _intMinValue;
    private int? _intMaxValue;
    private decimal? _decimalMinValue;
    private decimal? _decimalMaxValue;
    private DateTime? _minDate;
    private DateTime? _maxDate;
    private bool _defaultBool;
    private int? _defaultInt;
    private decimal? _defaultDecimal;
    private DateTime? _defaultDate;

    // AutoCounter
    private string _autoDirection = "inc";
    private int _autoStepInt = 1;
    private decimal _autoStepDecimal = 1m;
    private int _autoStartInt;
    private decimal _autoStartDecimal;
    private FilterLogic _autoConditionLogic = FilterLogic.And;
    private List<AutoCounterCondition> _autoConditions = [];

    private List<ActionFieldResponse> EligibleConditionFields =>
        SiblingFields.Where(f => f.Id != Field.Id).ToList();

    private static FilterOperator[] OperatorsFor(FieldType? type) => type switch
    {
        FieldType.Dropdown or FieldType.CompositeDropdown => [FilterOperator.Equals, FilterOperator.NotEquals, FilterOperator.IsEmpty, FilterOperator.IsNotEmpty],
        FieldType.Boolean => [FilterOperator.Equals, FilterOperator.NotEquals],
        FieldType.Integer or FieldType.Decimal => [FilterOperator.Equals, FilterOperator.NotEquals, FilterOperator.GreaterThan, FilterOperator.GreaterThanOrEqual, FilterOperator.LessThan, FilterOperator.LessThanOrEqual, FilterOperator.IsEmpty, FilterOperator.IsNotEmpty],
        FieldType.Date => [FilterOperator.Equals, FilterOperator.NotEquals, FilterOperator.GreaterThan, FilterOperator.LessThan, FilterOperator.IsEmpty, FilterOperator.IsNotEmpty],
        _ => [FilterOperator.Equals, FilterOperator.NotEquals, FilterOperator.Contains, FilterOperator.NotContains, FilterOperator.StartsWith, FilterOperator.EndsWith, FilterOperator.IsEmpty, FilterOperator.IsNotEmpty]
    };

    private string OperatorLabel(FilterOperator op) => L[$"FilterOp_{op}"];

    private void AddAutoCondition()
    {
        var firstField = EligibleConditionFields.FirstOrDefault();
        if (firstField is null) return;
        _autoConditions.Add(new AutoCounterCondition(firstField.Id, FilterOperator.Equals, null));
    }

    private void RemoveAutoCondition(int idx)
    {
        if (idx < 0 || idx >= _autoConditions.Count) return;
        _autoConditions.RemoveAt(idx);
    }

    private void OnAutoConditionFieldChanged(int idx, string? raw)
    {
        if (!Guid.TryParse(raw, out var fid)) return;
        var cur = _autoConditions[idx];
        // Reset value when switching field types (operator may no longer apply).
        var refField = SiblingFields.FirstOrDefault(f => f.Id == fid);
        var ops = OperatorsFor(refField?.FieldType);
        var op = ops.Contains(cur.Operator) ? cur.Operator : FilterOperator.Equals;
        _autoConditions[idx] = new AutoCounterCondition(fid, op, null);
    }

    private void OnAutoConditionOperatorChanged(int idx, string? raw)
    {
        if (!Enum.TryParse<FilterOperator>(raw, out var op)) return;
        var cur = _autoConditions[idx];
        var value = (op is FilterOperator.IsEmpty or FilterOperator.IsNotEmpty) ? null : cur.Value;
        _autoConditions[idx] = cur with { Operator = op, Value = value };
    }

    private void OnAutoConditionValueChanged(int idx, string? value)
    {
        var cur = _autoConditions[idx];
        _autoConditions[idx] = cur with { Value = value };
    }

    private void OnAutoConditionUseCurrentChanged(int idx, bool useCurrent)
    {
        var cur = _autoConditions[idx];
        // Force operator to Equals and clear the literal value when switching to dynamic mode.
        _autoConditions[idx] = useCurrent
            ? cur with { UseCurrentValue = true, Operator = FilterOperator.Equals, Value = null }
            : cur with { UseCurrentValue = false };
    }

    private string[] ParsedDropdownValues =>
        string.IsNullOrWhiteSpace(Field.DropdownValues)
            ? []
            : DropdownValuesHelper.Split(Field.DropdownValues)
                .OrderBy(v => v, StringComparer.CurrentCultureIgnoreCase).ToArray();

    private void ToggleExpand()
    {
        _isExpanded = !_isExpanded;
        if (_isExpanded)
            LoadFromField();
    }

    private void CancelEdit()
    {
        _isExpanded = false;
        _fieldErrors = [];
    }

    private void LoadFromField()
    {
        _name = Field.Name;
        _description = Field.Description;
        _isRequired = Field.IsRequired;
        _defaultValue = Field.DefaultValue;
        _unit = Field.Unit;
        _order = Field.Order;
        _summaryMetrics = Field.SummaryMetrics;
        _trendAggregation = Field.TrendAggregation;
        _trendChartType = Field.TrendChartType;
        _targetValue = Field.TargetValue;
        _targetValueMode = Field.TargetValueMode;
        _initialValueBehavior = Field.InitialValueBehavior;
        _initialValuePeriodUnit = Field.InitialValuePeriodUnit;
        _initialValuePeriodCount = Field.InitialValuePeriodCount;
        _dropdownTrendValueFieldId = Field.DropdownTrendValueFieldId;
        _dropdownTrendAggregation = Field.DropdownTrendAggregation;
        _dropdownTrendChartType = Field.DropdownTrendChartType;

        // Load min/max
        switch (Field.FieldType)
        {
            case FieldType.Integer:
                _intMinValue = Field.MinValue.HasValue ? (int)Field.MinValue.Value : null;
                _intMaxValue = Field.MaxValue.HasValue ? (int)Field.MaxValue.Value : null;
                break;
            case FieldType.Decimal:
                _decimalMinValue = Field.MinValue;
                _decimalMaxValue = Field.MaxValue;
                break;
        }

        // Load AutoCounter config
        var ac = Field.AutoCounterConfig;
        if (ac is not null)
        {
            _autoDirection = ac.Step < 0 ? "dec" : "inc";
            var absStep = Math.Abs(ac.Step);
            _autoStepInt = (int)Math.Round(absStep);
            _autoStepDecimal = absStep == 0 ? 1m : absStep;
            if (Field.FieldType == FieldType.Integer)
            {
                _autoStartInt = (int)Math.Round(ac.StartValue);
                _autoStartDecimal = ac.StartValue;
            }
            else
            {
                _autoStartDecimal = ac.StartValue;
                _autoStartInt = (int)Math.Round(ac.StartValue);
            }
            _autoConditionLogic = ac.ConditionLogic;
            _autoConditions = ac.Conditions is null ? [] : new List<AutoCounterCondition>(ac.Conditions);
        }
        else
        {
            _autoDirection = "inc";
            _autoStepInt = 1;
            _autoStepDecimal = 1m;
            _autoStartInt = 0;
            _autoStartDecimal = 0m;
            _autoConditionLogic = FilterLogic.And;
            _autoConditions = [];
        }

        // Load default value
        if (!string.IsNullOrWhiteSpace(Field.DefaultValue))
        {
            switch (Field.FieldType)
            {
                case FieldType.Boolean:
                    _defaultBool = Field.DefaultValue.Equals("true", StringComparison.OrdinalIgnoreCase);
                    break;
                case FieldType.Integer when int.TryParse(Field.DefaultValue, CultureInfo.InvariantCulture, out var i):
                    _defaultInt = i;
                    break;
                case FieldType.Decimal when decimal.TryParse(Field.DefaultValue, CultureInfo.InvariantCulture, out var d):
                    _defaultDecimal = d;
                    break;
                case FieldType.Date when DateTime.TryParse(Field.DefaultValue, CultureInfo.InvariantCulture, out var dt):
                    _defaultDate = dt;
                    break;
            }
        }
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_name))
        {
            _fieldErrors = [L["Validation_NameRequired"]];
            return;
        }

        // Validate min ≤ max
        var validationErrors = ValidateMinMax();
        if (validationErrors.Count > 0)
        {
            _fieldErrors = validationErrors;
            return;
        }

        _saving = true;
        _fieldErrors = [];

        var (minValue, maxValue) = ResolveMinMax();
        var defaultVal = ResolveDefaultValue();
        var autoCounter = BuildAutoCounterConfig();

        var request = new UpdateActionFieldRequest(
            _name, _description, maxValue, minValue, _isRequired, defaultVal, _unit, _order,
            _summaryMetrics, _trendAggregation, _trendChartType, _targetValue,
            _targetValueMode,
            _initialValueBehavior, _initialValuePeriodUnit, _initialValuePeriodCount,
            _dropdownTrendValueFieldId, _dropdownTrendAggregation, _dropdownTrendChartType,
            autoCounter);

        var (ok, errs) = await ActionFieldService.UpdateAsync(TrackedActionId, Field.Id, request);

        if (ok)
        {
            _isExpanded = false;
            await OnSaved.InvokeAsync();
        }
        else
        {
            _fieldErrors = errs;
        }

        _saving = false;
    }

    private AutoCounterConfig? BuildAutoCounterConfig()
    {
        if (_initialValueBehavior != InitialValueBehavior.AutoCounter) return null;
        if (Field.FieldType is not (FieldType.Integer or FieldType.Decimal)) return null;

        var absStep = Field.FieldType == FieldType.Integer ? (decimal)_autoStepInt : _autoStepDecimal;
        if (absStep <= 0) absStep = 1m;
        var step = _autoDirection == "dec" ? -absStep : absStep;

        var startValue = Field.FieldType == FieldType.Integer ? (decimal)_autoStartInt : _autoStartDecimal;

        // Drop incomplete conditions (no field, or — for literal value-needing operators — no value).
        // UseCurrentValue conditions don't require a Value (they read the in-progress entry at compute time).
        var validConditions = _autoConditions
            .Where(c => c.FieldId != Guid.Empty)
            .Where(c => c.UseCurrentValue
                        || c.Operator is FilterOperator.IsEmpty or FilterOperator.IsNotEmpty
                        || !string.IsNullOrEmpty(c.Value))
            .ToList();

        return new AutoCounterConfig(
            step,
            startValue,
            _autoConditionLogic,
            validConditions.Count > 0 ? validConditions : null);
    }

    private string? ResolveDefaultValue() => Field.FieldType switch
    {
        FieldType.Boolean => _defaultBool ? "true" : "false",
        FieldType.Integer => _defaultInt?.ToString(CultureInfo.InvariantCulture),
        FieldType.Decimal => _defaultDecimal?.ToString(CultureInfo.InvariantCulture),
        FieldType.Date => _defaultDate?.ToString("yyyy-MM-dd"),
        _ => _defaultValue
    };

    private (decimal? Min, decimal? Max) ResolveMinMax() => Field.FieldType switch
    {
        FieldType.Integer => (_intMinValue, _intMaxValue),
        FieldType.Decimal => (_decimalMinValue, _decimalMaxValue),
        _ => (null, null)
    };

    private IReadOnlyList<string> ValidateMinMax()
    {
        var errors = new List<string>();
        var defaultVal = ResolveDefaultValue();

        switch (Field.FieldType)
        {
            case FieldType.Integer:
                if (_intMinValue.HasValue && _intMaxValue.HasValue && _intMinValue > _intMaxValue)
                    errors.Add(L["Validation_MinGreaterThanMax"]);
                if (_defaultInt.HasValue)
                {
                    if (_intMinValue.HasValue && _defaultInt < _intMinValue)
                        errors.Add(L["Validation_DefaultLessThanMin", _intMinValue]);
                    if (_intMaxValue.HasValue && _defaultInt > _intMaxValue)
                        errors.Add(L["Validation_DefaultGreaterThanMax", _intMaxValue]);
                }
                break;
            case FieldType.Decimal:
                if (_decimalMinValue.HasValue && _decimalMaxValue.HasValue && _decimalMinValue > _decimalMaxValue)
                    errors.Add(L["Validation_MinGreaterThanMax"]);
                if (_defaultDecimal.HasValue)
                {
                    if (_decimalMinValue.HasValue && _defaultDecimal < _decimalMinValue)
                        errors.Add(L["Validation_DefaultLessThanMin", _decimalMinValue]);
                    if (_decimalMaxValue.HasValue && _defaultDecimal > _decimalMaxValue)
                        errors.Add(L["Validation_DefaultGreaterThanMax", _decimalMaxValue]);
                }
                break;
            case FieldType.Date:
                if (_minDate.HasValue && _maxDate.HasValue && _minDate > _maxDate)
                    errors.Add(L["Validation_MinDateAfterMax"]);
                if (_defaultDate.HasValue)
                {
                    if (_minDate.HasValue && _defaultDate < _minDate)
                        errors.Add(L["Validation_DefaultDateBeforeMin", _minDate.Value.ToString("yyyy-MM-dd")]);
                    if (_maxDate.HasValue && _defaultDate > _maxDate)
                        errors.Add(L["Validation_DefaultDateAfterMax", _maxDate.Value.ToString("yyyy-MM-dd")]);
                }
                break;
        }

        return errors;
    }

    private void ToggleSummaryMetric(SummaryMetrics flag, bool enabled)
    {
        if (enabled)
            _summaryMetrics |= flag;
        else
            _summaryMetrics &= ~flag;
    }
}
