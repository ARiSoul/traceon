<div class="card h-100 @(Highlighted ? "border-success" : "")">
    <div class="card-body d-flex flex-column">
        <div class="d-flex justify-content-between align-items-start mb-1">
            <h6 class="card-title mb-0"><b>@Action.Name</b></h6>
            <div class="d-flex gap-1">
                <a href="/dashboard/action/@Action.Id"
                   class="btn btn-outline-secondary btn-sm py-0 px-1"
                   title="View statistics">
                    <i class="bi bi-bar-chart-line"></i>
                </a>
                <a href="/entries/action/@Action.Id"
                   class="btn btn-outline-secondary btn-sm py-0 px-1"
                   title="View entries">
                    <i class="bi bi-journal-text"></i>
                    @if (Action.EntryCount > 0)
                    {
                        <span class="ms-1" style="font-size: 0.7rem;">@Action.EntryCount</span>
                    }
                </a>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Action.Description))
        {
            <small class="text-muted d-block mb-2 text-truncate">@Action.Description</small>
        }

        @if (Action.Tags.Count > 0)
        {
            <div class="d-flex flex-wrap gap-1 mb-2">
                @foreach (var tag in Action.Tags)
                {
                    <span class="badge rounded-pill" style="background-color: @tag.Color; font-size: 0.7rem;">@tag.Name</span>
                }
            </div>
        }

        <div class="mt-auto pt-2 d-flex gap-2">
            <button class="btn btn-success btn-sm flex-fill"
                    @onclick="() => OnTrack.InvokeAsync(Action)">
                <i class="bi bi-bullseye me-1"></i>Track
            </button>

            @if (Action.FieldCount > 0)
            {
                <a href="/tracked-actions/@Action.Id/entries/new?returnUrl=%2F"
                   class="btn btn-outline-primary btn-sm flex-fill">
                    <i class="bi bi-pencil-square me-1"></i>
                    <span class="d-none d-md-inline">Full Entry</span>
                    <span class="d-md-none">Entry</span>
                    <span class="badge bg-secondary ms-1">@Action.FieldCount</span>
                </a>
            }
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public TrackedActionResponse Action { get; set; } = default!;

    [Parameter]
    public bool Highlighted { get; set; }

    [Parameter]
    public EventCallback<TrackedActionResponse> OnTrack { get; set; }
}
