@inject NavigationManager NavigationManager
@inject IStringLocalizer<SharedResource> L

<div class="card h-100 @(Highlighted ? "border-success" : "")">
    <div class="card-body d-flex flex-column">
        <div class="d-flex align-items-start gap-2 mb-2">
            <div class="flex-grow-1 min-width-0">
                <h5 class="card-title fw-bold mb-0 text-truncate">@Action.Name</h5>
                @if (!string.IsNullOrEmpty(Action.Description))
                {
                    <small class="text-muted text-truncate d-block">@Action.Description</small>
                }
            </div>
            @if (Action.Tags.Count > 0)
            {
                <div class="quick-track-tags flex-shrink-0">
                    @foreach (var tag in Action.Tags)
                    {
                        <span class="badge rounded-pill text-truncate" style="background-color: @tag.Color; font-size: 0.65rem; max-width: 100%;">@tag.Name</span>
                    }
                </div>
            }
        </div>

        @if (Balances.Count > 0)
        {
            <div class="d-flex flex-wrap gap-1 mb-2">
                @foreach (var bal in Balances)
                {
                    @if (bal.GoalValue.HasValue)
                    {
                        var remaining = bal.GoalValue.Value - bal.CurrentBalance;
                        <span class="badge bg-warning-subtle text-warning-emphasis rounded-pill"
                              title="@bal.Label — @L["Analytics_Goal"]">
                            <i class="bi bi-bullseye me-1"></i>@FormatNumeric(bal.CurrentBalance) / @FormatNumeric(bal.GoalValue.Value) @bal.Unit
                        </span>
                        <span class="badge @(remaining > 0 ? "bg-info" : "bg-success") rounded-pill"
                              title="@L["Analytics_Remaining"]">
                            <i class="bi bi-@(remaining > 0 ? "hourglass-split" : "check-circle") me-1"></i>@FormatNumeric(remaining) @bal.Unit
                        </span>
                    }
                    else
                    {
                        <span class="badge @(bal.CurrentBalance >= 0 ? "bg-success" : "bg-danger") rounded-pill"
                              title="@BuildBalanceTitle(bal)">
                            <i class="bi bi-wallet2 me-1"></i>@FormatBalance(bal.CurrentBalance) @bal.Unit
                        </span>
                    }
                }
            </div>
        }

        <div class="mt-auto pt-2">
            @if (Action.HasReceiptConfig)
            {
                <div class="d-flex gap-2 mb-2">
                    <button class="btn btn-outline-success btn-sm flex-fill"
                            @onclick="HandleTrack">
                        <i class="bi bi-bullseye me-1"></i>@L["Common_Track"]
                    </button>
                    <a href="/receipt-scan?actionId=@Action.Id"
                       class="btn btn-success btn-sm flex-fill">
                        <i class="bi bi-receipt me-1"></i>@L["Receipt_ScanNow"]
                    </a>
                </div>
            }
            else
            {
                <button class="btn btn-success btn-sm w-100 mb-2"
                        @onclick="HandleTrack">
                    <i class="bi bi-bullseye me-1"></i>@L["Common_Track"]
                </button>
            }
            <div class="d-flex justify-content-end gap-2">
                <a href="/tracked-actions/@Action.Id/edit"
                   class="btn btn-outline-secondary btn-sm py-0 px-2"
                   title="@L["TrackedActions_EditAction"]">
                    <i class="bi bi-pencil-square"></i>
                </a>
                <a href="/dashboard/action/@Action.Id/detail"
                   class="btn btn-outline-secondary btn-sm py-0 px-2"
                   title="@L["TrackedActions_Analytics"]">
                    <i class="bi bi-bar-chart-line me-1"></i><small>@L["Nav_Dashboard"]</small>
                </a>
                <a href="/entries/action/@Action.Id"
                   class="btn btn-outline-secondary btn-sm py-0 px-2"
                   title="@L["TrackedActions_ViewEntries"]">
                    <i class="bi bi-journal-text me-1"></i><small>@(EntryCountOverride ?? Action.EntryCount)</small>
                </a>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public TrackedActionResponse Action { get; set; } = default!;

    [Parameter]
    public bool Highlighted { get; set; }

    [Parameter]
    public List<BalanceSummary> Balances { get; set; } = [];

    [Parameter]
    public int? EntryCountOverride { get; set; }

    [Parameter]
    public EventCallback<TrackedActionResponse> OnTrack { get; set; }

    private async Task HandleTrack()
    {
        if (Action.FieldCount > 0)
        {
            var url = $"/tracked-actions/{Action.Id}/entries/new?returnUrl=%2F";
            NavigationManager.NavigateTo(url);
        }
        else
        {
            await OnTrack.InvokeAsync(Action);
        }
    }

    private static string FormatBalance(decimal value)
    {
        var prefix = value >= 0 ? "+" : "";
        return value == Math.Truncate(value)
            ? $"{prefix}{value:F0}"
            : $"{prefix}{value:F2}";
    }

    private static string FormatNumeric(decimal value)
    {
        return value == Math.Truncate(value)
            ? $"{value:F0}"
            : $"{value:F2}";
    }

    private string BuildBalanceTitle(BalanceSummary bal)
    {
        if (!bal.DiscountTotal.HasValue || bal.DiscountTotal.Value == 0)
            return bal.Label;

        var unit = string.IsNullOrEmpty(bal.Unit) ? "" : $" {bal.Unit}";
        return $"{bal.Label} ({L["Analytics_Discounts"]}: {FormatNumeric(bal.DiscountTotal.Value)}{unit})";
    }
}
