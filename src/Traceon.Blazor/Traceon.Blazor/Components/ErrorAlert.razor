@if (Errors.Count > 0)
{
    <div class="alert alert-danger @(_dismissible ? "alert-dismissible" : "") fade show" role="alert">
        <div class="d-flex align-items-start gap-2">
            <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
            <div class="flex-grow-1">
                @if (Errors.Count == 1)
                {
                    @Errors[0]
                }
                else
                {
                    <ul class="mb-0 ps-3">
                        @foreach (var error in Errors)
                        {
                            <li>@error</li>
                        }
                    </ul>
                }
            </div>
            @if (_dismissible)
            {
                <button type="button" class="btn-close flex-shrink-0" @onclick="Dismiss"></button>
            }
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<string> Errors { get; set; } = [];

    [Parameter]
    public EventCallback OnDismiss { get; set; }

    private bool _dismissible => OnDismiss.HasDelegate;

    private async Task Dismiss()
    {
        await OnDismiss.InvokeAsync();
    }
}
