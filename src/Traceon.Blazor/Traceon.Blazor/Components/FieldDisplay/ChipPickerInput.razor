@inject IStringLocalizer<SharedResource> L

@if (Groups is { Count: > 0 })
{
    @foreach (var group in Groups)
    {
        <div class="mb-1">
            @if (!string.IsNullOrEmpty(group.GroupName) && Groups.Count > 1)
            {
                <div class="text-muted small mb-1">@group.GroupName</div>
            }
            <div class="d-flex flex-wrap gap-1">
                @foreach (var option in group.Values)
                {
                    @RenderChip(option)
                }
            </div>
        </div>
    }
}
else
{
    <div class="d-flex flex-wrap gap-1">
        @foreach (var option in Options)
        {
            @RenderChip(option)
        }
    </div>
}

@code {
    [Parameter] public List<string> Options { get; set; } = [];
    [Parameter] public List<(string GroupName, string[] Values)>? Groups { get; set; }

    /// <summary>For single-select mode: bound value (null/empty = none selected).</summary>
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }

    /// <summary>For multi-select mode: bound set of selected values.</summary>
    [Parameter] public HashSet<string>? SelectedValues { get; set; }
    [Parameter] public EventCallback<HashSet<string>> SelectedValuesChanged { get; set; }

    [Parameter] public bool IsMulti { get; set; }
    [Parameter] public bool IsReadOnly { get; set; }

    private bool IsSelected(string option) => IsMulti
        ? SelectedValues?.Contains(option, StringComparer.OrdinalIgnoreCase) == true
        : string.Equals(Value, option, StringComparison.OrdinalIgnoreCase);

    private RenderFragment RenderChip(string option) => __builder =>
    {
        var selected = IsSelected(option);
        var classes = selected
            ? "btn btn-primary btn-sm"
            : "btn btn-outline-secondary btn-sm";
        <button type="button" class="@classes" disabled="@IsReadOnly"
                @onclick="() => OnClickAsync(option)">
            @option
        </button>
    };

    private async Task OnClickAsync(string option)
    {
        if (IsReadOnly) return;

        if (IsMulti)
        {
            var set = SelectedValues is null
                ? new HashSet<string>(StringComparer.OrdinalIgnoreCase)
                : new HashSet<string>(SelectedValues, StringComparer.OrdinalIgnoreCase);
            if (!set.Remove(option)) set.Add(option);
            await SelectedValuesChanged.InvokeAsync(set);
        }
        else
        {
            // Click on the same chip twice → deselect (toggle semantics).
            var newValue = string.Equals(Value, option, StringComparison.OrdinalIgnoreCase) ? null : option;
            await ValueChanged.InvokeAsync(newValue);
        }
    }
}
