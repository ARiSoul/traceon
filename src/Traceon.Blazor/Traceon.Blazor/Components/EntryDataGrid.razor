@* Reusable entry list with DataGrid, filtering by action, period, sorting, pagination, edit/delete *@
@inject IStringLocalizer<SharedResource> L
@using Blazored.LocalStorage
@inject ILocalStorageService LocalStorage

<div class="d-md-none mb-2">
    <button class="btn btn-outline-secondary btn-sm w-100" @onclick="() => _showFilters = !_showFilters">
        <i class="bi bi-funnel me-1"></i>
        @L["DataGrid_Filter"]
        <i class="bi bi-chevron-@(_showFilters ? "up" : "down") ms-1"></i>
    </button>
</div>

<div class="@(_showFilters ? "" : "d-none") d-md-block">
<div class="row g-2 mb-3">
    @if (!LockActionFilter)
    {
        <div class="col-12 col-md-3">
            <label class="form-label form-label-sm mb-1">
                <i class="bi bi-funnel me-1"></i>@L["EntryGrid_Action"]
            </label>
            <select class="form-select form-select-sm" value="@_selectedActionId" @onchange="OnActionFilterChanged">
                <option value="">@L["EntryGrid_AllActions"]</option>
                @foreach (var action in _availableActions)
                {
                    <option value="@action.Id">@action.Name</option>
                }
            </select>
        </div>
    }

    <div class="col-12 col-md-3">
        <label class="form-label form-label-sm mb-1">
            <i class="bi bi-calendar-range me-1"></i>@L["Dashboard_Period"]
        </label>
        <select class="form-select form-select-sm" value="@_periodMode" @onchange="OnPeriodModeChanged">
            <option value="all">@L["Common_AllTime"]</option>
            <option value="days">@L["Dashboard_LastNDays"]</option>
            <option value="months">@L["Dashboard_LastNMonths"]</option>
            <option value="years">@L["Dashboard_LastNYears"]</option>
            <option value="custom">@L["Dashboard_CustomRange"]</option>
        </select>
    </div>

    @if (_periodMode is "days" or "months" or "years")
    {
        <div class="col-6 col-md-2">
            <label class="form-label form-label-sm mb-1">
                @(_periodMode switch { "days" => L["Dashboard_Days"], "months" => L["Dashboard_Months"], _ => L["Dashboard_Years"] })
            </label>
            <input type="number"
                   class="form-control form-control-sm"
                   min="1"
                   value="@_periodValue"
                   @onchange="OnPeriodValueChanged" />
        </div>
        <div class="col-6 col-md-2">
            <label class="form-label form-label-sm mb-1">@L["Filter_DateField"]</label>
            <select class="form-select form-select-sm" value="@_dateField" @onchange="OnDateFieldChanged">
                <option value="OccurredAtUtc">@L["Filter_Occurred"]</option>
                <option value="CreatedAtUtc">@L["Common_Created"]</option>
            </select>
        </div>
    }
    else if (_periodMode == "custom")
    {
        <div class="col-6 col-md-2">
            <label class="form-label form-label-sm mb-1">@L["Dashboard_From"]</label>
            <input type="date"
                   class="form-control form-control-sm"
                   value="@_customFrom?.ToString("yyyy-MM-dd")"
                   @onchange="OnCustomFromChanged" />
        </div>
        <div class="col-6 col-md-2">
            <label class="form-label form-label-sm mb-1">@L["Dashboard_To"]</label>
            <input type="date"
                   class="form-control form-control-sm"
                   value="@_customTo?.ToString("yyyy-MM-dd")"
                   @onchange="OnCustomToChanged" />
        </div>
        <div class="col-12 col-md-2">
            <label class="form-label form-label-sm mb-1">@L["Filter_DateField"]</label>
            <select class="form-select form-select-sm" value="@_dateField" @onchange="OnDateFieldChanged">
                <option value="OccurredAtUtc">@L["Filter_Occurred"]</option>
                <option value="CreatedAtUtc">@L["Common_Created"]</option>
            </select>
        </div>
    }
</div>

@if (_activeFields.Count > 0)
{
    <div class="row g-2 mb-3">
        <div class="col-12">
            <small class="text-muted fw-semibold">
                <i class="bi bi-sliders me-1"></i>@L["EntryGrid_FieldFilters"]
            </small>
        </div>
        @foreach (var field in _activeFields.OrderBy(f => f.Order))
        {
            var fieldId = field.Id;
            <div class="col-6 col-md-2">
                <label class="form-label form-label-sm mb-1">@field.Name</label>
                @if (field.FieldType == FieldType.Dropdown && field.DropdownValues is not null)
                {
                    <select class="form-select form-select-sm"
                            value="@GetFieldFilter(fieldId)"
                            @onchange="e => OnFieldFilterChangedAsync(fieldId, e)">
                        <option value="">@L["EntryGrid_AllValues"]</option>
                        @foreach (var opt in field.DropdownValues.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                        {
                            <option value="@opt">@opt</option>
                        }
                    </select>
                }
                else if (field.FieldType == FieldType.Boolean)
                {
                    <select class="form-select form-select-sm"
                            value="@GetFieldFilter(fieldId)"
                            @onchange="e => OnFieldFilterChangedAsync(fieldId, e)">
                        <option value="">@L["EntryGrid_AllValues"]</option>
                        <option value="true">@L["Common_Yes"]</option>
                        <option value="false">@L["Common_No"]</option>
                    </select>
                }
                else
                {
                    <div class="input-group input-group-sm">
                        <input type="text" class="form-control form-control-sm"
                               placeholder="@field.Name..."
                               value="@GetFieldFilter(fieldId)"
                               @onchange="e => OnFieldFilterChangedAsync(fieldId, e)"
                               @onkeydown="OnFieldFilterKeyDownAsync" />
                        @if (!string.IsNullOrEmpty(GetFieldFilter(fieldId)))
                        {
                            <button class="btn btn-outline-secondary" @onclick="() => ClearFieldFilterAsync(fieldId)">
                                <i class="bi bi-x"></i>
                            </button>
                        }
                    </div>
                }
            </div>
        }
    </div>
}
</div>

@if (_ready)
{
    <DataGrid @ref="_grid"
              TItem="ActionEntryResponse"
              LoadData="LoadDataAsync"
              Columns="_columns"
              FilterPlaceholder="@L["Filter_ByNotes"]"
              EmptyText="@L["EntryGrid_Empty"]"
              StorageKey="@StorageKey"
              HasExternalFilters="_hasExternalFilters"
              OnReset="OnGridResetAsync">
        <Toolbar>
              @if (_createActionId != Guid.Empty)
              {
                  <a href="/tracked-actions/@_createActionId/entries/new?returnUrl=@_encodedReturnUrl"
                     class="btn btn-primary">
                      <i class="bi bi-plus-circle me-1"></i>@L["Entries_NewEntry"]
                  </a>
              }
    </Toolbar>
    <RowActions>
        <ListActionsDropdown PrimaryText="@L["Common_Edit"]"
                             PrimaryIcon="pencil-square"
                             PrimaryButtonStyle="primary"
                             PrimaryAction="() => EditEntry(context)"
                             Actions="GetActions(context)"
                             OnAfterAction="StateHasChanged" />
    </RowActions>
</DataGrid>
}
else
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">@L["Common_Loading"]</span>
        </div>
    </div>
}

@code {
    /// <summary>
    /// Pre-selects this action in the filter. If <see cref="LockActionFilter"/> is false the user can change it.
    /// </summary>
    [Parameter]
    public Guid? TrackedActionId { get; set; }

    /// <summary>
    /// When true the action filter is hidden and locked to <see cref="TrackedActionId"/>.
    /// Use this when embedding inside a tracked action edit page.
    /// </summary>
    [Parameter]
    public bool LockActionFilter { get; set; }

    /// <summary>
    /// When provided, dynamic columns and field-value filters are generated for each action field.
    /// Use this when embedding inside a tracked action where the fields are known.
    /// </summary>
    [Parameter]
    public List<ActionFieldResponse>? ActionFields { get; set; }

    /// <summary>
    /// LocalStorage key for persisting grid and filter state.
    /// </summary>
    [Parameter]
    public string? StorageKey { get; set; }

    [Inject] private ActionEntryService EntryService { get; set; } = default!;
    [Inject] private TrackedActionService ActionService { get; set; } = default!;
    [Inject] private ActionFieldService ActionFieldService { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private DataGrid<ActionEntryResponse> _grid = default!;
    private List<TrackedActionResponse> _availableActions = [];
    private string _selectedActionId = "";
    private string _encodedReturnUrl = "";
    private bool _showFilters;
    private bool _loadingFields;
    private bool _ready;

    // Period filter state
    private string _periodMode = "years";
    private int _periodValue = 1;
    private string _dateField = "OccurredAtUtc";
    private DateTime? _customFrom;
    private DateTime? _customTo;

    private Guid _createActionId => TrackedActionId.HasValue && LockActionFilter
        ? TrackedActionId.Value
        : (Guid.TryParse(_selectedActionId, out var id) ? id : Guid.Empty);

    private List<DataGridColumn<ActionEntryResponse>> _columns = [];

    // Effective field list: either externally provided or dynamically loaded
    private List<ActionFieldResponse> _activeFields = [];

    // Field value filters: fieldId -> filter value
    private Dictionary<Guid, string> _fieldFilters = [];

    private string? EntryStorageKey => StorageKey is not null ? $"traceon_entry_{StorageKey}" : null;

    protected override async Task OnInitializedAsync()
    {
        _encodedReturnUrl = Uri.EscapeDataString(Nav.ToBaseRelativePath(Nav.Uri) is { Length: > 0 } rel ? $"/{rel}" : "/");

        if (TrackedActionId.HasValue)
        {
            _selectedActionId = TrackedActionId.Value.ToString();
        }

        await RestoreEntryFiltersAsync();

        // Use externally-provided fields, or load them for the pre-selected action
        if (ActionFields is { Count: > 0 })
        {
            _activeFields = ActionFields;
        }
        else if (Guid.TryParse(_selectedActionId, out var preselectedId) && preselectedId != Guid.Empty)
        {
            _activeFields = await ActionFieldService.GetByTrackedActionAsync(preselectedId);
        }

        RebuildColumns();

        if (!LockActionFilter)
        {
            _availableActions = await ActionService.GetAllAsync();
        }

        _ready = true;
    }

    private bool _hasExternalFilters =>
        _periodMode != "years"
        || _periodValue != 1
        || _dateField != "OccurredAtUtc"
        || _customFrom.HasValue
        || _customTo.HasValue
        || _fieldFilters.Count > 0
        || (!LockActionFilter && !string.IsNullOrEmpty(_selectedActionId) && _selectedActionId != (TrackedActionId?.ToString() ?? ""));

    // ── Filter persistence ──

    private async Task RestoreEntryFiltersAsync()
    {
        if (EntryStorageKey is null) return;

        try
        {
            var state = await LocalStorage.GetItemAsync<EntryFilterState>(EntryStorageKey);
            if (state is null) return;

            if (!LockActionFilter && !string.IsNullOrEmpty(state.SelectedActionId))
                _selectedActionId = state.SelectedActionId;
            if (state.PeriodMode is not null) _periodMode = state.PeriodMode;
            if (state.PeriodValue.HasValue) _periodValue = state.PeriodValue.Value;
            if (state.DateField is not null) _dateField = state.DateField;
            _customFrom = state.CustomFrom;
            _customTo = state.CustomTo;
            if (state.FieldFilters is not null)
                _fieldFilters = state.FieldFilters
                    .Where(kv => Guid.TryParse(kv.Key, out _))
                    .ToDictionary(kv => Guid.Parse(kv.Key), kv => kv.Value);
        }
        catch { /* best effort */ }
    }

    private async Task SaveEntryFiltersAsync()
    {
        if (EntryStorageKey is null) return;

        try
        {
            var state = new EntryFilterState
            {
                SelectedActionId = LockActionFilter ? null : _selectedActionId,
                PeriodMode = _periodMode,
                PeriodValue = _periodValue,
                DateField = _dateField,
                CustomFrom = _customFrom,
                CustomTo = _customTo,
                FieldFilters = _fieldFilters.Count > 0
                    ? _fieldFilters.ToDictionary(kv => kv.Key.ToString(), kv => kv.Value)
                    : null
            };

            await LocalStorage.SetItemAsync(EntryStorageKey, state);
        }
        catch { /* best effort */ }
    }

    private async Task OnGridResetAsync()
    {
        _selectedActionId = TrackedActionId?.ToString() ?? "";
        _periodMode = "years";
        _periodValue = 1;
        _dateField = "OccurredAtUtc";
        _customFrom = null;
        _customTo = null;
        _fieldFilters.Clear();

        if (ActionFields is { Count: > 0 })
            _activeFields = ActionFields;
        else if (Guid.TryParse(_selectedActionId, out var id) && id != Guid.Empty)
            _activeFields = await ActionFieldService.GetByTrackedActionAsync(id);
        else
            _activeFields = [];

        RebuildColumns();

        if (EntryStorageKey is not null)
        {
            try { await LocalStorage.RemoveItemAsync(EntryStorageKey); } catch { }
        }
    }

    private sealed class EntryFilterState
    {
        public string? SelectedActionId { get; set; }
        public string? PeriodMode { get; set; }
        public int? PeriodValue { get; set; }
        public string? DateField { get; set; }
        public DateTime? CustomFrom { get; set; }
        public DateTime? CustomTo { get; set; }
        public Dictionary<string, string>? FieldFilters { get; set; }
    }

    private bool HasActionFilter =>
        Guid.TryParse(_selectedActionId, out var id) && id != Guid.Empty;

    private void RebuildColumns()
    {
        _columns = [];

        if (!HasActionFilter)
        {
            _columns.Add(new()
            {
                Title = L["EntryGrid_Action"],
                Selector = x => x.ActionName,
                SortField = "ActionName",
                IsMobileTitle = true
            });
        }

        _columns.Add(new()
        {
            Title = L["EntryGrid_Date"],
            Selector = x => x.OccurredAtUtc.ToLocalTime(),
            SortField = "OccurredAtUtc",
            Format = "g",
            IsMobileTitle = HasActionFilter
        });

        _columns.Add(new()
        {
            Title = L["EntryGrid_Notes"],
            Selector = x => x.Notes ?? "",
            Template = item => builder =>
            {
                if (!string.IsNullOrEmpty(item.Notes))
                {
                    builder.OpenElement(0, "span");
                    builder.AddAttribute(1, "class", "text-truncate d-inline-block");
                    builder.AddAttribute(2, "style", "max-width: 200px;");
                    builder.AddAttribute(3, "title", item.Notes);
                    builder.AddContent(4, item.Notes);
                    builder.CloseElement();
                }
                else
                {
                    builder.OpenElement(0, "span");
                    builder.AddAttribute(1, "class", "text-muted");
                    builder.AddContent(2, "\u2014");
                    builder.CloseElement();
                }
            }
        });

        // Add dynamic columns for each action field
        foreach (var field in _activeFields.OrderBy(f => f.Order))
        {
            var fieldId = field.Id;
            var fieldUnit = field.Unit;
            var fieldType = field.FieldType;

            _columns.Add(new()
            {
                Title = field.Name,
                Selector = x => x.FieldValues.FirstOrDefault(fv => fv.ActionFieldId == fieldId)?.Value ?? "",
                Template = item => builder =>
                {
                    var value = item.FieldValues.FirstOrDefault(fv => fv.ActionFieldId == fieldId)?.Value;
                    if (!string.IsNullOrEmpty(value))
                    {
                        if (fieldType == FieldType.Boolean)
                        {
                            var icon = value.Equals("true", StringComparison.OrdinalIgnoreCase)
                                ? "check-circle-fill text-success" : "x-circle-fill text-danger";
                            builder.OpenElement(0, "i");
                            builder.AddAttribute(1, "class", $"bi bi-{icon}");
                            builder.CloseElement();
                        }
                        else
                        {
                            var showUnit = fieldType is FieldType.Integer or FieldType.Decimal
                                           && !string.IsNullOrWhiteSpace(fieldUnit);
                            builder.OpenElement(0, "span");
                            builder.AddContent(1, showUnit ? $"{value} {fieldUnit}" : value);
                            builder.CloseElement();
                        }
                    }
                    else
                    {
                        builder.OpenElement(0, "span");
                        builder.AddAttribute(1, "class", "text-muted");
                        builder.AddContent(2, "\u2014");
                        builder.CloseElement();
                    }
                },
                HideOnMobile = true
            });
        }

        _columns.Add(new()
        {
            Title = L["Common_Created"],
            Selector = x => x.CreatedAtUtc.ToLocalTime(),
            SortField = "CreatedAtUtc",
            Format = "g",
            HideOnMobile = true
        });
    }

    private string? BuildFilterString()
    {
        var clauses = new List<string>();

        // Action filter
        if (Guid.TryParse(_selectedActionId, out var actionId) && actionId != Guid.Empty)
        {
            clauses.Add($"TrackedActionId eq {actionId}");
        }

        // Period filter
        var dateFilter = BuildDateFilter();
        if (dateFilter is not null)
        {
            clauses.Add(dateFilter);
        }

        // Field value filters
        if (_activeFields.Count > 0)
        {
            foreach (var (fieldId, value) in _fieldFilters)
            {
                if (string.IsNullOrWhiteSpace(value)) continue;

                var field = _activeFields.FirstOrDefault(f => f.Id == fieldId);
                if (field is null) continue;

                var escaped = value.Replace("'", "''");

                if (field.FieldType is FieldType.Dropdown or FieldType.Boolean)
                {
                    clauses.Add($"FieldValues/any(fv: fv/ActionFieldId eq {fieldId} and fv/Value eq '{escaped}')");
                }
                else
                {
                    var lower = escaped.ToLowerInvariant();
                    clauses.Add($"FieldValues/any(fv: fv/ActionFieldId eq {fieldId} and contains(tolower(fv/Value),'{lower}'))");
                }
            }
        }

        return clauses.Count > 0 ? string.Join(" and ", clauses) : null;
    }

    private string? BuildDateFilter()
    {
        DateTime? from = null;
        DateTime? to = null;

        switch (_periodMode)
        {
            case "days":
                from = DateTime.UtcNow.AddDays(-_periodValue);
                break;
            case "months":
                from = DateTime.UtcNow.AddMonths(-_periodValue);
                break;
            case "years":
                from = DateTime.UtcNow.AddYears(-_periodValue);
                break;
            case "custom":
                from = _customFrom;
                to = _customTo?.AddDays(1); // inclusive end
                break;
            default:
                return null;
        }

        var parts = new List<string>();

        if (from.HasValue)
            parts.Add($"{_dateField} ge {from.Value:yyyy-MM-ddTHH:mm:ssZ}");
        if (to.HasValue)
            parts.Add($"{_dateField} le {to.Value:yyyy-MM-ddTHH:mm:ssZ}");

        return parts.Count > 0 ? string.Join(" and ", parts) : null;
    }

    private async Task<DataGridResult<ActionEntryResponse>> LoadDataAsync(DataGridRequest request)
    {
        return await EntryService.QueryAsync(request, ["Notes", "ActionName"], BuildFilterString());
    }

    private void EditEntry(ActionEntryResponse entry)
    {
        Nav.NavigateTo($"/tracked-actions/{entry.TrackedActionId}/entries/{entry.Id}/edit?returnUrl={_encodedReturnUrl}");
    }

    private List<ListAction> GetActions(ActionEntryResponse entry)
    {
        return
        [
            ListAction.Button(L["Common_Delete"], () => DeleteAsync(entry), "trash", ListActionStyle.Danger),
        ];
    }

    private async Task DeleteAsync(ActionEntryResponse entry)
    {
        var (success, _) = await EntryService.DeleteAsync(entry.TrackedActionId, entry.Id);
        if (success)
            await _grid.RefreshAsync();
    }

    private async Task OnActionFilterChanged(ChangeEventArgs e)
    {
        _selectedActionId = e.Value?.ToString() ?? "";
        _fieldFilters.Clear();

        if (Guid.TryParse(_selectedActionId, out var actionId) && actionId != Guid.Empty)
        {
            _loadingFields = true;
            StateHasChanged();

            _activeFields = await ActionFieldService.GetByTrackedActionAsync(actionId);
            _loadingFields = false;
        }
        else
        {
            _activeFields = [];
        }

        RebuildColumns();
        await _grid.RefreshAsync();
        await SaveEntryFiltersAsync();
    }

    private async Task OnPeriodModeChanged(ChangeEventArgs e)
    {
        _periodMode = e.Value?.ToString() ?? "all";

        // Set sensible defaults
        _periodValue = _periodMode switch
        {
            "days" => 30,
            "months" => 1,
            "years" => 1,
            _ => _periodValue
        };

        if (_periodMode == "custom")
        {
            _customFrom = DateTime.Today.AddMonths(-1);
            _customTo = DateTime.Today;
        }

        await _grid.RefreshAsync();
        await SaveEntryFiltersAsync();
    }

    private async Task OnPeriodValueChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var val) && val > 0)
            _periodValue = val;

        await _grid.RefreshAsync();
        await SaveEntryFiltersAsync();
    }

    private async Task OnDateFieldChanged(ChangeEventArgs e)
    {
        _dateField = e.Value?.ToString() ?? "OccurredAtUtc";
        await _grid.RefreshAsync();
        await SaveEntryFiltersAsync();
    }

    private async Task OnCustomFromChanged(ChangeEventArgs e)
    {
        _customFrom = DateTime.TryParse(e.Value?.ToString(), out var d) ? d : null;
        await _grid.RefreshAsync();
        await SaveEntryFiltersAsync();
    }

    private async Task OnCustomToChanged(ChangeEventArgs e)
    {
        _customTo = DateTime.TryParse(e.Value?.ToString(), out var d) ? d : null;
        await _grid.RefreshAsync();
        await SaveEntryFiltersAsync();
    }

    // Field filter helpers
    private string GetFieldFilter(Guid fieldId)
        => _fieldFilters.TryGetValue(fieldId, out var val) ? val : "";

    private async Task OnFieldFilterChangedAsync(Guid fieldId, ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? "";
        if (string.IsNullOrWhiteSpace(value))
            _fieldFilters.Remove(fieldId);
        else
            _fieldFilters[fieldId] = value;

        await _grid.RefreshAsync();
        await SaveEntryFiltersAsync();
    }

    private async Task OnFieldFilterKeyDownAsync(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await _grid.RefreshAsync();
    }

    private async Task ClearFieldFilterAsync(Guid fieldId)
    {
        _fieldFilters.Remove(fieldId);
        await _grid.RefreshAsync();
        await SaveEntryFiltersAsync();
    }
}
