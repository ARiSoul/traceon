@typeparam TItem
@inject IStringLocalizer<SharedResource> L
@using Blazored.LocalStorage
@inject ILocalStorageService LocalStorage

<div class="data-grid" @onclick="CloseSummaryDropdown">
    @if (FilterPlaceholder is not null || Toolbar is not null || _hasActiveState)
    {
        <div class="data-grid-toolbar">
            @if (FilterPlaceholder is not null)
            {
                <div class="data-grid-filter">
                    <input type="text"
                           class="form-control"
                           placeholder="@FilterPlaceholder"
                           @bind="_filterInput"
                           @bind:event="oninput"
                           @onkeydown="OnFilterKeyDownAsync" />
                    <button class="btn btn-outline-primary" @onclick="ApplyFilterAsync" disabled="@_loading">
                        <i class="bi bi-funnel me-1"></i>@L["DataGrid_Filter"]
                    </button>
                    @if (!string.IsNullOrWhiteSpace(_appliedFilter))
                    {
                        <button class="btn btn-outline-secondary" @onclick="ClearFilterAsync" disabled="@_loading">
                             <i class="bi bi-x-circle me-1"></i>@L["DataGrid_Clear"]
                        </button>
                    }
                </div>
            }
            @if (_hasActiveState && StorageKey is not null)
            {
                <button class="btn btn-outline-warning" @onclick="ResetAllAsync" disabled="@_loading"
                        title="@L["DataGrid_ResetAll"]">
                    <i class="bi bi-arrow-counterclockwise me-1"></i>@L["DataGrid_ResetAll"]
                </button>
            }
            @if (Toolbar is not null)
            {
                <div class="data-grid-toolbar-actions">
                    @Toolbar
                </div>
            }
        </div>
    }

    @if (_loading)
    {
        <div class="data-grid-loading">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">@L["Common_Loading"]</span>
            </div>
        </div>
    }
    else if (_items.Count == 0)
    {
        <div class="data-grid-empty">
            <p class="text-muted mb-0">@(EmptyText ?? L["Common_NoItemsFound"])</p>
        </div>
    }
    else
    {
        @if (SelectionEnabled && _selectedIds.Count > 0)
        {
            <div class="d-flex align-items-center gap-2 mb-2 flex-wrap">
                <span class="badge bg-primary py-1 px-2">
                    <i class="bi bi-check2-square me-1"></i>@_selectedIds.Count @L["DataGrid_Selected"]
                </span>
                @if (BulkActions is not null)
                {
                    @BulkActions
                }
                <button class="btn btn-outline-secondary btn-sm py-0" @onclick="ClearSelection">
                    <i class="bi bi-x-lg me-1"></i>@L["DataGrid_ClearSelection"]
                </button>
            </div>
        }

        @* ── Desktop table ── *@
        <div class="data-grid-table d-none d-md-block">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            @if (SelectionEnabled)
                            {
                                <th style="width: 40px;">
                                    <input type="checkbox" class="form-check-input"
                                           checked="@_allPageSelected"
                                           @onchange="ToggleAllPageSelection" />
                                </th>
                            }
                            @for (var i = 0; i < Columns.Count; i++)
                            {
                                var colIndex = i;
                                var col = Columns[i];
                                <th @onclick="() => SortByAsync(col)"
                                    class="@(col.SortField is not null ? "sortable" : "")">
                                    <div class="column-header">
                                        <span class="column-title"
                                              role="@(col.SortField is not null ? "button" : null)">
                                            @col.Title
                                            @if (col.SortField is not null && _sortField == col.SortField)
                                            {
                                                <i class="bi bi-@(_sortDescending ? "sort-down" : "sort-up") sort-indicator"></i>
                                            }
                                        </span>
                                        @{
                                            var summaryOpts = GetAvailableSummaries(colIndex);
                                        }
                                        @if (summaryOpts.Count > 0)
                                        {
                                            <div class="summary-toggle-wrapper" @onclick:stopPropagation>
                                                <button class="btn-summary-toggle @(HasActiveSummaries(colIndex) ? "active" : "")"
                                                        @onclick="() => ToggleSummaryDropdown(colIndex)"
                                                        title="@L["DataGrid_Summaries"]">
                                                    <i class="bi bi-calculator"></i>
                                                </button>
                                                @if (_summaryDropdownIndex == colIndex)
                                                {
                                                    <div class="summary-dropdown-menu">
                                                        @foreach (var opt in summaryOpts)
                                                        {
                                                            var capturedOpt = opt;
                                                            var isChecked = IsSummaryActive(colIndex, capturedOpt);
                                                            <label class="summary-option">
                                                                <input type="checkbox" checked="@isChecked"
                                                                       @onchange="() => ToggleSummaryAsync(colIndex, capturedOpt)" />
                                                                <span>@GetSummaryLabel(capturedOpt)</span>
                                                            </label>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                </th>
                            }
                            @if (RowActions is not null)
                            {
                                <th class="text-end"></th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in _items)
                        {
                            var itemId = ItemKey?.Invoke(item);
                            var isSelected = itemId is not null && _selectedIds.Contains(itemId.Value);
                            <tr class="@(isSelected ? "table-primary" : "")">
                                @if (SelectionEnabled)
                                {
                                    <td @onclick:stopPropagation="true">
                                        <input type="checkbox" class="form-check-input"
                                               checked="@isSelected"
                                               @onchange="() => ToggleItemSelection(itemId)" />
                                    </td>
                                }
                                @for (var i = 0; i < Columns.Count; i++)
                                {
                                    var col = Columns[i];
                                    <td>
                                        @if (col.Template is not null)
                                        {
                                            @col.Template(item)
                                        }
                                        else
                                        {
                                            @FormatValue(col, item)
                                        }
                                    </td>
                                }
                                @if (RowActions is not null)
                                {
                                    <td class="text-end text-nowrap">@RowActions(item)</td>
                                }
                            </tr>
                        }
                    </tbody>
                    @if (_hasSummaryResults)
                    {
                        <tfoot>
                            <tr class="summary-row">
                                @if (SelectionEnabled)
                                {
                                    <td></td>
                                }
                                @for (var i = 0; i < Columns.Count; i++)
                                {
                                    var col = Columns[i];
                                    <td>
                                        @if (_computedSummaries.TryGetValue(i, out var results))
                                        {
                                            <div class="d-flex flex-wrap gap-1">
                                                @foreach (var r in results)
                                                {
                                                    <span class="badge bg-body-secondary text-body border">
                                                        <small class="text-muted me-1">@GetSummaryLabel(r.Type):</small>@FormatSummaryValue(r.Value, col)
                                                    </span>
                                                }
                                            </div>
                                        }
                                    </td>
                                }
                                @if (RowActions is not null)
                                {
                                    <td></td>
                                }
                            </tr>
                        </tfoot>
                    }
                </table>
            </div>
        </div>

        @* ── Mobile cards ── *@
        <div class="data-grid-cards d-md-none">
            @{
                var sortableColumns = Columns.Where(c => c.SortField is not null).ToList();
            }
            @if (sortableColumns.Count > 0)
            {
                <div class="d-flex gap-2 mb-2 align-items-center">
                    <select class="form-select form-select-sm flex-grow-1"
                            value="@(_sortField ?? "")"
                            @onchange="OnMobileSortFieldChangedAsync">
                        <option value="">@L["DataGrid_SortBy"]…</option>
                        @foreach (var col in sortableColumns)
                        {
                            <option value="@col.SortField">@col.Title</option>
                        }
                    </select>
                    @if (_sortField is not null)
                    {
                        <button class="btn btn-outline-secondary btn-sm flex-shrink-0"
                                @onclick="ToggleMobileSortDirectionAsync"
                                title="@(_sortDescending ? L["DataGrid_SortAsc"] : L["DataGrid_SortDesc"])">
                            <i class="bi bi-@(_sortDescending ? "sort-down" : "sort-up")"></i>
                        </button>
                    }
                    <button class="btn btn-outline-secondary btn-sm flex-shrink-0 @(_summarySelections.Count > 0 ? "active" : "")"
                            @onclick="() => _showMobileSummaries = !_showMobileSummaries"
                            title="@L["DataGrid_Summaries"]">
                        <i class="bi bi-calculator"></i>
                    </button>
                </div>
            }
            else
            {
                <div class="d-flex justify-content-end mb-2">
                    <button class="btn btn-outline-secondary btn-sm @(_summarySelections.Count > 0 ? "active" : "")"
                            @onclick="() => _showMobileSummaries = !_showMobileSummaries"
                            title="@L["DataGrid_Summaries"]">
                        <i class="bi bi-calculator me-1"></i>@L["DataGrid_Summaries"]
                    </button>
                </div>
            }

            @if (_showMobileSummaries)
            {
                <div class="card mb-2 border-secondary">
                    <div class="card-body py-2 px-3">
                        <div class="fw-semibold mb-2 text-muted small">
                            <i class="bi bi-calculator me-1"></i>@L["DataGrid_Summaries"]
                        </div>
                        @for (var i = 0; i < Columns.Count; i++)
                        {
                            var colIndex = i;
                            var col = Columns[i];
                            var opts = GetAvailableSummaries(colIndex);
                            @if (opts.Count > 0)
                            {
                                <div class="mb-2">
                                    <small class="fw-semibold">@col.Title</small>
                                    <div class="d-flex flex-wrap gap-1 mt-1">
                                        @foreach (var opt in opts)
                                        {
                                            var capturedOpt = opt;
                                            var active = IsSummaryActive(colIndex, capturedOpt);
                                            <button class="btn btn-sm @(active ? "btn-primary" : "btn-outline-secondary") py-0 px-2"
                                                    style="font-size: 0.75rem;"
                                                    @onclick="() => ToggleSummaryAsync(colIndex, capturedOpt)">
                                                @GetSummaryLabel(capturedOpt)
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            }

            @if (SelectionEnabled)
            {
                <div class="d-flex align-items-center gap-2 mb-2">
                    <input type="checkbox" class="form-check-input"
                           checked="@_allPageSelected"
                           @onchange="ToggleAllPageSelection" />
                    <small class="text-muted">@L["DataGrid_SelectAll"]</small>
                </div>
            }

            @foreach (var item in _items)
            {
                var mobileItemId = ItemKey?.Invoke(item);
                var mobileIsSelected = mobileItemId is not null && _selectedIds.Contains(mobileItemId.Value);
                <div class="card mb-2 @(mobileIsSelected ? "border-primary" : "")">
                    <div class="card-body py-2 px-3">
                        @{ var titleCol = Columns.FirstOrDefault(c => c.IsMobileTitle); }
                        <div class="d-flex align-items-start gap-2">
                            @if (SelectionEnabled)
                            {
                                <input type="checkbox" class="form-check-input mt-1"
                                       checked="@mobileIsSelected"
                                       @onchange="() => ToggleItemSelection(mobileItemId)" />
                            }
                            <div class="flex-grow-1 min-w-0">
                        @if (titleCol is not null)
                        {
                            <div class="fw-semibold mb-1">
                                @if (titleCol.Template is not null)
                                {
                                    @titleCol.Template(item)
                                }
                                else
                                {
                                    @FormatValue(titleCol, item)
                                }
                            </div>
                        }
                        @foreach (var col in Columns.Where(c => !c.HideOnMobile && !c.IsMobileTitle))
                        {
                            <div class="d-flex justify-content-between align-items-start py-1 mobile-field">
                                <span class="text-muted small me-2">@col.Title</span>
                                <span class="text-end">
                                    @if (col.Template is not null)
                                    {
                                        @col.Template(item)
                                    }
                                    else
                                    {
                                        @FormatValue(col, item)
                                    }
                                </span>
                            </div>
                        }
                        @if (RowActions is not null)
                        {
                            <div class="d-flex justify-content-end pt-1 mt-1 border-top">
                                @RowActions(item)
                            </div>
                        }
                            </div>
                        </div>
                    </div>
                </div>
            }

            @* ── Mobile summaries ── *@
            @if (_hasSummaryResults)
            {
                <div class="card mb-2 border-secondary">
                    <div class="card-body py-2 px-3">
                        <div class="fw-semibold mb-1 text-muted small">
                            <i class="bi bi-calculator me-1"></i>@L["DataGrid_Summaries"]
                        </div>
                        @for (var i = 0; i < Columns.Count; i++)
                        {
                            if (!_computedSummaries.TryGetValue(i, out var results)) continue;
                            var col = Columns[i];
                            <div class="d-flex justify-content-between align-items-start py-1 mobile-field">
                                <span class="text-muted small me-2">@col.Title</span>
                                <span class="text-end">
                                    @foreach (var r in results)
                                    {
                                        <span class="badge bg-body-secondary text-body border me-1">
                                            <small class="text-muted me-1">@GetSummaryLabel(r.Type):</small>@FormatSummaryValue(r.Value, col)
                                        </span>
                                    }
                                </span>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        @if (_totalCount > 0)
        {
            <div class="data-grid-footer">
                <div class="data-grid-info">
                    <span class="text-muted small">
                        @L["DataGrid_Showing"] <strong>@(_firstRecord)–@(_lastRecord)</strong> @L["DataGrid_Of"] <strong>@_totalCount</strong>
                    </span>
                </div>

                <nav class="data-grid-pagination">
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(_page <= 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="GoToFirstPageAsync" disabled="@(_page <= 1)" title="@L["DataGrid_FirstPage"]">
                                <i class="bi bi-chevron-double-left"></i>
                            </button>
                        </li>
                        <li class="page-item @(_page <= 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="PreviousPageAsync" disabled="@(_page <= 1)">
                                <i class="bi bi-chevron-left"></i>
                            </button>
                        </li>

                        @foreach (var p in GetPageNumbers())
                        {
                            <li class="page-item @(p == _page ? "active" : "")">
                                <button class="page-link" @onclick="() => GoToPageAsync(p)">@p</button>
                            </li>
                        }

                        <li class="page-item @(_page >= _totalPages ? "disabled" : "")">
                            <button class="page-link" @onclick="NextPageAsync" disabled="@(_page >= _totalPages)">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </li>
                        <li class="page-item @(_page >= _totalPages ? "disabled" : "")">
                            <button class="page-link" @onclick="GoToLastPageAsync" disabled="@(_page >= _totalPages)" title="@L["DataGrid_LastPage"]">
                                <i class="bi bi-chevron-double-right"></i>
                            </button>
                        </li>
                    </ul>
                </nav>

                <div class="data-grid-page-size">
                    <select class="form-select form-select-sm" value="@_pageSize" @onchange="OnPageSizeChangedAsync">
                        @foreach (var size in PageSizeOptions)
                        {
                            <option value="@size">@size @L["DataGrid_PerPage"]</option>
                        }
                    </select>
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter, EditorRequired]
    public required Func<DataGridRequest, Task<DataGridResult<TItem>>> LoadData { get; set; }

    [Parameter, EditorRequired]
    public required List<DataGridColumn<TItem>> Columns { get; set; }

    [Parameter] public RenderFragment? Toolbar { get; set; }
    [Parameter] public RenderFragment<TItem>? RowActions { get; set; }
    [Parameter] public RenderFragment? BulkActions { get; set; }
    [Parameter] public string? FilterPlaceholder { get; set; }
    [Parameter] public string? EmptyText { get; set; }
    [Parameter] public int PageSize { get; set; } = 10;
    [Parameter] public int[] PageSizeOptions { get; set; } = [10, 25, 50, 100];
    [Parameter] public string? DefaultSortField { get; set; }
    [Parameter] public bool DefaultSortDescending { get; set; }

    /// <summary>When true, rows can be selected via checkboxes. Requires <see cref="ItemKey"/> to be set.</summary>
    [Parameter] public bool SelectionEnabled { get; set; }

    /// <summary>Function that returns a unique <see cref="Guid"/> key for each item. Required when <see cref="SelectionEnabled"/> is true.</summary>
    [Parameter] public Func<TItem, Guid>? ItemKey { get; set; }

    /// <summary>
    /// When set, grid state (sort, filter, page size, summaries) is persisted
    /// to localStorage under this key. Also enables the "Reset All" button.
    /// </summary>
    [Parameter] public string? StorageKey { get; set; }

    /// <summary>Invoked when the user clicks "Reset All" so parent components can clear their own filters.</summary>
    [Parameter] public EventCallback OnReset { get; set; }

    /// <summary>When true, the Reset All button is shown even if the DataGrid's own state is at defaults.
    /// Use this when a parent component has its own persisted filters.</summary>
    [Parameter] public bool HasExternalFilters { get; set; }

    private IReadOnlyList<TItem> _items = [];
    private bool _loading = true;
    private int _totalCount;
    private int _totalPages;
    private int _page = 1;
    private int _pageSize;
    private string? _sortField;
    private bool _sortDescending;
    private string? _filterInput;
    private string? _appliedFilter;

    // Selection state
    private HashSet<Guid> _selectedIds = [];
    private bool _allPageSelected => SelectionEnabled && _items.Count > 0 && ItemKey is not null
        && _items.All(i => _selectedIds.Contains(ItemKey(i)));

    // Summary state
    private int _summaryDropdownIndex = -1;
    private bool _showMobileSummaries;
    private Dictionary<int, List<ColumnSummaryType>> _summarySelections = [];
    private Dictionary<int, List<SummaryResult>> _computedSummaries = [];
    private bool _hasSummaryResults => _computedSummaries.Count > 0;

    private bool _hasActiveState =>
        HasExternalFilters
        || _appliedFilter is not null
        || (_sortField is not null && _sortField != DefaultSortField)
        || _sortDescending != DefaultSortDescending
        || _pageSize != PageSize
        || _summarySelections.Count > 0;

    private int _firstRecord => (_page - 1) * _pageSize + 1;
    private int _lastRecord => Math.Min(_page * _pageSize, _totalCount);

    private string StorageFullKey => $"traceon_grid_{StorageKey}";

    protected override async Task OnInitializedAsync()
    {
        _pageSize = PageSize;
        _sortField = DefaultSortField;
        _sortDescending = DefaultSortDescending;

        await RestoreStateAsync();
        await LoadDataInternalAsync();
    }

    public async Task RefreshAsync()
    {
        _selectedIds.Clear();
        await LoadDataInternalAsync();
    }

    /// <summary>Returns the set of currently selected item IDs.</summary>
    public IReadOnlySet<Guid> SelectedIds => _selectedIds;

    /// <summary>Returns the currently selected items from the loaded page.</summary>
    public IReadOnlyList<TItem> SelectedItems => SelectionEnabled && ItemKey is not null
        ? _items.Where(i => _selectedIds.Contains(ItemKey(i))).ToList()
        : [];

    private void ToggleItemSelection(Guid? id)
    {
        if (id is null) return;
        if (!_selectedIds.Remove(id.Value))
            _selectedIds.Add(id.Value);
    }

    private void ToggleAllPageSelection(ChangeEventArgs e)
    {
        if (ItemKey is null) return;
        var check = (bool)(e.Value ?? false);
        if (check)
        {
            foreach (var item in _items)
                _selectedIds.Add(ItemKey(item));
        }
        else
        {
            foreach (var item in _items)
                _selectedIds.Remove(ItemKey(item));
        }
    }

    private void ClearSelection() => _selectedIds.Clear();

    // ── Persistence ──

    private async Task RestoreStateAsync()
    {
        if (StorageKey is null) return;

        try
        {
            var state = await LocalStorage.GetItemAsync<DataGridPersistedState>(StorageFullKey);
            if (state is null) return;

            if (state.SortField is not null) _sortField = state.SortField;
            _sortDescending = state.SortDescending;
            if (!string.IsNullOrWhiteSpace(state.SearchTerm))
            {
                _filterInput = state.SearchTerm;
                _appliedFilter = state.SearchTerm;
            }
            if (state.PageSize.HasValue && PageSizeOptions.Contains(state.PageSize.Value))
                _pageSize = state.PageSize.Value;
            if (state.CurrentPage is > 0)
                _page = state.CurrentPage.Value;

            if (state.Summaries is not null)
            {
                _summarySelections = [];
                foreach (var (title, types) in state.Summaries)
                {
                    var colIndex = Columns.FindIndex(c => c.Title == title);
                    if (colIndex >= 0)
                        _summarySelections[colIndex] = [.. types];
                }
            }
        }
        catch { /* localStorage may be unavailable */ }
    }

    private async Task SaveStateAsync()
    {
        if (StorageKey is null) return;

        try
        {
            var summaries = _summarySelections.Count > 0
                ? _summarySelections.ToDictionary(
                    kv => Columns[kv.Key].Title,
                    kv => kv.Value)
                : null;

            var state = new DataGridPersistedState
            {
                SortField = _sortField,
                SortDescending = _sortDescending,
                SearchTerm = _appliedFilter,
                PageSize = _pageSize,
                CurrentPage = _page > 1 ? _page : null,
                Summaries = summaries
            };

            await LocalStorage.SetItemAsync(StorageFullKey, state);
        }
        catch { /* best effort */ }
    }

    private async Task ResetAllAsync()
    {
        _sortField = DefaultSortField;
        _sortDescending = DefaultSortDescending;
        _pageSize = PageSize;
        _filterInput = null;
        _appliedFilter = null;
        _page = 1;
        _summarySelections.Clear();
        _computedSummaries.Clear();
        _summaryDropdownIndex = -1;

        if (StorageKey is not null)
        {
            try { await LocalStorage.RemoveItemAsync(StorageFullKey); } catch { }
        }

        await OnReset.InvokeAsync();
        await LoadDataInternalAsync();
    }

    // ── Data loading ──

    private async Task LoadDataInternalAsync()
    {
        _loading = true;
        _summaryDropdownIndex = -1;
        StateHasChanged();

        var request = new DataGridRequest(_page, _pageSize, _sortField, _sortDescending, _appliedFilter);
        var result = await LoadData(request);

        _items = result.Items;
        _totalCount = result.TotalCount;
        _totalPages = Math.Max(1, (int)Math.Ceiling((double)_totalCount / _pageSize));

        // If the requested page is past the last page (e.g., the only row on this page
        // was just deleted), clamp and re-fetch so the user lands on the previous page
        // with actual content instead of an empty grid.
        if (_page > _totalPages)
        {
            _page = _totalPages;
            request = new DataGridRequest(_page, _pageSize, _sortField, _sortDescending, _appliedFilter);
            result = await LoadData(request);
            _items = result.Items;
            _totalCount = result.TotalCount;
            _totalPages = Math.Max(1, (int)Math.Ceiling((double)_totalCount / _pageSize));
        }

        ComputeSummaries();
        await SaveStateAsync();

        _loading = false;
        StateHasChanged();
    }

    // ── Sorting ──

    private async Task SortByAsync(DataGridColumn<TItem> column)
    {
        if (column.SortField is null) return;

        if (_sortField == column.SortField)
            _sortDescending = !_sortDescending;
        else
        {
            _sortField = column.SortField;
            _sortDescending = false;
        }

        _page = 1;
        await LoadDataInternalAsync();
        await SaveStateAsync();
    }

    private async Task OnMobileSortFieldChangedAsync(ChangeEventArgs e)
    {
        var field = e.Value?.ToString();
        if (string.IsNullOrEmpty(field))
        {
            _sortField = DefaultSortField;
            _sortDescending = DefaultSortDescending;
        }
        else
        {
            _sortField = field;
            _sortDescending = false;
        }

        _page = 1;
        await LoadDataInternalAsync();
        await SaveStateAsync();
    }

    private async Task ToggleMobileSortDirectionAsync()
    {
        _sortDescending = !_sortDescending;
        _page = 1;
        await LoadDataInternalAsync();
        await SaveStateAsync();
    }

    // ── Filtering ──

    private async Task ApplyFilterAsync()
    {
        _appliedFilter = string.IsNullOrWhiteSpace(_filterInput) ? null : _filterInput;
        _page = 1;
        await LoadDataInternalAsync();
        await SaveStateAsync();
    }

    private async Task ClearFilterAsync()
    {
        _filterInput = null;
        _appliedFilter = null;
        _page = 1;
        await LoadDataInternalAsync();
        await SaveStateAsync();
    }

    private async Task OnFilterKeyDownAsync(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await ApplyFilterAsync();
    }

    // ── Pagination ──

    private async Task NextPageAsync()
    {
        if (_page < _totalPages)
        {
            _page++;
            await LoadDataInternalAsync();
        }
    }

    private async Task PreviousPageAsync()
    {
        if (_page > 1)
        {
            _page--;
            await LoadDataInternalAsync();
        }
    }

    private async Task GoToPageAsync(int page)
    {
        if (page != _page && page >= 1 && page <= _totalPages)
        {
            _page = page;
            await LoadDataInternalAsync();
        }
    }

    private async Task GoToFirstPageAsync()
    {
        if (_page > 1)
        {
            _page = 1;
            await LoadDataInternalAsync();
        }
    }

    private async Task GoToLastPageAsync()
    {
        if (_page < _totalPages)
        {
            _page = _totalPages;
            await LoadDataInternalAsync();
        }
    }

    private async Task OnPageSizeChangedAsync(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var newSize) && newSize != _pageSize)
        {
            _pageSize = newSize;
            _page = 1;
            await LoadDataInternalAsync();
            await SaveStateAsync();
        }
    }

    private IEnumerable<int> GetPageNumbers()
    {
        const int maxVisible = 5;
        var half = maxVisible / 2;
        var start = Math.Max(1, _page - half);
        var end = Math.Min(_totalPages, start + maxVisible - 1);
        start = Math.Max(1, end - maxVisible + 1);

        for (var i = start; i <= end; i++)
            yield return i;
    }

    // ── Summaries ──

    private void CloseSummaryDropdown()
    {
        if (_summaryDropdownIndex >= 0)
        {
            _summaryDropdownIndex = -1;
            StateHasChanged();
        }
    }

    private void ToggleSummaryDropdown(int colIndex)
    {
        _summaryDropdownIndex = _summaryDropdownIndex == colIndex ? -1 : colIndex;
    }

    private List<ColumnSummaryType> GetAvailableSummaries(int colIndex)
    {
        if (_items.Count == 0 || colIndex >= Columns.Count) return [];

        var col = Columns[colIndex];
        var sample = col.Selector(_items[0]);

        if (IsNumericValue(sample) || (sample is string s && decimal.TryParse(s, CultureInfo.InvariantCulture, out _)))
            return [ColumnSummaryType.Sum, ColumnSummaryType.Avg, ColumnSummaryType.Min, ColumnSummaryType.Max, ColumnSummaryType.Count];

        if (sample is DateTime or DateTimeOffset)
            return [ColumnSummaryType.Min, ColumnSummaryType.Max, ColumnSummaryType.Count];

        return [ColumnSummaryType.Count];
    }

    private bool HasActiveSummaries(int colIndex) =>
        _summarySelections.TryGetValue(colIndex, out var list) && list.Count > 0;

    private bool IsSummaryActive(int colIndex, ColumnSummaryType type) =>
        _summarySelections.TryGetValue(colIndex, out var list) && list.Contains(type);

    private async Task ToggleSummaryAsync(int colIndex, ColumnSummaryType type)
    {
        if (!_summarySelections.TryGetValue(colIndex, out var list))
        {
            list = [];
            _summarySelections[colIndex] = list;
        }

        if (!list.Remove(type))
            list.Add(type);

        if (list.Count == 0)
            _summarySelections.Remove(colIndex);

        ComputeSummaries();
        await SaveStateAsync();
    }

    private void ComputeSummaries()
    {
        _computedSummaries = [];
        if (_items.Count == 0 || _summarySelections.Count == 0) return;

        foreach (var (colIndex, types) in _summarySelections)
        {
            if (colIndex >= Columns.Count) continue;
            var col = Columns[colIndex];
            var results = new List<SummaryResult>();

            foreach (var type in types)
            {
                var value = ComputeSingleSummary(col, type);
                if (value is not null)
                    results.Add(new(type, value));
            }

            if (results.Count > 0)
                _computedSummaries[colIndex] = results;
        }
    }

    private object? ComputeSingleSummary(DataGridColumn<TItem> col, ColumnSummaryType type)
    {
        if (type == ColumnSummaryType.Count)
            return _items.Count(item => col.Selector(item) is not null and not "");

        // Try numeric
        var nums = _items
            .Select(item => TryGetNumericValue(col.Selector(item)))
            .Where(v => v.HasValue)
            .Select(v => v!.Value)
            .ToList();

        if (nums.Count > 0)
        {
            return type switch
            {
                ColumnSummaryType.Sum => nums.Sum(),
                ColumnSummaryType.Avg => Math.Round(nums.Average(), 2),
                ColumnSummaryType.Min => nums.Min(),
                ColumnSummaryType.Max => nums.Max(),
                _ => null
            };
        }

        // Try DateTime for Min/Max
        if (type is ColumnSummaryType.Min or ColumnSummaryType.Max)
        {
            var dates = _items
                .Select(item => col.Selector(item))
                .Where(v => v is DateTime or DateTimeOffset)
                .Select(v => v is DateTimeOffset dto ? dto.DateTime : (DateTime)v!)
                .ToList();

            if (dates.Count > 0)
                return type == ColumnSummaryType.Min ? dates.Min() : dates.Max();
        }

        return null;
    }

    private static decimal? TryGetNumericValue(object? value)
    {
        return value switch
        {
            null => null,
            decimal d => d,
            int i => i,
            long l => l,
            double d => (decimal)d,
            float f => (decimal)f,
            short s => s,
            byte b => b,
            string str => decimal.TryParse(str, CultureInfo.InvariantCulture, out var p) ? p : null,
            _ => null
        };
    }

    private static bool IsNumericValue(object? value) =>
        value is int or long or float or double or decimal or short or byte;

    private string GetSummaryLabel(ColumnSummaryType type) => type switch
    {
        ColumnSummaryType.Sum => L["DataGrid_Sum"],
        ColumnSummaryType.Avg => L["DataGrid_Avg"],
        ColumnSummaryType.Min => L["DataGrid_Min"],
        ColumnSummaryType.Max => L["DataGrid_Max"],
        ColumnSummaryType.Count => L["DataGrid_Count"],
        _ => type.ToString()
    };

    private static string FormatSummaryValue(object? value, DataGridColumn<TItem> col)
    {
        if (value is null) return "";
        if (value is DateTime dt)
            return dt.ToLocalTime().ToString(col.Format ?? "g");
        if (value is decimal d)
            return d == Math.Truncate(d) ? d.ToString("N0") : d.ToString("N2");
        return value.ToString() ?? "";
    }

    // ── Formatting ──

    private static string FormatValue(DataGridColumn<TItem> column, TItem item)
    {
        var value = column.Selector(item);
        if (value is null) return "";
        if (column.Format is not null && value is IFormattable formattable)
            return formattable.ToString(column.Format, null);
        return value.ToString() ?? "";
    }

    private sealed record SummaryResult(ColumnSummaryType Type, object Value);
}
