@inherits LayoutComponentBase
@inject IStringLocalizer<SharedResource> L

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <AuthorizeView>
                <Authorized>
                    <button class="btn btn-link text-decoration-none p-0" @onclick="CycleThemeAsync"
                            title="@($"{L["Layout_Theme"]}: {ThemeService.CurrentTheme}")">
                        <i class="bi bi-@ThemeIcon"></i>
                    </button>
                    <a href="/settings" class="text-decoration-none">
                        <i class="bi bi-person-circle me-1"></i>@context.User.Identity?.Name
                    </a>
                    <button class="btn btn-link text-decoration-none p-0" @onclick="LogoutAsync">
                        <i class="bi bi-box-arrow-right me-1"></i>@L["Layout_Logout"]
                    </button>
                </Authorized>
                <NotAuthorized>
                    <a href="/auth/login">
                        <i class="bi bi-box-arrow-in-right me-1"></i>@L["Layout_Login"]
                    </a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    [Inject] private AuthService Auth { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;
    [Inject] private ThemeService ThemeService { get; set; } = default!;
    [Inject] private LocalizationService LocalizationService { get; set; } = default!;
    [Inject] private UserPreferenceService PreferenceService { get; set; } = default!;

    private bool _preferencesSynced;

    private string ThemeIcon => ThemeService.CurrentTheme switch
    {
        "light" => "sun-fill",
        "dark" => "moon-fill",
        _ => "circle-half"
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_preferencesSynced)
        {
            _preferencesSynced = true;
            await SyncPreferencesFromServerAsync();
        }
    }

    private async Task SyncPreferencesFromServerAsync()
    {
        try
        {
            var (theme, language, _) = await PreferenceService.GetAsync();

            // If server returned nothing, user is anonymous or has no prefs yet
            if (theme is null && language is null)
                return;

            await ThemeService.ApplyFromServer(theme);

            var languageChanged = await LocalizationService.ApplyFromServer(language);
            if (languageChanged)
            {
                // Reload to apply the new culture — localStorage is already updated
                // so the next reload won't trigger another change
                Nav.NavigateTo(Nav.Uri, forceLoad: true);
                return;
            }

            StateHasChanged();
        }
        catch
        {
            // Not authenticated or offline — use localStorage values
        }
    }

    private async Task CycleThemeAsync()
    {
        var next = ThemeService.CurrentTheme switch
        {
            "system" => "light",
            "light" => "dark",
            _ => "system"
        };
        await ThemeService.SetThemeAsync(next);
        await PreferenceService.SaveAsync(next, LocalizationService.CurrentLanguage);
    }

    private async Task LogoutAsync()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/auth/login", forceLoad: true);
    }
}
