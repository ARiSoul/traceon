@inherits LayoutComponentBase
@inject IStringLocalizer<SharedResource> L

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <AuthorizeView>
                <Authorized>
                    <button class="btn btn-link text-decoration-none p-0" @onclick="CycleThemeAsync"
                            title="@($"{L["Layout_Theme"]}: {ThemeService.CurrentTheme}")">
                        <i class="bi bi-@ThemeIcon"></i>
                    </button>
                    <a href="/settings" class="text-decoration-none">
                        <i class="bi bi-person-circle me-1"></i>@context.User.Identity?.Name
                    </a>
                    <button class="btn btn-link text-decoration-none p-0" @onclick="LogoutAsync">
                        <i class="bi bi-box-arrow-right me-1"></i>@L["Layout_Logout"]
                    </button>
                </Authorized>
                <NotAuthorized>
                    <a href="/auth/login">
                        <i class="bi bi-box-arrow-in-right me-1"></i>@L["Layout_Login"]
                    </a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    [Inject] private AuthService Auth { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;
    [Inject] private ThemeService ThemeService { get; set; } = default!;

    private string ThemeIcon => ThemeService.CurrentTheme switch
    {
        "light" => "sun-fill",
        "dark" => "moon-fill",
        _ => "circle-half"
    };

    private async Task CycleThemeAsync()
    {
        var next = ThemeService.CurrentTheme switch
        {
            "system" => "light",
            "light" => "dark",
            _ => "system"
        };
        await ThemeService.SetThemeAsync(next);
    }

    private async Task LogoutAsync()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/auth/login", forceLoad: true);
    }
}
