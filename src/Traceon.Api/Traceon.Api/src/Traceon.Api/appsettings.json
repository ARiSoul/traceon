{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/traceon-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName" ],
    "Properties": {
      "Application": "Traceon.Api"
    }
  },
  "Jwt": {
    "Key": "TraceonDevelopmentSecretKey_MustBeAtLeast256Bits!",
    "Issuer": "Traceon.Api",
    "Audience": "Traceon.Blazor",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "Email": {
    "SmtpHost": "smtp.sendgrid.net",
    "SmtpPort": 587,
    "SmtpUser": "apikey",
    "SmtpPassword": "",
    "UseSsl": true,
    "FromEmail": "noreply@arisoul.org",
    "FromName": "Traceon",
    "ClientBaseUrl": "https://traceon.arisoul.org",
    "FeedbackEmail": "rjr.sousa0915@gmail.com"
  },
  "ExternalAuth": {
    "Google": {
      "ClientId": "191691137227-t0quc43vb0r4907fi4fh2dr8ob23dbsl.apps.googleusercontent.com",
      "ClientSecret": ""
    },
    "Microsoft": {
      "ClientId": "ae8d8bd2-cdf0-4f76-949d-13f7f74fbdfd",
      "ClientSecret": ""
    }
  },
  "AllowedHosts": "*",
  "Purge": {
    "IntervalHours": 24,
    "DefaultRetentionDays": 180
  },
  "AllowedOrigins": [
    "https://traceon.arisoul.org"
  ]
}
